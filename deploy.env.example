# Identifiants FTP O2Switch
# Copier ce fichier en "deploy.env" et remplir les valeurs
# NE PAS committer deploy.env dans le repo

FTP_HOST=ftp.oceanphenix.fr
FTP_USER=votre_login_cpanel
FTP_PASS=votre_mot_de_passe_ftp

# FTP_REMOTE = racine du site sur le serveur (voir cPanel > Domaines)
# Le dossier correspond exactement au nom du sous-domaine configuré dans cPanel.
# Exemples O2Switch :
#   FTP_REMOTE=/tourdata2026.oceanphenix.fr/
#   FTP_REMOTE=/goal.oceanphenix.fr/
#   FTP_REMOTE=/www.oceanphenix.fr/
#   FTP_REMOTE=/public_html/          ← domaine principal uniquement
FTP_REMOTE=/goal.oceanphenix.fr/
