# Identifiants FTP O2Switch
# Copier ce fichier en "deploy.env" et remplir les valeurs
# NE PAS committer deploy.env dans le repo

FTP_HOST=ftp.oceanphenix.fr
FTP_USER=votre_login_cpanel
FTP_PASS=votre_mot_de_passe_ftp

# FTP_REMOTE = racine du site sur le serveur (voir cPanel > Domaines > Racine du document)
# Sur O2Switch, chaque sous-domaine a son propre dossier — NE PAS utiliser public_html sauf domaine principal.
# Exemples O2Switch :
#   FTP_REMOTE=/goal.oceanphenix.fr/          ← sous-domaine goal (actuel)
#   FTP_REMOTE=/tourdata2026.oceanphenix.fr/  ← sous-domaine tourdata2026
#   FTP_REMOTE=/www.oceanphenix.fr/           ← sous-domaine www
#   FTP_REMOTE=/public_html/                  ← domaine principal nu (oceanphenix.fr sans sous-domaine)
FTP_REMOTE=/goal.oceanphenix.fr/
