# Bloquer l'accès direct aux fichiers sensibles
# strava-env.php : credentials (jamais dans le repo — upload manuel)
# strava-cache.json : cache serveur auto-généré par strava.php
# admin-env.php : surcharge de la clé admin (jamais dans le repo)

<Files "strava-env.php">
    Require all denied
</Files>

<Files "strava-cache.json">
    Require all denied
</Files>

<Files "admin-env.php">
    Require all denied
</Files>

# Pas d'index directory listing
Options -Indexes
