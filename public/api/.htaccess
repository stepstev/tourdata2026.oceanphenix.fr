# Bloquer l'accès direct aux fichiers sensibles de l'API Strava
# strava-env.php : credentials (jamais dans le repo — upload manuel)
# strava-cache.json : cache serveur auto-généré par strava.php

<Files "strava-env.php">
    Require all denied
</Files>

<Files "strava-cache.json">
    Require all denied
</Files>

# Bloquer l'accès direct à la clé OpenAgenda
# radar-env.php : credentials (jamais dans le repo — upload manuel)
<Files "radar-env.php">
    Require all denied
</Files>

# Pas d'index directory listing
Options -Indexes
