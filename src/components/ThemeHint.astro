---
// src/components/ThemeHint.astro — One-time theme mode hint popup
---

<div class="theme-hint" id="theme-hint" role="status" aria-live="polite">
  <div class="theme-hint__icons">
    <svg class="theme-hint__icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="2"/>
      <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    </svg>
    <span class="theme-hint__separator">/</span>
    <svg class="theme-hint__icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>
  <p class="theme-hint__text">
    Mode clair activé — basculez en <strong>dark mode</strong> via l'icône <svg class="theme-hint__inline-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg> dans la barre de navigation.
  </p>
  <button class="theme-hint__close" id="theme-hint-close" aria-label="Fermer">
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    </svg>
  </button>
</div>

<style>
  .theme-hint {
    position: fixed;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%) translateY(120%);
    z-index: 10000;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1.25rem;
    border-radius: 0.75rem;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    opacity: 0;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.4s ease;
    max-width: min(90vw, 520px);
    pointer-events: none;
    /* Light theme (default) */
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(0, 0, 0, 0.08);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.1);
    color: #2a3d50;
  }

  .theme-hint.visible {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
    pointer-events: auto;
  }

  .theme-hint.hiding {
    transform: translateX(-50%) translateY(120%);
    opacity: 0;
    pointer-events: none;
  }

  .theme-hint__icons {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    flex-shrink: 0;
    color: #1a6d96;
  }

  .theme-hint__icon {
    width: 1.15rem;
    height: 1.15rem;
  }

  .theme-hint__separator {
    font-size: 0.85rem;
    opacity: 0.4;
    font-weight: 500;
  }

  .theme-hint__text {
    font-size: 0.85rem;
    line-height: 1.5;
    margin: 0;
    font-family: var(--font-secondary, 'Inter', sans-serif);
  }

  .theme-hint__text strong {
    font-weight: 600;
  }

  .theme-hint__inline-icon {
    width: 0.9rem;
    height: 0.9rem;
    vertical-align: -0.15em;
    opacity: 0.7;
  }

  .theme-hint__close {
    flex-shrink: 0;
    width: 1.5rem;
    height: 1.5rem;
    padding: 0;
    border: none;
    background: transparent;
    cursor: pointer;
    color: inherit;
    opacity: 0.5;
    transition: opacity 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .theme-hint__close:hover {
    opacity: 1;
  }

  .theme-hint__close svg {
    width: 0.9rem;
    height: 0.9rem;
  }

  /* Dark mode override */
  :global([data-theme]) .theme-hint {
    /* No popup in dark — but technically keep it for consistency */
  }

  /* Keep it readable at very small screens */
  @media (max-width: 480px) {
    .theme-hint {
      bottom: 1rem;
      padding: 0.65rem 1rem;
      gap: 0.5rem;
    }
    .theme-hint__text {
      font-size: 0.8rem;
    }
  }
</style>

<script src="/js/theme-hint.js" is:inline></script>
