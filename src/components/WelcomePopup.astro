---
// src/components/WelcomePopup.astro
---

<!-- Welcome Popup 2026 -->
<div class="welcome-popup-overlay" id="welcome-popup">
  <div class="welcome-popup">
    <div class="popup-close" id="popup-close">
      <i class="fas fa-times"></i>
    </div>
    <div class="popup-image-container">
      <img src="/Images/2026_.png" alt="Bienvenue 2026" class="popup-image" loading="eager" />
    </div>
    <div class="popup-text">
      <h2>Bienvenue en 2026 !</h2>
      <p>Découvrez l'innovation et la data</p>
    </div>
  </div>
</div>

<!-- Popup Relaunch Button -->
<div class="popup-relaunch-btn" id="popup-relaunch" title="Revoir l'animation 2026">
  <i class="fas fa-star"></i>
</div>
