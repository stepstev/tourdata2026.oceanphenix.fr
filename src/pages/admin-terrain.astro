  <!-- Strava tab JS -->
  <script is:inline>
  (function () {
    function onReady(fn) {
      if (document.readyState !== 'loading') fn(); else document.addEventListener('DOMContentLoaded', fn);
    }
    onReady(function () {
      // Test connexion
      const testBtn    = document.getElementById('strava-test-btn');
      const testResult = document.getElementById('strava-test-result');
      if (testBtn) {
        testBtn.addEventListener('click', function () {
          testResult.style.display = '';
          testResult.className = 'admin-strava-result info';
          testResult.textContent = 'Connexion en cours\u2026';
          fetch('/api/strava.php')
            .then(function (r) { return r.json(); })
            .then(function (d) {
              if (d.error) throw new Error(d.error);
              testResult.className = 'admin-strava-result ok';
              testResult.innerHTML =
                '<i class="fas fa-check-circle"></i> Connexion OK &mdash; ' +
                (d.athlete?.name || '') + ' &bull; ' +
                (d.total_count || 0) + ' activit\u00e9(s) &bull; mis \u00e0 jour ' +
                (d.updated_at ? new Date(d.updated_at).toLocaleTimeString('fr-FR', {hour:'2-digit',minute:'2-digit'}) : '') +
                (d._mock ? ' <em style="opacity:.6">(mock local)</em>' : '');
            })
            .catch(function (e) {
              testResult.className = 'admin-strava-result error';
              testResult.innerHTML = '<i class="fas fa-exclamation-triangle"></i> ' + e.message;
            });
        });
      }

      // Copier strava-env.php
      const copyEnvBtn = document.getElementById('strava-copy-env-btn');
      if (copyEnvBtn) {
        copyEnvBtn.addEventListener('click', function () {
          const code = document.getElementById('strava-env-code')?.textContent || '';
          navigator.clipboard.writeText(code).then(function () {
            copyEnvBtn.innerHTML = '<i class="fas fa-check"></i> Copi\u00e9 !';
            setTimeout(function () { copyEnvBtn.innerHTML = '<i class="fas fa-copy"></i> Copier'; }, 2000);
          });
        });
      }

      // Copier tag
      const copyTagBtn = document.getElementById('strava-copy-tag-btn');
      if (copyTagBtn) {
        copyTagBtn.addEventListener('click', function () {
          navigator.clipboard.writeText('#Tourdata2026').then(function () {
            copyTagBtn.innerHTML = '<i class="fas fa-check"></i>';
            setTimeout(function () { copyTagBtn.innerHTML = '<i class="fas fa-copy"></i>'; }, 2000);
          });
        });
      }
    });
  })();
  </script>
</BaseLayout>

