---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import OceanBackground from '../components/OceanBackground.astro';
import CopyrightBar from '../components/CopyrightBar.astro';
import etapesData from '../data/terrain-etapes.json';
---

<BaseLayout
  title="Admin Terrain | OceanPhenix"
  description="Interface d'administration du parcours terrain"
  lastModified="12/03/2026 12:00"
>
  <link slot="head" rel="stylesheet" href="/lib/leaflet.min.css" />
  <OceanBackground />
  <Nav />

  <main class="main-content admin-page">

    <!-- Auth gate -->
    <div id="admin-auth" class="admin-auth">
      <div class="admin-auth-card">
        <h1><i class="fas fa-lock"></i> Admin Terrain</h1>
        <p>Accès réservé — entrez le mot de passe d'administration.</p>
        <div class="admin-form-group">
          <input type="password" id="admin-pass" placeholder="Mot de passe" autocomplete="off" />
        </div>
        <div class="admin-form-group admin-captcha-group">
          <label id="captcha-label" class="captcha-question"></label>
          <input type="text" id="admin-captcha" placeholder="Votre réponse" autocomplete="off" inputmode="numeric" />
        </div>
        <button id="admin-login-btn" class="admin-btn admin-btn--accent">
          <i class="fas fa-sign-in-alt"></i> Accéder
        </button>
        <p id="admin-auth-error" class="admin-error" style="display:none;">Mot de passe ou captcha incorrect</p>
      </div>
    </div>

    <!-- Admin panel (hidden until auth) -->
    <div id="admin-panel" class="admin-panel" style="display:none;">

      <!-- Top bar -->
      <div class="admin-topbar">
        <div class="admin-topbar-left">
          <h1><i class="fas fa-cogs"></i> Admin — Terrain Data</h1>
          <div class="admin-topbar-meta">
            <span id="admin-last-saved" class="admin-last-saved" style="display:none;"></span>
            <span id="admin-last-published" class="admin-last-published" style="display:none;"></span>
          </div>
        </div>
        <div class="admin-topbar-actions">

          <!-- ── Publier tout ── -->
          <div class="admin-publish-wrap">
            <div class="abtn-wrap">
              <button id="admin-publish-btn" class="admin-btn admin-btn--publish">
                <i class="fas fa-cloud-upload-alt"></i> Publier tout
              </button>
              <div class="abtn-tip abtn-tip--wide">
                <strong><i class="fas fa-cloud-upload-alt"></i> Publier tout</strong>
                <p>Envoie <em>toutes</em> les données (étapes, journal, coworking, radar) au serveur o2switch via <code>/api/admin-save.php</code>.</p>
                <p>Le fichier <code>data/site-data.json</code> est mis à jour immédiatement — le site public reflète les changements <strong>sans rebuild ni FTP</strong>.</p>
                <hr class="abtn-tip-hr"/>
                <p class="abtn-tip-note"><i class="fas fa-key"></i> Demande la clé secrète au 1er usage. Elle est mémorisée ensuite.</p>
              </div>
            </div>
            <span id="admin-publish-status" class="admin-publish-status" style="display:none;"></span>
          </div>

          <!-- ── Sauvegarder ── -->
          <div class="abtn-wrap">
            <button id="admin-save-btn" class="admin-btn">
              <i class="fas fa-save"></i> Sauvegarder
            </button>
            <div class="abtn-tip">
              <strong><i class="fas fa-save"></i> Sauvegarder</strong>
              <p>Enregistre toutes les modifications <strong>dans ce navigateur uniquement</strong> (localStorage).</p>
              <p>Rien n'est envoyé au serveur. Utile pour garder un brouillon entre deux sessions.</p>
              <hr class="abtn-tip-hr"/>
              <p class="abtn-tip-note"><i class="fas fa-info-circle"></i> Après Sauvegarder → cliquez <strong>Publier tout</strong> pour mettre le site en ligne.</p>
            </div>
          </div>

          <!-- Séparateur -->
          <span class="admin-topbar-sep"></span>

          <!-- ── Visibilité terrain ── -->
          <div class="abtn-wrap">
            <button id="admin-visibility-btn" class="admin-visibility-btn">
              <span class="vis-dot"></span>
              <span class="vis-label"></span>
            </button>
            <div class="abtn-tip">
              <strong><i class="fas fa-eye"></i> Visibilité page Terrain</strong>
              <p>Bascule la page <code>/terrain</code> entre <strong>publique</strong> (visible par tous) et <strong>privée</strong> (vos visiteurs voient une page vide ou sont redirigés).</p>
              <hr class="abtn-tip-hr"/>
              <p class="abtn-tip-note"><i class="fas fa-exclamation-triangle"></i> N'oubliez pas de cliquer <strong>Publier tout</strong> pour appliquer le changement sur le site.</p>
            </div>
          </div>

          <!-- ── Importer ── -->
          <div class="abtn-wrap">
            <button id="admin-import-btn" class="admin-btn">
              <i class="fas fa-upload"></i> Importer
            </button>
            <div class="abtn-tip">
              <strong><i class="fas fa-upload"></i> Importer un JSON</strong>
              <p>Charge un fichier <code>.json</code> exporté précédemment (depuis un autre navigateur ou une sauvegarde) et remplace toutes les données en mémoire.</p>
              <hr class="abtn-tip-hr"/>
              <p class="abtn-tip-note"><i class="fas fa-info-circle"></i> Après import → cliquez <strong>Sauvegarder</strong> puis <strong>Publier tout</strong>.</p>
            </div>
          </div>

          <!-- ── Réinitialiser ── -->
          <div class="abtn-wrap">
            <button id="admin-reset-cache-btn" class="admin-btn admin-btn--danger-light">
              <i class="fas fa-trash-alt"></i> Réinitialiser
            </button>
            <div class="abtn-tip abtn-tip--danger">
              <strong><i class="fas fa-trash-alt"></i> Réinitialiser le cache local</strong>
              <p>Efface <em>toutes</em> les données de ce navigateur (étapes, journal, radar, GPX…) et recharge la page.</p>
              <p>Après réinitialisation, les données affichées sont celles du <strong>dernier "Publier tout"</strong> sur le serveur.</p>
              <hr class="abtn-tip-hr"/>
              <p class="abtn-tip-note"><i class="fas fa-exclamation-triangle"></i> Action irréversible — utilisez uniquement si le localStorage est corrompu ou pour repartir de l'état serveur.</p>
            </div>
          </div>

          <input type="file" id="admin-import-file" accept=".json" style="display:none" />
        </div>
      </div>

      <!-- Tabs -->
      <div class="admin-tabs">
        <!-- Contenu (publié via Publier tout) -->
        <button class="admin-tab admin-tab--active" data-tab="dashboard">
          <i class="fas fa-tachometer-alt"></i> Dashboard
        </button>
        <button class="admin-tab" data-tab="etapes">
          <i class="fas fa-map-marked-alt"></i> Étapes
        </button>
        <button class="admin-tab" data-tab="journal">
          <i class="fas fa-book-open"></i> Journal
        </button>
        <button class="admin-tab" data-tab="coworking">
          <i class="fas fa-building"></i> Coworking
        </button>
        <button class="admin-tab" data-tab="radar-pro">
          <i class="fas fa-crosshairs"></i> Radar Pro
        </button>
        <button class="admin-tab" data-tab="liens-utiles">
          <i class="fas fa-link"></i> Liens utiles
        </button>
        <!-- Séparateur Contenu / Outils -->
        <span class="admin-tabs-sep" aria-hidden="true" title="Outils">›</span>
        <!-- Outils -->
        <button class="admin-tab admin-tab--tool" data-tab="photos">
          <i class="fas fa-images"></i> Photos
        </button>
        <button class="admin-tab admin-tab--tool" data-tab="gpx">
          <i class="fas fa-route"></i> GPX
        </button>
        <button class="admin-tab admin-tab--tool" data-tab="preview">
          <i class="fas fa-eye"></i> Aperçu
        </button>
        <button class="admin-tab admin-tab--tool" data-tab="villes">
          <i class="fas fa-map-pin"></i> Villes
        </button>
        <button class="admin-tab admin-tab--tool" data-tab="strava">
          <i class="fab fa-strava"></i> Strava
        </button>
      </div>

      <!-- ============================== -->
      <!-- TAB: Dashboard                 -->
      <!-- ============================== -->
      <div class="admin-tab-content admin-tab-content--active" id="tab-dashboard">

        <!-- Info barre déploiement -->
        <div class="admin-infobar">
          <span class="admin-infobar-item">
            <i class="fas fa-key"></i>
            Clé 1er usage&nbsp;: <code>op-admin-save-2026-oceanphenix</code>
          </span>
          <span class="admin-infobar-sep">·</span>
          <span class="admin-infobar-item">
            <i class="fas fa-server"></i>
            FTP&nbsp;: <code>goal.oceanphenix.fr/api/admin-save.php</code>
            <span class="admin-guide-status admin-guide-status--ok">✓ dans le build</span>
          </span>
          <span class="admin-infobar-sep">·</span>
          <span class="admin-infobar-item" style="opacity:0.7;">
            <code>admin-env.php</code> <span class="admin-guide-status admin-guide-status--todo">optionnel — surcharge clé</span>
          </span>
        </div>

        <div class="admin-card">
          <h2><i class="fas fa-tachometer-alt"></i> Données du dashboard</h2>
          <div class="admin-form-row">
            <div class="admin-form-group">
              <label>Km parcourus</label>
              <input type="number" id="dash-km" min="0" step="1" />
            </div>
            <div class="admin-form-group">
              <label>Jours de route</label>
              <input type="number" id="dash-jours" min="0" step="1" />
            </div>
          </div>
          <div class="admin-form-row">
            <div class="admin-form-group">
              <label>Besoins identifiés</label>
              <input type="number" id="dash-besoins" min="0" step="1" />
            </div>
            <div class="admin-form-group">
              <label>Rencontres entreprises</label>
              <input type="number" id="dash-rencontres" min="0" step="1" />
            </div>
          </div>
          <div class="admin-form-row">
            <div class="admin-form-group">
              <label>Étape en cours (texte libre)</label>
              <input type="text" id="dash-encours" placeholder="Ex: En route vers Dreux" />
            </div>
            <div class="admin-form-group">
              <label>Prochaine étape</label>
              <select id="dash-prochaine"></select>
            </div>
          </div>
          <div class="admin-form-row">
            <div class="admin-form-group">
              <label>Jours prévus</label>
              <input type="number" id="dash-joursprevus" min="0" step="1" />
            </div>
          </div>
          <hr style="border:0;border-top:1px solid #1e2a3e;margin:1rem 0;" />
          <h3 style="color:#4db8d4;font-size:0.95rem;margin-bottom:0.75rem;"><i class="fas fa-route"></i> Infos parcours (hero)</h3>
          <div class="admin-form-row">
            <div class="admin-form-group">
              <label>Km total (ex: ~3 150)</label>
              <input type="text" id="dash-km-total" placeholder="~3 150" />
            </div>
            <div class="admin-form-group">
              <label>Nombre d'étapes</label>
              <input type="number" id="dash-nb-etapes" min="1" step="1" />
            </div>
            <div class="admin-form-group">
              <label>Période (ex: Avril – Juillet 2026)</label>
              <input type="text" id="dash-periode" placeholder="Avril – Juillet 2026" />
            </div>
          </div>
          <div class="admin-form-actions">
            <button id="dash-validate-btn" class="admin-btn admin-btn--accent">
              <i class="fas fa-check"></i> Valider les données dashboard
            </button>
          </div>
        </div>

        <div class="admin-card">
          <h2><i class="fas fa-map-pin"></i> Position actuelle</h2>
          <div class="admin-form-row">
            <div class="admin-form-group">
              <label>Ville</label>
              <input type="text" id="pos-ville" />
            </div>
            <div class="admin-form-group">
              <label>Statut</label>
              <select id="pos-statut">
                <option value="Préparation">Préparation</option>
                <option value="En route">En route</option>
                <option value="Étape">Étape</option>
                <option value="Repos">Repos</option>
                <option value="Terminé">Terminé</option>
              </select>
            </div>
          </div>
          <div class="admin-form-row">
            <div class="admin-form-group">
              <label>Latitude</label>
              <input type="number" id="pos-lat" step="0.0001" />
            </div>
            <div class="admin-form-group">
              <label>Longitude</label>
              <input type="number" id="pos-lng" step="0.0001" />
            </div>
          </div>
          <div class="admin-form-group">
            <label>Date de départ</label>
            <input type="date" id="pos-depart" />
          </div>
          <div class="admin-form-actions">
            <button id="pos-validate-btn" class="admin-btn admin-btn--accent">
              <i class="fas fa-check"></i> Valider la position
            </button>
          </div>
        </div>
      </div>

      <!-- ============================== -->
      <!-- TAB: Étapes                    -->
      <!-- ============================== -->
      <div class="admin-tab-content" id="tab-etapes">
        <div class="admin-card">
          <h2><i class="fas fa-map-marked-alt"></i> Gestion des étapes</h2>
          <p class="admin-hint">Cliquez sur une étape pour la modifier. Changez le statut pour marquer une étape comme visitée.</p>
          <div class="admin-form-actions" style="margin-bottom:1rem;">
            <button id="etape-add-btn" class="admin-btn admin-btn--accent">
              <i class="fas fa-plus"></i> Nouvelle étape
            </button>
          </div>
          <div style="overflow-x:auto;">
            <table id="etapes-table" class="admin-etapes-table">
              <thead>
                <tr>
                  <th style="width:40px;">#</th>
                  <th>Ville</th>
                  <th>Région</th>
                  <th style="text-align:center;">Km</th>
                  <th style="text-align:center;">Statut</th>
                  <th style="text-align:center;">Lat</th>
                  <th style="text-align:center;">Lng</th>
                  <th style="text-align:center;width:55px;">Visible</th>
                  <th style="text-align:center;width:80px;">Actions</th>
                </tr>
              </thead>
              <tbody id="etapes-list"></tbody>
            </table>
          </div>
          <div id="etapes-summary" class="admin-etapes-summary"></div>
          <div id="etape-editor" class="admin-etape-editor" style="display:none;">
            <h3 id="etape-editor-title">Modifier l'étape</h3>
            <input type="hidden" id="etape-edit-id" />
            <div class="admin-form-row">
              <div class="admin-form-group">
                <label>Ville</label>
                <input type="text" id="etape-edit-ville" />
              </div>
              <div class="admin-form-group">
                <label>Région</label>
                <input type="text" id="etape-edit-region" />
              </div>
            </div>
            <div class="admin-form-row">
              <div class="admin-form-group">
                <label>Type</label>
                <select id="etape-edit-type">
                  <option value="etape">Étape</option>
                  <option value="depart">Départ</option>
                  <option value="arrivee">Arrivée</option>
                </select>
              </div>
              <div class="admin-form-group">
                <label>Statut</label>
                <select id="etape-edit-statut">
                  <option value="planifie">Planifié</option>
                  <option value="actuel">Actuel</option>
                  <option value="visite">Visité</option>
                </select>
              </div>
              <div class="admin-form-group">
                <label>Distance depuis départ (km)</label>
                <input type="number" id="etape-edit-dist" min="0" />
              </div>
            </div>
            <div class="admin-form-row">
              <div class="admin-form-group">
                <label>Latitude</label>
                <input type="number" id="etape-edit-lat" step="0.0001" />
              </div>
              <div class="admin-form-group">
                <label>Longitude</label>
                <input type="number" id="etape-edit-lng" step="0.0001" />
              </div>
            </div>
            <div class="admin-form-group">
              <label>Date estimée</label>
              <input type="date" id="etape-edit-date" />
            </div>
            <div class="admin-form-group">
              <label>Description</label>
              <textarea id="etape-edit-desc" rows="3"></textarea>
            </div>
            <div class="admin-form-actions">
              <button id="etape-save-btn" class="admin-btn admin-btn--accent">
                <i class="fas fa-check"></i> Valider
              </button>
              <button id="etape-cancel-btn" class="admin-btn">
                <i class="fas fa-times"></i> Annuler
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- ============================== -->
      <!-- TAB: Journal                   -->
      <!-- ============================== -->
      <div class="admin-tab-content" id="tab-journal">
        <div class="admin-card">
          <h2><i class="fas fa-book-open"></i> Journal du terrain</h2>
          <div id="journal-list" class="admin-journal-list"></div>
          <h3 class="admin-subtitle"><i class="fas fa-plus"></i> Nouvelle entrée</h3>
          <div class="admin-form-row">
            <div class="admin-form-group">
              <label>Date</label>
              <input type="date" id="journal-date" />
            </div>
            <div class="admin-form-group">
              <label>Ville</label>
              <input type="text" id="journal-ville" />
            </div>
          </div>
          <div class="admin-form-group">
            <label>Titre</label>
            <input type="text" id="journal-titre" placeholder="Ex: Arrivée à Caen — premiers contacts" />
          </div>
          <div class="admin-form-group">
            <label>Contenu</label>
            <textarea id="journal-contenu" rows="5" placeholder="Racontez votre journée, rencontres, observations..."></textarea>
          </div>
          <div class="admin-form-group">
            <label>Tags (séparés par des virgules)</label>
            <input type="text" id="journal-tags" placeholder="rencontre, diagnostic, data, sponsor" />
          </div>
          <button id="journal-add-btn" class="admin-btn admin-btn--accent">
            <i class="fas fa-plus"></i> Ajouter au journal
          </button>

          <p class="admin-hint" style="margin-top:1.25rem;padding:0.75rem 1rem;border-left:3px solid rgba(77,184,212,0.3);background:rgba(77,184,212,0.04);">
            <i class="fas fa-cloud-upload-alt" style="color:var(--accent-cyan);margin-right:0.4rem;"></i>
            Les entrées du journal sont incluses dans <strong>Publier tout</strong> — aucune action supplémentaire.
          </p>
        </div>
      </div>

      <!-- ============================== -->
      <!-- TAB: Photos                    -->
      <!-- ============================== -->
      <div class="admin-tab-content" id="tab-photos">
        <div class="admin-card">
          <h2><i class="fas fa-images"></i> Photos du parcours</h2>
          <p class="admin-hint">
            Les photos sont référencées par leur chemin dans <code>/Images/terrain/</code>.
            Uploadez-les via FTP ou le gestionnaire de fichiers O2switch, puis ajoutez le chemin ici.
          </p>

          <div class="admin-photos-grid" id="photos-grid"></div>

          <h3 class="admin-subtitle"><i class="fas fa-plus"></i> Ajouter une photo</h3>
          <div class="admin-form-group">
            <label>Sélectionner une image (pour prévisualiser et obtenir le nom)</label>
            <input type="file" id="photo-file-input" accept="image/*" />
          </div>
          <div class="admin-photo-preview" id="photo-preview" style="display:none;">
            <img id="photo-preview-img" alt="Aperçu" />
            <div class="admin-photo-preview-info">
              <p>Fichier : <strong id="photo-preview-name"></strong></p>
              <p>Chemin qui sera ajouté : <code id="photo-preview-path"></code></p>
            </div>
          </div>
          <div class="admin-form-group">
            <label>Ou entrer le chemin manuellement</label>
            <input type="text" id="photo-path-input" placeholder="/Images/terrain/nom-du-fichier.jpg" />
          </div>
          <div class="admin-form-actions">
            <button id="photo-add-btn" class="admin-btn admin-btn--accent">
              <i class="fas fa-plus"></i> Ajouter la photo
            </button>
            <button id="photo-download-btn" class="admin-btn" style="display:none;">
              <i class="fas fa-download"></i> Télécharger (pour upload FTP)
            </button>
          </div>
        </div>
      </div>

      <!-- ============================== -->
      <!-- TAB: GPX                       -->
      <!-- ============================== -->
      <div class="admin-tab-content" id="tab-gpx">
        <div class="admin-card">
          <h2><i class="fas fa-route"></i> Parcours GPX</h2>
          <p class="admin-hint">
            Importez vos fichiers GPX Garmin / Strava / Komoot. Le tracé sera stocké et affiché directement
            sur la carte Terrain. Activez/désactivez la visibilité de chaque parcours.
          </p>

          <div class="admin-form-group">
            <label>Charger un fichier GPX</label>
            <input type="file" id="gpx-file-input" accept=".gpx" />
          </div>

          <div id="gpx-info" class="admin-gpx-info" style="display:none;">
            <div class="admin-form-row">
              <div class="admin-form-group">
                <label>Nom du fichier</label>
                <input type="text" id="gpx-filename" readonly />
              </div>
              <div class="admin-form-group">
                <label>Points GPS</label>
                <input type="text" id="gpx-points" readonly />
              </div>
            </div>
            <div class="admin-form-row">
              <div class="admin-form-group">
                <label>Distance estimée</label>
                <input type="text" id="gpx-distance" readonly />
              </div>
              <div class="admin-form-group">
                <label>Dénivelé estimé</label>
                <input type="text" id="gpx-elevation" readonly />
              </div>
            </div>
          </div>

          <div id="gpx-map" class="admin-gpx-map" style="display:none;"></div>

          <div id="gpx-actions" class="admin-form-actions" style="display:none;">
            <button id="gpx-download-btn" class="admin-btn">
              <i class="fas fa-download"></i> Télécharger le GPX
            </button>
            <button id="gpx-add-btn" class="admin-btn admin-btn--accent">
              <i class="fas fa-plus"></i> Ajouter au parcours
            </button>
          </div>

          <h3 class="admin-subtitle" style="display:flex;align-items:center;justify-content:space-between;">Fichiers GPX enregistrés
            <button id="admin-export-gpx-btn" class="admin-btn" style="font-size:0.8rem;padding:4px 10px;" title="Exporter tous les tracés GPX enregistrés">
              <i class="fas fa-download"></i> Exporter GPX
            </button>
          </h3>
          <div id="gpx-list" class="admin-gpx-list">
            <p class="admin-hint">Aucun fichier GPX enregistré pour le moment.</p>
          </div>
        </div>
      </div>

      <!-- ============================== -->
      <!-- TAB: Preview                   -->
      <!-- ============================== -->
      <div class="admin-tab-content" id="tab-preview">
        <div class="admin-card">
          <h2><i class="fas fa-eye"></i> Aperçu des données</h2>
          <p class="admin-hint">Voici le JSON complet tel qu'il sera exporté. Vérifiez les données avant de les exporter.</p>
          <pre id="preview-json" class="admin-json-preview"></pre>
          <div class="admin-form-actions">
            <button id="preview-copy-btn" class="admin-btn admin-btn--accent">
              <i class="fas fa-copy"></i> Copier le JSON
            </button>
            <button id="preview-export-btn" class="admin-btn">
              <i class="fas fa-download"></i> Exporter en fichier
            </button>
