window.resetAudit=function(){
  state.answers={};
  try{localStorage.removeItem(LS_KEY);}catch(e){}
  if(state.chart){state.chart.destroy();state.chart=null;}
  document.getElementById('ad-report').style.display='none';
  buildQuestionnaire();
  updateRadar();
  window.scrollTo({top:0,behavior:'smooth'});
};

/* ─── Init ───────────────────────────────────────────────────── */
function init(){
  var hadSaved=loadFromStorage();
  // Sync profil button active state
  if(hadSaved){
    document.querySelectorAll('[data-p]').forEach(function(b){
      b.classList.toggle('is-active',b.dataset.p===state.profile);
    });
    var info={pme:'33 questions · 3 par dimension · ~6 min',
              eti:'44 questions · jusqu\'à 4 par dimension · ~8 min',
              gc:'55 questions · 5 par dimension · ~10 min'};
    var infoEl=document.getElementById('ad-profil-info-txt');
    if(infoEl) infoEl.textContent=info[state.profile]||info.pme;
  }
  buildQuestionnaire();
  if(hadSaved) restoreVisualStates();
  initProfileBtns();
  // Wait for Chart.js to be available
  var attempts=0;
  function tryRadar(){
    if(window.Chart){updateRadar();}
    else if(++attempts<20){setTimeout(tryRadar,150);}
  }
  tryRadar();
}

if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',init);}
else{init();}

}());

/* ── Info modal ─────────────────────────────────────────── */
(function(){
  function openModal(){
    const m=document.getElementById('ad-info-modal');
    if(m){m.hidden=false;document.body.style.overflow='hidden';}
  }
  function closeModal(){
    const m=document.getElementById('ad-info-modal');
    if(m){m.hidden=true;document.body.style.overflow='';}
  }
  function setup(){
    const btn=document.getElementById('ad-info-btn');
    const cl=document.getElementById('ad-modal-close');
    const st=document.getElementById('ad-modal-start');
    const ov=document.getElementById('ad-info-modal');
    if(btn)btn.addEventListener('click',openModal);
    if(cl)cl.addEventListener('click',closeModal);
    if(st)st.addEventListener('click',closeModal);
    if(ov)ov.addEventListener('click',function(e){if(e.target===ov)closeModal();});
    document.addEventListener('keydown',function(e){if(e.key==='Escape')closeModal();});
  }
  if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',setup);}
  else{setup();}
}());
  </script>

