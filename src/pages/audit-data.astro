/* reglementaire tags */
.ad-modal-regs{display:flex;flex-wrap:wrap;gap:.4rem;margin-top:.6rem;}
.ad-mreg{display:inline-flex;align-items:center;gap:.3rem;font-size:.76rem;font-weight:700;padding:.25rem .8rem;border-radius:var(--radius-full,999px);}
.ad-mreg--rgpd{background:rgba(220,60,60,.12);border:1px solid rgba(220,60,60,.3);color:#e08080;}
