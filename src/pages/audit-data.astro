.ad-chip--green{background:rgba(34,197,94,.08);border-color:rgba(34,197,94,.2);color:#4caf77;}

/* ── Info button ──────────────────────────────────────────── */
.ad-info-btn{display:inline-flex;align-items:center;gap:.55rem;padding:.6rem 1.3rem .6rem 1rem;margin-top:.9rem;background:linear-gradient(135deg,rgba(234,120,40,.18),rgba(200,80,10,.22));border:1.5px solid rgba(234,120,40,.7);color:#ffb07a;border-radius:var(--radius-full,999px);cursor:pointer;font-size:.9rem;font-weight:600;letter-spacing:.02em;transition:all .18s ease;animation:ad-info-pulse 2s ease-in-out infinite;}
