var state = {profile:'pme', answers:{}, chart:null};

function getLevel(s){return LEVELS.find(function(l){return s>=l.min&&s<l.max;})||LEVELS[0];}

function getQuestions(ki){
  var qs = KA[ki].q.pme.slice();
  if(state.profile==='eti') qs.push(KA[ki].q.extra[0]);
  if(state.profile==='gc')  qs=qs.concat(KA[ki].q.extra);
  return qs;
}

function kaScore(ki){
  var qs=getQuestions(ki), tot=0, cnt=0;
  qs.forEach(function(_,qi){
    var v=state.answers[ki+'_'+qi];
    if(v!=null&&v>=0){tot+=v;cnt++;}
  });
  return cnt===0?0:parseFloat(((tot/(cnt*4))*5).toFixed(2));
}

function kaAnswered(ki){
  return getQuestions(ki).every(function(_,qi){return state.answers[ki+'_'+qi]!=null;});
}

function countAnswered(){return KA.filter(function(_,i){return kaAnswered(i);}).length;}

/* ─── Build questionnaire ────────────────────────────────────── */
function buildQuestionnaire(){
  var html='';
  KA.forEach(function(ka,ki){
    var qs=getQuestions(ki);
    var isDone=kaAnswered(ki);
    html+='<div class="ad-ka-block" id="ad-ka-'+ki+'">';
    html+='<div class="ad-ka-head" onclick="toggleKA('+ki+')">';
    html+='<div class="ad-ka-head-left">';
    html+='<span class="ad-ka-num">'+String(ki+1).padStart(2,'0')+'</span>';
    html+='<div class="ad-ka-head-info">';
    html+='<span class="ad-ka-id"><i class="fas '+ka.icon+'" style="color:'+ka.color+'"></i> '+ka.id+'</span>';
    html+='<span class="ad-ka-lbl">'+ka.label+'</span>';
    html+='<span class="ad-ka-desc">'+ka.desc+'</span>';
    html+='</div></div>';
    html+='<div class="ad-ka-head-right">';
    html+='<span class="ad-ka-score-badge" id="ad-ka-score-'+ki+'">—</span>';
    html+='<span class="ad-ka-ref">'+ka.ref+'</span>';
    html+='<i class="fas fa-chevron-down ad-ka-chevron" id="ad-ka-chev-'+ki+'"></i>';
    html+='</div></div>';
    // Body
    html+='<div class="ad-ka-body" id="ad-ka-body-'+ki+'">';
    qs.forEach(function(q,qi){
      var isExtra=qi>=3;
      html+='<div class="ad-question'+(isExtra?' ad-question--extra':'')+'">';
      if(isExtra) html+='<div class="ad-extra-badge"><i class="fas fa-plus-circle"></i> '+state.profile.toUpperCase()+' only</div>';
      html+='<p class="ad-q-n">Q'+(qi+1)+' / '+qs.length+'</p>';
      html+='<p class="ad-q-t">'+q.t+'</p>';
      html+='<p class="ad-q-h"><i class="fas fa-circle-info"></i> '+q.h+'</p>';
      html+='<div class="ad-opts">';
      OPTS.forEach(function(o,oi){
        var sel=state.answers[ki+'_'+qi]===o.val;
        html+='<label id="adl-'+ki+'-'+qi+'-'+oi+'" class="ad-opt'+(sel?' is-sel':'')+' '+o.cls+'"'+(sel?' style="background:rgba(240,130,20,0.22);border-color:#f0924a;box-shadow:0 0 0 2px rgba(240,140,40,0.3);"':'')+'>'; 
        html+='<input type="radio" name="k'+ki+'q'+qi+'" value="'+o.val+'"'+(sel?' checked':'')+' onchange="setAnswer('+ki+','+qi+','+oi+')">';
        html+='<span class="ad-opt-ic">'+o.icon+'</span>';
        html+='<span class="ad-opt-lb">'+o.lbl+'</span>';
        html+='<span class="ad-opt-sb">'+o.sub+'</span>';
        html+='</label>';
      });
      html+='</div></div>';
      if(qi<qs.length-1) html+='<hr class="ad-sep">';
    });
    html+='</div>';// /body
    html+='</div>';// /block
  });
  document.getElementById('ad-qcol').innerHTML=html;
  // Open first block
  openKA(0);
}

window.toggleKA=function(ki){
  var body=document.getElementById('ad-ka-body-'+ki);
  var chev=document.getElementById('ad-ka-chev-'+ki);
  var isOpen=body.style.display!=='none'&&body.style.display!=='';
  // Close all
  KA.forEach(function(_,i){
    var b=document.getElementById('ad-ka-body-'+i);
    var c=document.getElementById('ad-ka-chev-'+i);
    if(b){b.style.display='none';}
    if(c){c.style.transform='';}
    document.getElementById('ad-ka-'+i).classList.remove('is-open');
  });
  if(!isOpen){
    body.style.display='block';
    chev.style.transform='rotate(180deg)';
    document.getElementById('ad-ka-'+ki).classList.add('is-open');
    // Scroll the opened block into view to prevent layout jump
    setTimeout(function(){
      var block=document.getElementById('ad-ka-'+ki);
      if(block) block.scrollIntoView({behavior:'smooth',block:'nearest'});
    },50);
  }
};

function openKA(ki){
  var body=document.getElementById('ad-ka-body-'+ki);
  var chev=document.getElementById('ad-ka-chev-'+ki);
  if(!body) return;
  KA.forEach(function(_,i){
    var b=document.getElementById('ad-ka-body-'+i);
    var c=document.getElementById('ad-ka-chev-'+i);
    if(b) b.style.display='none';
    if(c) c.style.transform='';
    document.getElementById('ad-ka-'+i).classList.remove('is-open');
  });
  body.style.display='block';
  chev.style.transform='rotate(180deg)';
  document.getElementById('ad-ka-'+ki).classList.add('is-open');
}

/* ─── LocalStorage persistence ──────────────────────────────── */
var LS_KEY='dms_audit_v1';
function saveToStorage(){
  try{localStorage.setItem(LS_KEY,JSON.stringify({profile:state.profile,answers:state.answers}));}catch(e){}
}
function loadFromStorage(){
  try{
    var raw=localStorage.getItem(LS_KEY);
    if(!raw) return false;
    var d=JSON.parse(raw);
    if(d.profile) state.profile=d.profile;
    if(d.answers) state.answers=d.answers;
    return true;
  }catch(e){return false;}
}
/* Restore orange highlight on all labels after buildQuestionnaire() */
function restoreVisualStates(){
  KA.forEach(function(_,ki){
    var qs=getQuestions(ki);
    qs.forEach(function(_,qi){
      var saved=state.answers[ki+'_'+qi];
      if(saved==null) return;
      OPTS.forEach(function(o,oi){
        var lbl=document.getElementById('adl-'+ki+'-'+qi+'-'+oi);
        if(!lbl) return;
        var sel=(o.val===saved);
        lbl.classList.toggle('is-sel',sel);
        lbl.style.background  = sel ? 'rgba(240,130,20,0.22)' : '';
        lbl.style.borderColor = sel ? '#f0924a'                 : '';
        lbl.style.boxShadow   = sel ? '0 0 0 2px rgba(240,140,40,0.30)' : '';
      });
    });
  });
}

/* ─── Answer handler ─────────────────────────────────────────── */
/* oi = index in OPTS array (0=yes/4, 1=partial/2, 2=no/0, 3=dunno/-1) */
window.setAnswer=function(ki,qi,oi){
  var val=OPTS[oi].val;
  state.answers[ki+'_'+qi]=val;
  // Update each option label directly by id — reliable regardless of CSS cascade
  OPTS.forEach(function(_,i){
    var lbl=document.getElementById('adl-'+ki+'-'+qi+'-'+i);
    if(!lbl) return;
    var sel=(i===oi);
    lbl.classList.toggle('is-sel',sel);
    lbl.style.background  = sel ? 'rgba(240,130,20,0.22)' : '';
    lbl.style.borderColor = sel ? '#f0924a'                 : '';
    lbl.style.boxShadow   = sel ? '0 0 0 2px rgba(240,140,40,0.3)' : '';
  });
  updateKAScoreBadge(ki);
  saveToStorage();
  updateRadar();
  // Auto-advance to next KA
  if(kaAnswered(ki)&&ki<10){
    setTimeout(function(){openKA(ki+1);},400);
  }
};

function updateKAScoreBadge(ki){
  var el=document.getElementById('ad-ka-score-'+ki);
  if(!el) return;
  var s=kaScore(ki);
  var qs=getQuestions(ki);
  var answered=qs.filter(function(_,qi){return state.answers[ki+'_'+qi]!=null;}).length;
  if(answered===0){el.textContent='—';el.style.background='';el.style.color='';el.style.borderColor='';return;}
  var lv=getLevel(s);
  el.textContent=s.toFixed(1)+'/5';
  el.style.background=lv.col+'22';
  el.style.color=lv.col;
  el.style.borderColor=lv.col+'55';
}

/* ─── Radar update ───────────────────────────────────────────── */
function getScores(){return KA.map(function(_,i){return kaScore(i);});}
function getBench(){return KA.map(function(ka){return ka.bench[state.profile]||ka.bench.pme;});}

function updateRadar(){
  var scores=getScores();
  var bench=getBench();
  var isDark=document.documentElement.getAttribute('data-theme')!=='light';
  var tc=isDark?'#8fa3b8':'#4a6275';
  var gc=isDark?'rgba(255,255,255,0.07)':'rgba(0,0,0,0.08)';
  var lc=isDark?'#ccd8e0':'#1a2535';

  if(!state.chart){
    var canvas=document.getElementById('ad-radar');
    if(!canvas||!window.Chart) return;
    state.chart=new Chart(canvas,{
      type:'radar',
      data:{
        labels:KA.map(function(k){return k.short;}),
        datasets:[
          {label:'Votre score',data:scores,
           backgroundColor:'rgba(77,184,212,0.15)',borderColor:'#4db8d4',borderWidth:2.5,
           pointBackgroundColor:'#4db8d4',pointRadius:4,pointHoverRadius:7,
           fill:true},
          {label:'Benchmark '+state.profile.toUpperCase(),data:bench,
           backgroundColor:'rgba(200,122,74,0.08)',borderColor:'#c87a4a',borderWidth:1.5,
           borderDash:[6,4],pointBackgroundColor:'#c87a4a',pointRadius:3,pointHoverRadius:5,
           fill:true}
        ]
      },
      options:{
        responsive:true,maintainAspectRatio:true,
        animation:{duration:500},
        scales:{r:{min:0,max:5,ticks:{stepSize:1,color:tc,backdropColor:'transparent',font:{size:10}},
          grid:{color:gc},angleLines:{color:gc},
          pointLabels:{color:lc,font:{size:10,weight:'600'}}}},
        plugins:{
          legend:{position:'bottom',labels:{color:lc,boxWidth:12,padding:12,font:{size:11}}},
          tooltip:{callbacks:{label:function(c){return ' '+c.dataset.label+' : '+c.raw.toFixed(1)+'/5';}}}
        }
      }
    });
  } else {
    state.chart.data.datasets[0].data=scores;
    state.chart.data.datasets[1].data=bench;
    state.chart.data.datasets[1].label='Benchmark '+state.profile.toUpperCase();
    state.chart.update('active');
  }

  // Global score
  var filled=scores.filter(function(s){return s>0;}).length;
  var avg=filled>0?parseFloat((scores.reduce(function(a,b){return a+b;},0)/11).toFixed(2)):0;
  var lv=getLevel(avg);
  var arc=document.getElementById('ad-gs-arc');
  var valEl=document.getElementById('ad-gs-val');
  var lvlEl=document.getElementById('ad-gs-level');
  var pctEl=document.getElementById('ad-gs-pct');
  var progEl=document.getElementById('ad-gs-progress-bar');
  var ansEl=document.getElementById('ad-gs-answered');

  if(filled>0){
    valEl.textContent=avg.toFixed(1);
    lvlEl.textContent=lv.lbl;
    lvlEl.style.color=lv.col;
    pctEl.textContent=Math.round((avg/5)*100)+'% de maturité globale';
    arc.style.stroke=lv.col;
    arc.style.strokeDashoffset=(263.9-(avg/5)*263.9).toString();
  }
  var done=countAnswered();
  progEl.style.width=Math.round((done/11)*100)+'%';
  ansEl.textContent=done+' / 11 dimensions répondues';

  // Show CTA in radar card only at 11/11
  var btn=document.getElementById('ad-show-results-btn');
  if(btn) btn.style.display=done===11?'':'none';
  // Validate bar: show from 1 answered dimension
  var bar=document.getElementById('ad-validate-bar');
  var barSpan=document.getElementById('ad-validate-bar-info');
  var barBtn=document.getElementById('ad-validate-bar-btn');
  if(bar){
    bar.style.display=done>=1?'':'none';
    if(barSpan){
      if(done===11){
        barSpan.innerHTML='<i class="fas fa-circle-check"></i> 11 / 11 dimensions complétées — rapport complet prêt';
      } else {
        barSpan.innerHTML='<i class="fas fa-floppy-disk"></i> '+done+' / 11 dimensions répondues — résultats enregistrés localement';
      }
    }
    if(barBtn){
      if(done===11){
        barBtn.innerHTML='<i class="fas fa-chart-bar"></i> Générer mon rapport DataMaturity Score™ <i class="fas fa-arrow-right"></i>';
        barBtn.style.opacity='1';
      } else {
        barBtn.innerHTML='<i class="fas fa-chart-bar"></i> Calculer mon score partiel ('+done+'/11) <i class="fas fa-arrow-right"></i>';
        barBtn.style.opacity='.85';
      }
    }
  }

  // Mini bars
  updateMiniBars(scores,bench);
}

function updateMiniBars(scores,bench){
  var el=document.getElementById('ad-mini-bars');
  if(!el) return;
  el.innerHTML=KA.map(function(ka,i){
    var s=scores[i];var lv=getLevel(s);var pct=(s/5)*100;var bp=(bench[i]/5)*100;
    return '<div class="ad-mb-row">'+
      '<span class="ad-mb-id"><i class="fas '+ka.icon+'" style="color:'+ka.color+'"></i> '+ka.id+'</span>'+
      '<div class="ad-mb-track">'+
        '<div class="ad-mb-fill" style="width:'+pct+'%;background:'+lv.col+'"></div>'+
        '<div class="ad-mb-bench" style="left:'+bp+'%"></div>'+
      '</div>'+
      '<span class="ad-mb-val" style="color:'+lv.col+'">'+s.toFixed(1)+'</span>'+
    '</div>';
  }).join('');
}

/* ─── Profile switch ─────────────────────────────────────────── */
function initProfileBtns(){
  document.querySelectorAll('[data-p]').forEach(function(btn){
    btn.addEventListener('click',function(){
      state.profile=this.dataset.p;
      state.answers={};
      saveToStorage();
      document.querySelectorAll('[data-p]').forEach(function(b){b.classList.remove('is-active');});
      this.classList.add('is-active');
      var info={pme:'33 questions · 3 par dimension · ~6 min',
                eti:'44 questions · jusqu\'à 4 par dimension · ~8 min',
                gc:'55 questions · 5 par dimension · ~10 min'};
      document.getElementById('ad-profil-info-txt').textContent=info[state.profile];
      if(state.chart){state.chart.destroy();state.chart=null;}
      buildQuestionnaire();
      updateRadar();
      document.getElementById('ad-report').style.display='none';
    });
  });
}

