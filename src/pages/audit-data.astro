.ad-modal-section ul li{margin-bottom:.35rem;color:#90aabf;}
.ad-modal-section ul li::marker{color:#4db8d4;}

/* maturity levels */
.ad-modal-levels{display:flex;flex-wrap:wrap;gap:.45rem;margin-top:.75rem;}
.ad-mlvl{display:inline-flex;align-items:center;gap:.35rem;font-size:.78rem;padding:.3rem .8rem;border-radius:var(--radius-full,999px);font-weight:600;border:1px solid transparent;}
.ad-mlvl strong{font-size:.72rem;opacity:.75;font-weight:700;}
.ad-mlvl--0{background:rgba(160,60,60,.12);border-color:rgba(200,80,80,.3);color:#e08080;}
.ad-mlvl--1{background:rgba(200,100,40,.12);border-color:rgba(220,130,60,.3);color:#e0a060;}
