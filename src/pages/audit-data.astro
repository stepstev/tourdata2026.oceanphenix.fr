/* header band */
.ad-modal-header{display:flex;align-items:center;gap:1rem;padding:1.6rem 2rem 1.3rem;border-bottom:1px solid rgba(255,255,255,.07);background:linear-gradient(135deg,rgba(77,184,212,.08),rgba(45,90,140,.06));}
