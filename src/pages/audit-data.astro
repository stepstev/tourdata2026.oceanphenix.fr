.ad-info-btn:hover .ad-info-btn-arrow{transform:translateX(3px);opacity:1;}
[data-theme="light"] .ad-info-btn{background:linear-gradient(135deg,rgba(180,70,0,.08),rgba(180,70,0,.15));border-color:rgba(200,80,10,.6);color:#b84600;box-shadow:0 2px 12px rgba(200,80,10,.14);}
[data-theme="light"] .ad-info-btn:hover{background:linear-gradient(135deg,rgba(200,80,10,.18),rgba(200,80,10,.28));border-color:#b84600;color:#6b2200;}
[data-theme="light"] .ad-info-btn .fa-circle-info{color:#b84600;}
[data-theme="light"] .ad-info-btn:hover .fa-circle-info{color:#6b2200;}

/* ── Info modal ───────────────────────────────────────────── */
.ad-modal-overlay{position:fixed;inset:0;z-index:9000;background:rgba(0,0,0,.72);backdrop-filter:blur(6px);display:flex;align-items:center;justify-content:center;padding:1rem;}
.ad-modal-overlay[hidden]{display:none;}
.ad-modal-box{background:#0d1e30;border:1px solid rgba(77,184,212,.22);border-radius:1.4rem;width:100%;max-width:700px;max-height:90vh;overflow-y:auto;padding:0;position:relative;box-shadow:0 32px 80px rgba(0,0,0,.7);}
.ad-modal-box::-webkit-scrollbar{width:5px;}
