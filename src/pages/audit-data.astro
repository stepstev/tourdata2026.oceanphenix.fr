/* ── Profil bar ───────────────────────────────────────────── */
.ad-profil-bar{display:flex;flex-wrap:wrap;align-items:center;gap:.8rem;max-width:1100px;margin:0 auto var(--spacing-lg);padding:.8rem var(--spacing-md);background:rgba(8,18,34,.85);border:1px solid rgba(77,184,212,.2);border-radius:var(--radius-lg);backdrop-filter:blur(16px);}
.ad-profil-label{font-size:var(--text-sm);color:#b0c8dc;font-weight:600;display:flex;align-items:center;gap:.4rem;}
.ad-profil-btns{display:flex;gap:.4rem;flex-wrap:wrap;}
.ad-profil-btn{display:inline-flex;align-items:center;gap:.45rem;padding:.5rem 1rem;border-radius:var(--radius-sm);background:rgba(255,255,255,.07);border:1.5px solid rgba(255,255,255,.16);color:#b0c8dc;font-size:var(--text-sm);cursor:pointer;transition:all var(--transition-fast);}
.ad-profil-btn em{font-size:var(--text-xs);opacity:.65;}
.ad-profil-btn:hover{border-color:rgba(77,184,212,.5);color:#dce8f4;background:rgba(77,184,212,.1);}
.ad-profil-btn.is-active{background:rgba(77,184,212,.15);border-color:rgba(77,184,212,.6);color:#7ecfe0;font-weight:600;}
.ad-profil-info{margin-left:auto;font-size:var(--text-xs);color:#8fa8bc;display:flex;align-items:center;gap:.4rem;}

/* ── Layout ───────────────────────────────────────────────── */
.ad-layout{display:grid;grid-template-columns:1fr 360px;gap:var(--spacing-lg);max-width:1100px;margin:0 auto;padding:0 var(--spacing-md);align-items:start;}
@media(max-width:900px){.ad-layout{grid-template-columns:1fr;}}

/* ── KA blocks (colonne gauche) ───────────────────────────── */
.ad-qcol{display:flex;flex-direction:column;gap:.5rem;background:rgba(6,14,28,.92);border:1px solid rgba(77,184,212,.2);border-radius:var(--radius-xl);padding:var(--spacing-md);backdrop-filter:blur(20px);box-shadow:0 4px 32px rgba(0,0,0,.5);position:relative;z-index:4;}

.ad-ka-block{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.14);border-radius:var(--radius-md);overflow:hidden;transition:border-color var(--transition-fast);}
.ad-ka-block.is-open{border-color:rgba(77,184,212,.4);background:rgba(8,20,42,.7);}

.ad-ka-head{display:flex;align-items:center;justify-content:space-between;gap:.8rem;padding:.8rem var(--spacing-md);cursor:pointer;user-select:none;transition:background var(--transition-fast);}
.ad-ka-head:hover{background:rgba(77,184,212,.07);}
.ad-ka-block.is-open .ad-ka-head{background:rgba(77,184,212,.1);}

.ad-ka-head-left{display:flex;align-items:center;gap:.75rem;flex:1;min-width:0;}
