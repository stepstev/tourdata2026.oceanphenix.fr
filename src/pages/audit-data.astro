---
// src/pages/audit-data.astro — DataMaturity Score™
// Audit de maturité data — DAMA-DMBOK2 · EDM Council DCAM · CMMI-DMM · RGPD · DMA
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CopyrightBar from '../components/CopyrightBar.astro';
import OceanBackground from '../components/OceanBackground.astro';
---

<BaseLayout
  title="Audit Maturité Data — DataMaturity Score™ | TourData 2026"
  description="Évaluez gratuitement la maturité data de votre organisation. Basé sur DAMA-DMBOK2, RGPD, DMA. Radar interactif, score /5 et plan d'action — par Stéphane Celton, OceanPhenix."
  lastModified="31/03/2026 10:00"
>

  <OceanBackground />
  <Nav />

  <main class="ad-page main-content">

    <!-- ══ HERO ═══════════════════════════════════════════════ -->
    <section class="ad-hero">
      <div class="ad-hero-badge"><i class="fas fa-database"></i> Outil Terrain — TourData 2026</div>
      <h1 class="ad-hero-title">
        <i class="fas fa-chart-bar ad-cu"></i> DataMaturity Score™
      </h1>
      <button class="ad-info-btn" id="ad-info-btn" aria-label="En savoir plus sur cet audit">
        <i class="fas fa-circle-info"></i>
        <span>À propos de cet audit</span>
        <i class="fas fa-chevron-right ad-info-btn-arrow"></i>
      </button>
      <p class="ad-hero-sub">Évaluez la maturité data de votre organisation · 11 dimensions DAMA-DMBOK2 · Score /5 · Radar interactif · Plan d'action</p>
      <div class="ad-hero-chips">
        <span class="ad-chip">DAMA-DMBOK2</span><span class="ad-chip">EDM Council DCAM</span>
        <span class="ad-chip">CMMI-DMM niveaux 0→5</span><span class="ad-chip">RGPD · DMA · NIS2</span>
        <span class="ad-chip ad-chip--green">Gratuit · Anonyme · Local</span>
      </div>
    </section>

    <!-- ══ PROFIL SELECTOR ════════════════════════════════════ -->
    <div class="ad-profil-bar">
      <span class="ad-profil-label"><i class="fas fa-building"></i> Votre organisation :</span>
      <div class="ad-profil-btns">
        <button class="ad-profil-btn is-active" data-p="pme"><i class="fas fa-store"></i> PME / TPE <em>&lt; 250 salariés</em></button>
        <button class="ad-profil-btn" data-p="eti"><i class="fas fa-building-user"></i> ETI <em>250–5 000</em></button>
        <button class="ad-profil-btn" data-p="gc"><i class="fas fa-city"></i> Grand Compte <em>&gt; 5 000</em></button>
      </div>
      <div class="ad-profil-info" id="ad-profil-info">
        <i class="fas fa-circle-info"></i> <span id="ad-profil-info-txt">33 questions · 3 par dimension · ~6 min</span>
      </div>
    </div>

    <!-- ══ LAYOUT PRINCIPAL : questionnaire + radar ═══════════ -->
    <div class="ad-layout">

      <!-- ── Colonne gauche : questionnaire ─────────────────── -->
      <div class="ad-qcol" id="ad-qcol">
        <!-- généré par JS -->
      </div>

      <!-- ── Colonne droite : radar sticky ──────────────────── -->
      <div class="ad-rcol">
        <div class="ad-radar-card" id="ad-radar-card">

          <!-- Score global -->
          <div class="ad-global-score" id="ad-global-score">
            <div class="ad-gs-ring-wrap">
              <svg viewBox="0 0 100 100" class="ad-gs-ring">
                <circle class="ad-gs-bg" cx="50" cy="50" r="42" fill="none" stroke-width="8"/>
                <circle class="ad-gs-arc" id="ad-gs-arc" cx="50" cy="50" r="42" fill="none" stroke-width="8"
                  stroke-dasharray="263.9" stroke-dashoffset="263.9" transform="rotate(-90 50 50)"/>
              </svg>
              <div class="ad-gs-center">
                <span class="ad-gs-val" id="ad-gs-val">—</span>
                <span class="ad-gs-max">/5</span>
              </div>
            </div>
            <div class="ad-gs-right">
              <div class="ad-gs-level" id="ad-gs-level">Remplissez le questionnaire</div>
              <div class="ad-gs-pct" id="ad-gs-pct"></div>
              <div class="ad-gs-progress-wrap">
                <div class="ad-gs-progress-bar" id="ad-gs-progress-bar" style="width:0%"></div>
              </div>
              <div class="ad-gs-answered" id="ad-gs-answered">0 / 11 dimensions répondues</div>
            </div>
          </div>

          <!-- Radar -->
          <div class="ad-radar-canvas-wrap">
            <canvas id="ad-radar" width="420" height="380"></canvas>
          </div>

          <!-- Mini barres -->
          <div class="ad-mini-bars" id="ad-mini-bars">
            <!-- injecté par JS -->
          </div>

          <!-- CTA résultats -->
          <button class="ad-btn ad-btn--primary ad-btn--full" id="ad-show-results-btn" onclick="showResults()" style="display:none">
            <i class="fas fa-chart-bar"></i> Voir le rapport complet
          </button>
        </div>
      </div>
    </div>

    <!-- ══ RÉFÉRENCES NORMATIVES ═══════════════════════════════ -->
    <div class="ad-normrefs">
      <div class="ad-normrefs-header">
        <h3 class="ad-normrefs-title"><i class="fas fa-book-open"></i> Références normatives &amp; cadres de conformité</h3>
        <div class="ad-normrefs-legend">
          <span class="ad-nrleg ad-nrleg--red"><i class="fas fa-gavel"></i> Réglementations UE obligatoires</span>
          <span class="ad-nrleg ad-nrleg--green"><i class="fas fa-flag"></i> Cadres français</span>
          <span class="ad-nrleg ad-nrleg--blue"><i class="fas fa-layer-group"></i> Frameworks méthodologiques</span>
          <span class="ad-nrleg ad-nrleg--purple"><i class="fas fa-certificate"></i> Normes ISO</span>
        </div>
      </div>

      <div class="ad-nrtable-wrap">
        <table class="ad-nrtable">
          <thead>
            <tr>
              <th class="ad-nrth-cat">Catégorie</th>
              <th>Référence</th>
              <th class="ad-nrth-desc">Description</th>
              <th class="ad-nrth-scope">Périmètre</th>
              <th class="ad-nrth-link">Lien</th>
            </tr>
          </thead>
          <tbody>

            <!-- ── 1. Réglementations européennes obligatoires ── -->
            <tr class="ad-nrtr--red">
              <td class="ad-nrtd-cat" rowspan="7"><span class="ad-nrcat ad-nrcat--red"><i class="fas fa-gavel"></i><br>Règle&shy;mentations<br>UE<br>obligatoires</span></td>
              <td class="ad-nrtd-ref"><strong>RGPD 2016/679</strong><span class="ad-nrver ad-nrver--red">Obligatoire</span></td>
              <td>Protection des données personnelles — Art. 5, 24, 30, 32, 35. Base incontournable : privacy, gouvernance, sécurité</td>
              <td><span class="ad-nrtag ad-nrtag--red">Données perso</span><span class="ad-nrtag ad-nrtag--red">CNIL</span></td>
              <td><a class="ad-nrlink" href="https://eur-lex.europa.eu/legal-content/FR/TXT/?uri=CELEX:32016R0679" target="_blank" rel="noopener"><i class="fas fa-arrow-up-right-from-square"></i> eur-lex.eu</a></td>
            </tr>
            <tr class="ad-nrtr--red">
              <td class="ad-nrtd-ref"><strong>NIS2 — 2022/2555</strong><span class="ad-nrver ad-nrver--red">Obligatoire</span></td>
              <td>Cybersécurité des SI — renforce les obligations pour les entreprises critiques</td>
              <td><span class="ad-nrtag ad-nrtag--red">Cybersécurité</span><span class="ad-nrtag ad-nrtag--red">SI critique</span></td>
              <td><a class="ad-nrlink" href="https://eur-lex.europa.eu/legal-content/FR/TXT/?uri=CELEX:32022L2555" target="_blank" rel="noopener"><i class="fas fa-arrow-up-right-from-square"></i> eur-lex.eu</a></td>
            </tr>
            <tr class="ad-nrtr--red">
              <td class="ad-nrtd-ref"><strong>DMA 2022/1925</strong><span class="ad-nrver ad-nrver--red">Obligatoire</span></td>
              <td>Digital Markets Act — interopérabilité &amp; accès aux données (très ciblé : grands acteurs uniquement)</td>
              <td><span class="ad-nrtag ad-nrtag--red">Gatekeepers</span><span class="ad-nrtag ad-nrtag--red">CA &gt; 75 M€</span></td>
              <td><a class="ad-nrlink" href="https://eur-lex.europa.eu/legal-content/FR/TXT/?uri=CELEX:32022R1925" target="_blank" rel="noopener"><i class="fas fa-arrow-up-right-from-square"></i> eur-lex.eu</a></td>
            </tr>
            <tr class="ad-nrtr--red">
              <td class="ad-nrtd-ref"><strong>DORA — 2022/2554</strong><span class="ad-nrver ad-nrver--red">💥 Essentiel</span></td>
              <td>Digital Operational Resilience Act — résilience IT, gestion des incidents, prestataires critiques. <em>Essentiel si finance / assurance</em></td>
              <td><span class="ad-nrtag ad-nrtag--red">Finance</span><span class="ad-nrtag ad-nrtag--red">Résilience IT</span></td>
              <td><a class="ad-nrlink" href="https://eur-lex.europa.eu/legal-content/FR/TXT/?uri=CELEX:32022R2554" target="_blank" rel="noopener"><i class="fas fa-arrow-up-right-from-square"></i> eur-lex.eu</a></td>
            </tr>
            <tr class="ad-nrtr--red">
              <td class="ad-nrtd-ref"><strong>AI Act — 2024/1689</strong><span class="ad-nrver ad-nrver--red">💥 Stratégique</span></td>
              <td>Règlement européen sur l'IA — encadrement des systèmes d'intelligence artificielle par niveau de risque</td>
              <td><span class="ad-nrtag ad-nrtag--red">IA / ML</span><span class="ad-nrtag ad-nrtag--red">Risque IA</span></td>
              <td><a class="ad-nrlink" href="https://eur-lex.europa.eu/legal-content/FR/TXT/?uri=CELEX:32024R1689" target="_blank" rel="noopener"><i class="fas fa-arrow-up-right-from-square"></i> eur-lex.eu</a></td>
            </tr>
            <tr class="ad-nrtr--red">
              <td class="ad-nrtd-ref"><strong>Data Governance Act — 2022/868</strong><span class="ad-nrver ad-nrver--red">En vigueur</span></td>
              <td>Gouvernance et partage des données — espace européen des données, intermédiaires de données</td>
              <td><span class="ad-nrtag ad-nrtag--red">Gouvernance</span><span class="ad-nrtag ad-nrtag--red">Partage data</span></td>
              <td><a class="ad-nrlink" href="https://eur-lex.europa.eu/legal-content/FR/TXT/?uri=CELEX:32022R0868" target="_blank" rel="noopener"><i class="fas fa-arrow-up-right-from-square"></i> eur-lex.eu</a></td>
            </tr>
            <tr class="ad-nrtr--red">
              <td class="ad-nrtd-ref"><strong>Data Act — 2023/2854</strong><span class="ad-nrver ad-nrver--red">En vigueur</span></td>
              <td>Accès et utilisation des données industrielles / IoT — droits sur les données générées par les objets connectés</td>
              <td><span class="ad-nrtag ad-nrtag--red">IoT / Industrie</span><span class="ad-nrtag ad-nrtag--red">Accès data</span></td>
              <td><a class="ad-nrlink" href="https://eur-lex.europa.eu/legal-content/FR/TXT/?uri=CELEX:32023R2854" target="_blank" rel="noopener"><i class="fas fa-arrow-up-right-from-square"></i> eur-lex.eu</a></td>
            </tr>

            <!-- ── 2. Cadres français ── -->
            <tr class="ad-nrtr--green">
              <td class="ad-nrtd-cat" rowspan="2"><span class="ad-nrcat ad-nrcat--green"><i class="fas fa-flag"></i><br>Cadres<br>français</span></td>
              <td class="ad-nrtd-ref"><strong>ANSSI — Guides sécurité SI</strong><span class="ad-nrver ad-nrver--green">Référentiel</span></td>
              <td>EBIOS RM (analyse de risque), Guide hygiène informatique (42 mesures), RGS (systèmes d'information de l'État)</td>
              <td><span class="ad-nrtag ad-nrtag--green">Cybersécurité</span><span class="ad-nrtag ad-nrtag--green">EBIOS RM</span><span class="ad-nrtag ad-nrtag--green">RGS</span></td>
              <td><a class="ad-nrlink" href="https://cyber.gouv.fr/publications" target="_blank" rel="noopener"><i class="fas fa-arrow-up-right-from-square"></i> cyber.gouv.fr</a></td>
            </tr>
            <tr class="ad-nrtr--green">
              <td class="ad-nrtd-ref"><strong>CNIL — Guides RGPD</strong><span class="ad-nrver ad-nrver--green">Autorité</span></td>
              <td>RGPD côté France — guides pratiques, contrôles, sanctions. Autorité de contrôle nationale (Art. 51 RGPD)</td>
              <td><span class="ad-nrtag ad-nrtag--green">RGPD France</span><span class="ad-nrtag ad-nrtag--green">Conformité</span></td>
              <td><a class="ad-nrlink" href="https://www.cnil.fr/fr/rgpd-de-quoi-parle-t-on" target="_blank" rel="noopener"><i class="fas fa-arrow-up-right-from-square"></i> cnil.fr</a></td>
            </tr>

            <!-- ── 3. Frameworks méthodologiques ── -->
            <tr class="ad-nrtr--blue">
              <td class="ad-nrtd-cat" rowspan="3"><span class="ad-nrcat ad-nrcat--blue"><i class="fas fa-layer-group"></i><br>Frameworks<br>méthodo&shy;logiques</span></td>
              <td class="ad-nrtd-ref"><strong>DAMA-DMBOK v2</strong><span class="ad-nrver">2017</span></td>
              <td>Data Management Body of Knowledge — 11 Knowledge Areas couvrant l'intégralité du data management</td>
              <td><span class="ad-nrtag">Gouvernance</span><span class="ad-nrtag">Qualité</span><span class="ad-nrtag">Architecture</span></td>
              <td><a class="ad-nrlink" href="https://www.dama.org/cpages/body-of-knowledge" target="_blank" rel="noopener"><i class="fas fa-arrow-up-right-from-square"></i> dama.org</a></td>
            </tr>
            <tr class="ad-nrtr--blue">
              <td class="ad-nrtd-ref"><strong>EDM Council DCAM v2</strong><span class="ad-nrver">2020</span></td>
              <td>Data Capability Assessment Model — 8 capacités data pour évaluer et piloter la maturité</td>
              <td><span class="ad-nrtag">Maturité</span><span class="ad-nrtag">Capabilities</span></td>
              <td><a class="ad-nrlink" href="https://edmcouncil.org/page/dcam" target="_blank" rel="noopener"><i class="fas fa-arrow-up-right-from-square"></i> edmcouncil.org</a></td>
            </tr>
            <tr class="ad-nrtr--blue">
              <td class="ad-nrtd-ref"><strong>SEI CMMI-DMM</strong><span class="ad-nrver">CMU</span></td>
              <td>Data Management Maturity — modèle de maturité en 5 niveaux (base du scoring DataMaturity Score™)</td>
              <td><span class="ad-nrtag">Niveaux maturité</span><span class="ad-nrtag">Scoring</span></td>
              <td><a class="ad-nrlink" href="https://resources.sei.cmu.edu/library/asset-view.cfm?assetid=484574" target="_blank" rel="noopener"><i class="fas fa-arrow-up-right-from-square"></i> sei.cmu.edu</a></td>
            </tr>

            <!-- ── 4. Normes ISO ── -->
            <tr class="ad-nrtr--purple">
              <td class="ad-nrtd-cat" rowspan="4"><span class="ad-nrcat ad-nrcat--purple"><i class="fas fa-certificate"></i><br>Normes<br>ISO</span></td>
              <td class="ad-nrtd-ref"><strong>ISO 27001</strong><span class="ad-nrver ad-nrver--purple">Norme ISO</span></td>
              <td>Système de Management de la Sécurité de l'Information (SMSI) — norme de référence cybersécurité, certifiable</td>
              <td><span class="ad-nrtag ad-nrtag--purple">Cybersécurité</span><span class="ad-nrtag ad-nrtag--purple">SMSI</span></td>
              <td><a class="ad-nrlink" href="https://www.iso.org/fr/standard/27001" target="_blank" rel="noopener"><i class="fas fa-arrow-up-right-from-square"></i> iso.org</a></td>
            </tr>
            <tr class="ad-nrtr--purple">
              <td class="ad-nrtd-ref"><strong>ISO 27002</strong><span class="ad-nrver ad-nrver--purple">Norme ISO</span></td>
              <td>Code de bonnes pratiques pour la sécurité de l'information — 93 mesures de sécurité (révision 2022)</td>
              <td><span class="ad-nrtag ad-nrtag--purple">Sécurité SI</span><span class="ad-nrtag ad-nrtag--purple">Contrôles</span></td>
              <td><a class="ad-nrlink" href="https://www.iso.org/fr/standard/75652.html" target="_blank" rel="noopener"><i class="fas fa-arrow-up-right-from-square"></i> iso.org</a></td>
            </tr>
            <tr class="ad-nrtr--purple">
              <td class="ad-nrtd-ref"><strong>ISO 8000</strong><span class="ad-nrver ad-nrver--purple">Norme ISO</span></td>
              <td>Qualité des données maîtresses &amp; de référence — portabilité et échange de données de qualité</td>
              <td><span class="ad-nrtag ad-nrtag--purple">Qualité data</span><span class="ad-nrtag ad-nrtag--purple">MDM</span></td>
              <td><a class="ad-nrlink" href="https://www.iso.org/fr/standard/45086.html" target="_blank" rel="noopener"><i class="fas fa-arrow-up-right-from-square"></i> iso.org</a></td>
            </tr>
            <tr class="ad-nrtr--purple">
              <td class="ad-nrtd-ref"><strong>ISO 22301</strong><span class="ad-nrver ad-nrver--purple">Norme ISO</span></td>
              <td>Système de Management de la Continuité d'Activité (SMCA) — PRA/PCA, résilience opérationnelle</td>
              <td><span class="ad-nrtag ad-nrtag--purple">Continuité</span><span class="ad-nrtag ad-nrtag--purple">PRA/PCA</span></td>
              <td><a class="ad-nrlink" href="https://www.iso.org/fr/standard/75106.html" target="_blank" rel="noopener"><i class="fas fa-arrow-up-right-from-square"></i> iso.org</a></td>
            </tr>

          </tbody>
        </table>
      </div>
    </div>

    <!-- ══ RAPPORT COMPLET (affiché après completion) ═════════ -->
    <div class="ad-report" id="ad-report" style="display:none">

      <!-- Titre du rapport -->
      <div class="ad-report-titlebar">
        <div class="ad-rtb-icon"><i class="fas fa-chart-bar"></i></div>
        <div class="ad-rtb-info">
          <h2 class="ad-rtb-h2">Rapport DataMaturity Score™</h2>
          <p class="ad-rtb-meta" id="ad-rtb-meta">Évaluation complète — 11 dimensions DAMA-DMBOK2</p>
        </div>
        <span class="ad-rtb-stamp"><i class="fas fa-lock"></i> Local · Anonyme</span>
      </div>

      <!-- Score général -->
      <div class="ad-report-hero" id="ad-report-hero">
        <!-- injecté -->
      </div>

      <!-- Radar 11 dimensions -->
      <div class="ad-report-section">
        <h3 class="ad-report-h3"><i class="fas fa-chart-area"></i> Radar de maturité — 11 dimensions</h3>
        <div class="ad-report-radar-wrap">
          <canvas id="ad-report-radar" width="480" height="400" aria-label="Radar de maturité DataMaturity Score"></canvas>
        </div>
      </div>

      <!-- Recommandations -->
      <div class="ad-report-section">
        <h3 class="ad-report-h3"><i class="fas fa-route"></i> Plan d'action prioritaire</h3>
        <div class="ad-reco-grid" id="ad-reco-grid"></div>
      </div>

      <!-- Conformité -->
      <div class="ad-report-section">
        <h3 class="ad-report-h3"><i class="fas fa-shield-halved"></i> Conformité réglementaire</h3>
        <div class="ad-comp-grid" id="ad-comp-grid"></div>
      </div>

      <!-- Outils officiels -->
      <div class="ad-report-section">
        <h3 class="ad-report-h3"><i class="fas fa-building-columns"></i> Valider votre score — Outils officiels</h3>
        <div class="ad-official-row">
          <a class="ad-official-card" href="https://www.francenum.gouv.fr/guides-et-conseils/strategie-numerique/diagnostic-numerique/quel-est-le-niveau-de-maturite-de-votre" target="_blank" rel="noopener">
            <i class="fas fa-flag ad-official-icon"></i>
            <div><strong>Diagnostic France Num</strong><span>Référentiel officiel maturité numérique — Gouvernement français</span><span class="ad-official-url">francenum.gouv.fr</span></div>
            <i class="fas fa-arrow-up-right-from-square"></i>
          </a>
          <a class="ad-official-card" href="https://formulaire.observatoire-data-ia.fr/" target="_blank" rel="noopener">
            <i class="fas fa-chart-network ad-official-icon"></i>
            <div><strong>Observatoire Data &amp; IA</strong><span>Formulaire national d'évaluation Data/IA 2024-2026</span><span class="ad-official-url">formulaire.observatoire-data-ia.fr</span></div>
            <i class="fas fa-arrow-up-right-from-square"></i>
          </a>
        </div>
      </div>

      <!-- Sources -->
      <div class="ad-report-section ad-sources">
        <h3 class="ad-report-h3"><i class="fas fa-book-open"></i> Sources &amp; Méthodologie</h3>
        <div class="ad-src-grid">
          <a class="ad-src-item" href="https://www.dama.org/cpages/body-of-knowledge" target="_blank" rel="noopener"><i class="fas fa-database"></i><span><strong>DAMA-DMBOK v2</strong> — 11 Knowledge Areas</span></a>
          <a class="ad-src-item" href="https://edmcouncil.org/page/dcam" target="_blank" rel="noopener"><i class="fas fa-diagram-project"></i><span><strong>EDM Council DCAM v2</strong> — 8 capabilities</span></a>
          <a class="ad-src-item" href="https://resources.sei.cmu.edu/library/asset-view.cfm?assetid=484574" target="_blank" rel="noopener"><i class="fas fa-layer-group"></i><span><strong>SEI CMMI-DMM</strong> — 5 niveaux maturité</span></a>
          <a class="ad-src-item" href="https://eur-lex.europa.eu/legal-content/FR/TXT/?uri=CELEX:32016R0679" target="_blank" rel="noopener"><i class="fas fa-user-shield"></i><span><strong>RGPD 2016/679</strong> — Art. 5, 24, 30, 32</span></a>
          <a class="ad-src-item" href="https://eur-lex.europa.eu/legal-content/FR/TXT/?uri=CELEX:32022R1925" target="_blank" rel="noopener"><i class="fas fa-scale-balanced"></i><span><strong>DMA 2022/1925</strong> — Digital Markets Act</span></a>
          <a class="ad-src-item" href="https://eur-lex.europa.eu/legal-content/FR/TXT/?uri=CELEX:32022L2555" target="_blank" rel="noopener"><i class="fas fa-network-wired"></i><span><strong>NIS2 2022/2555</strong> — Cybersécurité SI</span></a>
          <a class="ad-src-item" href="https://www.cnil.fr/fr/rgpd-de-quoi-parle-t-on" target="_blank" rel="noopener"><i class="fas fa-balance-scale"></i><span><strong>CNIL</strong> — Guide RGPD pratique</span></a>
          <a class="ad-src-item" href="https://www.ssi.gouv.fr/guide/" target="_blank" rel="noopener"><i class="fas fa-shield"></i><span><strong>ANSSI</strong> — Sécurité SI guides</span></a>
