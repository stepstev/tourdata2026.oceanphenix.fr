.ad-ka-head-info{display:flex;flex-direction:column;gap:.15rem;min-width:0;}
.ad-ka-id{font-size:var(--text-sm);font-weight:700;color:#dce8f4;display:flex;align-items:center;gap:.4rem;}
.ad-ka-lbl{font-size:.72rem;color:#8fa8bc;font-weight:500;}
.ad-ka-desc{font-size:.7rem;color:#8fa8bc;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:300px;}

.ad-ka-head-right{display:flex;align-items:center;gap:.5rem;flex-shrink:0;}
.ad-ka-score-badge{font-size:.7rem;font-weight:700;padding:.18rem .5rem;border-radius:var(--radius-full);border:1px solid transparent;transition:all .3s;background:rgba(255,255,255,.08);color:#8fa8bc;}
.ad-ka-ref{font-size:.62rem;color:#6a8090;display:none;}
@media(min-width:720px){.ad-ka-ref{display:block;}}
.ad-ka-chevron{color:#6a8090;font-size:.7rem;transition:transform var(--transition-fast);}

/* KA body */
.ad-ka-body{display:none;padding:var(--spacing-md);border-top:1px solid rgba(77,184,212,.15);}
.ad-question{padding-bottom:var(--spacing-md);}
.ad-question--extra{background:rgba(200,122,74,.05);border-left:2px solid rgba(200,122,74,.3);padding-left:.85rem;border-radius:0 var(--radius-sm) var(--radius-sm) 0;margin-top:.4rem;}
.ad-extra-badge{font-size:.62rem;color:#c8946a;font-weight:700;letter-spacing:.05em;margin-bottom:.35rem;text-transform:uppercase;}
.ad-q-n{font-size:.68rem;color:#c8946a;font-weight:700;letter-spacing:.04em;margin-bottom:.4rem;text-transform:uppercase;}
.ad-q-t{font-size:.95rem;color:#e8f2fa;font-weight:600;line-height:1.65;margin-bottom:.5rem;}
.ad-q-h{font-size:.8rem;color:#9ab8cc;margin-bottom:.85rem;display:flex;gap:.35rem;align-items:flex-start;line-height:1.55;}
.ad-q-h i{flex-shrink:0;margin-top:.15rem;color:#6a90a8;}
.ad-sep{border:none;border-top:1px solid rgba(255,255,255,.08);margin:.75rem 0;}

/* Options — palette neutre, couleur uniquement sur l'icône */
.ad-opts{display:grid;grid-template-columns:repeat(4,1fr);gap:.35rem;}
@media(max-width:600px){.ad-opts{grid-template-columns:repeat(2,1fr);}}

.ad-opt{display:flex;flex-direction:column;align-items:center;gap:.35rem;padding:.8rem .45rem;border-radius:var(--radius-sm);background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.18);cursor:pointer;transition:all var(--transition-fast);text-align:center;}
.ad-opt input{display:none;}
.ad-opt:hover{border-color:rgba(77,184,212,.5);background:rgba(77,184,212,.12);}
.ad-opt-ic{font-size:1.2rem;line-height:1;color:#6a90a8;transition:color .2s;}
.opt-y .ad-opt-ic{color:#22c55e;}
.opt-p .ad-opt-ic{color:#f59e0b;}
.opt-n .ad-opt-ic{color:#ef4444;}
.opt-\? .ad-opt-ic{color:#94a3b8;}
.ad-opt-lb{font-size:.78rem;font-weight:700;color:#c8dce8;line-height:1.35;}
.ad-opt-sb{font-size:.68rem;color:#8aaabb;line-height:1.35;}

/* Sélectionné dark mode — fond coloré semi-opaque + texte vif */
.ad-opt.is-sel{border-color:rgba(240,140,40,.7);background:rgba(235,120,20,.28);box-shadow:0 0 0 2px rgba(240,140,30,.25);}
.ad-opt.is-sel .ad-opt-ic{color:#f0a030;}
.ad-opt.is-sel .ad-opt-lb{color:#fde8c0;font-weight:700;}
.ad-opt.is-sel .ad-opt-sb{color:#f0b870;}

/* ── Colonne droite — Radar card ──────────────────────────── */
.ad-rcol{position:sticky;top:90px;z-index:5;}
.ad-radar-card{background:rgba(8,18,34,.9);border:1px solid rgba(77,184,212,.18);border-radius:var(--radius-xl);padding:var(--spacing-md);backdrop-filter:blur(16px);}

/* Score anneau */
.ad-global-score{display:flex;align-items:center;gap:var(--spacing-sm);margin-bottom:var(--spacing-sm);padding-bottom:var(--spacing-sm);border-bottom:1px solid rgba(255,255,255,.07);}
.ad-gs-ring-wrap{position:relative;width:76px;height:76px;flex-shrink:0;}
.ad-gs-ring{width:100%;height:100%;}
.ad-gs-bg{stroke:rgba(255,255,255,.07);}
.ad-gs-arc{stroke:#4db8d4;stroke-linecap:round;transition:stroke-dashoffset 1s ease,stroke .4s;}
.ad-gs-center{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);display:flex;align-items:baseline;gap:.05rem;}
.ad-gs-val{font-size:1.35rem;font-weight:800;color:#c8d8e4;line-height:1;}
.ad-gs-max{font-size:.6rem;color:#4a6275;}
.ad-gs-right{flex:1;min-width:0;}
.ad-gs-level{font-size:.8rem;font-weight:700;margin-bottom:.2rem;transition:color .4s;color:#7ecfe0;}
.ad-gs-pct{font-size:.68rem;color:#6a7f90;margin-bottom:.35rem;}
.ad-gs-progress-wrap{height:3px;background:rgba(255,255,255,.07);border-radius:3px;overflow:hidden;margin-bottom:.3rem;}
.ad-gs-progress-bar{height:100%;background:#4db8d4;transition:width .5s ease;}
.ad-gs-answered{font-size:.62rem;color:#4a6275;}

/* Radar */
.ad-radar-canvas-wrap{margin:.4rem 0;}
.ad-radar-canvas-wrap canvas{max-width:100%;height:auto;}

/* Mini barres */
.ad-mini-bars{display:flex;flex-direction:column;gap:.28rem;margin-top:.4rem;}
.ad-mb-row{display:flex;align-items:center;gap:.4rem;}
.ad-mb-id{width:64px;font-size:.62rem;color:#8fa8bc;display:flex;align-items:center;gap:.2rem;flex-shrink:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.ad-mb-track{flex:1;height:4px;background:rgba(255,255,255,.12);border-radius:3px;overflow:hidden;position:relative;}
.ad-mb-fill{height:100%;border-radius:3px;transition:width .5s ease;}
.ad-mb-bench{position:absolute;top:0;width:1.5px;height:100%;background:rgba(200,122,74,.5);}
.ad-mb-val{width:30px;text-align:right;font-size:.62rem;font-weight:700;flex-shrink:0;}

/* CTA dans le radar */
.ad-btn--full{width:100%;justify-content:center;margin-top:var(--spacing-sm);}
/* (le bouton radar .ad-btn--primary reste, masqué par JS) */

/* ── Barre de validation fixe ─────────────────────────────── */
.ad-validate-bar{position:fixed;bottom:0;left:0;right:0;z-index:100;background:rgba(8,18,34,.97);border-top:1px solid rgba(77,184,212,.3);backdrop-filter:blur(16px);padding:.9rem var(--spacing-md);box-shadow:0 -8px 32px rgba(0,0,0,.35);}
.ad-validate-inner{max-width:1100px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;gap:var(--spacing-md);flex-wrap:wrap;}
.ad-validate-info{display:flex;align-items:center;gap:.6rem;font-size:var(--text-sm);color:#7ecfe0;font-weight:500;}
.ad-validate-info i{font-size:1.1rem;}
.ad-btn-validate{display:inline-flex;align-items:center;gap:.6rem;padding:.8rem 2rem;border-radius:var(--radius-full);background:#4db8d4;color:#fff;font-size:var(--text-sm);font-weight:700;cursor:pointer;border:none;box-shadow:0 4px 20px rgba(77,184,212,.35);transition:all var(--transition-fast);letter-spacing:.01em;}
.ad-btn-validate:hover{transform:translateY(-2px);box-shadow:0 6px 24px rgba(77,184,212,.5);}
@media(max-width:600px){.ad-validate-info span{font-size:.75rem;}.ad-btn-validate{width:100%;justify-content:center;}}

/* ── Boutons génériques ───────────────────────────────────── */
.ad-btn{display:inline-flex;align-items:center;gap:.5rem;padding:.65rem 1.4rem;border-radius:var(--radius-full);font-size:var(--text-sm);font-weight:600;cursor:pointer;transition:all var(--transition-fast);border:none;text-decoration:none;}
.ad-btn--primary{background:#4db8d4;color:#fff;box-shadow:0 3px 12px rgba(77,184,212,.25);}
.ad-btn--primary:hover{transform:translateY(-2px);box-shadow:0 5px 18px rgba(77,184,212,.4);}
.ad-btn--copper{background:linear-gradient(135deg,#b8784a,#9a6038);color:#e8d4c0;}
.ad-btn--copper:hover{transform:translateY(-2px);}
.ad-btn--ghost{background:transparent;border:1px solid rgba(255,255,255,.15);color:#8fa3b8;}
.ad-btn--ghost:hover{border-color:rgba(77,184,212,.4);color:#c8d8e4;}

/* ── Rapport complet ──────────────────────────────────────── */
.ad-report{max-width:1100px;margin:var(--spacing-xl) auto 0;padding:0 var(--spacing-md);}
.ad-report-section{padding:var(--spacing-lg) 0;border-top:1px solid rgba(255,255,255,.06);}
.ad-report-h3{font-size:var(--text-base);color:#c8d8e4;font-weight:700;margin-bottom:var(--spacing-md);display:flex;align-items:center;gap:.6rem;letter-spacing:.01em;}
.ad-report-h3 i{color:#6a7f90;}

/* Hero rapport */
.ad-report-hero{display:flex;flex-wrap:wrap;gap:var(--spacing-lg);align-items:flex-start;background:rgba(8,18,34,.85);border:1px solid rgba(77,184,212,.2);border-radius:var(--radius-xl);padding:var(--spacing-lg);margin-bottom:var(--spacing-lg);backdrop-filter:blur(16px);}
.ad-rh-score{display:flex;align-items:center;gap:var(--spacing-md);}
.ad-rh-ring-wrap{position:relative;width:96px;height:96px;flex-shrink:0;}
.ad-rh-ring{width:100%;height:100%;}
.ad-rh-bg{stroke:rgba(255,255,255,.07);}
.ad-rh-center{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);display:flex;flex-direction:column;align-items:center;}
.ad-rh-val{font-size:1.75rem;font-weight:800;color:#c8d8e4;line-height:1;}
.ad-rh-unit{font-size:.65rem;color:#4a6275;}
.ad-rh-lv{font-size:.95rem;font-weight:700;margin-bottom:.3rem;}
.ad-rh-desc{font-size:.8rem;color:#6a7f90;margin-bottom:.35rem;line-height:1.5;}
.ad-rh-sub{font-size:.7rem;color:#4a6275;}
.ad-rh-angles{flex:1;min-width:200px;}
.ad-rh-ang-title{font-size:.75rem;font-weight:700;color:#a07050;margin-bottom:.6rem;display:flex;align-items:center;gap:.4rem;text-transform:uppercase;letter-spacing:.04em;}
.ad-rh-ang-item{font-size:.8rem;color:#8fa3b8;margin-bottom:.35rem;display:flex;align-items:center;gap:.45rem;line-height:1.4;}

/* Recommandations */
.ad-reco-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:var(--spacing-md);}
.ad-reco-card{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);border-radius:var(--radius-lg);padding:var(--spacing-md);}
.ad-reco-qw{border-top:2px solid rgba(77,184,212,.5);}
.ad-reco-mt{border-top:2px solid rgba(200,160,80,.5);}
.ad-reco-lt{border-top:2px solid rgba(77,184,212,.25);}
.ad-reco-badge{font-size:.68rem;font-weight:700;letter-spacing:.05em;text-transform:uppercase;margin-bottom:.7rem;display:flex;align-items:center;gap:.4rem;color:#6a7f90;}
.ad-reco-qw .ad-reco-badge i{color:#7ecfe0;}
.ad-reco-mt .ad-reco-badge i{color:#c8a050;}
.ad-reco-lt .ad-reco-badge i{color:#4a6275;}
.ad-reco-card ul{list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:.5rem;}
.ad-reco-card li{font-size:.8rem;color:#b0c4d4;line-height:1.55;padding-left:1rem;position:relative;}
.ad-reco-card li::before{content:'→';position:absolute;left:0;color:#4db8d4;font-weight:700;}
.ad-reco-card li strong{color:#dce8f4;}

/* Conformité */
.ad-comp-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:.6rem;}
.ad-comp-item{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);border-radius:var(--radius-md);padding:.8rem var(--spacing-sm);display:flex;flex-direction:column;gap:.25rem;}
.ad-comp-item strong{font-size:.72rem;font-weight:700;letter-spacing:.04em;color:#dce8f4;}
.ad-comp-item em{font-size:.65rem;color:#8fa8bc;font-style:normal;line-height:1.5;}
.ad-comp-s{font-size:.8rem;font-weight:700;}
.ad-comp-ok{color:#4caf77;}.ad-comp-warn{color:#c8a050;}.ad-comp-na{color:#4a6275;}

/* Outils officiels */
.ad-official-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:var(--spacing-md);}
.ad-official-card{display:flex;align-items:flex-start;gap:var(--spacing-sm);background:rgba(77,184,212,.04);border:1px solid rgba(77,184,212,.15);border-radius:var(--radius-lg);padding:var(--spacing-md);text-decoration:none;transition:all var(--transition-fast);}
.ad-official-card:hover{border-color:rgba(77,184,212,.35);background:rgba(77,184,212,.08);transform:translateY(-2px);}
.ad-official-icon{font-size:1.3rem;color:#4db8d4;flex-shrink:0;margin-top:.1rem;opacity:.85;}
.ad-official-card div{flex:1;}
.ad-official-card strong{display:block;font-size:.8rem;color:#b0c0cc;margin-bottom:.2rem;font-weight:700;}
.ad-official-card span{display:block;font-size:.72rem;color:#6a7f90;line-height:1.5;}
.ad-official-url{color:#4db8d4!important;font-weight:500;margin-top:.25rem;opacity:.8;}

/* Sources */
.ad-src-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(230px,1fr));gap:.4rem;}
.ad-src-item{display:flex;gap:.55rem;align-items:flex-start;padding:.6rem .75rem;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);border-radius:var(--radius-md);text-decoration:none;transition:border-color var(--transition-fast);}
.ad-src-item:hover{border-color:rgba(77,184,212,.3);background:rgba(77,184,212,.08);}
.ad-src-item>i{color:#8a6a50;font-size:.9rem;flex-shrink:0;margin-top:.15rem;}
.ad-src-item span{font-size:.72rem;color:#8fa8bc;line-height:1.5;}
.ad-src-item strong{color:#b8d0e4;}

/* ── Références normatives — tableau pro ────────────────── */
.ad-normrefs{max-width:1100px;margin:var(--spacing-xl) auto var(--spacing-lg);padding:0 var(--spacing-md);}
.ad-normrefs-header{display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:.8rem;margin-bottom:1.2rem;padding-bottom:.9rem;border-bottom:1px solid rgba(77,184,212,.18);}
.ad-normrefs-title{font-size:var(--text-base);color:#c8d8e4;font-weight:700;display:flex;align-items:center;gap:.6rem;letter-spacing:.01em;margin:0;}
.ad-normrefs-title i{color:#4db8d4;}
.ad-normrefs-legend{display:flex;flex-wrap:wrap;gap:.5rem;}
.ad-nrleg{display:inline-flex;align-items:center;gap:.35rem;font-size:.72rem;font-weight:600;padding:.25rem .75rem;border-radius:999px;letter-spacing:.03em;}
.ad-nrleg--blue{background:rgba(77,184,212,.1);border:1px solid rgba(77,184,212,.3);color:#7ecfe0;}
.ad-nrleg--red{background:rgba(220,70,70,.1);border:1px solid rgba(220,70,70,.3);color:#e08080;}
.ad-nrleg--green{background:rgba(80,200,120,.08);border:1px solid rgba(80,200,120,.28);color:#70cc90;}
.ad-nrleg--purple{background:rgba(160,100,220,.08);border:1px solid rgba(160,100,220,.28);color:#c090e8;}

/* table wrapper — scroll horizontal sur mobile */
.ad-nrtable-wrap{width:100%;overflow-x:auto;border-radius:1rem;border:1px solid rgba(255,255,255,.09);box-shadow:0 4px 32px rgba(0,0,0,.35);}
.ad-nrtable{width:100%;border-collapse:collapse;font-size:.84rem;}
.ad-nrtable thead tr{background:rgba(77,184,212,.1);border-bottom:1px solid rgba(77,184,212,.25);}
.ad-nrtable th{padding:.75rem 1rem;text-align:left;font-size:.72rem;font-weight:700;color:#7ecfe0;text-transform:uppercase;letter-spacing:.06em;white-space:nowrap;}
.ad-nrth-cat{width:120px;}
.ad-nrth-desc{width:35%;}
.ad-nrth-scope{width:20%;}
.ad-nrth-link{width:130px;}

/* rows */
.ad-nrtable tbody tr{border-bottom:1px solid rgba(255,255,255,.05);transition:background .15s ease;}
.ad-nrtable tbody tr:last-child{border-bottom:none;}
.ad-nrtable td{padding:.7rem 1rem;vertical-align:middle;color:#90aabf;line-height:1.5;}

/* category cell */
.ad-nrtd-cat{padding:.6rem .75rem;text-align:center;vertical-align:middle;}
.ad-nrcat{display:inline-flex;flex-direction:column;align-items:center;gap:.35rem;font-size:.7rem;font-weight:700;padding:.6rem .8rem;border-radius:.7rem;line-height:1.3;text-align:center;}
.ad-nrcat i{font-size:1.1rem;}
.ad-nrcat--blue{background:rgba(77,184,212,.1);border:1px solid rgba(77,184,212,.25);color:#7ecfe0;}
.ad-nrcat--red{background:rgba(220,70,70,.1);border:1px solid rgba(220,70,70,.25);color:#e08080;}
.ad-nrcat--green{background:rgba(80,200,120,.08);border:1px solid rgba(80,200,120,.22);color:#70cc90;}
.ad-nrcat--purple{background:rgba(160,100,220,.1);border:1px solid rgba(160,100,220,.25);color:#c090e8;}

/* ref cell */
.ad-nrtd-ref{white-space:nowrap;}
.ad-nrtd-ref strong{display:block;color:#dce8f4;font-weight:700;font-size:.86rem;}
.ad-nrver{display:inline-block;margin-top:.2rem;font-size:.63rem;font-weight:700;padding:.1rem .5rem;border-radius:999px;background:rgba(77,184,212,.1);border:1px solid rgba(77,184,212,.2);color:#7ecfe0;letter-spacing:.04em;text-transform:uppercase;}
.ad-nrver--red{background:rgba(220,70,70,.1);border-color:rgba(220,70,70,.25);color:#e08080;}
.ad-nrver--green{background:rgba(80,200,120,.08);border-color:rgba(80,200,120,.22);color:#70cc90;}
.ad-nrver--purple{background:rgba(160,100,220,.1);border-color:rgba(160,100,220,.25);color:#c090e8;}

/* tags */
.ad-nrtag{display:inline-block;font-size:.64rem;font-weight:600;padding:.1rem .5rem;border-radius:999px;margin:.1rem .1rem;background:rgba(77,184,212,.07);border:1px solid rgba(77,184,212,.18);color:#6dc8d8;letter-spacing:.03em;}
.ad-nrtag--red{background:rgba(220,70,70,.07);border-color:rgba(220,70,70,.2);color:#e08080;}
.ad-nrtag--green{background:rgba(80,200,120,.06);border-color:rgba(80,200,120,.2);color:#70cc90;}
.ad-nrtag--purple{background:rgba(160,100,220,.07);border-color:rgba(160,100,220,.2);color:#c090e8;}

/* link */
.ad-nrlink{display:inline-flex;align-items:center;gap:.3rem;font-size:.78rem;font-weight:600;color:#4db8d4;text-decoration:none;padding:.3rem .7rem;border-radius:999px;background:rgba(77,184,212,.08);border:1px solid rgba(77,184,212,.2);transition:all .15s ease;white-space:nowrap;}
.ad-nrlink:hover{background:rgba(77,184,212,.2);border-color:#4db8d4;color:#fff;}
.ad-nrlink i{font-size:.65rem;}

/* row color coding */
.ad-nrtr--blue{background:rgba(77,184,212,.025);}
.ad-nrtr--blue:hover{background:rgba(77,184,212,.07)!important;}
.ad-nrtr--red{background:rgba(220,70,70,.025);}
.ad-nrtr--red:hover{background:rgba(220,70,70,.07)!important;}
.ad-nrtr--green{background:rgba(80,200,120,.02);}
.ad-nrtr--green:hover{background:rgba(80,200,120,.06)!important;}
.ad-nrtr--purple{background:rgba(160,100,220,.025);}
.ad-nrtr--purple:hover{background:rgba(160,100,220,.07)!important;}

/* ── Light theme ── */
[data-theme="light"] .ad-normrefs-header{border-bottom-color:#d0dde8;}
[data-theme="light"] .ad-normrefs-title{color:#1a2535;}
[data-theme="light"] .ad-normrefs-title i{color:#1a6080;}
[data-theme="light"] .ad-nrleg--blue{background:rgba(26,103,140,.1);border-color:rgba(26,103,140,.35);color:#0d5478;}
[data-theme="light"] .ad-nrleg--red{background:rgba(180,40,40,.1);border-color:rgba(180,40,40,.35);color:#8a1010;}
[data-theme="light"] .ad-nrleg--green{background:rgba(30,140,70,.1);border-color:rgba(30,140,70,.35);color:#0f5c2a;}
[data-theme="light"] .ad-nrleg--purple{background:rgba(120,60,180,.1);border-color:rgba(120,60,180,.35);color:#5a1a90;}
[data-theme="light"] .ad-nrtable-wrap{background:#fff;border-color:#c8d8e4;box-shadow:0 2px 16px rgba(0,30,60,.1);}
[data-theme="light"] .ad-nrtable thead tr{background:#e8f4fb;border-bottom:2px solid #b0cfe0;}
[data-theme="light"] .ad-nrtable th{color:#0a4a6a;font-size:.73rem;}
[data-theme="light"] .ad-nrtable tbody tr{border-bottom-color:#d8e8f0;}
[data-theme="light"] .ad-nrtable td{color:#1a2e3e;background:#fff;}
[data-theme="light"] .ad-nrcat--blue{background:#daeef8;border-color:#6ab8d8;color:#0a4a6a;}
[data-theme="light"] .ad-nrcat--red{background:#fce8e8;border-color:#d88080;color:#7a1010;}
[data-theme="light"] .ad-nrcat--green{background:#d8f0e4;border-color:#6abf8a;color:#0a5022;}
[data-theme="light"] .ad-nrcat--purple{background:#ede8f8;border-color:#9a6ccc;color:#4a1080;}
[data-theme="light"] .ad-nrtd-ref strong{color:#0a2030;font-weight:700;}
[data-theme="light"] .ad-nrver{background:#daeef8;border-color:#6ab8d8;color:#0a4a6a;}
[data-theme="light"] .ad-nrver--red{background:#fce8e8;border-color:#d88080;color:#7a1010;}
[data-theme="light"] .ad-nrver--green{background:#d8f0e4;border-color:#6abf8a;color:#0a5022;}
[data-theme="light"] .ad-nrver--purple{background:#ede8f8;border-color:#9a6ccc;color:#4a1080;}
[data-theme="light"] .ad-nrtag{background:#daeef8;border-color:#6ab8d8;color:#0a4a6a;}
[data-theme="light"] .ad-nrtag--red{background:#fce8e8;border-color:#d88080;color:#7a1010;}
[data-theme="light"] .ad-nrtag--green{background:#d8f0e4;border-color:#6abf8a;color:#0a5022;}
[data-theme="light"] .ad-nrtag--purple{background:#ede8f8;border-color:#9a6ccc;color:#4a1080;}
[data-theme="light"] .ad-nrlink{background:#daeef8;border-color:#6ab8d8;color:#0a4a6a;font-weight:700;}
[data-theme="light"] .ad-nrlink:hover{background:#0d6b94;border-color:#0d6b94;color:#fff;}
[data-theme="light"] .ad-nrtr--blue td{background:#f0f9fd!important;}
[data-theme="light"] .ad-nrtr--blue:hover td{background:#daeef8!important;}
[data-theme="light"] .ad-nrtr--red td{background:#fff5f5!important;}
[data-theme="light"] .ad-nrtr--red:hover td{background:#fcdada!important;}
[data-theme="light"] .ad-nrtr--green td{background:#f3fdf6!important;}
[data-theme="light"] .ad-nrtr--green:hover td{background:#d8f0e4!important;}
[data-theme="light"] .ad-nrtr--purple td{background:#f8f4fc!important;}
[data-theme="light"] .ad-nrtr--purple:hover td{background:#ede8f8!important;}

/* Actions rapport */
.ad-report-actions{display:flex;flex-wrap:wrap;gap:var(--spacing-sm);justify-content:center;padding:var(--spacing-lg) 0;}

/* ── Titre du rapport généré ─────────────────────────── */
.ad-report-titlebar{display:flex;align-items:center;gap:1.2rem;background:linear-gradient(135deg,rgba(77,184,212,.1),rgba(45,100,140,.07));border:1.5px solid rgba(77,184,212,.28);border-radius:var(--radius-xl);padding:1.4rem 2rem;margin-bottom:var(--spacing-lg);}
.ad-rtb-icon{width:52px;height:52px;background:rgba(77,184,212,.15);border:1px solid rgba(77,184,212,.3);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.4rem;color:#4db8d4;flex-shrink:0;}
.ad-rtb-info{flex:1;min-width:0;}
.ad-rtb-h2{font-size:1.35rem;font-weight:800;color:#e8f4fc;margin:0 0 .25rem;letter-spacing:-.02em;}
.ad-rtb-meta{font-size:.78rem;color:#6a90a8;margin:0;line-height:1.5;}
.ad-rtb-meta strong{color:#8dc8da;}
.ad-rtb-stamp{font-size:.68rem;font-weight:600;color:#4db8d4;background:rgba(77,184,212,.1);border:1px solid rgba(77,184,212,.2);border-radius:999px;padding:.3rem .8rem;white-space:nowrap;display:inline-flex;align-items:center;gap:.3rem;flex-shrink:0;}
/* Radar canvas dans le rapport */
.ad-report-radar-wrap{display:flex;justify-content:center;padding:var(--spacing-sm) 0 var(--spacing-md);max-width:560px;margin:0 auto;}
.ad-report-radar-wrap canvas{width:100%!important;height:auto!important;}
/* Light theme */
[data-theme="light"] .ad-report-titlebar{background:linear-gradient(135deg,rgba(26,103,130,.06),rgba(26,103,130,.04));border-color:rgba(26,103,130,.25);}
[data-theme="light"] .ad-rtb-icon{background:rgba(26,103,130,.08);border-color:rgba(26,103,130,.25);color:#1a6580;}
[data-theme="light"] .ad-rtb-h2{color:#1a2535;}
[data-theme="light"] .ad-rtb-meta{color:#5a7080;}
[data-theme="light"] .ad-rtb-meta strong{color:#1a6080;}
[data-theme="light"] .ad-rtb-stamp{color:#1a6080;background:rgba(26,103,130,.07);border-color:rgba(26,103,130,.2);}

/* ══ Light theme — refonte complète lisibilité pro ════════ */

/* Hero */
[data-theme="light"] .ad-hero-sub{color:#3d5060;}
[data-theme="light"] .ad-hero-badge{background:rgba(26,103,130,.1);border-color:rgba(26,103,130,.25);color:#1a6580;}
[data-theme="light"] .ad-chip{background:rgba(0,0,0,.05);border-color:rgba(0,0,0,.12);color:#3d5060;}
[data-theme="light"] .ad-chip--green{background:rgba(34,197,94,.1);border-color:rgba(34,197,94,.25);color:#186b38;}

/* Profil bar */
[data-theme="light"] .ad-profil-bar{background:#fff;border-color:#d0dde8;box-shadow:0 1px 6px rgba(0,30,60,.07);}
[data-theme="light"] .ad-profil-label{color:#2a3e50;font-weight:600;}
[data-theme="light"] .ad-profil-btn{border-color:#b8ccd8;color:#2a3e50;background:#f5f9fc;}
[data-theme="light"] .ad-profil-btn:hover{border-color:rgba(26,103,130,.5);color:#1a4060;background:#eaf3f8;}
[data-theme="light"] .ad-profil-btn.is-active{background:rgba(26,103,130,.12);border-color:rgba(26,103,130,.55);color:#1a5070;font-weight:700;}
[data-theme="light"] .ad-profil-info{color:#5a7080;}

/* ── Colonne questionnaire — fond blanc comme la radar card ── */
[data-theme="light"] .ad-qcol{background:#fff;border:1px solid #b8d0e0;border-radius:var(--radius-xl);padding:var(--spacing-md);box-shadow:0 2px 16px rgba(0,30,60,.1);}

/* ── KA blocks ── */
[data-theme="light"] .ad-ka-block{background:#f8fbfd;border-color:#d0dde8;box-shadow:0 1px 4px rgba(0,30,60,.06);}
[data-theme="light"] .ad-ka-block.is-open{border-color:#1a7fa0;background:#fff;box-shadow:0 3px 16px rgba(26,103,130,.12);}
[data-theme="light"] .ad-ka-head:hover{background:#eef6fa;}
[data-theme="light"] .ad-ka-block.is-open .ad-ka-head{background:#e4f2f9;}
