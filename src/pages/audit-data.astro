/* close */
.ad-modal-close{position:absolute;top:1rem;right:1rem;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);color:#7a96aa;width:2.1rem;height:2.1rem;border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:.85rem;transition:all .15s ease;z-index:2;}
