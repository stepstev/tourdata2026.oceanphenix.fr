            <line x1="143" y1="169" x2="184" y2="122" stroke="rgba(77,184,212,0.18)" stroke-width="1"/>

            <!-- PHP Proxy box -->
            <text x="260" y="72" text-anchor="middle" font-size="9" fill="rgba(77,184,212,0.52)"
                  font-weight="600" letter-spacing="0.1em">PROXY SÉCURISÉ</text>
            <rect x="186" y="78" width="148" height="72" rx="6"
                  fill="rgba(11,20,40,0.75)" stroke="rgba(77,184,212,0.42)" stroke-width="1.5"/>
            <text x="260" y="104" text-anchor="middle" font-size="13" font-weight="700" fill="#c8dde8">PHP 8 Proxy</text>
            <line x1="206" y1="110" x2="314" y2="110" stroke="rgba(77,184,212,0.14)" stroke-width="0.8"/>
            <text x="260" y="124" text-anchor="middle" font-size="10" fill="#5a7a90">Clés API &middot; Cache TTL</text>
            <text x="260" y="138" text-anchor="middle" font-size="10" fill="#5a7a90">CORS &middot; Rate limit</text>

            <!-- Sécurité note sous le proxy -->
            <rect x="186" y="162" width="148" height="28" rx="4"
                  fill="rgba(200,122,74,0.07)" stroke="rgba(200,122,74,0.22)" stroke-width="0.8"/>
            <text x="260" y="180" text-anchor="middle" font-size="10" fill="rgba(200,122,74,0.85)">
