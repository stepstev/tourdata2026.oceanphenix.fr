            <line x1="90"  y1="180" x2="277" y2="158" stroke="rgba(77,184,212,0.22)" stroke-width="1.1"/>
            <line x1="90"  y1="190" x2="277" y2="216" stroke="rgba(77,184,212,0.22)" stroke-width="1.1"/>
            <line x1="90"  y1="200" x2="277" y2="274" stroke="rgba(77,184,212,0.22)" stroke-width="1.1"/>

            <!-- ── Acteur : Visiteur / Entreprise (droite haut) ── -->
            <circle cx="708" cy="130" r="18" fill="rgba(10,18,34,0.8)" stroke="rgba(77,184,212,0.5)" stroke-width="1.8"/>
            <line x1="708" y1="148" x2="708" y2="185" stroke="rgba(77,184,212,0.5)" stroke-width="1.8"/>
            <line x1="708" y1="160" x2="690" y2="172" stroke="rgba(77,184,212,0.5)" stroke-width="1.8"/>
            <line x1="708" y1="160" x2="726" y2="172" stroke="rgba(77,184,212,0.5)" stroke-width="1.8"/>
            <line x1="708" y1="185" x2="693" y2="204" stroke="rgba(77,184,212,0.5)" stroke-width="1.8"/>
            <line x1="708" y1="185" x2="723" y2="204" stroke="rgba(77,184,212,0.5)" stroke-width="1.8"/>
