              <pattern id="df-dot" width="20" height="20" patternUnits="userSpaceOnUse">
                <circle cx="1" cy="1" r="0.7" fill="rgba(77,184,212,0.06)"/>
              </pattern>
              <marker id="arr" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto">
                <polygon points="0 0, 8 3, 0 6" fill="rgba(77,184,212,0.65)"/>
              </marker>
            </defs>

            <rect width="780" height="222" fill="url(#df-dot)" rx="10"/>

            <!-- Label zone Sources -->
            <text x="78" y="18" text-anchor="middle" font-size="9" fill="rgba(77,184,212,0.5)"
