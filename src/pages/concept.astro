    <!-- ============================================= -->
    <!-- 7. ROADMAP PRODUIT                            -->
    <!-- ============================================= -->
    <section class="cp-section cp-section--alt" id="roadmap">
      <div class="cp-container">
        <div class="cp-section-header">
          <div class="cp-section-badge">
            <i class="fas fa-route"></i> Roadmap
          </div>
          <h2 class="cp-section-title">Vision Produit &amp; Jalons</h2>
          <p class="cp-section-desc">
            Du concept à la livraison finale — 5 phases couvrant idéation, build, tour terrain et valorisation post-parcours.
          </p>
        </div>
        <div class="cp-timeline" id="cp-timeline">
          {jalons.map((j) => (
            <div class="cp-tl-item" data-jalon-id={j.id}>
              <div class={`cp-tl-node cp-tl-node--${j.statut}`}></div>
              <div class="cp-tl-content">
                <span class={`cp-tl-date${j.statut === 'active' ? ' cp-tl-date--active' : ''}`}>{j.date}</span>
                <span class="cp-tl-title">{j.titre}</span>
                <span class="cp-tl-sub">{j.sous}</span>
              </div>
            </div>
          ))}
        </div>

        <!-- Hydration runtime : remplace la timeline si site-data.json contient roadmap -->
        <script is:inline>
          (function () {
            function renderTimeline(container, jalons) {
              container.innerHTML = '';
              jalons.forEach(function (j) {
                var item = document.createElement('div');
                item.className = 'cp-tl-item';
                item.dataset.jalonId = j.id || '';

                var node = document.createElement('div');
                node.className = 'cp-tl-node cp-tl-node--' + (j.statut || 'future');

                var content = document.createElement('div');
                content.className = 'cp-tl-content';

                var date = document.createElement('span');
                date.className = 'cp-tl-date' + (j.statut === 'active' ? ' cp-tl-date--active' : '');
                date.textContent = j.date || '';

                var titre = document.createElement('span');
                titre.className = 'cp-tl-title';
                titre.textContent = j.titre || '';

                var sous = document.createElement('span');
                sous.className = 'cp-tl-sub';
                sous.textContent = j.sous || '';

                content.appendChild(date);
                content.appendChild(titre);
                content.appendChild(sous);
                item.appendChild(node);
                item.appendChild(content);
                container.appendChild(item);
              });
            }

            fetch('/data/site-data.json', { signal: AbortSignal.timeout(4000) })
              .then(function (r) { return r.ok ? r.json() : null; })
              .then(function (d) {
                if (!d || !d.roadmap || !Array.isArray(d.roadmap.jalons) || d.roadmap.jalons.length === 0) return;
                var container = document.getElementById('cp-timeline');
                if (container) renderTimeline(container, d.roadmap.jalons);
              })
              .catch(function () { /* réseau indisponible — rendu build utilisé */ });
          }());
        </script>
      </div>
    </section>

