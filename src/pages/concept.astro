            </text>

            <!-- Arrow Proxy → Astro -->
            <line x1="334" y1="114" x2="378" y2="114"
                  stroke="rgba(77,184,212,0.55)" stroke-width="1.6" marker-end="url(#arr)"/>

            <!-- Astro box -->
            <text x="455" y="72" text-anchor="middle" font-size="9" fill="rgba(77,184,212,0.52)"
                  font-weight="600" letter-spacing="0.1em">GÉNÉRATION</text>
