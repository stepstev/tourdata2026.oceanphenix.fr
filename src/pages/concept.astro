---
// src/pages/concept.astro — Architecture & Conception Produit
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CopyrightBar from '../components/CopyrightBar.astro';
import OceanBackground from '../components/OceanBackground.astro';
import '../styles/concept.css';
import roadmapData from '../data/concept-roadmap.json';

const jalons = roadmapData.jalons;
---

<BaseLayout
  title="Conception & Architecture — TourData 2026 | OceanPhenix"
  description="Architecture technique, idéation et modélisation du projet TourData 2026 — approche Data Product Manager, stack Astro + PHP + APIs, diagrammes UML vulgarisés."
  lastModified="30/03/2026 12:00"
>
  <OceanBackground />
  <Nav />

  <main class="concept-page main-content">

    <!-- ============================================= -->
    <!-- ============================================= -->
    <!-- 1. GENÈSE & IDÉATION                          -->
    <!-- ============================================= -->
    <section class="cp-section cp-section--alt" id="ideation">
      <div class="cp-container--wide">
        <div class="cp-section-header">
          <div class="cp-section-badge">
            <i class="fas fa-lightbulb"></i> Constat &middot; Fév 2026
          </div>
          <h2 class="cp-section-title">Pourquoi ce projet existe — signaux de terrain</h2>
          <p class="cp-section-desc">
            Ce projet n'est pas né d'une idée — il est né d'un ressenti.
            Vécu de l'intérieur, en tant qu'<strong>hypersensible cognitif</strong>,
            chaque signal de marché a été perçu avec une acuité particulière&nbsp;:
            le bruit, le silence des retours, la désorientation des transitions.
            Quatre constats convergents ont déclenché la conception du Tour de la Data.
          </p>
        </div>

        <!-- 4 constats en grille 2×2 -->
        <div class="cp-cards cp-cards--2col">
          <div class="cp-card">
            <div class="cp-card-icon"><i class="fas fa-filter-circle-xmark"></i></div>
            <div class="cp-card-label">Constat 1</div>
            <h3 class="cp-card-title">Trop d'intermédiaires, trop peu de signal</h3>
            <p class="cp-card-text">
              Les clients sont inondés de CV — plusieurs ESN proposent le même consultant pour
              une seule offre, sans retour, même pour des profils à 25 ans d'expérience data.
              Le pipeline <strong>ESN → plateforme → client</strong> génère un bruit énorme
              qui noie les bons profils.
            </p>
          </div>
          <div class="cp-card">
            <div class="cp-card-icon"><i class="fas fa-building-circle-xmark"></i></div>
            <div class="cp-card-label">Constat 2</div>
            <h3 class="cp-card-title">Les ESN et agences traditionnelles en recul</h3>
            <p class="cp-card-text">
              Les acteurs traditionnels de l'intermédiation sont en perte de vitesse.
              Le marché se tourne vers la <strong>flexibilité, l'expertise ciblée et la réactivité</strong> —
              des critères mieux adressés par des modèles directs que par les structures ESN classiques.
            </p>
          </div>
          <div class="cp-card">
            <div class="cp-card-icon"><i class="fas fa-city"></i></div>
            <div class="cp-card-label">Constat 3</div>
            <h3 class="cp-card-title">Un marché IDF sous tension, les régions sous-adressées</h3>
            <p class="cp-card-text">
              Le marché francilien ralentit : grands projets en pause, ESN en contraction,
              afflux de candidats du conseil. Les entreprises sont plus sélectives.
              Pendant ce temps, les PME et ETI régionales — souvent plus matures qu'on ne le croit —
              <strong>n'ont pas accès aux bons profils</strong>.
            </p>
          </div>
          <div class="cp-card">
            <div class="cp-card-icon"><i class="fas fa-link-slash"></i></div>
            <div class="cp-card-label">Constat 4</div>
            <h3 class="cp-card-title">La demande existe — mais le matching est cassé</h3>
            <p class="cp-card-text">
              Les grandes entreprises recourent de plus en plus à des freelances hautement spécialisés
              pour combler un déficit de compétences internes. Mais le <strong>contact direct reste rare</strong> :
              les algorithmes et les intermédiaires absorbent le signal avant qu'il n'atteigne
              le bon profil.
            </p>
          </div>
        </div>

        <!-- ── UX MAP — Apprentissage terrain ─────── -->
        <div class="cp-validation cp-uxmap-block">
          <div class="cp-validation-icon">
            <i class="fas fa-hand-holding-heart"></i>
          </div>
          <div>
            <div class="cp-validation-label">
              <i class="fas fa-map-location-dot" style="margin-right:0.4rem;font-size:0.8rem;"></i>
              Ce que mes expériences m'ont appris — UX Map de terrain
            </div>
            <p class="cp-validation-text">
              Avant de modéliser ces constats, j'ai d'abord dû les <strong>ressentir</strong>.
              Les mois de silence après des candidatures, la désorientation des transitions,
              le bruit sans signal — tout cela a précédé l'analyse.
              C'est une leçon fondamentale de l'UX profonde&nbsp;:
              <strong>ressentir avant d'agir</strong>.
              On ne cartographie pas des douleurs depuis l'extérieur.
              On les traverse, on les nomme, et seulement ensuite on les structure.
              Ce projet est une <strong>UX Map vécue de l'intérieur</strong> —
              les signaux ci-dessous ne sont pas des hypothèses de recherche,
              ce sont des <em>expériences directes reconstruites en langage produit</em>.
            </p>
          </div>
        </div>

      </div>
    </section>

    <!-- ============================================= -->
    <!-- 1b. DOULEURS — TRAVAIL & TRANSITION 2026      -->
    <!-- ============================================= -->
    <section class="cp-section" id="constat-marche">
      <div class="cp-container--wide">
        <div class="cp-section-header">
          <div class="cp-section-badge">
            <i class="fas fa-heart-crack"></i> Douleurs &middot; Avr 2026
          </div>
          <h2 class="cp-section-title">Ce que le marché ne voit pas — et n'écoute pas</h2>
          <p class="cp-section-desc">
            Ce projet est né d'un ressenti, pas d'une théorie.
            Six signaux humains qui révèlent pourquoi la <strong>transition du travail</strong>
            touche d'abord à l'identité, à la relation, et au sens — bien avant les chiffres.
          </p>
        </div>

        <div class="cp-cards cp-pain-grid">

          <!-- 01 — Transition du travail -->
          <div class="cp-card cp-pain-card">
            <div class="cp-pain-head">
              <div class="cp-card-icon"><i class="fas fa-route"></i></div>
              <span class="cp-pain-num">01</span>
            </div>
            <h3 class="cp-card-title">La transition du travail comme rupture</h3>
            <div class="cp-pain-stats">
              <span class="cp-stat">Reconversion · Freelance · Multi-activité</span>
              <span class="cp-stat cp-stat--warn">Parcours fragmentés, repères effacés</span>
            </div>
            <p class="cp-card-text">
              Les carrières linéaires ont disparu. Chaque transition expose une personne
              à un marché qui ne sait plus comment la lire — ni l'accueillir.
              La <strong>flexibilité imposée</strong> n'est pas une liberté : c'est une solitude.
            </p>
            <div class="cp-pain-insight">
              <i class="fas fa-arrow-right-long"></i> On a normalisé la transition sans jamais l'accompagner
            </div>
          </div>

          <!-- 02 — Éloignement des échanges humains -->
          <div class="cp-card cp-pain-card">
            <div class="cp-pain-head">
              <div class="cp-card-icon"><i class="fas fa-users-slash"></i></div>
              <span class="cp-pain-num">02</span>
            </div>
            <h3 class="cp-card-title">La relation humaine absente du processus</h3>
            <div class="cp-pain-stats">
              <span class="cp-stat">Zéro retour malgré 25 ans d'expérience</span>
              <span class="cp-stat cp-stat--down">Algorithmes · ATS · Silence</span>
            </div>
            <p class="cp-card-text">
              Les algorithmes ont remplacé les conversations. Les recruteurs ne rappellent plus.
              Les équipes se forment à distance, se dissolvent sans jamais se connaître vraiment.
              Le <strong>contact direct s'est évaporé</strong>.
            </p>
            <div class="cp-pain-insight">
              <i class="fas fa-arrow-right-long"></i> On a optimisé le processus en perdant la relation
            </div>
          </div>

          <!-- 03 — Douleurs non entendues -->
          <div class="cp-card cp-pain-card">
            <div class="cp-pain-head">
              <div class="cp-card-icon"><i class="fas fa-comment-slash"></i></div>
              <span class="cp-pain-num">03</span>
            </div>
            <h3 class="cp-card-title">Les vrais besoins ne sont pas entendus</h3>
            <div class="cp-pain-stats">
              <span class="cp-stat">Compétences cochées ≠ potentiel réel</span>
              <span class="cp-stat cp-stat--down">Signal faible ignoré</span>
            </div>
            <p class="cp-card-text">
              Les outils d'évaluation mesurent des cases à cocher, pas des humains.
              Les vrais besoins — sens, lien, sécurité, reconnaissance —
              restent <strong>non formulés, jamais écoutés</strong>.
            </p>
            <div class="cp-pain-insight">
              <i class="fas fa-arrow-right-long"></i> Le marché confond le besoin déclaré avec le besoin réel
            </div>
          </div>

          <!-- 04 — IA et incertitude identitaire -->
          <div class="cp-card cp-pain-card cp-pain-card--ai">
            <div class="cp-pain-head">
              <div class="cp-card-icon cp-card-icon--danger"><i class="fas fa-robot"></i></div>
              <span class="cp-pain-num">04</span>
            </div>
            <h3 class="cp-card-title">L'IA&nbsp;: accélérateur d'incertitude</h3>
            <div class="cp-pain-stats">
              <span class="cp-stat cp-stat--ai">Métiers redéfinis plus vite qu'on s'y adapte</span>
              <span class="cp-stat">Pression anxiogène · Identités déstabilisées</span>
            </div>
            <p class="cp-card-text">
              L'IA ne détruit pas massivement — elle <em>déstabilise durablement</em>.
              Elle creuse l'écart entre ceux qui s'adaptent et ceux qui subissent,
              sans offrir de cap, de repère, ni d'espace pour souffler.
            </p>
            <div class="cp-pain-insight cp-pain-insight--orange">
              <i class="fas fa-arrow-right-long"></i> Ce n'est pas une crise de l'emploi — c'est une crise de sens
            </div>
          </div>

          <!-- 05 — Perte de repères collectifs -->
          <div class="cp-card cp-pain-card">
            <div class="cp-pain-head">
              <div class="cp-card-icon"><i class="fas fa-compass-drafting"></i></div>
              <span class="cp-pain-num">05</span>
            </div>
            <h3 class="cp-card-title">Perte des repères humains du travail</h3>
            <div class="cp-pain-stats">
              <span class="cp-stat">Le collectif s'est effrité</span>
              <span class="cp-stat cp-stat--down">Isolement · Désorientation</span>
            </div>
            <p class="cp-card-text">
              Le chef, le bureau, l'équipe fixe, le projet commun — ces cadres ont volé en éclats.
              Ce vide institutionnel laisse les individus seuls face à des choix permanents,
              <strong>sans soutien, sans boussole</strong>.
            </p>
            <div class="cp-pain-insight">
              <i class="fas fa-arrow-right-long"></i> L'orientation est devenue une charge individuelle non partagée
            </div>
          </div>

          <!-- 06 — Contexte instable (pleine largeur) -->
          <div class="cp-card cp-pain-card cp-pain-card--wide">
            <div class="cp-pain-head">
              <div class="cp-card-icon"><i class="fas fa-earth-europe"></i></div>
              <span class="cp-pain-num">06</span>
            </div>
            <h3 class="cp-card-title">La bascule géopolitique mondiale — quand le monde légitime l'ensauvagement</h3>
            <div class="cp-pain-stats">
              <span class="cp-stat cp-stat--down">Bascule géopolitique mondiale</span>
              <span class="cp-stat cp-stat--down">Ensauvagement · Loi du plus fort</span>
              <span class="cp-stat cp-stat--warn">Déshumanisation normalisée</span>
              <span class="cp-stat">Instabilité structurelle, pas conjoncturelle</span>
            </div>
            <p class="cp-card-text">
              La bascule géopolitique — fractures entre blocs, retrait des solidarités collectives,
              montée de la logique de prédation — ne s'arrête pas aux portes du marché du travail.
              Elle le traverse. Les rapports entre acteurs durcissent&nbsp;:
              <strong>les loups avancent, les brebis s'organisent seules</strong>.
              L'ensauvagement n'est pas une métaphore — c'est la norme que certains systèmes
              commencent à légitimer. Dans ce contexte, la perte de repères n'est plus individuelle&nbsp;:
              elle est <strong>structurellement organisée</strong>.
            </p>
            <div class="cp-pain-insight">
              <i class="fas fa-arrow-right-long"></i>
              Ce que vit le marché du travail n'est pas une crise isolée — c'est l'écho d'un monde qui a normalisé la loi du plus fort
            </div>
          </div>

        </div><!-- /.cp-cards -->

        <!-- Synthèse : fractures + insight clé -->
        <div class="cp-fractures-block">
          <div class="cp-fractures-left">
            <div class="cp-fractures-header">
              <i class="fas fa-heart-crack"></i>
              <span>Les 6 Fractures Profondes du Travail 2026</span>
            </div>
            <div class="cp-fractures-list">
              <div class="cp-fracture"><i class="fas fa-xmark"></i> Transitions permanentes sans accompagnement</div>
              <div class="cp-fracture"><i class="fas fa-xmark"></i> Échanges humains remplacés par des processus</div>
              <div class="cp-fracture"><i class="fas fa-xmark"></i> Douleurs réelles non formulées, non entendues</div>
              <div class="cp-fracture"><i class="fas fa-xmark"></i> Identités professionnelles déstabilisées par l'IA</div>
              <div class="cp-fracture"><i class="fas fa-xmark"></i> Perte des repères collectifs et du sens partagé</div>
              <div class="cp-fracture cp-fracture--geo"><i class="fas fa-earth-europe"></i> Bascule géopolitique qui légitime l'ensauvagement des rapports humains</div>
            </div>
          </div>
          <div class="cp-fractures-right">
            <div class="cp-fractures-insight">
              <div class="cp-fractures-insight-label"><i class="fas fa-scale-balanced"></i> Posture Éthique</div>
              <p>
                Ce marché n'est pas en crise de l'emploi.
                Il est en <strong>crise d'écoute, de relation et de sens</strong>.
              </p>
              <p class="cp-fractures-quote">
                &laquo;&nbsp;Le problème n'est pas de <em>trouver un job</em> —
                c'est de retrouver une <em>place humaine dans un monde
                qui s'accélère sans jamais s'arrêter pour comprendre</em>.&nbsp;&raquo;
              </p>
              <p class="cp-fractures-strategic">
                Ce que vivent ceux en transition en 2026 n'est pas un échec personnel —
                c'est une <strong>réponse humaine cohérente à un système qui a cessé d'écouter</strong>,
                dans un monde géopolitique qui a <strong>normalisé l'ensauvagement</strong> des rapports de force.
              </p>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- ============================================= -->
    <!-- 2. STACK TECHNOLOGIQUE                        -->
    <!-- ============================================= -->
    <section class="cp-section" id="stack">
      <div class="cp-container">
        <div class="cp-section-header">
          <div class="cp-section-badge">
            <i class="fas fa-microchip"></i> Stack
          </div>
          <h2 class="cp-section-title">Technologies Utilisées</h2>
          <p class="cp-section-desc">
            Choix techniques orientés performance, maintenabilité et zéro dépendance superflue.
            Chaque couche a une responsabilité claire.
          </p>
        </div>
        <div class="cp-stack">
          <div class="cp-stack-row">
            <div class="cp-stack-layer"><i class="fas fa-desktop"></i>Présentation</div>
            <div class="cp-stack-tags">
              <span class="cp-tag">Astro 4</span>
              <span class="cp-tag">CSS Custom Properties</span>
              <span class="cp-tag">Vanilla JS</span>
              <span class="cp-tag">Inter (Google Fonts)</span>
              <span class="cp-tag">Font Awesome 6</span>
            </div>
          </div>
          <div class="cp-stack-row">
            <div class="cp-stack-layer"><i class="fas fa-map"></i>Cartographie</div>
            <div class="cp-stack-tags">
              <span class="cp-tag">Leaflet.js</span>
              <span class="cp-tag">MarkerCluster</span>
              <span class="cp-tag">OSM Overpass API</span>
              <span class="cp-tag">GeoJSON</span>
              <span class="cp-tag">GPX</span>
            </div>
          </div>
          <div class="cp-stack-row">
            <div class="cp-stack-layer"><i class="fas fa-plug"></i>APIs</div>
            <div class="cp-stack-tags">
              <span class="cp-tag cp-tag--orange">Strava API v3</span>
              <span class="cp-tag cp-tag--orange">OpenAgenda</span>
              <span class="cp-tag cp-tag--orange">Entreprises.gouv.fr</span>
              <span class="cp-tag cp-tag--orange">OpenWeather</span>
            </div>
          </div>
          <div class="cp-stack-row">
            <div class="cp-stack-layer"><i class="fas fa-server"></i>Backend</div>
            <div class="cp-stack-tags">
              <span class="cp-tag cp-tag--green">PHP 8</span>
              <span class="cp-tag cp-tag--green">Proxy CORS</span>
              <span class="cp-tag cp-tag--green">Cache fichier</span>
              <span class="cp-tag cp-tag--green">.htaccess</span>
              <span class="cp-tag cp-tag--green">JSON store</span>
            </div>
          </div>
          <div class="cp-stack-row">
            <div class="cp-stack-layer"><i class="fas fa-rocket"></i>Déploiement</div>
            <div class="cp-stack-tags">
              <span class="cp-tag">O2Switch</span>
              <span class="cp-tag">WinSCP FTP</span>
              <span class="cp-tag">deploy.bat</span>
              <span class="cp-tag">Astro SSG build</span>
              <span class="cp-tag">Git</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================= -->
    <!-- 3. DÉCISIONS DE CONCEPTION                    -->
    <!-- ============================================= -->
    <section class="cp-section cp-section--alt" id="decisions">
      <div class="cp-container">
        <div class="cp-section-header">
          <div class="cp-section-badge">
            <i class="fas fa-chess"></i> Arbitrages Produit
          </div>
          <h2 class="cp-section-title">Décisions de Conception</h2>
          <p class="cp-section-desc">
            Chaque choix technique répond à une contrainte produit. Voici les quatre arbitrages structurants.
          </p>
        </div>
        <div class="cp-decisions">
          <div class="cp-decision">
            <div class="cp-decision-head">
              <i class="fas fa-bolt"></i>
              <span class="cp-decision-title">Rendu statique plutôt que SPA</span>
            </div>
            <span class="cp-decision-choice">Astro SSG &rarr; pas de framework JS</span>
            <p class="cp-decision-why">
              Chargement instantané sur connexion mobile terrain. Aucun JavaScript obligatoire
              côté client — chaque page est un fichier HTML servi directement par Apache.
            </p>
          </div>
          <div class="cp-decision">
            <div class="cp-decision-head">
              <i class="fas fa-shield-halved"></i>
              <span class="cp-decision-title">Proxy PHP centralisé</span>
            </div>
            <span class="cp-decision-choice">PHP proxy &rarr; clés API hors dépôt Git</span>
            <p class="cp-decision-why">
              Toutes les clés API sensibles restent côté serveur dans un fichier .env.
              Le proxy gère aussi la mise en cache (TTL 5 min) pour ne pas saturer
              les quotas gratuits des APIs.
            </p>
          </div>
          <div class="cp-decision">
            <div class="cp-decision-head">
              <i class="fas fa-database"></i>
              <span class="cp-decision-title">JSON comme datastore</span>
            </div>
            <span class="cp-decision-choice">Fichiers JSON &rarr; pas de base de données</span>
            <p class="cp-decision-why">
              Les données de parcours (étapes, journal, GPX) sont stockées en JSON versionné
              dans Git. L'admin peut éditer en ligne, sans interface SQL.
              Parfait pour un projet solo à durée limitée.
            </p>
          </div>
          <div class="cp-decision">
            <div class="cp-decision-head">
              <i class="fas fa-palette"></i>
              <span class="cp-decision-title">Design tokens centralisés</span>
            </div>
            <span class="cp-decision-choice">CSS custom properties &rarr; thème light/dark</span>
            <p class="cp-decision-why">
              Un seul fichier <code>tokens.css</code> définit couleurs, espacement, typographie.
              Le basculement dark/light est géré par une seule surcharge de variables CSS
              sur <code>html[data-theme="light"]</code>.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================= -->
    <!-- 4. DIAGRAMME CAS D'USAGE (UML)                -->
    <!-- ============================================= -->
    <section class="cp-section" id="usecase">
      <div class="cp-container--wide">
        <div class="cp-section-header">
          <div class="cp-section-badge">
            <i class="fas fa-diagram-project"></i> UML &middot; Cas d'usage
          </div>
          <h2 class="cp-section-title">Acteurs &amp; Cas d'Usage</h2>
          <p class="cp-section-desc">
            3 acteurs, 5 cas d'usage principaux. Le Cycliste utilise toutes les fonctionnalités ;
            le Visiteur consulte ; l'Admin gère le contenu.
          </p>
        </div>
        <div class="cp-diagram-wrap">
          <svg viewBox="0 0 780 390" xmlns="http://www.w3.org/2000/svg"
               role="img" aria-label="Diagramme de cas d'usage UML TourData 2026"
               font-family="Inter, system-ui, sans-serif">
            <!-- Fond solide dark -->
            <rect width="780" height="390" fill="#0a1626" rx="10"/>
            <!-- Grille subtile -->
            <defs>
              <pattern id="uc-grid" width="24" height="24" patternUnits="userSpaceOnUse">
                <path d="M24 0H0V24" fill="none" stroke="rgba(77,184,212,0.055)" stroke-width="0.5"/>
              </pattern>
            </defs>
            <rect width="780" height="390" fill="url(#uc-grid)" rx="10"/>

            <!-- System boundary box -->
            <rect x="192" y="32" width="396" height="326"
                  fill="rgba(77,184,212,0.04)"
                  stroke="rgba(77,184,212,0.55)" stroke-width="1.8" rx="8"/>
            <text x="390" y="24" text-anchor="middle"
                  font-size="11" fill="rgba(77,184,212,0.75)" font-style="italic" letter-spacing="0.07em">«system»</text>
            <text x="390" y="57" text-anchor="middle"
                  font-size="15" font-weight="800" fill="#e8f4fc" letter-spacing="-0.01em">TourData 2026</text>
            <line x1="270" y1="65" x2="510" y2="65"
                  stroke="rgba(77,184,212,0.35)" stroke-width="1"/>

            <!-- UC1 — Terrain & Journal -->
            <ellipse cx="390" cy="102" rx="115" ry="24"
                     fill="rgba(77,184,212,0.12)" stroke="rgba(77,184,212,0.65)" stroke-width="1.5"/>
            <text x="390" y="107" text-anchor="middle" font-size="13.5" font-weight="600" fill="#e8f4fc">Terrain &amp; Journal</text>

            <!-- UC2 — Radar Entreprises -->
            <ellipse cx="390" cy="160" rx="115" ry="24"
                     fill="rgba(77,184,212,0.10)" stroke="rgba(77,184,212,0.55)" stroke-width="1.5"/>
