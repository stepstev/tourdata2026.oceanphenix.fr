            <line x1="72" y1="220" x2="57"  y2="239" stroke="rgba(77,184,212,0.72)" stroke-width="1.8"/>
            <line x1="72" y1="220" x2="87"  y2="239" stroke="rgba(77,184,212,0.72)" stroke-width="1.8"/>
            <text x="72" y="256" text-anchor="middle" font-size="12" font-weight="600" fill="#8fa3b8">Cycliste</text>

            <!-- Connections : Cycliste → UC1,2,3,4 -->
