            <text x="390" y="337" text-anchor="middle" font-size="12" font-weight="500" fill="#d4a07a">Administration</text>

            <!-- ── Acteur : Cycliste (gauche) ─────────── -->
            <circle cx="72" cy="165" r="18" fill="rgba(10,18,34,0.8)" stroke="rgba(77,184,212,0.72)" stroke-width="1.8"/>
            <line x1="72" y1="183" x2="72" y2="220" stroke="rgba(77,184,212,0.72)" stroke-width="1.8"/>
