            <!-- UC1 — Terrain & Journal -->
            <ellipse cx="390" cy="100" rx="113" ry="23"
                     fill="rgba(77,184,212,0.07)" stroke="rgba(77,184,212,0.38)" stroke-width="1.2"/>
            <text x="390" y="105" text-anchor="middle" font-size="12" font-weight="500" fill="#d0e8f5">Terrain &amp; Journal</text>

            <!-- UC2 — Radar Entreprises -->
            <ellipse cx="390" cy="158" rx="113" ry="23"
                     fill="rgba(77,184,212,0.07)" stroke="rgba(77,184,212,0.38)" stroke-width="1.2"/>
            <text x="390" y="163" text-anchor="middle" font-size="12" font-weight="500" fill="#d0e8f5">Radar Entreprises</text>

            <!-- UC3 — Météo Étapes -->
            <ellipse cx="390" cy="216" rx="113" ry="23"
                     fill="rgba(77,184,212,0.07)" stroke="rgba(77,184,212,0.38)" stroke-width="1.2"/>
            <text x="390" y="221" text-anchor="middle" font-size="12" font-weight="500" fill="#d0e8f5">Météo Étapes</text>

            <!-- UC4 — Dashboard Strava -->
            <ellipse cx="390" cy="274" rx="113" ry="23"
                     fill="rgba(77,184,212,0.07)" stroke="rgba(77,184,212,0.38)" stroke-width="1.2"/>
            <text x="390" y="279" text-anchor="middle" font-size="12" font-weight="500" fill="#d0e8f5">Dashboard Strava</text>

            <!-- UC5 — Administration (accent copper) -->
            <ellipse cx="390" cy="332" rx="113" ry="23"
