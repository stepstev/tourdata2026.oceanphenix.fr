  .mt-etape-card--error { color: var(--text-muted); font-size: 0.72rem; }

  /* ── ÉTATS ─────────────────────────────────────────────── */
  .mt-loading { padding: 3rem; text-align: center; color: var(--text-muted); font-size: 0.9rem; }
  .mt-key-warn {
    background: rgba(245,158,11,0.08);
    border: 1px solid rgba(245,158,11,0.25);
    border-radius: var(--radius-md);
    padding: 1.2rem 1.5rem; font-size: 0.83rem;
    color: var(--text-light); margin-bottom: 1.5rem; line-height: 1.6;
  }
