  .mt-key-warn code { background: rgba(0,0,0,0.3); padding: 1px 6px; border-radius: 4px; font-size: 0.78rem; }
  .mt-key-warn i    { color: #f59e0b; margin-right: 6px; }

  /* ── LIGHT THEME ──────────────────────────────────────── */
  [data-theme="light"] .mt-hero       { background: rgba(221,232,244,0.97); border-color: rgba(26,127,160,0.15); }
  [data-theme="light"] .mt-hero-title { color: #1a334c; }
  [data-theme="light"] .mt-hero-sub   { color: #4a6275; }
  [data-theme="light"] .mt-subnav     { background: rgba(221,232,244,0.96); border-color: rgba(26,127,160,0.15); }
  [data-theme="light"] .mt-tab        { color: #4a6275; }
  [data-theme="light"] .mt-tab--active { color: var(--accent-blue); background: rgba(26,127,160,0.1); }
  [data-theme="light"] .mt-current,
  [data-theme="light"] .mt-forecast-card,
  [data-theme="light"] .mt-etape-card,
  [data-theme="light"] .mt-hour-card   { background: rgba(240,247,254,0.97); border-color: rgba(26,127,160,0.16); }
  [data-theme="light"] .mt-temp,
  [data-theme="light"] .mt-fc-max,
  [data-theme="light"] .mt-etape-temp  { color: #1a334c; }
  [data-theme="light"] .mt-stat-val    { color: #1a334c; }
  [data-theme="light"] .mt-stat        { background: rgba(26,127,160,0.05); border-color: rgba(26,127,160,0.14); }

  /* ── RESPONSIVE ───────────────────────────────────────── */
  @media (max-width: 640px) {
    .mt-hero-inner      { flex-wrap: wrap; }
    .mt-hero-locate     { margin-left: 0; width: 100%; }
    .mt-current         { flex-direction: column; }
    .mt-current-stats   { grid-template-columns: repeat(2, 1fr); }
    .mt-forecast-grid   { grid-template-columns: repeat(2, 1fr); }
    .mt-etapes-grid     { grid-template-columns: repeat(2, 1fr); }
    .mt-score-inner     { flex-wrap: wrap; }
  }
