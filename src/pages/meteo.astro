  .mt-etape-name  { font-size: 0.72rem; font-weight: 700; color: var(--accent-cyan); }
  .mt-etape-icon  { width: 44px; height: 44px; }
  .mt-etape-temp  { font-size: 1.35rem; font-weight: 800; color: var(--text-light); }
