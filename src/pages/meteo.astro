---
// src/pages/meteo.astro — Météo Cycliste automatique (OpenWeather API gratuite)
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CopyrightBar from '../components/CopyrightBar.astro';
import OceanBackground from '../components/OceanBackground.astro';
---

<BaseLayout
  title="Météo Cycliste — TourData 2026 | OceanPhenix"
  description="Météo automatique en temps réel pour le Tour Data 2026 — conditions cyclistes, prévisions 5 jours, vent et précipitations sur les étapes."
  lastModified="28/03/2026 12:00"
>
  <OceanBackground />
  <Nav />

  <main class="meteo-page main-content">

    <!-- ══════════════════════════════════════════════════════
         HERO
    ══════════════════════════════════════════════════════ -->
    <section class="mt-hero">
      <div class="mt-hero-inner">
        <div class="mt-hero-icon-wrap">
          <i class="fas fa-cloud-sun-rain mt-hero-icon"></i>
        </div>
        <div class="mt-hero-text">
          <h1 class="mt-hero-title">Météo Cycliste</h1>
          <p class="mt-hero-sub">Conditions en temps réel &middot; Tour Data 2026</p>
        </div>
        <div class="mt-hero-locate">
          <button id="mt-locate-btn" class="mt-btn mt-btn--primary">
            <i class="fas fa-location-dot"></i> Ma position
          </button>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════
         SOUS-NAVIGATION
    ══════════════════════════════════════════════════════ -->
    <div class="mt-subnav-outer">
      <nav class="mt-subnav" role="tablist" aria-label="Sections météo">
        <button class="mt-tab mt-tab--active" data-tab="position" role="tab" aria-selected="true">
          <i class="fas fa-location-dot"></i> Ma position
        </button>
        <button class="mt-tab" data-tab="etapes" role="tab" aria-selected="false">
          <i class="fas fa-route"></i> Étapes Tour
        </button>
        <button class="mt-tab" data-tab="previsions" role="tab" aria-selected="false">
          <i class="fas fa-calendar-week"></i> Prévisions 5j
        </button>
        <button class="mt-tab" data-tab="carte" role="tab" aria-selected="false">
          <i class="fas fa-map-location-dot"></i> Carte France
        </button>
      </nav>
    </div>

    <!-- ══════════════════════════════════════════════════════
         CONTENU PRINCIPAL
    ══════════════════════════════════════════════════════ -->
    <div class="mt-container">

      <!-- ── Section MA POSITION ── -->
      <section id="mt-position" class="mt-section mt-section--active">

        <!-- Bloc tech info -->
        <div class="mt-tech-info">
          <div class="mt-tech-desc">
            <i class="fas fa-circle-info"></i>
            Météo temps réel à votre position GPS — température, vent, humidité et score cycliste calculé localement.
          </div>
          <div class="mt-tech-flow">
            <span class="mt-tf-step"><i class="fas fa-location-dot"></i> Geolocation API</span>
            <span class="mt-tf-arrow">→</span>
            <span class="mt-tf-step"><i class="fas fa-server"></i> api.open-meteo.com</span>
            <span class="mt-tf-arrow">→</span>
            <span class="mt-tf-step"><i class="fas fa-map-pin"></i> nominatim.openstreetmap.org</span>
            <span class="mt-tf-arrow">→</span>
            <span class="mt-tf-step mt-tf-step--out"><i class="fas fa-chart-simple"></i> Affichage + score</span>
          </div>
          <div class="mt-tech-tags">
            <span class="mt-tag">Gratuit · sans clé</span>
            <span class="mt-tag">Open-Meteo v1</span>
            <span class="mt-tag">Nominatim OSM</span>
            <span class="mt-tag">Score algorithmique local</span>
          </div>
        </div>

        <!-- Météo actuelle -->
        <div class="mt-current">
          <div class="mt-current-main">
            <span id="mt-icon" class="mt-weather-emoji" aria-hidden="true">🌤</span>
            <div class="mt-temp-wrap">
              <span id="mt-temp" class="mt-temp">—</span>
              <span class="mt-temp-unit">°C</span>
            </div>
            <div class="mt-desc-wrap">
              <span id="mt-desc" class="mt-desc">Chargement…</span>
              <span id="mt-city" class="mt-city"><i class="fas fa-location-dot"></i> —</span>
            </div>
          </div>

          <div class="mt-current-stats">
            <div class="mt-stat">
              <i class="fas fa-temperature-half mt-stat-icon"></i>
              <span class="mt-stat-label">Ressenti</span>
              <span id="mt-feels" class="mt-stat-val">—</span>
            </div>
            <div class="mt-stat">
              <i class="fas fa-droplet mt-stat-icon"></i>
              <span class="mt-stat-label">Humidité</span>
              <span id="mt-humidity" class="mt-stat-val">—</span>
            </div>
            <div class="mt-stat">
              <i class="fas fa-wind mt-stat-icon"></i>
              <span class="mt-stat-label">Vent</span>
              <span id="mt-wind" class="mt-stat-val">—</span>
            </div>
            <div class="mt-stat">
              <i class="fas fa-compass mt-stat-icon"></i>
              <span class="mt-stat-label">Direction</span>
              <span id="mt-wind-dir" class="mt-stat-val">—</span>
            </div>
            <div class="mt-stat">
              <i class="fas fa-gauge-high mt-stat-icon"></i>
              <span class="mt-stat-label">Pression</span>
              <span id="mt-pressure" class="mt-stat-val">—</span>
            </div>
            <div class="mt-stat">
              <i class="fas fa-eye mt-stat-icon"></i>
              <span class="mt-stat-label">Visibilité</span>
              <span id="mt-visibility" class="mt-stat-val">—</span>
            </div>
          </div>
        </div>

        <!-- Score cyclisme -->
        <div id="mt-cycling-score" class="mt-cycling-score hidden">
          <div class="mt-score-inner">
            <div class="mt-score-label">Score vélo</div>
            <div class="mt-score-dial">
              <span id="mt-score-val" class="mt-score-num">—</span>
              <span class="mt-score-max">/10</span>
            </div>
            <div id="mt-score-desc" class="mt-score-comment"></div>
          </div>
        </div>

        <!-- Bande horaire -->
        <div class="mt-hourly-wrap">
          <h3 class="mt-section-title"><i class="fas fa-clock"></i> Prochaines heures</h3>
          <div id="mt-hourly" class="mt-hourly"></div>
        </div>

      </section>

      <!-- ── Section ÉTAPES TOUR ── -->
      <section id="mt-etapes" class="mt-section">

        <!-- Bloc tech info -->
        <div class="mt-tech-info">
          <div class="mt-tech-desc">
            <i class="fas fa-circle-info"></i>
            Conditions météo actuelles sur chaque ville-étape du Tour Data 2026 — requêtes parallèles pour un chargement rapide.
          </div>
          <div class="mt-tech-flow">
            <span class="mt-tf-step"><i class="fas fa-route"></i> 21 étapes (coords GPS)</span>
            <span class="mt-tf-arrow">→</span>
            <span class="mt-tf-step"><i class="fas fa-server"></i> api.open-meteo.com <span class="mt-tf-badge">×21 Promise.all</span></span>
            <span class="mt-tf-arrow">→</span>
            <span class="mt-tf-step mt-tf-step--out"><i class="fas fa-grip"></i> Grille de vignettes</span>
          </div>
          <div class="mt-tech-tags">
            <span class="mt-tag">Gratuit · sans clé</span>
            <span class="mt-tag">Open-Meteo current</span>
            <span class="mt-tag">Promise.allSettled</span>
            <span class="mt-tag">WMO weather codes</span>
          </div>
        </div>

        <div class="mt-etapes-grid" id="mt-etapes-grid"></div>
      </section>

      <!-- ── Section PRÉVISIONS 5J ── -->
      <section id="mt-previsions" class="mt-section">

        <!-- Bloc tech info -->
        <div class="mt-tech-info">
          <div class="mt-tech-desc">
            <i class="fas fa-circle-info"></i>
            Prévisions journalières sur 5 jours à votre position — températures min/max, vent, précipitations et score cycliste par jour.
          </div>
          <div class="mt-tech-flow">
            <span class="mt-tf-step"><i class="fas fa-location-dot"></i> Position GPS</span>
            <span class="mt-tf-arrow">→</span>
            <span class="mt-tf-step"><i class="fas fa-server"></i> api.open-meteo.com <span class="mt-tf-badge">daily</span></span>
            <span class="mt-tf-arrow">→</span>
            <span class="mt-tf-step"><i class="fas fa-calculator"></i> Score algo local</span>
            <span class="mt-tf-arrow">→</span>
            <span class="mt-tf-step mt-tf-step--out"><i class="fas fa-table-cells"></i> 5 cartes / jours</span>
          </div>
          <div class="mt-tech-tags">
            <span class="mt-tag">Gratuit · sans clé</span>
            <span class="mt-tag">Open-Meteo daily forecast</span>
            <span class="mt-tag">temperature_2m_max/min</span>
            <span class="mt-tag">precipitation_probability_max</span>
          </div>
        </div>

        <div class="mt-forecast-grid" id="mt-forecast-grid"></div>
      </section>

      <!-- ── Section CARTE MÉTÉO FRANCE ── -->
      <section id="mt-carte" class="mt-section">

        <!-- Bloc tech info -->
        <div class="mt-tech-info">
          <div class="mt-tech-desc">
            <i class="fas fa-circle-info"></i>
            Carte interactive des températures max sur 28 villes françaises — marqueurs colorés par zone thermique, popup détaillé au clic.
          </div>
          <div class="mt-tech-flow">
            <span class="mt-tf-step"><i class="fas fa-city"></i> 28 villes (coords)</span>
            <span class="mt-tf-arrow">→</span>
            <span class="mt-tf-step"><i class="fas fa-server"></i> api.open-meteo.com <span class="mt-tf-badge">batch</span></span>
            <span class="mt-tf-arrow">→</span>
            <span class="mt-tf-step"><i class="fas fa-map"></i> Leaflet.js + OSM</span>
            <span class="mt-tf-arrow">→</span>
            <span class="mt-tf-step mt-tf-step--out"><i class="fas fa-location-pin"></i> Marqueurs J+0…J+5</span>
          </div>
          <div class="mt-tech-tags">
            <span class="mt-tag">Gratuit · sans clé</span>
            <span class="mt-tag">Open-Meteo batch API</span>
            <span class="mt-tag">Leaflet.js v1.9</span>
            <span class="mt-tag">OpenStreetMap tiles</span>
          </div>
        </div>

        <div class="mt-carte-bar">
          <div class="mt-period-bar">
            <span class="mt-period-label"><i class="fas fa-calendar-days"></i> Période :</span>
            <button class="mt-period-btn mt-period-btn--active" data-day="0">Auj.</button>
            <button class="mt-period-btn" data-day="1">J+1</button>
            <button class="mt-period-btn" data-day="2">J+2</button>
            <button class="mt-period-btn" data-day="3">J+3</button>
            <button class="mt-period-btn" data-day="4">J+4</button>
            <button class="mt-period-btn" data-day="5">J+5</button>
          </div>
          <div class="mt-map-legend">
            <span class="mt-legend-dot" style="background:#4a80a8"></span>&lt;5°
            <span class="mt-legend-dot" style="background:#3d8860"></span>5–15°
            <span class="mt-legend-dot" style="background:#7a7a38"></span>15–25°
            <span class="mt-legend-dot" style="background:#a04e2a"></span>&gt;25°
          </div>
        </div>
        <div class="mt-carte-wrap">
          <div id="mt-map-loading">
            <i class="fas fa-spinner fa-spin"></i> Chargement de la carte météo…
          </div>
          <div id="mt-map"></div>
        </div>
      </section>

    </div><!-- /.mt-container -->

  </main>

  <Footer />
  <CopyrightBar />

  <!-- ══════════════════════════════════════════════════════════
       JAVASCRIPT — Open-Meteo API (gratuit · sans clé API)
       https://open-meteo.com
  ══════════════════════════════════════════════════════════ -->
  <script is:inline>
  (function () {
    'use strict';

    // ── Open-Meteo — aucune clé requise ──────────────────────────────────────
    const OM = 'https://api.open-meteo.com/v1/forecast';
    const NOM = 'https://nominatim.openstreetmap.org/reverse'; // géocodage inverse

    // ── WMO weather codes ─────────────────────────────────────────────────────
    const WMO = {
      0:  { emoji: '☀️',  label: 'Ciel dégagé' },
      1:  { emoji: '🌤',  label: 'Principalement ensoleillé' },
      2:  { emoji: '⛅',  label: 'Partiellement nuageux' },
      3:  { emoji: '☁️',  label: 'Couvert' },
      45: { emoji: '🌫',  label: 'Brouillard' },
      48: { emoji: '🌫',  label: 'Brouillard givrant' },
      51: { emoji: '🌦',  label: 'Bruine légère' },
      53: { emoji: '🌦',  label: 'Bruine modérée' },
      55: { emoji: '🌧',  label: 'Bruine dense' },
      61: { emoji: '🌧',  label: 'Pluie légère' },
      63: { emoji: '🌧',  label: 'Pluie modérée' },
      65: { emoji: '🌧',  label: 'Pluie forte' },
      71: { emoji: '🌨',  label: 'Neige légère' },
      73: { emoji: '❄️',  label: 'Neige modérée' },
      75: { emoji: '❄️',  label: 'Neige intense' },
      77: { emoji: '🌨',  label: 'Grains de neige' },
      80: { emoji: '🌦',  label: 'Averses légères' },
      81: { emoji: '🌧',  label: 'Averses modérées' },
      82: { emoji: '⛈',   label: 'Averses violentes' },
      85: { emoji: '🌨',  label: 'Averses de neige' },
      86: { emoji: '🌨',  label: 'Averses de neige intenses' },
      95: { emoji: '⛈',   label: 'Orage' },
      96: { emoji: '⛈',   label: 'Orage avec grêle' },
      99: { emoji: '⛈',   label: 'Orage avec grêle forte' },
    };
    function wmo(code) { return WMO[code] ?? { emoji: '🌤', label: 'Inconnu' }; }

    // ── Étapes Tour Data 2026 ─────────────────────────────────────────────────
    const ETAPES = [
      { name: 'Paris',           lat: 48.856, lon:  2.352 },
      { name: 'Fontenay-lès-B.', lat: 48.638, lon:  2.094 },
      { name: 'Orléans',         lat: 47.902, lon:  1.909 },
      { name: 'Tours',           lat: 47.394, lon:  0.691 },
      { name: 'Le Mans',         lat: 47.995, lon:  0.192 },
      { name: 'Nantes',          lat: 47.218, lon: -1.553 },
      { name: 'Rennes',          lat: 48.117, lon: -1.677 },
      { name: 'Caen',            lat: 49.183, lon: -0.357 },
      { name: 'Rouen',           lat: 49.443, lon:  1.099 },
      { name: 'Lille',           lat: 50.629, lon:  3.057 },
      { name: 'Strasbourg',      lat: 48.573, lon:  7.752 },
      { name: 'Dijon',           lat: 47.322, lon:  5.041 },
      { name: 'Lyon',            lat: 45.748, lon:  4.847 },
      { name: 'Grenoble',        lat: 45.188, lon:  5.724 },
      { name: 'Bordeaux',        lat: 44.837, lon: -0.579 },
      { name: 'Toulouse',        lat: 43.605, lon:  1.444 },
      { name: 'Montpellier',     lat: 43.611, lon:  3.877 },
      { name: 'Marseille',       lat: 43.296, lon:  5.381 },
      { name: 'Nice',            lat: 43.710, lon:  7.262 },
    ];

    // ── Villes pour la carte météo France (couverture large) ─────────────────
    const MAP_CITIES = [
      { name: 'Paris',        lat: 48.856, lon:  2.352 },
      { name: 'Orléans',      lat: 47.902, lon:  1.909 },
      { name: 'Tours',        lat: 47.394, lon:  0.691 },
      { name: 'Le Mans',      lat: 47.995, lon:  0.192 },
      { name: 'Nantes',       lat: 47.218, lon: -1.553 },
      { name: 'Rennes',       lat: 48.117, lon: -1.677 },
      { name: 'Brest',        lat: 48.390, lon: -4.486 },
      { name: 'Quimper',      lat: 47.997, lon: -4.098 },
      { name: 'Vannes',       lat: 47.658, lon: -2.761 },
      { name: 'Caen',         lat: 49.183, lon: -0.357 },
      { name: 'Rouen',        lat: 49.443, lon:  1.099 },
      { name: 'Reims',        lat: 49.258, lon:  4.032 },
      { name: 'Lille',        lat: 50.629, lon:  3.057 },
      { name: 'Metz',         lat: 49.119, lon:  6.176 },
      { name: 'Strasbourg',   lat: 48.573, lon:  7.752 },
      { name: 'Besançon',     lat: 47.237, lon:  6.024 },
      { name: 'Dijon',        lat: 47.322, lon:  5.041 },
      { name: 'Angers',       lat: 47.478, lon: -0.563 },
      { name: 'Poitiers',     lat: 46.579, lon:  0.340 },
      { name: 'Limoges',      lat: 45.833, lon:  1.262 },
      { name: 'Lyon',         lat: 45.748, lon:  4.847 },
      { name: 'Clermont-Fd',  lat: 45.777, lon:  3.087 },
      { name: 'Grenoble',     lat: 45.188, lon:  5.724 },
      { name: 'Bordeaux',     lat: 44.837, lon: -0.579 },
      { name: 'Bayonne',      lat: 43.493, lon: -1.474 },
      { name: 'Toulouse',     lat: 43.605, lon:  1.444 },
      { name: 'Montpellier',  lat: 43.611, lon:  3.877 },
      { name: 'Perpignan',    lat: 42.698, lon:  2.895 },
      { name: 'Avignon',      lat: 43.949, lon:  4.806 },
      { name: 'Marseille',    lat: 43.296, lon:  5.381 },
      { name: 'Nice',         lat: 43.710, lon:  7.262 },
      { name: 'Ajaccio',      lat: 41.919, lon:  8.738 },
    ];

    // ── Utilitaires ───────────────────────────────────────────────────────────
    function windDirLabel(deg) {
      const dirs = ['N','NE','E','SE','S','SO','O','NO'];
      return dirs[Math.round((deg ?? 0) / 45) % 8];
    }

    function cyclingScore(temp, windKmh, rain) {
      // Score de base selon la température — idéal cycliste : 18-24°C
      // En-dessous de 15°C la pratique devient médiocre (base ≤ 5)
      let base;
      if      (temp <  0)  base = 1;   // gel — dangereux
      else if (temp <  5)  base = 2;   // très froid
      else if (temp < 10)  base = 3;   // froid, inconfortable
      else if (temp < 15)  base = 5;   // frais — médiocre au mieux
      else if (temp < 18)  base = 7;   // limite acceptable
      else if (temp <= 24) base = 10;  // zone idéale
      else if (temp <= 28) base = 8;   // chaud mais gérable
      else if (temp <= 32) base = 6;   // chaud, fatiguant
      else if (temp <= 36) base = 4;   // très chaud
      else                 base = 2;   // extrême

      // Pénalité vent (km/h)
      let windP = 0;
      if      (windKmh > 50) windP = 4;
      else if (windKmh > 35) windP = 3;
      else if (windKmh > 25) windP = 2;
      else if (windKmh > 15) windP = 1;

      // Pénalité précipitations (mm)
      let rainP = 0;
      if      (rain > 10) rainP = 4;
      else if (rain >  5) rainP = 3;
      else if (rain >  2) rainP = 2;
      else if (rain >  0) rainP = 1;

      const score = Math.max(0, Math.min(10, base - windP - rainP));
      const comments = {
        10:'🏆 Parfait pour le vélo !', 9:'✅ Excellentes conditions',
        8:'👍 Très bonnes conditions',  7:'🟢 Bonnes conditions',
        6:'🟡 Conditions correctes',    5:'⚠️ Conditions moyennes',
        4:'😐 Médiocre',                3:'🔴 Peu favorable',
        2:'🔴 Difficile à vélo',        1:'🚫 Déconseillé',
        0:'🚫 Conditions extrêmes',
      };
      return { score, comment: comments[score] ?? '' };
    }

    function scoreColor(s) { return s >= 7 ? '#5a9470' : s >= 5 ? '#9e7840' : '#9e5050'; }

    // Palette température professionnelle 4 zones (sobre, sans couleurs criardes)
    function tempTint(t) {
      if (t <  5) return '#4a80a8';   // bleu acier  — froid
      if (t < 15) return '#3d8a72';   // teal foncé  — frais
      if (t < 25) return '#8a7e3a';   // olive doré  — doux
      return '#a8602e';               // brun-orange — chaud
    }

    // ── Appel Open-Meteo ──────────────────────────────────────────────────────
    async function omFetch(lat, lon, extra = '') {
      const url = `${OM}?latitude=${lat}&longitude=${lon}`
        + `&current=temperature_2m,relative_humidity_2m,apparent_temperature,`
        + `precipitation,rain,weather_code,surface_pressure,wind_speed_10m,wind_direction_10m,visibility`
        + `&hourly=temperature_2m,precipitation_probability,weather_code,wind_speed_10m`
        + `&daily=weather_code,temperature_2m_max,temperature_2m_min,precipitation_sum,`
        + `wind_speed_10m_max,wind_direction_10m_dominant,precipitation_probability_max`
        + `&wind_speed_unit=kmh&forecast_days=6&timezone=auto${extra}`;
      const res = await fetch(url);
      if (!res.ok) throw new Error(`OM ${res.status}`);
      return res.json();
    }

    async function omFetchCurrent(lat, lon) {
      const url = `${OM}?latitude=${lat}&longitude=${lon}`
        + `&current=temperature_2m,weather_code,wind_speed_10m,wind_direction_10m,relative_humidity_2m,precipitation`
        + `&wind_speed_unit=kmh&forecast_days=1&timezone=auto`;
      const res = await fetch(url);
      if (!res.ok) throw new Error(`OM ${res.status}`);
      return res.json();
    }

    async function reverseGeocode(lat, lon) {
      try {
        const res = await fetch(
          `${NOM}?lat=${lat}&lon=${lon}&format=json&accept-language=fr`,
          { headers: { 'Accept-Language': 'fr' } }
        );
        if (!res.ok) return null;
        const d = await res.json();
        return d.address?.city ?? d.address?.town ?? d.address?.village ?? d.address?.county ?? null;
      } catch { return null; }
    }

    // ── Affichage météo actuelle ──────────────────────────────────────────────
    function displayCurrent(data, cityName) {
      const c    = data.current ?? {};
      const temp = Math.round(c.temperature_2m ?? 0);
      const wind = Math.round(c.wind_speed_10m ?? 0);
      const rain = c.precipitation ?? 0;
      const info = wmo(c.weather_code);

      document.getElementById('mt-icon').textContent       = info.emoji;
      document.getElementById('mt-temp').textContent       = temp;
      document.getElementById('mt-feels').textContent      = `${Math.round(c.apparent_temperature ?? 0)}°C`;
      document.getElementById('mt-humidity').textContent   = `${c.relative_humidity_2m ?? '—'}%`;
      document.getElementById('mt-wind').textContent       = `${wind} km/h`;
      document.getElementById('mt-wind-dir').textContent   = windDirLabel(c.wind_direction_10m);
      document.getElementById('mt-pressure').textContent   = `${Math.round(c.surface_pressure ?? 0)} hPa`;
      document.getElementById('mt-desc').textContent       = info.label;
      const vis = c.visibility != null ? `${(c.visibility / 1000).toFixed(1)} km` : '—';
      document.getElementById('mt-visibility').textContent = vis;
      if (cityName) document.getElementById('mt-city').innerHTML = `<i class="fas fa-location-dot"></i> ${cityName}`;

      const { score, comment } = cyclingScore(temp, wind, rain);
      const cls = score >= 7 ? 'mt-score--good' : score >= 5 ? 'mt-score--ok' : 'mt-score--bad';
      document.getElementById('mt-score-val').textContent   = score;
      document.getElementById('mt-score-desc').textContent  = comment;
      document.getElementById('mt-cycling-score').className = `mt-cycling-score ${cls}`;
    }

    // ── Bande horaire (12 prochaines heures) ─────────────────────────────────
    function displayHourly(data) {
      const now   = new Date();
      const hours = data.hourly?.time ?? [];
      const temps = data.hourly?.temperature_2m ?? [];
      const winds = data.hourly?.wind_speed_10m ?? [];
      const codes = data.hourly?.weather_code ?? [];
      const pops  = data.hourly?.precipitation_probability ?? [];

      const startIdx = hours.findIndex(t => new Date(t) >= now);
      const items = hours.slice(startIdx, startIdx + 12);

      document.getElementById('mt-hourly').innerHTML = items.map((t, i) => {
        const idx  = startIdx + i;
        const h    = new Date(t).getHours().toString().padStart(2, '0');
        const info = wmo(codes[idx]);
        const temp = Math.round(temps[idx] ?? 0);
        const wind = Math.round(winds[idx] ?? 0);
        const pop  = pops[idx] ?? 0;
        return `<div class="mt-hour-card">
          <span class="mt-hour-time">${h}h</span>
          <span class="mt-hour-emoji">${info.emoji}</span>
          <span class="mt-hour-temp">${temp}°</span>
          <span class="mt-hour-wind"><i class="fas fa-wind"></i> ${wind}</span>
          ${pop > 10 ? `<span class="mt-hour-rain"><i class="fas fa-droplet"></i> ${pop}%</span>` : ''}
        </div>`;
      }).join('');
    }

    // ── Prévisions 5 jours ────────────────────────────────────────────────────
    function displayForecast(data) {
      const daily = data.daily ?? {};
      const days  = daily.time ?? [];

      document.getElementById('mt-forecast-grid').innerHTML = days.map((t, i) => {
        const date    = new Date(t);
        const label   = date.toLocaleDateString('fr-FR', { weekday: 'long', day: 'numeric', month: 'short' });
        const info    = wmo(daily.weather_code?.[i]);
        const maxT    = Math.round(daily.temperature_2m_max?.[i] ?? 0);
        const minT    = Math.round(daily.temperature_2m_min?.[i] ?? 0);
        const maxWind = Math.round(daily.wind_speed_10m_max?.[i] ?? 0);
        const pop     = daily.precipitation_probability_max?.[i] ?? 0;
        const precip  = (daily.precipitation_sum?.[i] ?? 0).toFixed(1);
        const { score } = cyclingScore(maxT, maxWind, parseFloat(precip));
        const tc = tempTint(maxT);
        return `<div class="mt-forecast-card" style="--tc:${tc}">
          <div class="mt-fc-day">${label}</div>
          <span class="mt-fc-emoji">${info.emoji}</span>
          <div class="mt-fc-desc">${info.label}</div>
          <div class="mt-fc-temps">
            <span class="mt-fc-max">${maxT}°</span>
            <span class="mt-fc-sep">/</span>
            <span class="mt-fc-min">${minT}°</span>
          </div>
          <div class="mt-fc-stats">
            <span><i class="fas fa-wind"></i> ${maxWind} km/h</span>
            ${pop > 5  ? `<span><i class="fas fa-droplet"></i> ${pop}%</span>` : ''}
            ${parseFloat(precip) > 0 ? `<span><i class="fas fa-cloud-rain"></i> ${precip} mm</span>` : ''}
          </div>
          <div class="mt-fc-score" style="color:${scoreColor(score)}">🚴 ${score}/10</div>
        </div>`;
      }).join('');
    }

    // ── Météo étapes Tour ─────────────────────────────────────────────────────
    async function loadEtapes() {
      const grid = document.getElementById('mt-etapes-grid');
      grid.innerHTML = '<div class="mt-loading"><i class="fas fa-spinner fa-spin"></i> Chargement des étapes…</div>';
      const results = await Promise.allSettled(
        ETAPES.map(e => omFetchCurrent(e.lat, e.lon).then(d => ({ ...d, _nom: e.name })))
      );
      grid.innerHTML = results.map((r, i) => {
        if (r.status === 'rejected') return `<div class="mt-etape-card mt-etape-card--error">${ETAPES[i].name}<br><small>Erreur</small></div>`;
        const d    = r.value;
        const c    = d.current ?? {};
        const info = wmo(c.weather_code);
        const temp = Math.round(c.temperature_2m ?? 0);
        const wind = Math.round(c.wind_speed_10m ?? 0);
        const { score } = cyclingScore(temp, wind, c.precipitation ?? 0);
        const tc = tempTint(temp);
        return `<div class="mt-etape-card" style="--tc:${tc}">
          <div class="mt-etape-name">${d._nom}</div>
          <span class="mt-etape-emoji">${info.emoji}</span>
          <div class="mt-etape-temp">${temp}°C</div>
          <div class="mt-etape-desc">${info.label}</div>
          <div class="mt-etape-wind"><i class="fas fa-wind"></i> ${wind} km/h</div>
          <div class="mt-etape-score" style="color:${scoreColor(score)}">🚴 ${score}/10</div>
        </div>`;
      }).join('');
    }

    // ── Carte météo France ────────────────────────────────────────────────────
    let carteLoaded  = false;
    let mapInstance  = null;
    let mapMarkers   = [];
    let mapDayData   = null;

    function tempColor(t) {
      if (t <  0) return '#3d6e90';   // bleu froid profond
      if (t <  5) return '#4a80a8';   // bleu acier
      if (t < 10) return '#3a7a6a';   // teal foncé
      if (t < 15) return '#3d8860';   // vert sauge
      if (t < 20) return '#7a7a38';   // olive
      if (t < 25) return '#9a6830';   // ambre-brun
      return '#a04e2a';               // brun-orangé
    }

    function loadLeaflet() {
      return new Promise(resolve => {
        if (window.L) { resolve(); return; }
        const link  = document.createElement('link');
        link.rel    = 'stylesheet';
        link.href   = '/lib/leaflet.min.css';
        document.head.appendChild(link);
        const s    = document.createElement('script');
        s.src      = '/lib/leaflet.min.js';
        s.onload   = resolve;
        document.head.appendChild(s);
      });
    }

    async function omFetchMap() {
      // Open-Meteo batch : plusieurs lat/lon en une seule requête
      const lats = MAP_CITIES.map(c => c.lat).join(',');
      const lons = MAP_CITIES.map(c => c.lon).join(',');
      const url  = `${OM}?latitude=${lats}&longitude=${lons}`
        + `&daily=weather_code,temperature_2m_max,temperature_2m_min,`
        + `precipitation_probability_max,wind_speed_10m_max`
        + `&wind_speed_unit=kmh&forecast_days=6&timezone=auto`;
      const res  = await fetch(url);
      if (!res.ok) throw new Error(`OM map ${res.status}`);
      return res.json(); // array quand plusieurs coordonnées
    }

    function renderMapMarkers(data, dayIdx) {
      if (!mapInstance || !window.L) return;
      mapMarkers.forEach(m => m.remove());
      mapMarkers = [];
      const arr = Array.isArray(data) ? data : [data];
      arr.forEach((d, i) => {
        const city  = MAP_CITIES[i];
        if (!city) return;
        const daily = d.daily ?? {};
        const code  = daily.weather_code?.[dayIdx]  ?? 0;
        const maxT  = Math.round(daily.temperature_2m_max?.[dayIdx]  ?? 0);
        const minT  = Math.round(daily.temperature_2m_min?.[dayIdx]  ?? 0);
        const pop   = daily.precipitation_probability_max?.[dayIdx]  ?? 0;
        const wind  = Math.round(daily.wind_speed_10m_max?.[dayIdx]  ?? 0);
        const info  = wmo(code);
        const col   = tempColor(maxT);
        const icon  = window.L.divIcon({
          className: '',
          html: `<div class="mt-mm" style="--c:${col}">
            <span class="mt-mm-emoji">${info.emoji}</span>
            <span class="mt-mm-temp">${maxT}°</span>
            <span class="mt-mm-name">${city.name}</span>
          </div>`,
          iconAnchor: [32, 18],
          iconSize:   [64, 54],
        });
        const popup = window.L.popup({ className: 'mt-leaflet-popup' }).setContent(
          `<strong>${city.name}</strong><br>${info.emoji} ${info.label}<br>` +
          `🌡 ${maxT}° / ${minT}°&nbsp;&nbsp;💨 ${wind} km/h` +
          (pop > 5 ? `<br>💧 Pluie : ${pop}%` : '')
        );
        const marker = window.L.marker([city.lat, city.lon], { icon }).bindPopup(popup);
        marker.addTo(mapInstance);
        mapMarkers.push(marker);
      });
    }

    async function loadCarte(dayIdx) {
      await loadLeaflet();
      if (!mapInstance) {
        const el = document.getElementById('mt-map');
        if (!el) return;
        mapInstance = window.L.map('mt-map', {
          center: [46.5, 2.5], zoom: 5.6, zoomSnap: 0.2,
        });
        window.L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
          attribution: '© <a href="https://www.openstreetmap.org/copyright" target="_blank">OpenStreetMap</a>',
          maxZoom: 18,
        }).addTo(mapInstance);
      }
      const loading = document.getElementById('mt-map-loading');
      if (!mapDayData) {
        if (loading) loading.classList.add('is-visible');
        try {
          mapDayData = await omFetchMap();
        } catch (e) {
          console.error('Carte météo fetch error', e);
          if (loading) loading.classList.remove('is-visible');
          return;
        }
        if (loading) loading.classList.remove('is-visible');
      }
      renderMapMarkers(mapDayData, dayIdx);
      setTimeout(() => mapInstance.invalidateSize(), 80);
    }

    // ── Tabs ──────────────────────────────────────────────────────────────────
    let etapesLoaded   = false;
    let forecastLoaded = false;

    function switchTab(tab) {
      document.querySelectorAll('.mt-tab').forEach(b => {
        b.classList.toggle('mt-tab--active', b.dataset.tab === tab);
        b.setAttribute('aria-selected', b.dataset.tab === tab ? 'true' : 'false');
      });
      document.querySelectorAll('.mt-section').forEach(s =>
        s.classList.toggle('mt-section--active', s.id === `mt-${tab}`)
      );
      if (tab === 'etapes' && !etapesLoaded) { etapesLoaded = true; loadEtapes(); }
      if (tab === 'carte'  && !carteLoaded)  { carteLoaded  = true; loadCarte(0); }
    }

    // ── Chargement par coordonnées ────────────────────────────────────────────
    async function loadByCoords(lat, lon) {
      try {
        const [data, city] = await Promise.all([
          omFetch(lat, lon),
          reverseGeocode(lat, lon),
        ]);
        displayCurrent(data, city);
        displayHourly(data);
        displayForecast(data);
        forecastLoaded = true;
      } catch (e) {
        console.error('Open-Meteo error', e);
      }
    }

    function locateAndLoad() {
      if (!navigator.geolocation) { loadByCoords(48.856, 2.352); return; }
      navigator.geolocation.getCurrentPosition(
        pos => loadByCoords(pos.coords.latitude, pos.coords.longitude),
        ()   => loadByCoords(48.856, 2.352)
      );
    }

    // ── Init ──────────────────────────────────────────────────────────────────
    document.addEventListener('DOMContentLoaded', () => {
      document.querySelectorAll('.mt-tab').forEach(btn =>
        btn.addEventListener('click', () => switchTab(btn.dataset.tab))
      );
      document.getElementById('mt-locate-btn').addEventListener('click', locateAndLoad);

      // Boutons période carte
      document.querySelectorAll('.mt-period-btn').forEach(btn =>
        btn.addEventListener('click', () => {
          document.querySelectorAll('.mt-period-btn').forEach(b => b.classList.remove('mt-period-btn--active'));
          btn.classList.add('mt-period-btn--active');
          loadCarte(parseInt(btn.dataset.day, 10));
        })
      );

      const hash = location.hash.replace('#', '');
      if (['position', 'etapes', 'previsions', 'carte'].includes(hash)) switchTab(hash);

      locateAndLoad();
    });

  })();
  </script>

