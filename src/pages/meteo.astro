  .mt-cycling-score.hidden { display: none; }
  .mt-score--good { background: rgba(34,197,94,0.08);   border-color: rgba(34,197,94,0.2); }
  .mt-score--ok   { background: rgba(245,158,11,0.08);  border-color: rgba(245,158,11,0.2); }
  .mt-score--bad  { background: rgba(239,68,68,0.08);   border-color: rgba(239,68,68,0.2); }
  .mt-score-inner  { display: flex; align-items: center; gap: 1.25rem; }
  .mt-score-label  { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); }
  .mt-score-dial   { display: flex; align-items: baseline; gap: 2px; }
  .mt-score-num    { font-size: 2.4rem; font-weight: 900; color: var(--text-light); }
  .mt-score-max    { font-size: 1rem; color: var(--text-muted); }
  .mt-score-comment { font-size: 0.88rem; color: var(--text-light); }

  /* ── BANDE HORAIRE ────────────────────────────────────── */
  .mt-hourly-wrap  { margin-bottom: 1.5rem; }
  .mt-section-title {
    font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em;
    color: var(--text-muted); margin: 0 0 0.7rem;
    display: flex; align-items: center; gap: 6px;
  }
  .mt-section-title i { color: var(--accent-cyan); }
  .mt-hourly { display: flex; gap: 8px; overflow-x: auto; padding-bottom: 6px; }
  .mt-hour-card {
    flex-shrink: 0; min-width: 62px;
    background: rgba(10,24,44,0.85);
    border: 1px solid rgba(77,184,212,0.1);
    border-radius: var(--radius-sm);
    padding: 0.55rem 0.4rem;
    display: flex; flex-direction: column; align-items: center; gap: 3px;
    font-size: 0.7rem; color: var(--text-muted);
  }
  .mt-hour-time { font-weight: 700; color: var(--accent-cyan); }
  .mt-hour-icon { width: 32px; height: 32px; }
  .mt-hour-temp { font-size: 1rem; font-weight: 700; color: var(--text-light); }
  .mt-hour-rain { color: #60a5fa; }

  /* ── PRÉVISIONS 5J ────────────────────────────────────── */
  .mt-forecast-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(155px, 1fr)); gap: 1rem;
  }
  .mt-forecast-card {
    background: rgba(10,24,44,0.92);
    border: 1px solid rgba(77,184,212,0.12);
    border-radius: var(--radius-md);
    padding: 1rem;
    display: flex; flex-direction: column; align-items: center; gap: 0.35rem;
