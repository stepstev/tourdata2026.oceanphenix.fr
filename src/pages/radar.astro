    // ── Recherche principale ──────────────────────────────────
    async function search() {
      if (currentLat === null || currentLon === null) return;

      // Clé de cache : position arrondie 2 décimales (~1 km) + rayon + mode
      const cacheKey = `${currentLat.toFixed(2)},${currentLon.toFixed(2)},${currentRadius},${currentMode}`;
      const now = Date.now();

      // Throttle — même recherche < 20 s : servir le cache mémoire sans appel réseau
      if (cacheKey === lastSearchKey && (now - lastSearchTime) < SEARCH_THROTTLE_MS && searchCache.has(cacheKey)) {
        allResults = searchCache.get(cacheKey);
        renderResults();
        renderMapMarkers();
        return;
      }

      // Annuler toute recherche en cours
      if (searchAbortController) searchAbortController.abort();
      searchAbortController = new AbortController();
      const signal = searchAbortController.signal;

      showLoading(true);
      clearMapMarkers();
      ['results-list', 'list-camping', 'list-coworking', 'list-entreprise', 'list-evenement', 'list-piscine', 'list-fontaine', 'list-douche', 'list-abri'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.innerHTML = skeletonHTML(3);
      });
      document.getElementById('results-count').textContent = '⏳ Interrogation des sources…';

      // En dev : utiliser les données mock pour avoir un rendu immédiat
      if (IS_DEV) {
        await new Promise(r => setTimeout(r, 400));
        allResults = MOCK_RESULTS.map(r => ({
          ...r,
          dist: haversine(currentLat, currentLon, r.lat, r.lon)
        })).filter(r => r.dist <= currentRadius).sort((a, b) => a.dist - b.dist);
        renderResults();
        renderMapMarkers();
        showLoading(false);
        const n = allResults.filter(r => activeFilters.has(r.type)).length;
        showMapInfo('🧪', `DEV — ${n} lieu${n !== 1 ? 'x' : ''} simulé${n !== 1 ? 's' : ''}`, 'info', 3000);
        return;
      }

      // Rayon Overpass plafonné à OVERPASS_MAX_KM pour éviter les timeouts
      const radiusM = Math.min(currentRadius, OVERPASS_MAX_KM) * 1000;
      const isCyclo = currentMode === 'cyclo';

      // Appels conditionnels selon le mode — évite les timeouts inutiles
      const promises = [
        fetchOverpass(currentLat, currentLon, radiusM, signal),
        isCyclo ? fetchCampingsGouv(currentLat, currentLon, currentRadius, signal) : Promise.resolve([]),
        isCyclo ? Promise.resolve([]) : fetchEntreprises(currentLat, currentLon, signal),
        isCyclo ? Promise.resolve([]) : Promise.resolve(getCoworkingsNearby(currentLat, currentLon, currentRadius)),
        isCyclo ? Promise.resolve([]) : fetchEvents(currentLat, currentLon, currentRadius, signal),
      ];

      const [resOverpass, resCampings, resEntreprises, resCw, resEvents] = await Promise.allSettled(promises);

      // Requête annulée — une nouvelle recherche a déjà démarré
      if (signal.aborted) return;

      if (resOverpass.status    === 'rejected' && resOverpass.reason?.name !== 'AbortError') console.warn('Overpass:', resOverpass.reason);
      if (resCampings.status    === 'rejected' && resCampings.reason?.name !== 'AbortError') console.warn('Atout France:', resCampings.reason);
      if (resEntreprises.status === 'rejected' && resEntreprises.reason?.name !== 'AbortError') console.warn('INSEE SIRENE:', resEntreprises.reason);
      if (resEvents.status      === 'rejected' && resEvents.reason?.name !== 'AbortError') console.warn('OpenAgenda:', resEvents.reason);

      const adminEnts  = !isCyclo ? adminProData.entreprises : [];
      const adminEvts  = !isCyclo ? adminProData.events       : [];
      const raw = [
        ...adminEnts,
        ...adminEvts,
        ...(resOverpass.status    === 'fulfilled' ? resOverpass.value    : []),
        ...(resCampings.status    === 'fulfilled' ? resCampings.value    : []),
        ...(resEntreprises.status === 'fulfilled' ? resEntreprises.value : []),
        ...(resCw.status          === 'fulfilled' ? resCw.value         : []),
        ...(resEvents.status      === 'fulfilled' ? resEvents.value      : []),
      ];

      // Dédupliquer par id, calculer distance, filtrer rayon, trier
      const byId = new Map();
      for (const item of raw) {
        if (!byId.has(item.id)) byId.set(item.id, item);
      }
      allResults = [...byId.values()]
        .map(r => ({
          ...r,
          dist: (r.lat && r.lon) ? haversine(currentLat, currentLon, r.lat, r.lon) : null,
        }))
        // Sans GPS : entreprises et événements toujours inclus ; autres types : filtrage par rayon
        .filter(r => r.dist === null ? (r.type === 'entreprise' || r.type === 'evenement') : r.dist <= currentRadius)
        .sort((a, b) => {
          if (a.dist === null && b.dist === null) return 0;
          if (a.dist === null) return 1;
          if (b.dist === null) return -1;
          return a.dist - b.dist;
        });

      // Stocker en cache mémoire (max 30 entrées pour éviter la fuite mémoire)
      if (searchCache.size >= 30) searchCache.delete(searchCache.keys().next().value);
      searchCache.set(cacheKey, allResults);
      lastSearchKey  = cacheKey;
      lastSearchTime = Date.now();

      renderResults();
      renderMapMarkers();
      showLoading(false);

      const n = allResults.filter(r => activeFilters.has(r.type)).length;
      showMapInfo('🎯', `${n} lieu${n !== 1 ? 'x' : ''} trouvé${n !== 1 ? 's' : ''} — rayon ${currentRadius} km`, 'success', 3500);
    }

    // ── Rendu résultats ───────────────────────────────────────
    function renderItemHTML(r) {
      const ficheBtn = r.type === 'entreprise' && r.siren
        ? `<a href="https://annuaire-entreprises.data.gouv.fr/entreprise/${encodeURIComponent(r.siren)}" target="_blank" rel="noopener" class="result-btn btn-fiche"><i class="fas fa-external-link-alt"></i> Fiche</a>`
        : '';
      const eventBtn = r.type === 'evenement' && r.url
        ? `<a href="${escHtml(r.url)}" target="_blank" rel="noopener" class="result-btn btn-event"><i class="fas fa-calendar-check"></i> Voir</a>`
        : '';
      const hasGeo = r.lat && r.lon;
      const mapsUrl = hasGeo ? `https://www.google.com/maps/dir/?api=1&destination=${r.lat},${r.lon}&travelmode=bicycling` : null;
      const distLabel = r.dist !== null ? `${r.dist.toFixed(1)} km` : '';
      const color = TYPE_COLORS[r.type] || '#888';
      const dateLabel = r.dateDebut ? new Date(r.dateDebut).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' }) : '';

      return `
        <li class="result-item" data-id="${r.id}" data-type="${r.type}">
          <div class="result-left">
            <span class="type-dot" style="background:${color}"></span>
          </div>
          <div class="result-body">
            <div class="result-header-row">
              <span class="result-nom">${escHtml(r.nom)}</span>
              ${distLabel ? `<span class="result-dist">${distLabel}</span>` : ''}
            </div>
            ${dateLabel ? `<div class="result-meta result-date"><i class="fas fa-calendar-days"></i> ${dateLabel}</div>` : ''}
            ${r.adresse ? `<div class="result-adresse"><i class="fas fa-map-pin"></i> ${escHtml(r.adresse)}</div>` : ''}
            ${r.nafLabel ? `<div class="result-meta"><i class="fas fa-tag"></i> ${escHtml(r.nafLabel)}</div>` : ''}
            ${r.classement ? `<div class="result-meta"><i class="fas fa-star"></i> ${escHtml(String(r.classement))}</div>` : ''}
            ${r.type === 'piscine' && r.fee === 'yes' ? `<div class="result-meta"><i class="fas fa-ticket"></i> Payant</div>` : ''}
            ${r.type === 'piscine' && r.fee === 'no'  ? `<div class="result-meta"><i class="fas fa-ticket"></i> Gratuit</div>` : ''}
            ${r.type === 'abri' && r.capacity ? `<div class="result-meta"><i class="fas fa-person"></i> ${escHtml(r.capacity)} pers.</div>` : ''}
            ${r.source ? `<div class="result-source">Source : ${escHtml(r.source)}</div>` : ''}
            <div class="result-actions">
              ${mapsUrl ? `<a href="${mapsUrl}" target="_blank" rel="noopener" class="result-btn btn-go"><i class="fas fa-route"></i> Itinéraire</a>` : ''}
              ${ficheBtn}
              ${eventBtn}
            </div>
          </div>
        </li>`;
    }

    function renderResults() {
      const countEl = document.getElementById('results-count');
      const filtered = allResults.filter(r => activeFilters.has(r.type));

      countEl.textContent = `${filtered.length} résultat${filtered.length !== 1 ? 's' : ''} — rayon ${currentRadius} km`;

      const types = ['camping', 'coworking', 'entreprise', 'piscine', 'fontaine', 'douche', 'abri'];
      types.forEach(type => {
        const items = allResults.filter(r => r.type === type);
        const listEl = document.getElementById('list-' + type);
        const countBadge = document.getElementById('count-' + type);
        if (countBadge) countBadge.textContent = items.length;
        if (listEl) {
          listEl.innerHTML = items.length === 0
            ? '<li class="no-results"><i class="fas fa-search"></i> Aucun résultat dans cette catégorie.</li>'
            : items.map(r => renderItemHTML(r)).join('');
        }
      });

      // Événements — tableau de liens
      const evtBadge = document.getElementById('count-evenement');
      const evtItems = allResults.filter(r => r.type === 'evenement');
      if (evtBadge) evtBadge.textContent = evtItems.length;
      renderEventsTable(evtItems);

      const allList = document.getElementById('results-list');
      allList.innerHTML = filtered.length === 0
        ? '<li class="no-results"><i class="fas fa-search"></i> Aucun résultat. Sélectionnez une étape ou géolocalisez-vous.</li>'
        : filtered.map(r => renderItemHTML(r)).join('');
    }

    // ── Carte Leaflet ─────────────────────────────────────────
    function renderMapMarkers() {
      clearMapMarkers();
      if (!currentLat || !currentLon || !leafletMap) return;

      // Cercle rayon
      radiusCircle = L.circle([currentLat, currentLon], {
        radius: currentRadius * 1000,
        color: '#9a9245',
        weight: 1.5,
        dashArray: '6 4',
        fillColor: '#9a9245',
        fillOpacity: 0.04,
      }).addTo(leafletMap);

      // Marqueur position actuelle
      const posIcon = L.divIcon({
        className: 'pos-marker-wrap',
        html: '<div class="pos-marker">📍</div>',
        iconSize: [28, 28],
        iconAnchor: [14, 28],
      });
      posMarker = L.marker([currentLat, currentLon], { icon: posIcon })
        .bindPopup('<strong>Ma position</strong>')
        .addTo(leafletMap);

      // Marqueurs résultats — via cluster groups typés
      const filtered = allResults.filter(r => activeFilters.has(r.type) && r.lat && r.lon);
      for (const r of filtered) {
        const color  = TYPE_COLORS[r.type] || '#888';
        const distPopup = r.dist !== null ? `<br><em>${r.dist.toFixed(1)} km</em>` : '';
        const popup = `<strong style="font-size:0.85rem">${escHtml(r.nom)}</strong>${distPopup}${r.adresse ? `<br><small style="color:#a0b0c0">${escHtml(r.adresse)}</small>` : ''}`;
        const cluster = mapClusters[r.type];
        if (cluster) {
          cluster.addLayer(
            L.marker([r.lat, r.lon], { icon: makeMarkerIcon(color) }).bindPopup(popup)
          );
        }
      }

      // Recadrer
      const margin = currentRadius / 90;
      leafletMap.fitBounds([
        [currentLat - margin, currentLon - margin * 1.4],
        [currentLat + margin, currentLon + margin * 1.4],
      ], { padding: [24, 24] });
    }

    function clearMapMarkers() {
      if (posMarker) { posMarker.remove(); posMarker = null; }
      if (radiusCircle) { radiusCircle.remove(); radiusCircle = null; }
      Object.values(mapClusters).forEach(cg => cg.clearLayers());
    }


    // ── Utilitaires UI ────────────────────────────────────────
    function showLoading(on) {
      const dot    = document.getElementById('rd-dot');
      const loader = document.getElementById('loading-indicator');
      const idle   = document.getElementById('results-count');
      if (on) {
        dot.className = 'rd-dot loading';
        loader.classList.remove('hidden');
        idle.classList.add('hidden');
      } else {
        dot.className = 'rd-dot active';
        loader.classList.add('hidden');
        idle.classList.remove('hidden');
      }
    }

    function updateCatLabel() {
      document.querySelectorAll('.rd-cat-dropdown').forEach(dropdown => {
        const count = dropdown.querySelectorAll('.rd-cat-cb:checked').length;
        const label = dropdown.querySelector('.rd-cat-trigger-label');
        if (label) label.textContent = `${count} catégorie${count !== 1 ? 's' : ''}`;
      });
    }

    function toggleFilter(type, forceOn) {
      const chip = document.querySelector(`.chip[data-type="${type}"]`);
      const cb   = document.querySelector(`.rd-cat-cb[data-type="${type}"]`);
      const next = forceOn !== undefined ? forceOn : !activeFilters.has(type);
      if (next) { activeFilters.add(type); chip?.classList.add('active'); chip?.setAttribute('aria-pressed', 'true'); }
      else       { activeFilters.delete(type); chip?.classList.remove('active'); chip?.setAttribute('aria-pressed', 'false'); }
      if (cb && cb.checked !== next) cb.checked = next;
      updateCatLabel();
      renderResults();
      renderMapMarkers();
    }

    function labelForType(type) {
      return {
        camping:    'Camping',
        coworking:  'Coworking',
        entreprise: 'Entreprise',
        evenement:  'Événement',
        piscine:    'Piscine / Baignade',
        fontaine:   'Point d\'eau',
        douche:     'Douche publique',
        abri:       'Abri / Refuge',
      }[type] || type;
    }

    function escHtml(str) {
      return String(str ?? '').replace(/[&<>"']/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    }

    function skeletonHTML(n) {
      return Array.from({ length: n }, () =>
        '<li class="skeleton-item"><div class="skel-line skel-w70"></div><div class="skel-line skel-w45"></div></li>'
      ).join('');
    }

    function hintHTML() {
      return `<li class="rd-hint">
        <i class="fas fa-crosshairs"></i>
        <strong>Radar Terrain</strong>
        <span>Sélectionnez une étape dans le menu ou cliquez sur<br><em>📍 Je suis ici</em> pour lancer la recherche</span>
      </li>`;
    }

    // ── Tabs switching ────────────────────────────────────────
    function switchTab(tabName) {
      document.querySelectorAll('.rd-tab').forEach(t => {
        t.classList.toggle('rd-tab--active', t.dataset.tab === tabName);
        t.setAttribute('aria-selected', t.dataset.tab === tabName ? 'true' : 'false');
      });
      document.querySelectorAll('.rd-tab-content').forEach(c => {
        c.classList.toggle('rd-tab-content--active', c.id === 'tab-' + tabName);
      });
      // Refresh map when switching back to carte tab
      if (tabName === 'carte' && leafletMap) {
        setTimeout(() => leafletMap.invalidateSize(), 100);
      }
      // Charger les salons nationaux au premier accès
      if (tabName === 'salons' && !salonsLoaded) {
        fetchSalonsNationaux();
      }
      // Rendre les liens utiles à chaque accès (données légères)
      if (tabName === 'liens-utiles') {
        renderLiensUtiles();
      }
    }

    // ── Boot ──────────────────────────────────────────────────
    document.addEventListener('DOMContentLoaded', async () => {
      await loadAdminProData();
      initMap();

      // Tab switching
      document.querySelectorAll('.rd-tab').forEach(tab => {
        tab.addEventListener('click', () => switchTab(tab.dataset.tab));
      });

      // En dev : charger automatiquement les mocks sur Fontenay-lès-Briis
      if (IS_DEV) {
        document.getElementById('results-list').innerHTML = hintHTML();
        currentLat = 48.638;
        currentLon = 2.094;
        showMapInfo('🧪', 'Mode Dev — données mock activées', 'info', 3000);
        setTimeout(() => search(), 300);
      } else {
        document.getElementById('results-list').innerHTML = hintHTML();
      }

      // Bouton géolocalisation
      document.getElementById('btn-locate').addEventListener('click', locateMe);

      // Bouton actualiser — bypass du throttle cache
      document.getElementById('btn-refresh').addEventListener('click', () => {
        if (currentLat === null || currentLon === null) return;
        const cacheKey = `${currentLat.toFixed(2)},${currentLon.toFixed(2)},${currentRadius},${currentMode}`;
        searchCache.delete(cacheKey);
        lastSearchTime = 0;
        search();
      });



      // Filtres domaine salons
      document.querySelectorAll('[data-salon-domain]').forEach(chip => {
        chip.addEventListener('click', () => {
          const domain = chip.dataset.salonDomain;
          const active = chip.classList.toggle('salon-chip--active');
          if (active) salonDomains.add(domain); else salonDomains.delete(domain);
          renderSalons();
        });
      });

      // Filtres format salons
      document.querySelectorAll('[data-salon-format]').forEach(chip => {
        chip.addEventListener('click', () => {
          const fmt = chip.dataset.salonFormat;
          const active = chip.classList.toggle('salon-chip--active');
          if (active) salonFormats.add(fmt); else salonFormats.delete(fmt);
          renderSalons();
        });
      });



      // Sélecteur d'étape
      // Dropdown villes Data/IA
      const cityDropdown = document.getElementById('city-dropdown');
      const cityTrigger  = document.getElementById('city-trigger');
      const cityPanel    = document.getElementById('city-panel');
      const cityLabel    = document.getElementById('city-trigger-label');

      cityTrigger.addEventListener('click', (e) => {
        e.stopPropagation();
        const open = cityDropdown.getAttribute('aria-expanded') === 'true';
        cityDropdown.setAttribute('aria-expanded', String(!open));
        cityPanel.classList.toggle('rd-city-panel--open', !open);
      });

      cityPanel.querySelectorAll('.rd-city-item').forEach(btn => {
        btn.addEventListener('click', () => {
          const lat = parseFloat(btn.dataset.lat);
          const lon = parseFloat(btn.dataset.lon);
          const label = btn.textContent.trim();
          currentLat = lat;
          currentLon = lon;
          document.getElementById('btn-refresh').disabled = false;
          cityLabel.textContent = label;
          cityDropdown.setAttribute('aria-expanded', 'false');
          cityPanel.classList.remove('rd-city-panel--open');
          showMapInfo('🏙️', label, 'info', 2500);
          search();
        });
      });

      document.addEventListener('click', e => {
        if (!cityDropdown.contains(e.target)) {
          cityDropdown.setAttribute('aria-expanded', 'false');
          cityPanel.classList.remove('rd-city-panel--open');
        }
      });

      // Slider rayon
      const slider = document.getElementById('radius-slider');
      slider.addEventListener('input', () => {
        currentRadius = parseInt(slider.value);
        document.getElementById('radius-val').textContent = currentRadius;
      });
      slider.addEventListener('change', () => {
        if (currentLat !== null) search();
      });

      // Chips filtres
      document.querySelectorAll('.chip').forEach(chip => {
        chip.addEventListener('click', () => toggleFilter(chip.dataset.type));
      });

      // Combobox catégories — init générique (pro + cyclo)
      document.querySelectorAll('.rd-cat-dropdown').forEach(dropdown => {
        const trigger = dropdown.querySelector('.rd-cat-trigger');
        const panel   = dropdown.querySelector('.rd-cat-panel');
        const allCb   = panel.querySelector('.rd-cat-cb-all');
        const itemCbs = Array.from(panel.querySelectorAll('.rd-cat-cb'));

        function syncAllCheckbox() {
          if (!allCb) return;
          const checkedCount = itemCbs.filter(c => c.checked).length;
          allCb.checked = checkedCount === itemCbs.length;
          allCb.indeterminate = checkedCount > 0 && checkedCount < itemCbs.length;
        }

        trigger.addEventListener('click', (e) => {
          e.stopPropagation();
          const open = dropdown.getAttribute('aria-expanded') === 'true';
          dropdown.setAttribute('aria-expanded', String(!open));
          panel.classList.toggle('rd-cat-panel--open', !open);
        });

        if (allCb) {
          allCb.addEventListener('change', () => {
            itemCbs.forEach(cb => {
              cb.checked = allCb.checked;
              toggleFilter(cb.dataset.type, allCb.checked);
            });
            setViewActive(null);
          });
        }

        itemCbs.forEach(cb => {
          cb.addEventListener('change', () => {
            toggleFilter(cb.dataset.type, cb.checked);
            syncAllCheckbox();
            setViewActive(null);
          });
        });
      });

      document.addEventListener('click', e => {
        document.querySelectorAll('.rd-cat-dropdown').forEach(dropdown => {
          if (!dropdown.contains(e.target)) {
            dropdown.setAttribute('aria-expanded', 'false');
            dropdown.querySelector('.rd-cat-panel')?.classList.remove('rd-cat-panel--open');
          }
        });
      });

      // ── Modes PRO / CYCLO ─────────────────────────────────
      const MODE_FILTERS = {
        pro:   ['coworking', 'entreprise', 'evenement'],
        cyclo: ['camping', 'piscine', 'fontaine', 'douche', 'abri'],
      };
      const ALL_TYPES = ['camping', 'coworking', 'entreprise', 'evenement', 'piscine', 'fontaine', 'douche', 'abri'];

      // Désactive visuellement tous les boutons de mode (filtres personnalisés)
      function setViewActive(view) {
        document.querySelectorAll('.rd-mode-btn').forEach(b => {
          b.classList.toggle('rd-mode-btn--active', b.dataset.mode === view);
        });
      }

      function applyMode(mode) {
        currentMode = mode;
        // 1. Filtres actifs
        const active = MODE_FILTERS[mode] || [];
        ALL_TYPES.forEach(t => toggleFilter(t, active.includes(t)));

        // 2. Boutons mode
        document.querySelectorAll('.rd-mode-btn').forEach(b => {
          b.classList.toggle('rd-mode-btn--active', b.dataset.mode === mode);
        });

        // 3. Panneaux de contrôles contextuels
        document.querySelectorAll('.rd-mode-controls').forEach(ctrl => {
          ctrl.classList.toggle('rd-mode-controls--hidden', ctrl.id !== `mode-ctrl-${mode}`);
        });

        // 4. Tabs — visibilité selon data-modes
        document.querySelectorAll('.rd-tab[data-modes]').forEach(tab => {
          const modes = tab.dataset.modes.split(',');
          tab.classList.toggle('rd-tab--mode-hidden', !modes.includes(mode));
        });

        // 5. Chips carte — cohérence avec les types actifs
        document.querySelectorAll('.chip[data-type]').forEach(chip => {
          chip.classList.toggle('chip--hidden', !active.includes(chip.dataset.type));
        });

        updateCatLabel();

        // 6. Hint strip mode
        const hintIcon = document.querySelector('#rd-mode-hint .fa-fw');
        const hintText = document.getElementById('rd-mode-hint-text');
        if (hintIcon && hintText) {
          if (mode === 'cyclo') {
            hintIcon.className = 'fas fa-bicycle fa-fw';
            hintText.innerHTML = 'Mode <strong>Cyclo</strong> — campings, points d\'eau, douches, piscines publiques et abris à proximité de votre position.';
          } else {
            hintIcon.className = 'fas fa-briefcase fa-fw';
            hintText.innerHTML = 'Mode <strong>Pro</strong> — coworkings et espaces de travail, entreprises data/IT du département, salons &amp; forums emploi à venir.';
          }
        }

        // 7. Si le tab actif n'est plus disponible dans ce mode → retour sur Carte
        const currentTab = document.querySelector('.rd-tab--active');
        if (currentTab) {
          const modes = (currentTab.dataset.modes || '').split(',');
          if (!modes.includes(mode)) switchTab('carte');
        }

        // 7. Relancer la recherche — les sources de données diffèrent selon le mode
        if (currentLat !== null && currentLon !== null) {
          clearTimeout(modeChangeTimer);
          modeChangeTimer = setTimeout(() => search(), 300);
        }
      }

      document.querySelectorAll('.rd-mode-btn').forEach(btn => {
        btn.addEventListener('click', () => applyMode(btn.dataset.mode));
      });

      // Mode Pro actif au démarrage
      applyMode('pro');

    });

  })();
  </script>

  <style is:global>
  /* ============================================================
     RADAR TERRAIN — Design system admin-style OceanPhenix
  ============================================================ */

  /* ── Layout racine ───────────────────────────────────────── */
  .radar-page {
    display: flex;
    flex-direction: column;
    min-height: calc(100dvh - 5rem);
  }

  /* ── Hero section (cohérent strava/terrain) ─────────── */
  .rd-hero {
    text-align: center;
    padding: 1.6rem 1rem 0.8rem;
  }

  .rd-hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 1.2rem;
