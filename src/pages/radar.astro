  /* ── Dropdown villes Data/IA ──────────────────────────── */
  .rd-city-dropdown {
    position: relative;
    flex-shrink: 0;
  }

  .rd-city-trigger {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 7px 10px;
    height: 34px;
    background: rgba(20, 40, 68, 0.9);
    color: var(--text-light);
    border: 1px solid rgba(45, 130, 170, 0.3);
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
    font-family: var(--font-primary);
    cursor: pointer;
    white-space: nowrap;
    transition: border-color .2s, background .2s;
    min-width: 150px;
  }
  .rd-city-trigger:hover {
    border-color: var(--accent-cyan);
    background: rgba(30, 58, 95, 0.95);
  }
  .rd-city-dropdown[aria-expanded="true"] .rd-city-trigger {
    border-color: var(--accent-cyan);
    background: rgba(30, 58, 95, 0.95);
  }
  .rd-city-trigger-icon { color: var(--accent-cyan); font-size: 0.8rem; }
  .rd-city-chevron { font-size: 0.65rem; color: var(--text-muted); margin-left: auto; transition: transform .2s; }
  .rd-city-dropdown[aria-expanded="true"] .rd-city-chevron { transform: rotate(180deg); }

  .rd-city-panel {
    display: none;
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    z-index: 999;
    min-width: 230px;
    max-height: 380px;
    overflow-y: auto;
    background: rgba(8, 15, 28, 0.99);
    border: 1px solid rgba(77, 184, 212, 0.35);
    border-top: 2px solid rgba(77, 184, 212, 0.5);
    border-radius: var(--radius-sm);
    box-shadow: 0 12px 40px rgba(0,0,0,0.6), 0 0 0 1px rgba(77,184,212,0.05);
    backdrop-filter: blur(12px);
    padding: 0.3rem 0;
    animation: dropdownFadeIn .15s ease;
  }
  .rd-city-panel--open { display: block; }
  @keyframes dropdownFadeIn {
    from { opacity: 0; transform: translateY(-4px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .rd-city-group { padding: 0.2rem 0; border-bottom: 1px solid rgba(45,130,170,0.08); }
  .rd-city-group:last-child { border-bottom: none; }

  .rd-city-group-label {
    padding: 0.4rem 0.9rem 0.2rem;
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .rd-city-group-label i { color: rgba(77,184,212,0.5); font-size: 0.65rem; }

  .rd-city-item {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    width: 100%;
    padding: 0.38rem 0.9rem;
    background: none;
    border: none;
    color: var(--text-light);
    font-size: 0.82rem;
    font-family: var(--font-primary);
    cursor: pointer;
    text-align: left;
    transition: background .15s, color .15s;
  }
  .rd-city-item:hover {
    background: rgba(77,184,212,0.08);
    color: var(--accent-cyan);
  }
  .rd-city-item i { font-size: 0.78rem; width: 14px; text-align: center; flex-shrink: 0; }

  /* Light mode */
  [data-theme="light"] .rd-city-trigger {
    background: #fff; color: #1a2535; border-color: rgba(26,127,160,.25);
  }
  [data-theme="light"] .rd-city-panel {
    background: #fff; border-color: rgba(26,101,128,0.2);
    box-shadow: 0 8px 24px rgba(26,101,128,0.12);
  }
  [data-theme="light"] .rd-city-item { color: #1a2535; }
  [data-theme="light"] .rd-city-item:hover { background: rgba(26,101,128,0.07); color: #1a6580; }
  [data-theme="light"] .rd-city-group { border-bottom-color: rgba(26,101,128,0.08); }

  .rd-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 0 16px;
    height: 34px;
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
    font-weight: 600;
    font-family: var(--font-primary);
    cursor: pointer;
    white-space: nowrap;
    text-decoration: none;
    transition: var(--transition-fast);
    border: 1px solid transparent;
    flex-shrink: 0;
  }
  .rd-btn--primary {
    background: var(--accent-cyan);
    color: #0b1a2e;
    border-color: var(--accent-cyan);
  }
  .rd-btn--primary:hover { background: var(--accent-light-cyan); border-color: var(--accent-light-cyan); }

  .rd-btn--ghost {
    background: transparent;
    color: var(--text-muted);
    border-color: rgba(45, 130, 170, 0.25);
  }
  .rd-btn--ghost:hover { border-color: var(--accent-cyan); color: var(--accent-cyan); }
  .rd-btn--ghost:disabled { opacity: .35; cursor: not-allowed; }
  .rd-btn--full { width: 100%; justify-content: center; }

  /* ── Toggle vue PRO / CYCLO ──────────────────────────────── */
  .rd-view-toggle {
    display: flex;
    flex-shrink: 0;
    border-radius: var(--radius-sm);
    border: 1px solid rgba(77, 184, 212, 0.3);
    overflow: hidden;
    height: 34px;
  }
  .rd-view-btn {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 0 13px;
    height: 100%;
    background: rgba(20, 40, 68, 0.7);
    color: var(--text-muted);
    border: none;
    font-size: 0.78rem;
    font-weight: 600;
    font-family: var(--font-primary);
    cursor: pointer;
    white-space: nowrap;
    transition: background .15s, color .15s;
    border-right: 1px solid rgba(77, 184, 212, 0.2);
  }
  .rd-view-btn:last-child { border-right: none; }
  .rd-view-btn i { font-size: 0.75rem; }
  .rd-view-btn:hover {
    background: rgba(30, 58, 95, 0.9);
    color: var(--text-light);
  }
  .rd-view-btn--active {
    background: rgba(77, 184, 212, 0.18);
    color: var(--accent-cyan);
  }
  .rd-view-btn--active:hover {
    background: rgba(77, 184, 212, 0.26);
  }
  /* Light mode */
  [data-theme="light"] .rd-view-toggle { border-color: rgba(26,127,160,.3); }
  [data-theme="light"] .rd-view-btn {
    background: #fff;
    color: #4a6275;
    border-right-color: rgba(26,127,160,.15);
  }
  [data-theme="light"] .rd-view-btn:hover { background: #f0f8ff; color: #1a2535; }
  [data-theme="light"] .rd-view-btn--active { background: rgba(26,127,160,.12); color: #0e7fa8; }
  [data-theme="light"] .rd-view-btn--active:hover { background: rgba(26,127,160,.2); }

  .rd-radius-inline {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
    height: 34px;
    padding: 0 10px;
    background: rgba(20, 40, 68, 0.6);
    border: 1px solid rgba(45, 130, 170, 0.2);
    border-radius: var(--radius-sm);
  }
  .rd-radius-label {
    font-size: var(--text-xs);
    color: var(--text-muted);
    white-space: nowrap;
  }
  .rd-radius-label strong { color: var(--accent-cyan); font-weight: 700; }
  #radius-slider {
    width: 80px;
    accent-color: var(--accent-cyan);
    cursor: pointer;
  }

  .rd-status {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
    margin-left: auto;
  }

  .rd-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--text-muted);
    flex-shrink: 0;
    transition: background .3s;
  }
  .rd-dot.active  { background: var(--status-ok); box-shadow: 0 0 6px var(--status-ok); }
  .rd-dot.loading { background: var(--accent-cyan); animation: pulse-dot 1s ease infinite; }
  .rd-dot.error   { background: var(--status-err); }
  @keyframes pulse-dot { 0%,100%{opacity:1} 50%{opacity:.3} }

  .rd-status-label {
    font-size: var(--text-xs);
    color: var(--text-muted);
    max-width: 220px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .rd-status-label.hidden { display: none; }

  /* ── Container admin-style ─────────────────────────────── */
  .rd-container {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    padding: 0 var(--spacing-sm) 2rem;
    flex: 1;
  }

  /* ── Tabs — inspiré admin-terrain ──────────────────────── */
  .rd-tabs {
    display: flex;
    gap: 0;
    border-bottom: 1px solid rgba(45, 130, 170, 0.12);
    margin-bottom: 1rem;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .rd-tabs::-webkit-scrollbar { display: none; }

  .rd-tab {
    padding: 0.65rem 1rem;
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    color: var(--text-muted);
    font-size: var(--text-sm);
    font-weight: 600;
    font-family: var(--font-primary);
    cursor: pointer;
    transition: var(--transition-fast);
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 0.45rem;
  }
  .rd-tab:hover { color: var(--text-light); }
  .rd-tab--active {
    color: var(--accent-cyan);
    border-bottom-color: var(--accent-cyan);
  }

  .rd-tab-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--dot-color, #888);
    opacity: .5;
    transition: opacity .2s;
    flex-shrink: 0;
  }
  .rd-tab--active .rd-tab-dot { opacity: 1; }

  .rd-tab-count {
    font-size: 0.65rem;
    background: rgba(77, 184, 212, 0.12);
    border: 1px solid rgba(77, 184, 212, 0.2);
    color: var(--accent-cyan);
    border-radius: var(--radius-full);
    padding: 0 6px;
    min-width: 18px;
    text-align: center;
    line-height: 1.5;
  }

  .rd-tab-content { display: none; }
  .rd-tab-content--active { display: block; }

  /* ── Card — admin-style ────────────────────────────────── */
  .rd-card {
    background: rgba(12, 20, 36, 0.8);
    border: 1px solid rgba(45, 130, 170, 0.1);
    border-radius: var(--radius-md);
    padding: 1.2rem;
    margin-bottom: 1.5rem;
  }

  .rd-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .rd-card-header h3 {
    font-size: var(--text-lg);
    color: var(--heading-color);
    margin: 0;
    font-weight: 700;
  }
  .rd-card-header h3 i {
    margin-right: 0.4rem;
  }

  .rd-card-hint {
    font-size: var(--text-xs);
    color: var(--text-muted);
    letter-spacing: var(--ls-label);
  }

  .rd-card-badges {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  /* ── Carte ─────────────────────────────────────────────── */
  .rd-map-frame {
    height: 45vh;
    min-height: 320px;
    overflow: hidden;
    border-radius: var(--radius-sm);
    border: 1px solid rgba(45, 130, 170, 0.1);
    position: relative;
  }

  /* ── Overlay centré sur la carte ──────────────────────── */
  .map-info-overlay {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 1000;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 22px;
    border-radius: var(--radius-full);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    font-size: var(--text-sm);
    font-weight: 600;
    font-family: var(--font-primary);
    pointer-events: none;
    white-space: nowrap;
    max-width: 88%;
    box-shadow: 0 4px 24px rgba(0,0,0,.45);
    transition: opacity .25s ease, transform .25s ease;
    opacity: 1;
  }

  /* États */
  .map-info-overlay--hidden {
    opacity: 0;
    transform: translate(-50%, calc(-50% + 8px));
    pointer-events: none;
  }
  .map-info-overlay--info,
  .map-info-overlay--loading {
    background: rgba(10, 20, 38, 0.96);
    border: 1px solid rgba(77, 184, 212, 0.3);
    color: #e8ecf0;
  }
  .map-info-overlay--loading #map-info-icon {
    display: inline-block;
    animation: spin-slow 1.2s linear infinite;
  }
  @keyframes spin-slow { to { transform: rotate(360deg); } }
  .map-info-overlay--success {
    background: rgba(10, 20, 38, 0.96);
    border: 1px solid rgba(77, 184, 212, 0.3);
    color: #e8ecf0;
  }
  .map-info-overlay--error {
    background: rgba(10, 20, 38, 0.96);
    border: 1px solid rgba(239, 68, 68, 0.4);
    color: #fca5a5;
  }
  #map-info-icon { font-size: 1.1rem; flex-shrink: 0; }

  #radar-map {
    width: 100%;
    height: 100%;
    filter: brightness(.88) saturate(.70) hue-rotate(2deg);
    transition: filter .3s;
  }
  .rd-map-frame:hover #radar-map {
    filter: brightness(.95) saturate(.80) hue-rotate(2deg);
  }

  .leaflet-popup-content-wrapper,
  .leaflet-popup-tip   { filter: brightness(1.65) saturate(2.5); }
  .leaflet-control-zoom { filter: brightness(1.65) saturate(2.5); }

  .pos-marker {
    font-size: 22px;
    filter: drop-shadow(0 2px 6px rgba(0,0,0,.9));
    animation: bounce .9s ease infinite alternate;
  }
  @keyframes bounce { to { transform: translateY(-5px); } }

  /* ── Combobox catégories ─────────────────────────────────── */
  .rd-cat-dropdown { position: relative; flex-shrink: 0; }

  .rd-cat-trigger {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 0 12px;
    height: 34px;
    background: rgba(20, 40, 68, 0.9);
    color: var(--text-light);
    border: 1px solid rgba(77, 184, 212, 0.3);
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
    font-family: var(--font-primary);
    font-weight: 500;
    cursor: pointer;
    white-space: nowrap;
    transition: border-color .2s, background .2s, box-shadow .2s;
    min-width: 148px;
  }
  .rd-cat-trigger:hover {
    border-color: var(--accent-cyan);
    background: rgba(30, 58, 95, 0.95);
  }
  .rd-cat-dropdown[aria-expanded="true"] .rd-cat-trigger {
    border-color: var(--accent-cyan);
    background: rgba(30, 58, 95, 0.95);
    box-shadow: 0 0 0 2px rgba(77, 184, 212, 0.15);
  }
  .rd-cat-icon { color: var(--accent-cyan); font-size: 0.82rem; }
  .rd-cat-chevron { font-size: 0.65rem; color: var(--accent-cyan); opacity: 0.7; margin-left: auto; transition: transform .2s; }
  .rd-cat-dropdown[aria-expanded="true"] .rd-cat-chevron { transform: rotate(180deg); opacity: 1; }

  .rd-cat-panel {
    display: none;
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    z-index: 1000;
    min-width: 230px;
    background: rgba(8, 15, 28, 0.99);
    border: 1px solid rgba(77, 184, 212, 0.35);
    border-top: 2px solid rgba(77, 184, 212, 0.5);
    border-radius: var(--radius-sm);
    box-shadow: 0 12px 40px rgba(0,0,0,0.6), 0 0 0 1px rgba(77,184,212,0.05);
    backdrop-filter: blur(12px);
    padding: 0.4rem 0;
    animation: dropdownFadeIn .15s ease;
  }
  .rd-cat-panel--open { display: block; }
  .rd-cat-item--hidden { display: none !important; }
  .rd-cat-item--all {
    font-weight: 600;
    border-bottom: 1px solid rgba(77, 184, 212, 0.15);
    margin-bottom: 2px;
    padding-bottom: 6px;
  }

  .rd-cat-panel-header {
    padding: 0.3rem 0.9rem 0.4rem;
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-muted);
    border-bottom: 1px solid rgba(77, 184, 212, 0.08);
    margin-bottom: 0.25rem;
  }

  .rd-cat-item {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.5rem 0.9rem;
    cursor: pointer;
    transition: background .15s, color .15s;
    font-size: 0.83rem;
    color: var(--text-light);
    font-family: var(--font-primary);
    user-select: none;
    border-left: 2px solid transparent;
  }
  .rd-cat-item:hover {
    background: rgba(77, 184, 212, 0.1);
    color: #e0f7ff;
    border-left-color: rgba(77, 184, 212, 0.4);
  }
  .rd-cat-item:has(.rd-cat-cb:checked) {
    background: rgba(77, 184, 212, 0.06);
  }
  .rd-cat-item i { font-size: 0.82rem; width: 15px; text-align: center; flex-shrink: 0; }
  .rd-cat-cb {
    accent-color: var(--accent-cyan);
    width: 15px; height: 15px;
    cursor: pointer;
    flex-shrink: 0;
  }

  /* Light mode — cat-dropdown */
  [data-theme="light"] .rd-cat-trigger {
    background: #fff;
    color: #1a2535;
    border-color: rgba(26, 101, 128, 0.3);
  }
  [data-theme="light"] .rd-cat-trigger:hover,
  [data-theme="light"] .rd-cat-dropdown[aria-expanded="true"] .rd-cat-trigger {
    background: #f0f8ff;
    border-color: #1a7fa0;
  }
  [data-theme="light"] .rd-cat-panel {
    background: #fff;
    border-color: rgba(26, 101, 128, 0.25);
    border-top-color: #1a7fa0;
    box-shadow: 0 8px 24px rgba(26, 101, 128, 0.15);
  }
  [data-theme="light"] .rd-cat-item { color: #1a2535; }
  [data-theme="light"] .rd-cat-item:hover {
    background: rgba(26, 101, 128, 0.07);
    color: #1a6580;
    border-left-color: rgba(26, 101, 128, 0.3);
  }
  [data-theme="light"] .rd-cat-panel-header { color: #6b7280; border-bottom-color: rgba(26,101,128,0.1); }

  /* ── Chips filtres ─────────────────────────────────────── */
  .chip--hidden { display: none !important; }
  .chip {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 4px 10px;
    border-radius: var(--radius-full);
    border: 1px solid rgba(45, 130, 170, 0.2);
    background: transparent;
    color: var(--text-muted);
    font-size: var(--text-xs);
    font-family: var(--font-primary);
    cursor: pointer;
    white-space: nowrap;
    transition: var(--transition-fast);
    user-select: none;
  }
  .chip i {
    font-size: 0.75rem;
    opacity: 0.6;
    transition: opacity .2s;
  }
  .chip.active {
    border-color: rgba(var(--chip-rgb, 77,184,212), 0.5);
    background: rgba(var(--chip-rgb, 77,184,212), 0.1);
    color: var(--text-light);
  }
  .chip.active i { opacity: 1; color: var(--chip-color, var(--accent-cyan)); }
  .chip:hover { border-color: var(--chip-color, var(--accent-cyan)); color: var(--text-light); }
  .chip:hover i { opacity: 1; }

  /* ── Résultats (listes) ────────────────────────────────── */
  .rd-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
    max-height: 55vh;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: rgba(77,184,212,.2) transparent;
  }

  .result-item {
    display: flex;
    gap: 12px;
    padding: 12px 14px;
    background: rgba(18, 30, 50, 0.6);
    border: 1px solid rgba(45, 130, 170, 0.08);
    border-radius: var(--radius-sm);
    transition: border-color var(--transition-fast), background var(--transition-fast);
  }
  .result-item:hover {
    border-color: rgba(77, 184, 212, 0.28);
    background: rgba(18, 30, 50, 0.95);
  }

  .result-left { flex-shrink: 0; padding-top: 4px; }

  .type-dot {
    display: block;
    width: 10px; height: 10px;
    border-radius: 50%;
    box-shadow: 0 0 7px currentColor;
  }

  .result-body { flex: 1; min-width: 0; }

  .result-header-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 4px;
    flex-wrap: wrap;
  }

  .result-nom {
    flex: 1;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text-light);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0;
  }

  .result-dist {
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--accent-cyan);
    flex-shrink: 0;
    background: rgba(77, 184, 212, 0.08);
    padding: 2px 8px;
    border-radius: var(--radius-sm);
    border: 1px solid rgba(77, 184, 212, 0.15);
  }

  .result-adresse, .result-meta {
    font-size: var(--text-xs);
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 4px;
    margin-bottom: 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .result-source {
    font-size: 0.65rem;
    color: rgba(143, 163, 184, 0.45);
    margin-bottom: 6px;
    letter-spacing: 0.03em;
  }

  .result-actions {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-top: 8px;
  }

  .result-btn {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 4px 10px;
    font-size: 0.72rem;
    font-weight: 600;
    font-family: var(--font-primary);
    border-radius: var(--radius-sm);
    border: 1px solid rgba(45, 130, 170, 0.2);
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    text-decoration: none;
    transition: var(--transition-fast);
    line-height: 1.4;
  }
  .result-btn:hover { border-color: rgba(77,184,212,0.4); color: var(--text-light); background: rgba(255,255,255,0.04); }
  .btn-go   { }
  .btn-fiche { }
  .btn-event { background: rgba(244,63,94,0.12); color: #f43f5e; border-color: rgba(244,63,94,0.3); }
  .btn-event:hover { background: rgba(244,63,94,0.22); }
  .result-date { color: #f43f5e; font-size: 0.75rem; font-weight: 600; }

  /* Empty / skeleton / hint */
  .no-results {
    padding: 32px 16px;
    color: var(--text-muted);
    font-size: var(--text-sm);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }
  .no-results i { font-size: 1.5rem; opacity: .4; }

  .rd-hint {
    padding: 32px 16px;
    text-align: center;
    color: var(--text-muted);
    font-size: var(--text-sm);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }
  .rd-hint i { font-size: 2rem; opacity: .25; }
  .rd-hint strong { color: var(--accent-cyan); font-size: var(--text-base); }

  .skeleton-item {
    padding: 12px 14px;
    background: rgba(18, 30, 50, 0.6);
    border: 1px solid rgba(45, 130, 170, 0.06);
    border-radius: var(--radius-sm);
  }
  .skel-line {
    height: 10px;
    border-radius: 4px;
    background: linear-gradient(90deg, rgba(77,184,212,.06) 25%, rgba(77,184,212,.14) 50%, rgba(77,184,212,.06) 75%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
    margin-bottom: 8px;
  }
  .skel-w70 { width: 70%; }
  .skel-w45 { width: 45%; }
  @keyframes shimmer { to { background-position: -200% 0; } }

  /* ── Toasts ────────────────────────────────────────────── */
  #toast-container {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 9999;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    pointer-events: none;
  }

  .toast {
    background: rgba(12, 20, 36, 0.97);
    border: 1px solid rgba(45, 130, 170, 0.35);
    color: var(--text-light);
    padding: 8px 18px;
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    opacity: 0;
    transform: translateY(8px);
    transition: opacity .2s, transform .2s;
    backdrop-filter: blur(10px);
    max-width: 88vw;
    text-align: center;
    box-shadow: var(--shadow-md);
  }
  .toast-show { opacity: 1; transform: translateY(0); }
  .toast-error { border-color: rgba(239,68,68,.45); color: #fca5a5; }

  /* ── Responsive ────────────────────────────────────────── */
  @media (max-width: 640px) {
    .rd-header { padding: 8px 12px; margin: 0 8px 0.5rem; }
    .rd-toolbar { gap: 6px; }
    .rd-select { min-width: 120px; max-width: none; flex: 1; }
    .rd-radius-inline { margin-left: 0; width: 100%; }
    #radius-slider { flex: 1; }
    .rd-container { padding: 0 8px; }
    .rd-tabs { gap: 0; }
    .rd-tab { padding: 0.5rem 0.7rem; font-size: var(--text-xs); }
    .rd-card { padding: 0.8rem; }
    .rd-map-frame { height: 38vh; min-height: 250px; }
    .rd-list { max-height: 45vh; gap: 6px; }
    .result-item { padding: 10px; gap: 8px; }
  }

  /* ── Micro-footer ──────────────────────────────────────── */
  /* ── Note technique ── */
  .rd-tech-note {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    max-width: 860px;
    margin: 0.6rem auto 0;
    padding: 0.6rem 1rem;
    border-top: 1px solid rgba(77,184,212,0.08);
  }

  .rd-tech-note-icon {
    color: rgba(77,184,212,0.4);
    font-size: 0.7rem;
    margin-top: 0.15rem;
    flex-shrink: 0;
  }

  .rd-tech-note p {
    font-size: 0.72rem;
    line-height: 1.6;
    color: var(--text-muted);
    margin: 0;
  }

  .rd-tech-note p strong { color: rgba(200,215,230,0.7); font-weight: 600; }
  .rd-tech-note p code {
    font-size: 0.68rem;
    background: rgba(77,184,212,0.08);
    padding: 1px 4px;
    border-radius: 3px;
    color: var(--accent-cyan);
  }

  [data-theme="light"] .rd-tech-note {
    border-top-color: rgba(26,101,128,0.1);
  }
  [data-theme="light"] .rd-tech-note p { color: #6a85a0; }
  [data-theme="light"] .rd-tech-note p strong { color: #3a5268; }
  [data-theme="light"] .rd-tech-note-icon { color: rgba(26,101,128,0.3); }

  .rd-footer {
    flex-shrink: 0;
    background: rgba(8, 15, 28, 0.97);
    border-top: 1px solid rgba(45, 130, 170, 0.15);
    padding: 0.8rem 1.2rem 0.6rem;
  }

  .rd-footer-nav {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1.4rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(45, 130, 170, 0.08);
  }
  .rd-footer-nav a {
    color: var(--text-muted);
    font-size: 0.72rem;
    font-weight: 500;
    font-family: var(--font-primary);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    transition: color var(--transition-fast);
    padding: 0.15rem 0;
  }
  .rd-footer-nav a:hover { color: var(--accent-cyan); }
  .rd-footer-nav a i { font-size: 0.65rem; opacity: 0.75; }
  .rd-footer-nav--active {
    color: var(--accent-cyan) !important;
    font-weight: 600 !important;
  }
  .rd-footer-nav--active i { opacity: 1 !important; }

  .rd-footer-copy-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-size: 0.65rem;
    color: var(--text-muted);
    flex-wrap: wrap;
    opacity: 0.7;
  }
  .rd-footer-copy  { color: var(--text-muted); }
  .rd-footer-copy strong { color: var(--accent-cyan); font-weight: 600; }
  .rd-footer-sep   { color: rgba(143, 163, 184, 0.3); }
  .rd-footer-project { color: var(--text-muted); }
  .rd-footer-project i { color: var(--text-muted); margin-right: 3px; }
  .rd-footer-link  {
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }
  .rd-footer-link:hover { color: var(--accent-cyan); }

  @media (max-width: 480px) {
    .rd-footer-nav { gap: 0.8rem; }
    .rd-footer-nav a { font-size: 0.68rem; }
  }

  /* ── Light theme ────────────────────────────────────────── */
  [data-theme="light"] .rd-header    { background: rgba(234,241,247,.98); border-color: rgba(26,127,160,.2); border-bottom-color: rgba(26,127,160,.35); }
  [data-theme="light"] .rd-toolbar-sep { background: rgba(26,127,160,.2); }
  [data-theme="light"] .rd-select    { background: #fff; color: #1a2535; border-color: rgba(26,127,160,.25); }

  /* Bouton "Je suis ici" en light */
  [data-theme="light"] .rd-btn--primary {
    background: #0e7fa8;
    border-color: #0e7fa8;
    color: #fff;
  }
  [data-theme="light"] .rd-btn--primary:hover { background: #0a6a8f; border-color: #0a6a8f; }

  [data-theme="light"] .rd-btn--ghost { color: #4a6275; border-color: rgba(26,127,160,.2); }

  /* Périmètre (radius) en light */
  [data-theme="light"] .rd-radius-inline {
    background: #fff;
    border-color: rgba(26,127,160,.25);
  }
  [data-theme="light"] .rd-radius-label { color: #4a6275; }
  [data-theme="light"] .rd-radius-label strong { color: #0e7fa8; }

  [data-theme="light"] .rd-tabs      { border-color: rgba(26,127,160,.12); }
  [data-theme="light"] .rd-tab:hover { color: #1a2535; }
  [data-theme="light"] .rd-tab--active { color: var(--accent-cyan); border-bottom-color: var(--accent-cyan); }
  [data-theme="light"] .rd-card      { background: rgba(255,255,255,.85); border-color: rgba(26,127,160,.12); }
  [data-theme="light"] .rd-card-header h3 { color: var(--heading-color); }
  [data-theme="light"] .chip.active  { background: rgba(26,127,160,.1); border-color: #1a7fa0; color: #1a2535; }
  [data-theme="light"] .result-item  { background: rgba(255,255,255,.8); border-color: rgba(26,127,160,.1); }
  [data-theme="light"] .result-nom   { color: #1a2535; }
  [data-theme="light"] #radar-map    { filter: brightness(.95) saturate(.75); }
  [data-theme="light"] .rd-map-frame { border-color: rgba(26,127,160,.12); }
  [data-theme="light"] .rd-footer    { background: rgba(228,238,248,.97); border-top-color: rgba(26,127,160,.15); }
  [data-theme="light"] .rd-footer-nav a { color: #4a6275; }
  [data-theme="light"] .rd-footer-nav a:hover { color: var(--accent-cyan); }
  [data-theme="light"] .rd-footer-copy-row { color: #5a7285; }
  [data-theme="light"] .rd-hero-badge { background: rgba(26,127,160,.07); border-color: rgba(26,127,160,.22); }

  .rd-wip-notice {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    margin-top: 0.85rem;
    padding: 0.5rem 1.1rem;
    background: rgba(234, 88, 12, 0.12);
    border: 1.5px solid rgba(234, 88, 12, 0.55);
    border-radius: 999px;
    font-size: 0.83rem;
    font-weight: 700;
    color: #ea580c;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    box-shadow: 0 0 12px rgba(234, 88, 12, 0.15);
  }
  .rd-wip-notice i { font-size: 0.8rem; }
  [data-theme="light"] .skeleton-item { background: rgba(200,215,230,.55); border-color: rgba(26,127,160,.08); }
  [data-theme="light"] .skel-line     { background: linear-gradient(90deg, rgba(26,127,160,.1) 25%, rgba(26,127,160,.22) 50%, rgba(26,127,160,.1) 75%); background-size: 200% 100%; }
  [data-theme="light"] .result-dist   { color: var(--accent-cyan); background: rgba(26,127,160,.08); border-color: rgba(26,127,160,.18); }
  [data-theme="light"] .result-adresse, [data-theme="light"] .result-meta, [data-theme="light"] .result-source { color: var(--text-muted); }
  [data-theme="light"] .no-results    { color: var(--text-muted); }

  /* toast-info (toast default type) */
  .toast-info { border-color: rgba(77, 184, 212, 0.45); color: var(--text-light); }

  /* ══════════════════════════════════════════════════════════
     MODEBAR — Sélecteur de mode + contrôles contextuels
  ══════════════════════════════════════════════════════════ */

  .rd-modebar {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    max-width: 1200px;
    margin: 0 auto 0.5rem;
    width: 100%;
    padding: 8px 16px;
    background: rgba(8, 15, 28, 0.92);
    border: 1px solid rgba(45, 130, 170, 0.14);
    border-bottom: 2px solid rgba(45, 130, 170, 0.18);
    border-radius: var(--radius-md);
    box-shadow: 0 2px 14px rgba(0,0,0,.22);
  }

  .rd-modebar-sep {
    width: 1px;
    height: 38px;
    background: rgba(77, 184, 212, 0.14);
    flex-shrink: 0;
  }

  /* Toggle PRO / CYCLO */
  .rd-mode-toggle {
    display: flex;
    gap: 5px;
    flex-shrink: 0;
  }

  .rd-mode-btn {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 7px 13px;
    background: rgba(20, 40, 68, 0.7);
    border: 1px solid rgba(45, 130, 170, 0.2);
    border-radius: var(--radius-sm);
    cursor: pointer;
    text-align: left;
    font-family: var(--font-primary);
    transition: border-color .2s, background .2s;
  }
  .rd-mode-btn:hover {
    border-color: rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.04);
  }

  .rd-mode-btn-icon {
    font-size: 1rem;
    color: var(--text-muted);
    transition: color .2s;
    flex-shrink: 0;
    width: 16px;
    text-align: center;
  }

  .rd-mode-btn-body {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .rd-mode-btn-title {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--text-light);
    letter-spacing: 0.02em;
    transition: color .2s;
    line-height: 1.2;
  }

  .rd-mode-btn-sub {
    font-size: 0.68rem;
    color: rgba(160, 180, 200, 0.8);
    font-weight: 400;
    white-space: nowrap;
    line-height: 1.2;
  }

  .rd-mode-btn:hover .rd-mode-btn-icon,
  .rd-mode-btn:hover .rd-mode-btn-title { color: var(--text-light); }

  /* Actif — style unifié Pro & Cyclo */
  .rd-mode-btn--active {
    border-color: rgba(255, 255, 255, 0.22);
    background: rgba(255, 255, 255, 0.07);
  }
  .rd-mode-btn--active .rd-mode-btn-icon,
  .rd-mode-btn--active .rd-mode-btn-title { color: var(--text-light); }
  .rd-mode-btn--active .rd-mode-btn-sub   { color: rgba(200, 215, 230, 0.9); }

  /* Panneaux contrôles contextuels */
  .rd-mode-controls {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    flex: 1;
  }
  .rd-mode-controls--hidden { display: none !important; }

  .rd-mode-cyclo-hint {
    font-size: 0.72rem;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 6px;
    font-style: italic;
  }

  /* ── Steps guide (①②③) ──────────────────────────────────── */
  .rd-steps-guide {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    background: rgba(255,255,255,0.04);
    border-bottom: 1px solid rgba(255,255,255,0.06);
    font-size: 0.72rem;
    color: var(--text-muted);
    flex-wrap: wrap;
  }
  .rd-step {
    display: flex;
    align-items: center;
    gap: 5px;
  }
  .rd-step-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--accent, #1a7fa0);
    color: #fff;
    font-size: 0.65rem;
    font-weight: 700;
    flex-shrink: 0;
  }
  .rd-step-arrow {
    color: rgba(255,255,255,0.2);
    font-size: 0.7rem;
  }
  [data-theme="light"] .rd-steps-guide {
    background: rgba(0,0,0,0.03);
    border-bottom-color: rgba(0,0,0,0.07);
  }
  [data-theme="light"] .rd-step-arrow { color: rgba(0,0,0,0.2); }

  /* ── Mode badge (2a / 2b) ───────────────────────────────── */
  .rd-mode-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    border-radius: 4px;
    background: rgba(255,255,255,0.12);
    color: rgba(255,255,255,0.7);
    font-size: 0.58rem;
    font-weight: 700;
    flex-shrink: 0;
  }
  .rd-mode-btn--active .rd-mode-badge {
    background: var(--accent, #1a7fa0);
    color: #fff;
  }
  [data-theme="light"] .rd-mode-badge { background: rgba(0,0,0,0.08); color: #4a6275; }
  [data-theme="light"] .rd-mode-btn--active .rd-mode-badge { background: var(--accent, #1a7fa0); color: #fff; }

  /* ── Mode hint strip ────────────────────────────────────── */
  .rd-mode-hint {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    background: rgba(255,255,255,0.03);
    border-top: 1px solid rgba(255,255,255,0.05);
    font-size: 0.72rem;
    color: var(--text-muted);
    font-style: italic;
    transition: color 0.2s;
  }
  .rd-mode-hint .fa-fw { color: var(--accent, #1a7fa0); flex-shrink: 0; }
  [data-theme="light"] .rd-mode-hint {
    background: rgba(0,0,0,0.02);
    border-top-color: rgba(0,0,0,0.06);
  }

  /* Tab caché par mode */
  .rd-tab--mode-hidden { display: none !important; }

  /* Light mode modebar */
  [data-theme="light"] .rd-modebar {
    background: rgba(234, 241, 247, 0.98);
    border-color: rgba(26, 127, 160, 0.18);
    border-bottom-color: rgba(26, 127, 160, 0.28);
  }
  [data-theme="light"] .rd-modebar-sep { background: rgba(26, 127, 160, 0.14); }
  [data-theme="light"] .rd-mode-btn {
    background: #fff;
    border-color: rgba(26, 127, 160, 0.2);
  }
  [data-theme="light"] .rd-mode-btn:hover { background: #f0f8ff; }
  [data-theme="light"] .rd-mode-btn-title { color: #4a6275; }
  [data-theme="light"] .rd-mode-btn:hover .rd-mode-btn-title { color: #1a2535; }
  [data-theme="light"] .rd-mode-btn--active {
    background: rgba(0, 0, 0, 0.06);
    border-color: rgba(26, 127, 160, 0.35);
  }
  [data-theme="light"] .rd-mode-btn--active .rd-mode-btn-icon,
  [data-theme="light"] .rd-mode-btn--active .rd-mode-btn-title { color: #1a2535; }
  [data-theme="light"] .rd-mode-btn--active .rd-mode-btn-sub   { color: #4a6275; }

  /* Responsive modebar */
  @media (max-width: 640px) {
    .rd-modebar { padding: 7px 10px; gap: 7px; }
    .rd-mode-btn { padding: 6px 10px; gap: 7px; }
    .rd-mode-btn-sub { display: none; }
    .rd-modebar-sep { display: none; }
    .rd-mode-controls { gap: 6px; }
  }

  /* ══════════════════════════════════════════════════════════
     MODULE — SALONS FRANCE
  ══════════════════════════════════════════════════════════ */

  /* Bouton toolbar Salons FR */
  .rd-btn--salons {
    font-weight: 600;
    letter-spacing: 0.01em;
  }
  .rd-btn--salons-active {
    background: rgba(255, 255, 255, 0.09) !important;
    border-color: rgba(255, 255, 255, 0.22) !important;
    color: var(--text-light) !important;
  }

  /* Tab Salons FR */
  .rd-tab--salons.rd-tab--active {
    color: #06b6d4;
    border-bottom-color: #06b6d4;
  }

  /* Badge national dans le card header */
  .salon-national-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 3px 10px;
    background: rgba(6, 182, 212, 0.1);
    border: 1px solid rgba(6, 182, 212, 0.28);
    border-radius: var(--radius-full);
    color: #06b6d4;
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    flex-shrink: 0;
  }
  .salon-national-badge i { font-size: 0.6rem; opacity: 0.8; }

  /* Zone filtres domaine + format */
  .salons-filters {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    margin-bottom: 1rem;
    padding: 0.6rem 0.9rem;
    background: rgba(6, 182, 212, 0.04);
    border: 1px solid rgba(6, 182, 212, 0.1);
    border-radius: var(--radius-sm);
  }

  .salons-filter-group {
    display: flex;
    align-items: center;
    gap: 7px;
    flex-wrap: wrap;
  }

  .salons-filter-label {
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .salons-filter-label i { font-size: 0.6rem; opacity: 0.7; }

  .salons-filter-sep {
    width: 1px;
    height: 22px;
    background: rgba(6, 182, 212, 0.15);
    flex-shrink: 0;
  }

  .salons-chips { display: flex; gap: 4px; flex-wrap: wrap; }

  /* Chip générique salons */
  .salon-chip {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 3px 9px;
    border-radius: var(--radius-full);
    border: 1px solid rgba(45, 130, 170, 0.2);
    background: transparent;
    color: var(--text-muted);
    font-size: 0.68rem;
    font-weight: 600;
    font-family: var(--font-primary);
    cursor: pointer;
    transition: var(--transition-fast);
    user-select: none;
  }
  .salon-chip i { font-size: 0.62rem; }
  .salon-chip:hover {
    border-color: var(--accent-cyan);
    color: var(--text-light);
  }
  .salon-chip--active {
    border-color: rgba(77, 184, 212, 0.5);
    color: var(--accent-cyan);
    background: rgba(77, 184, 212, 0.06);
  }

  [data-theme="light"] .salon-chip--active {
    background: rgba(0, 0, 0, 0.04);
  }
  [data-theme="light"] .salons-filters {
    background: rgba(6, 182, 212, 0.03);
    border-color: rgba(6, 182, 212, 0.12);
  }

  /* ── Link tables (événements & salons) ──────────────────── */
  .rd-link-table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .lt-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.78rem;
    color: var(--text-light);
  }

  .lt-table thead th {
    padding: 6px 10px;
    text-align: left;
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    border-bottom: 1px solid rgba(255,255,255,0.07);
    white-space: nowrap;
  }

  .lt-table tbody tr {
    border-bottom: 1px solid rgba(255,255,255,0.04);
    transition: background var(--transition-fast);
  }
  .lt-table tbody tr:last-child { border-bottom: none; }
  .lt-table tbody tr:hover { background: rgba(255,255,255,0.03); }

  .lt-table td {
    padding: 7px 10px;
    vertical-align: top;
  }

  .lt-date {
    white-space: nowrap;
    color: var(--text-muted);
    font-size: 0.72rem;
    font-variant-numeric: tabular-nums;
    min-width: 80px;
  }

  .lt-nom { min-width: 160px; }

  .lt-lieu {
    color: var(--text-muted);
    font-size: 0.72rem;
    max-width: 160px;
  }

  .lt-fmt {
    white-space: nowrap;
    color: var(--text-muted);
    font-size: 0.7rem;
  }

  .lt-link {
    color: var(--accent-cyan);
    text-decoration: none;
    transition: opacity var(--transition-fast);
  }
  .lt-link:hover { opacity: 0.75; text-decoration: underline; }
  .lt-link i { font-size: 0.58rem; margin-left: 4px; opacity: 0.5; vertical-align: middle; }

  .lt-badges {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
    margin-top: 4px;
  }

  .lt-badge {
    display: inline-flex;
    align-items: center;
    padding: 1px 7px;
    border-radius: 3px;
    border: 1px solid var(--badge-color, #888);
    color: var(--badge-color, #888);
    background: transparent;
    font-size: 0.58rem;
