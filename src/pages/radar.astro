      leafletMap = L.map('radar-map', {
        center: [46.6, 2.3],
        zoom: 6,
        zoomControl: true,
      });

      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© <a href="https://openstreetmap.org">OpenStreetMap</a>',
        maxZoom: 19,
      }).addTo(leafletMap);

      createClusters();
      // Dark filter appliqué via CSS
    }

    // ── Overlay info centré sur la carte ────────────────────
    let _mapInfoTimer = null;
    function showMapInfo(icon, text, type = 'info', duration = 3500) {
      const overlay = document.getElementById('map-info-overlay');
      const iconEl  = document.getElementById('map-info-icon');
      const textEl  = document.getElementById('map-info-text');
      if (!overlay) return;
      iconEl.textContent = icon;
      textEl.textContent = text;
      overlay.className = `map-info-overlay map-info-overlay--${type}`;
      clearTimeout(_mapInfoTimer);
      if (duration > 0) {
        _mapInfoTimer = setTimeout(() => {
          overlay.classList.add('map-info-overlay--hidden');
        }, duration);
      }
    }
    // ── Géolocalisation ───────────────────────────────────────
    function locateMe() {
      if (!navigator.geolocation) {
        showMapInfo('❌', 'Géolocalisation non supportée par ce navigateur', 'error', 4000);
        return;
      }
      showMapInfo('📡', 'Localisation en cours…', 'loading', 0);
      navigator.geolocation.getCurrentPosition(
        pos => {
          currentLat = pos.coords.latitude;
          currentLon = pos.coords.longitude;
          document.getElementById('btn-refresh').disabled = false;
          showMapInfo('✅', `Position : ${currentLat.toFixed(4)}, ${currentLon.toFixed(4)}`, 'success', 3000);
          search();
        },
        err => {
          const msgs = {
            1: 'Permission refusée — activez la géolocalisation',
            2: 'Position indisponible',
            3: 'Délai dépassé',
          };
          showMapInfo('🔒', msgs[err.code] || 'Erreur de géolocalisation', 'error', 5000);
        },
        { timeout: 15000, maximumAge: 300000, enableHighAccuracy: true }
      );
    }

    // ── Haversine ─────────────────────────────────────────────
    function haversine(lat1, lon1, lat2, lon2) {
      const R = 6371;
      const dLat = (lat2 - lat1) * Math.PI / 180;
      const dLon = (lon2 - lon1) * Math.PI / 180;
      const a =
        Math.sin(dLat / 2) ** 2 +
        Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *
        Math.sin(dLon / 2) ** 2;
      return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
    }

    // ── Sources de données ────────────────────────────────────

    async function fetchOverpass(lat, lon, radiusM, signal) {
      const radiusKm = Math.round(radiusM / 1000);
      const url = `/api/radar-proxy.php?type=overpass&lat=${lat}&lon=${lon}&radius=${radiusKm}&mode=${currentMode}`;
      const resp = await fetch(url, { signal: signal ?? AbortSignal.timeout(25000) });
      if (!resp.ok) throw new Error(`Overpass HTTP ${resp.status}`);
      const data = await resp.json();

      return (data.elements || []).map(el => {
        const elLat = el.lat ?? el.center?.lat;
        const elLon = el.lon ?? el.center?.lon;
        if (!elLat || !elLon) return null;

        const tags = el.tags || {};
        let type = 'autre';
        if (tags.tourism === 'camp_site')                                                  type = 'camping';
        else if (tags.amenity === 'coworking_space')                                       type = 'coworking';
        else if (tags.amenity === 'shower')                                                type = 'douche';
        else if (tags.amenity === 'drinking_water' || tags.man_made === 'water_tap')       type = 'fontaine';
        else if (tags.leisure === 'swimming_pool' || tags.sport === 'swimming')            type = 'piscine';
        else if (tags.amenity === 'shelter' || tags.tourism === 'wilderness_hut' || tags.tourism === 'alpine_hut') type = 'abri';

        const adresseParts = [
          tags['addr:housenumber'],
          tags['addr:street'],
          tags['addr:city'],
        ].filter(Boolean);

        const extra = {};
        if (type === 'piscine') {
          extra.access = tags.access || 'public';
          extra.fee    = tags.fee || null;
        }
        if (type === 'abri') {
          extra.capacity = tags.capacity || null;
        }

        return {
          id: `osm-${el.id}`,
          nom: tags.name || labelForType(type),
          type,
          lat: elLat,
          lon: elLon,
          adresse: adresseParts.join(' ') || null,
          phone:   tags.phone || tags['contact:phone'] || null,
          website: tags.website || tags['contact:website'] || null,
          source: 'OpenStreetMap',
          ...extra,
        };
      }).filter(r => r.type !== 'autre');
    }

    async function fetchCampingsGouv(lat, lon, radiusKm, signal) {
      const url = `/api/radar-proxy.php?type=campings&lat=${lat}&lon=${lon}&radius=${radiusKm}`;
      const resp = await fetch(url, { signal: signal ?? AbortSignal.timeout(15000) });
      if (!resp.ok) throw new Error(`Campings proxy HTTP ${resp.status}`);
      const data = await resp.json();

      return (data.results || [])
        .filter(r => {
          const g = r.coordonnees_geo;
          if (!g) return false;
          // OpenDataSoft v2 retourne {lat, lon} ou GeoJSON {coordinates:[lon,lat]}
          return (g.lat && g.lon) || (Array.isArray(g.coordinates) && g.coordinates.length === 2);
        })
        .map(r => {
          const g = r.coordonnees_geo;
          const coords = Array.isArray(g.coordinates) ? g.coordinates : [];
          const lat = g.lat !== undefined ? g.lat : coords[1];
          const lon = g.lon !== undefined ? g.lon : coords[0];
          return {
            id: `atout-${r.nom_commercial}-${r.code_postal}`,
            nom: r.nom_commercial || 'Camping',
            type: 'camping',
            lat: parseFloat(lat),
            lon: parseFloat(lon),
            adresse: [r.adresse, r.code_postal, r.commune].filter(Boolean).join(' '),
            classement: r.classement || null,
            nbEmplacements: r.nombre_emplacements || null,
            source: 'Atout France',
          };
        });
    }

    async function fetchEntreprises(lat, lon, signal) {
      // 1. Code département via proxy (évite appel direct depuis mobile)
      const geoResp = await fetch(
        `/api/radar-proxy.php?type=commune&lat=${lat}&lon=${lon}`,
        { signal: signal ?? AbortSignal.timeout(8000) }
      );
      if (!geoResp.ok) throw new Error(`Commune proxy HTTP ${geoResp.status}`);
      const geoData = await geoResp.json();
      const dept = geoData[0]?.codeDepartement;
      if (!dept) throw new Error('Département introuvable');

      // 2. Entreprises via proxy (le proxy gère les 5 codes NAF côté serveur)
      const entResp = await fetch(
        `/api/radar-proxy.php?type=entreprises&dept=${encodeURIComponent(dept)}`,
        { signal: signal ?? AbortSignal.timeout(20000) }
      );
      if (!entResp.ok) throw new Error(`Entreprises proxy HTTP ${entResp.status}`);
      const entData = await entResp.json();

      if (entData._debug) console.debug('[Radar/entreprises]', entData._debug, `total brut: ${entData._count}`);

      const seen = new Set();
      const results = [];
      for (const e of (entData.results || [])) {
        if (!e.siren || seen.has(e.siren)) continue;
        seen.add(e.siren);
        const siege = e.siege;
        // GPS optionnel — on garde l'entreprise même sans coordonnées (affichée en liste, pas sur carte)
        const hasGeo = siege?.latitude && siege?.longitude;
        results.push({
          id: `siren-${e.siren}`,
          nom: e.nom_complet || 'Entreprise',
          type: 'entreprise',
          lat: hasGeo ? parseFloat(siege.latitude)  : null,
          lon: hasGeo ? parseFloat(siege.longitude) : null,
          adresse: siege ? [siege.adresse, siege.code_postal, siege.libelle_commune].filter(Boolean).join(' ') : '',
          source: 'INSEE SIRENE',
          siren: e.siren,
          naf: e.activite_principale,
          nafLabel: e.libelle_activite_principale_libelle_65 || e.activite_principale,
        });
      }
      return results;
    }

    function getCoworkingsNearby(lat, lon, radiusKm) {
      return COWORKINGS_STATIC
        .filter(c => haversine(lat, lon, c.lat, c.lon) <= radiusKm)
        .map(c => ({
          id: `cw-${c.ville}-${c.nom}`.replace(/\s+/g, '-').toLowerCase(),
          nom: c.nom,
          type: 'coworking',
          lat: c.lat,
          lon: c.lon,
          adresse: c.adresse,
          source: 'Données statiques',
        }));
    }

    async function fetchEvents(lat, lon, radiusKm, signal) {
      const url = `/api/radar-proxy.php?type=events&lat=${lat}&lon=${lon}&radius=${radiusKm}`;
      const resp = await fetch(url, { signal: signal ?? AbortSignal.timeout(15000) });
      if (!resp.ok) throw new Error(`Events HTTP ${resp.status}`);
      const data = await resp.json();
      if (data.error || data._error || !data.events) return [];
      return (data.events || []).map(e => {
        const loc = e.location || {};
        const title = e.title?.fr || e.title?.en || 'Événement';
        const timing = e.timings?.[0];
        const dateDebut = timing?.begin ? timing.begin.substring(0, 10) : null;
        const adresseParts = [loc.address, loc.postalCode, loc.city].filter(Boolean);
        return {
          id: `evt-${e.uid}`,
          nom: title,
          type: 'evenement',
          lat: loc.latitude ? parseFloat(loc.latitude) : null,
          lon: loc.longitude ? parseFloat(loc.longitude) : null,
          adresse: adresseParts.join(' ') || loc.name || null,
          source: 'OpenAgenda',
          dateDebut,
          url: e.links?.[0]?.link || null,
        };
      });
    }

    // ── Classification automatique des salons ─────────────────

    function classifyEventDomaines(text) {
      const t = (text || '').toLowerCase();
      const tags = [];
      if (/\b(emploi|recrutement|recrute|job\b|jobs\b|carrière|forum emploi|job.?dating|salon.?emploi)\b/.test(t)) tags.push('emploi');
      if (/\b(data|données|big.?data|bi\b|analytique|dataiku|power.?bi|tableau\b|spark|dbt|databricks|data.?science|data.?warehouse|data.?lake)\b/.test(t)) tags.push('data');
      if (/\b(ia\b|intelligence.?artificielle|machine.?learning|deep.?learning|llm|gpt|nlp|computer.?vision|mlops|ia.?générative|genai)\b/.test(t)) tags.push('ia');
      if (/\b(développeur|dev\b|devops|kubernetes|docker|microservice|fullstack|front.?end|back.?end|api\b|cloud)\b/.test(t)) tags.push('dev');
      return tags.length > 0 ? tags : ['tech'];
    }

    function classifyEventFormat(text) {
      const t = (text || '').toLowerCase();
      if (/\b(visio|visioconférence|en.?ligne|online|distanciel|webinaire|webinar)\b/.test(t)) return 'visio';
      if (/\b(hybride|hybrid)\b/.test(t)) return 'hybride';
      if (/\b(présentiel|en.?présentiel|sur.?place|physique)\b/.test(t)) return 'presentiel';
      return 'autre';
    }

    // ── Salons nationaux — fetch ───────────────────────────────

    async function fetchSalonsNationaux() {
      if (salonsLoaded) { renderSalons(); return; }

      const countEl = document.getElementById('count-salons');
      if (countEl) countEl.textContent = '…';

      // Affiche l'indicateur dans la status bar
      const dot    = document.getElementById('rd-dot');
      const loader = document.getElementById('loading-indicator');
      const idle   = document.getElementById('results-count');
      dot.className = 'rd-dot loading';
      if (loader) { loader.textContent = 'Recherche nationale…'; loader.classList.remove('hidden'); }
      if (idle)   idle.classList.add('hidden');

      const listEl = document.getElementById('salons-timeline');
      if (listEl) listEl.innerHTML = skeletonHTML(4);

      if (IS_DEV) {
        await new Promise(r => setTimeout(r, 450));
        salonsData = MOCK_SALONS.map(s => ({
          ...s,
          domaines: classifyEventDomaines(s.nom + ' ' + (s.adresse || '') + ' ' + (s.format || '')),
          format:   s.format || classifyEventFormat(s.nom),
        })).sort((a, b) => (a.dateDebut || '').localeCompare(b.dateDebut || ''));
        // Injecter les salons curés en admin (premier)
        const adminSalonsDev = adminProData.salons.map(s => ({
          ...s,
          domaines: s.domaines && s.domaines.length ? s.domaines : ['data'],
          format:   s.format || 'autre',
        }));
        salonsData = [...adminSalonsDev, ...salonsData];
        salonsLoaded = true;
        renderSalons();
        if (dot)    dot.className = 'rd-dot active';
        if (loader) loader.classList.add('hidden');
        if (idle)   idle.classList.remove('hidden');
        return;
      }

      try {
        const resp = await fetch('/api/radar-proxy.php?type=salons-nationaux', {
          signal: AbortSignal.timeout(20000),
        });
        if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
        const data = await resp.json();

        salonsData = (data.events || []).map(e => {
          const loc   = e.location || {};
          const title = e.title?.fr || e.title?.en || 'Événement';
          const timing = e.timings?.[0];
          const dateDebut = timing?.begin ? timing.begin.substring(0, 10) : null;
          const adresseParts = [loc.address, loc.postalCode, loc.city].filter(Boolean);
          const fullText = [title, adresseParts.join(' '), e.description?.fr || ''].join(' ');
          return {
            id:       `salon-${e.uid}`,
            nom:      title,
            adresse:  adresseParts.join(' ') || loc.name || null,
            lat:      loc.latitude  ? parseFloat(loc.latitude)  : null,
            lon:      loc.longitude ? parseFloat(loc.longitude) : null,
            dateDebut,
            url:      e.links?.[0]?.link || null,
            source:   'OpenAgenda',
            domaines: classifyEventDomaines(fullText),
            format:   classifyEventFormat(fullText),
          };
        }).sort((a, b) => (a.dateDebut || '').localeCompare(b.dateDebut || ''));

        // Injecter les salons curés en admin (premier)
        const adminSalons = adminProData.salons.map(s => ({
          ...s,
          domaines: s.domaines && s.domaines.length ? s.domaines : ['data'],
          format:   s.format || 'autre',
        }));
        salonsData = [...adminSalons, ...salonsData];

        salonsLoaded = true;
        renderSalons();
      } catch (err) {
        console.warn('[Radar/salons-nationaux]', err);
        if (listEl) listEl.innerHTML = `
          <li class="no-results">
            <i class="fas fa-exclamation-triangle"></i>
            Impossible de charger les salons. Vérifiez la clé OpenAgenda ou réessayez.
          </li>`;
        if (countEl) countEl.textContent = '!';
      } finally {
        if (dot)    dot.className = 'rd-dot active';
        if (loader) loader.classList.add('hidden');
        if (idle)   idle.classList.remove('hidden');
      }
    }

