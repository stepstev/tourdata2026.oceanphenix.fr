  }

  .rd-toolbar {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  /* Séparateur visuel entre groupes toolbar */
  .rd-toolbar-sep {
    width: 1px;
    height: 24px;
    background: rgba(77, 184, 212, 0.15);
    flex-shrink: 0;
  }

  .rd-select {
    min-width: 150px;
    max-width: 220px;
    padding: 0 12px;
    height: 34px;
    background: rgba(20, 40, 68, 0.9);
