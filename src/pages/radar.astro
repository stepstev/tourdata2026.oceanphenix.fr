      abri:     '#84cc16',
    };
    // Coworkings statiques enrichis
    const COWORKINGS_STATIC = [
      { nom: 'La Ruche',           ville: 'Paris',       lat: 48.866, lon:  2.387, adresse: '24 Rue Brézin, 75014 Paris' },
      { nom: 'Mutinerie',          ville: 'Paris',       lat: 48.862, lon:  2.365, adresse: '181 Rue du Temple, 75003 Paris' },
      { nom: 'Darwin Écosystème',  ville: 'Bordeaux',    lat: 44.841, lon: -0.565, adresse: '87 Quai des Queyries, 33100 Bordeaux' },
      { nom: 'La Cordée',          ville: 'Lyon',        lat: 45.748, lon:  4.847, adresse: '1 Rue du Palais de Justice, 69005 Lyon' },
      { nom: 'La Cantine',         ville: 'Toulouse',    lat: 43.608, lon:  1.445, adresse: '2 Place Dupuy, 31000 Toulouse' },
      { nom: 'Remix Coworking',    ville: 'Nantes',      lat: 47.218, lon: -1.553, adresse: 'Nantes Centre' },
      { nom: 'Le Dôme',            ville: 'Caen',        lat: 49.183, lon: -0.357, adresse: 'Caen' },
      { nom: 'La Station',         ville: 'Nice',        lat: 43.706, lon:  7.267, adresse: '89 Rue de France, 06000 Nice' },
      { nom: 'Village by CA',      ville: 'Rennes',      lat: 48.112, lon: -1.680, adresse: 'Rennes' },
      { nom: 'Le Palace',          ville: 'Montpellier', lat: 43.611, lon:  3.877, adresse: 'Montpellier' },
      { nom: 'Cité de l\'innovation', ville: 'Marseille', lat: 43.293, lon: 5.393, adresse: '2 Rue de la Charité, 13002 Marseille' },
    ];


    // ── État ──────────────────────────────────────────────────
    let currentLat = null;
    let currentLon = null;
    let currentRadius = 10;
    let currentMode = 'pro';
    let activeFilters = new Set(); // Initialisé par applyView('pro') au boot
    let allResults = [];
    let searchAbortController = null; // Annule les requêtes en cours si nouvelle recherche
    let modeChangeTimer = null;       // Debounce changement de mode
    const searchCache   = new Map();  // Cache mémoire session : clé → résultats
    let lastSearchKey   = null;       // Dernière clé recherchée
    let lastSearchTime  = 0;          // Timestamp dernière recherche (ms)
    const SEARCH_THROTTLE_MS = 20000; // 20 s min entre deux recherches identiques
    const OVERPASS_MAX_KM    = 15;    // Rayon max Overpass (au-delà → trop lourd)
    let leafletMap = null;
    let mapClusters = {};     // cluster group par type
    let posMarker   = null;   // marqueur position actuelle
    let radiusCircle = null;

    // ── Données admin : liens utiles (localStorage) ───────────
    let adminProData = { liens: [] };

    async function loadAdminProData() {
      try { adminProData.liens = JSON.parse(localStorage.getItem('op-radar-liens') || '[]'); } catch(e) { adminProData.liens = []; }

      try {
        const resp = await fetch('/data/site-data.json', { signal: AbortSignal.timeout(5000) });
        if (resp.ok) {
          const d = await resp.json();
          const r = d.radar || {};
          if (Array.isArray(r.liens) && r.liens.length) adminProData.liens = r.liens;
        }
      } catch(_) { /* localStorage conservé */ }
    }

    // ── Mode dev : détection + mock data ──────────────────────
    const IS_DEV = location.hostname === 'localhost' || location.hostname === '127.0.0.1';

    const MOCK_RESULTS = [
      { id: 'mock-camp-1', nom: 'Camping La Belle Étoile', type: 'camping', lat: 48.642, lon: 2.098, adresse: '12 Chemin des Prés, 91580 Fontenay-lès-Briis', classement: '3 étoiles', source: 'Mock Dev', dist: 1.2 },
      { id: 'mock-camp-2', nom: 'Camping Le Bois Joli', type: 'camping', lat: 48.651, lon: 2.075, adresse: '3 Route de Briis, 91580', classement: '2 étoiles', source: 'Mock Dev', dist: 2.8 },
      { id: 'mock-camp-3', nom: 'Camping Municipal des Saules', type: 'camping', lat: 48.625, lon: 2.110, adresse: 'Allée des Saules, 91580', source: 'Mock Dev', dist: 3.5 },
      { id: 'mock-cw-1', nom: 'CoWork Valley', type: 'coworking', lat: 48.636, lon: 2.102, adresse: '5 Rue du Commerce, 91580 Fontenay-lès-Briis', source: 'Mock Dev', dist: 0.8 },
      { id: 'mock-cw-2', nom: 'La Ruche Numérique', type: 'coworking', lat: 48.648, lon: 2.088, adresse: '18 Boulevard Central, 91580', source: 'Mock Dev', dist: 1.9 },
      // Cyclo
      { id: 'mock-pisc-1', nom: 'Piscine Municipale de Briis', type: 'piscine', lat: 48.641, lon: 2.092, adresse: 'Rue des Sports, 91640 Briis-sous-Forges', source: 'Mock Dev', dist: 0.9, access: 'public', fee: 'yes' },
      { id: 'mock-pisc-2', nom: 'Base de Loisirs — Lac de la Haute-Vallée', type: 'piscine', lat: 48.628, lon: 2.107, adresse: 'Base de Loisirs, 91580', source: 'Mock Dev', dist: 2.2, access: 'public', fee: 'yes' },
      { id: 'mock-font-1', nom: 'Fontaine Place de l\'Église', type: 'fontaine', lat: 48.638, lon: 2.094, adresse: 'Place de l\'Église, 91580 Fontenay-lès-Briis', source: 'Mock Dev', dist: 0.4 },
      { id: 'mock-font-2', nom: 'Point d\'eau — Stade Municipal', type: 'fontaine', lat: 48.650, lon: 2.081, adresse: 'Rue du Stade, 91580', source: 'Mock Dev', dist: 1.7 },
      { id: 'mock-dch-1', nom: 'Douches — Camping Aire Naturelle', type: 'douche', lat: 48.643, lon: 2.098, adresse: 'Chemin Rural, 91580', source: 'Mock Dev', dist: 1.1 },
      { id: 'mock-abri-1', nom: 'Abri Cycliste — Forêt de Rambouillet', type: 'abri', lat: 48.622, lon: 2.078, adresse: 'Forêt Régionale, 91580', source: 'Mock Dev', dist: 3.4, capacity: '8' },
    ];

    // ── MarkerCluster helpers ─────────────────────────────────
    function makeClusterIcon(color) {
      return (cluster) => {
        const n = cluster.getChildCount();
        const size = n < 10 ? 30 : n < 100 ? 36 : 42;
        return L.divIcon({
          html: `<div style="
            background:${color};width:${size}px;height:${size}px;border-radius:50%;
            display:flex;align-items:center;justify-content:center;
            color:#fff;font-weight:700;font-size:${size < 36 ? 0.75 : 0.85}rem;
            border:2px solid rgba(11,26,46,0.8);box-shadow:0 2px 6px rgba(0,0,0,0.4)
          ">${n}</div>`,
          className: '',
          iconSize: [size, size],
          iconAnchor: [size / 2, size / 2],
        });
      };
    }

    function makeMarkerIcon(color) {
      return L.divIcon({
        html: `<div style="
          width:12px;height:12px;border-radius:50%;
          background:${color};border:2px solid #0b1a2e;
          box-shadow:0 1px 4px rgba(0,0,0,0.5)
        "></div>`,
        className: '',
        iconSize: [12, 12],
        iconAnchor: [6, 6],
      });
    }

    function createClusters() {
      const types = Object.keys(TYPE_COLORS);
      types.forEach(type => {
        const color = TYPE_COLORS[type];
        mapClusters[type] = L.markerClusterGroup({
          maxClusterRadius: 55,
          showCoverageOnHover: false,
          iconCreateFunction: makeClusterIcon(color),
        });
        leafletMap.addLayer(mapClusters[type]);
      });
    }

    // ── Init carte ────────────────────────────────────────────
    function initMap() {
      leafletMap = L.map('radar-map', {
        center: [46.6, 2.3],
        zoom: 6,
        zoomControl: true,
      });

      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© <a href="https://openstreetmap.org">OpenStreetMap</a>',
        maxZoom: 19,
      }).addTo(leafletMap);

      createClusters();
      // Dark filter appliqué via CSS
    }

    // ── Overlay info centré sur la carte ────────────────────
    let _mapInfoTimer = null;
    function showMapInfo(icon, text, type = 'info', duration = 3500) {
      const overlay = document.getElementById('map-info-overlay');
      const iconEl  = document.getElementById('map-info-icon');
      const textEl  = document.getElementById('map-info-text');
      if (!overlay) return;
      iconEl.textContent = icon;
      textEl.textContent = text;
      overlay.className = `map-info-overlay map-info-overlay--${type}`;
      clearTimeout(_mapInfoTimer);
      if (duration > 0) {
        _mapInfoTimer = setTimeout(() => {
          overlay.classList.add('map-info-overlay--hidden');
        }, duration);
      }
    }
    // ── Géolocalisation ───────────────────────────────────────
    function locateMe() {
      if (!navigator.geolocation) {
        showMapInfo('❌', 'Géolocalisation non supportée par ce navigateur', 'error', 4000);
        return;
      }
      showMapInfo('📡', 'Localisation en cours…', 'loading', 0);
      navigator.geolocation.getCurrentPosition(
        pos => {
          currentLat = pos.coords.latitude;
          currentLon = pos.coords.longitude;
          // Indiquer visuellement que GPS est la source active
          const lbl = document.getElementById('city-trigger-label');
          if (lbl) lbl.textContent = '📍 Ma position GPS';
          document.getElementById('btn-locate')?.classList.add('rd-btn--gps-active');
          showMapInfo('✅', 'Position GPS acquise', 'success', 3000);
          search();
        },
        err => {
          const msgs = {
            1: 'Permission refusée — activez la géolocalisation',
            2: 'Position indisponible',
            3: 'Délai dépassé',
          };
          showMapInfo('🔒', msgs[err.code] || 'Erreur de géolocalisation', 'error', 5000);
        },
        { timeout: 15000, maximumAge: 300000, enableHighAccuracy: true }
      );
    }

    // ── Haversine ─────────────────────────────────────────────
    function haversine(lat1, lon1, lat2, lon2) {
      const R = 6371;
      const dLat = (lat2 - lat1) * Math.PI / 180;
      const dLon = (lon2 - lon1) * Math.PI / 180;
      const a =
        Math.sin(dLat / 2) ** 2 +
        Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *
        Math.sin(dLon / 2) ** 2;
      return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
    }

    // ── Sources de données ────────────────────────────────────

    async function fetchOverpass(lat, lon, radiusM, signal, nocache = false) {
      const radiusKm = Math.round(radiusM / 1000);
      const nc = nocache ? '&nocache=1' : '';
      const url = `/api/radar-proxy.php?type=overpass&lat=${lat}&lon=${lon}&radius=${radiusKm}&mode=${currentMode}${nc}`;
      const resp = await fetch(url, { signal: signal ?? AbortSignal.timeout(25000) });
      if (!resp.ok) {
        const err = new Error(`Overpass HTTP ${resp.status}`);
        err.name = 'OverpassUnavailable';
        throw err;
      }
      const data = await resp.json();

      return (data.elements || []).map(el => {
        const elLat = el.lat ?? el.center?.lat;
        const elLon = el.lon ?? el.center?.lon;
        if (!elLat || !elLon) return null;

        const tags = el.tags || {};
        let type = 'autre';
        if (tags.tourism === 'camp_site')                                                  type = 'camping';
        else if (tags.amenity === 'coworking_space' || tags.office === 'coworking')        type = 'coworking';
        else if (tags.amenity === 'shower')                                                type = 'douche';
        else if (tags.amenity === 'drinking_water' || tags.man_made === 'water_tap')       type = 'fontaine';
        else if (tags.leisure === 'swimming_pool' || tags.sport === 'swimming')            type = 'piscine';
        else if (tags.amenity === 'shelter' || tags.tourism === 'wilderness_hut' || tags.tourism === 'alpine_hut') type = 'abri';

        const adresseParts = [
          tags['addr:housenumber'],
          tags['addr:street'],
          tags['addr:city'],
        ].filter(Boolean);

        const extra = {};
        if (type === 'piscine') {
          extra.access = tags.access || 'public';
          extra.fee    = tags.fee || null;
        }
        if (type === 'abri') {
          extra.capacity = tags.capacity || null;
        }

        return {
          id: `osm-${el.id}`,
          nom: tags.name || labelForType(type),
          type,
          lat: elLat,
          lon: elLon,
          adresse: adresseParts.join(' ') || null,
          phone:   tags.phone || tags['contact:phone'] || null,
          website: tags.website || tags['contact:website'] || null,
          source: 'OpenStreetMap',
          ...extra,
        };
      }).filter(r => r.type !== 'autre');
    }

    async function fetchCampingsGouv(lat, lon, radiusKm, signal, nocache = false) {
      const nc = nocache ? '&nocache=1' : '';
      const url = `/api/radar-proxy.php?type=campings&lat=${lat}&lon=${lon}&radius=${radiusKm}${nc}`;
      const resp = await fetch(url, { signal: signal ?? AbortSignal.timeout(15000) });
      if (!resp.ok) throw new Error(`Campings proxy HTTP ${resp.status}`);
      const data = await resp.json();

      return (data.results || [])
        .filter(r => {
          const g = r.coordonnees_geo;
          if (!g) return false;
          // OpenDataSoft v2 retourne {lat, lon} ou GeoJSON {coordinates:[lon,lat]}
          return (g.lat && g.lon) || (Array.isArray(g.coordinates) && g.coordinates.length === 2);
        })
        .map(r => {
          const g = r.coordonnees_geo;
          const coords = Array.isArray(g.coordinates) ? g.coordinates : [];
          const lat = g.lat !== undefined ? g.lat : coords[1];
          const lon = g.lon !== undefined ? g.lon : coords[0];
          return {
            id: `atout-${r.nom_commercial}-${r.code_postal}`,
            nom: r.nom_commercial || 'Camping',
            type: 'camping',
            lat: parseFloat(lat),
            lon: parseFloat(lon),
            adresse: [r.adresse, r.code_postal, r.commune].filter(Boolean).join(' '),
            classement: r.classement || null,
            nbEmplacements: r.nombre_emplacements || null,
            source: 'Atout France',
          };
        });
    }

    function getCoworkingsNearby(lat, lon, radiusKm) {
      return COWORKINGS_STATIC
        .filter(c => haversine(lat, lon, c.lat, c.lon) <= radiusKm)
        .map(c => ({
          id: `cw-${c.ville}-${c.nom}`.replace(/\s+/g, '-').toLowerCase(),
          nom: c.nom,
          type: 'coworking',
          lat: c.lat,
          lon: c.lon,
          adresse: c.adresse,
          source: 'Données statiques',
        }));
    }

    // ── Liens utiles ──────────────────────────────────────────
    const LIEN_CAT = {
      officiel:   { label: 'Organisateurs officiels', icon: 'fa-calendar-alt' },
      veille:     { label: 'Plateformes de veille',   icon: 'fa-globe'        },
      agregateur: { label: 'Agrégateurs',             icon: 'fa-newspaper'    },
    };

    function renderLiensUtiles() {
      const wrap = document.getElementById('liens-utiles-content');
      if (!wrap) return;
      const liens = adminProData.liens || [];

      if (liens.length === 0) {
        wrap.innerHTML = `<p class="lt-empty"><i class="fas fa-link"></i> Aucun lien configuré — ajoutez des liens dans l'admin (<strong>Liens utiles</strong>).</p>`;
        return;
      }

      const groups = {};
      liens.forEach(l => {
        const cat = l.categorie || 'autre';
        if (!groups[cat]) groups[cat] = [];
        groups[cat].push(l);
      });

      const catOrder = ['officiel', 'veille', 'agregateur'];
      Object.keys(groups).forEach(c => { if (!catOrder.includes(c)) catOrder.push(c); });

      let html = '';
      catOrder.forEach(cat => {
        if (!groups[cat] || groups[cat].length === 0) return;
        const cfg = LIEN_CAT[cat] || { label: cat, icon: 'fa-link' };
        html += `<div class="lu-section">
          <h4 class="lu-section-title"><i class="fas ${cfg.icon}"></i>${cfg.label}</h4>
          <div class="rd-link-table-wrap">
          <table class="lt-table">
            <thead><tr>
              <th>Nom</th><th>Date</th><th>Lieu</th><th>Lien</th><th>Description</th>
            </tr></thead>
            <tbody>`;
        groups[cat].forEach(l => {
          const urlDisplay = (l.url || '').replace(/^https?:\/\//, '');
          const urlHtml = l.url
            ? `<a href="${escHtml(l.url)}" target="_blank" rel="noopener" class="lt-link">${escHtml(urlDisplay)}<i class="fas fa-arrow-up-right-from-square"></i></a>`
            : '—';
          html += `<tr>
            <td class="lt-nom">${escHtml(l.nom || '')}</td>
            <td class="lt-date">${escHtml(l.date || '—')}</td>
            <td class="lt-lieu">${escHtml(l.lieu || '—')}</td>
            <td>${urlHtml}</td>
            <td class="lt-lieu lu-desc">${escHtml(l.interet || '')}</td>
          </tr>`;
        });
        html += `</tbody></table></div></div>`;
      });

      wrap.innerHTML = html;
    }

    // ── Recherche principale ──────────────────────────────────
    async function search(forceRefresh = false) {
      if (currentLat === null || currentLon === null) return;

      // Active les boutons dès qu'une position est disponible
      const btnRefresh   = document.getElementById('btn-refresh');
      const btnClearCache = document.getElementById('btn-clear-cache');
      if (btnRefresh)    btnRefresh.disabled = false;
      if (btnClearCache) btnClearCache.disabled = false;

      // Clé de cache : position arrondie 2 décimales (~1 km) + rayon + mode
      const cacheKey = `${currentLat.toFixed(2)},${currentLon.toFixed(2)},${currentRadius},${currentMode}`;
      const now = Date.now();

      // forceRefresh : vide l'entrée mémoire pour cette clé + passera nocache=1 au PHP
      if (forceRefresh) {
        searchCache.delete(cacheKey);
        lastSearchKey  = null;
        lastSearchTime = 0;
      }

      // Throttle — même recherche < 20 s : servir le cache mémoire sans appel réseau
      if (!forceRefresh && cacheKey === lastSearchKey && (now - lastSearchTime) < SEARCH_THROTTLE_MS && searchCache.has(cacheKey)) {
        allResults = searchCache.get(cacheKey);
        renderResults();
        renderMapMarkers();
        return;
      }

      // Annuler toute recherche en cours
      if (searchAbortController) searchAbortController.abort();
      searchAbortController = new AbortController();
      const signal = searchAbortController.signal;

      showLoading(true);
      clearMapMarkers();
      ['results-list', 'list-camping', 'list-coworking', 'list-piscine', 'list-fontaine', 'list-douche', 'list-abri'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.innerHTML = skeletonHTML(3);
      });
      document.getElementById('results-count').textContent = '⏳ Interrogation des sources…';

      // En dev : utiliser les données mock pour avoir un rendu immédiat
      if (IS_DEV) {
        await new Promise(r => setTimeout(r, 400));
        allResults = MOCK_RESULTS.map(r => ({
          ...r,
          dist: haversine(currentLat, currentLon, r.lat, r.lon)
        })).filter(r => r.dist <= currentRadius).sort((a, b) => a.dist - b.dist);
        renderResults();
        renderMapMarkers();
        showLoading(false);
        const n = allResults.filter(r => activeFilters.has(r.type)).length;
        showMapInfo('🧪', `DEV — ${n} lieu${n !== 1 ? 'x' : ''} simulé${n !== 1 ? 's' : ''}`, 'info', 3000);
        return;
      }

      // Rayon Overpass plafonné à OVERPASS_MAX_KM pour éviter les timeouts
      const radiusM = Math.min(currentRadius, OVERPASS_MAX_KM) * 1000;
      const isCyclo = currentMode === 'cyclo';

      // Appels conditionnels selon le mode — évite les timeouts inutiles
      const promises = [
        fetchOverpass(currentLat, currentLon, radiusM, signal, forceRefresh),
        isCyclo ? fetchCampingsGouv(currentLat, currentLon, currentRadius, signal, forceRefresh) : Promise.resolve([]),
        isCyclo ? Promise.resolve([]) : Promise.resolve(getCoworkingsNearby(currentLat, currentLon, currentRadius)),
      ];

      const [resOverpass, resCampings, resCw] = await Promise.allSettled(promises);

      // Requête annulée — une nouvelle recherche a déjà démarré
      if (signal.aborted) return;

      const overpassFailed = resOverpass.status === 'rejected' && resOverpass.reason?.name === 'OverpassUnavailable';
      const campingsFailed = resCampings.status === 'rejected' && resCampings.reason?.name !== 'AbortError';
      // console.warn uniquement pour les erreurs inattendues (pas service unavailable, pas abort)
      if (resOverpass.status === 'rejected' && !overpassFailed && resOverpass.reason?.name !== 'AbortError') {
        console.warn('Overpass:', resOverpass.reason);
      }
      if (campingsFailed) console.warn('Atout France:', resCampings.reason);

      const raw = [
        ...(resOverpass.status === 'fulfilled' ? resOverpass.value : []),
        ...(resCampings.status === 'fulfilled' ? resCampings.value : []),
        ...(resCw.status       === 'fulfilled' ? resCw.value       : []),
      ];

      // Dédupliquer par id, calculer distance, filtrer rayon, trier
      const byId = new Map();
      for (const item of raw) {
        if (!byId.has(item.id)) byId.set(item.id, item);
      }
      allResults = [...byId.values()]
        .map(r => ({
          ...r,
          dist: (r.lat && r.lon) ? haversine(currentLat, currentLon, r.lat, r.lon) : null,
        }))
        .filter(r => r.dist !== null && r.dist <= currentRadius)
        .sort((a, b) => {
          if (a.dist === null && b.dist === null) return 0;
          if (a.dist === null) return 1;
          if (b.dist === null) return -1;
          return a.dist - b.dist;
        });

      // Stocker en cache mémoire — uniquement si pas d'erreur API
      // (une erreur API ne doit pas bloquer le retry immédiat via le combo)
      const hadApiError = overpassFailed || campingsFailed;
      if (!hadApiError) {
        if (searchCache.size >= 30) searchCache.delete(searchCache.keys().next().value);
        searchCache.set(cacheKey, allResults);
        lastSearchKey  = cacheKey;
        lastSearchTime = Date.now();
      }

      renderResults();
      renderMapMarkers();
      showLoading(false);

      const n = allResults.filter(r => activeFilters.has(r.type)).length;
      const hadAnyError = overpassFailed || campingsFailed;

      if (hadAnyError) {
        const msg = overpassFailed && campingsFailed
          ? 'Sources indisponibles — résultats partiels. Cliquez sur "Vider cache" pour réessayer.'
          : overpassFailed
            ? 'OSM indisponible — résultats partiels. Cliquez sur "Vider cache" pour réessayer.'
            : 'Atout France indisponible — campings partiels.';
        showMapInfo('⚠️', msg, 'warn', 0); // 0 = persistent jusqu'à prochaine action
        showApiErrorBanner(msg);
      } else {
        hideApiErrorBanner();
        showMapInfo('🎯', `${n} lieu${n !== 1 ? 'x' : ''} trouvé${n !== 1 ? 's' : ''} — rayon ${currentRadius} km`, 'success', 3500);
        if (forceRefresh) showMapInfo('✅', 'Cache vidé — données fraîches chargées', 'success', 3000);
      }
    }

    // ── Banner erreur API ─────────────────────────────────────
    function showApiErrorBanner(msg) {
      let banner = document.getElementById('rd-api-error-banner');
      if (!banner) {
        banner = document.createElement('div');
        banner.id = 'rd-api-error-banner';
        banner.className = 'rd-api-error-banner';
        const panel = document.getElementById('rd-panel-bottom');
        if (panel) panel.insertAdjacentElement('beforebegin', banner);
      }
      banner.innerHTML = `<i class="fas fa-triangle-exclamation"></i> ${msg}`;
      banner.classList.remove('rd-api-error-banner--hidden');
    }

    function hideApiErrorBanner() {
      const banner = document.getElementById('rd-api-error-banner');
      if (banner) banner.classList.add('rd-api-error-banner--hidden');
    }

    // ── Rendu résultats ───────────────────────────────────────
    function renderItemHTML(r) {
      const hasGeo = r.lat && r.lon;
      const mapsUrl = hasGeo ? `https://www.google.com/maps/dir/?api=1&destination=${r.lat},${r.lon}&travelmode=bicycling` : null;
      const distLabel = r.dist !== null ? `${r.dist.toFixed(1)} km` : '';
      const color = TYPE_COLORS[r.type] || '#888';

      return `
        <li class="result-item" data-id="${r.id}" data-type="${r.type}">
          <div class="result-left">
            <span class="type-dot" style="background:${color}"></span>
          </div>
          <div class="result-body">
            <div class="result-header-row">
              <span class="result-nom">${escHtml(r.nom)}</span>
              ${distLabel ? `<span class="result-dist">${distLabel}</span>` : ''}
            </div>
            ${r.adresse ? `<div class="result-adresse"><i class="fas fa-map-pin"></i> ${escHtml(r.adresse)}</div>` : ''}
            ${r.classement ? `<div class="result-meta"><i class="fas fa-star"></i> ${escHtml(String(r.classement))}</div>` : ''}
            ${r.type === 'piscine' && r.fee === 'yes' ? `<div class="result-meta"><i class="fas fa-ticket"></i> Payant</div>` : ''}
            ${r.type === 'piscine' && r.fee === 'no'  ? `<div class="result-meta"><i class="fas fa-ticket"></i> Gratuit</div>` : ''}
            ${r.type === 'abri' && r.capacity ? `<div class="result-meta"><i class="fas fa-person"></i> ${escHtml(r.capacity)} pers.</div>` : ''}
            ${r.source ? `<div class="result-source">Source : ${escHtml(r.source)}</div>` : ''}
            <div class="result-actions">
              ${mapsUrl ? `<a href="${mapsUrl}" target="_blank" rel="noopener" class="result-btn btn-go"><i class="fas fa-route"></i> Itinéraire</a>` : ''}
            </div>
          </div>
        </li>`;
    }

    function renderResults() {
      const countEl = document.getElementById('results-count');
      const filtered = allResults.filter(r => activeFilters.has(r.type));

      countEl.textContent = `${filtered.length} résultat${filtered.length !== 1 ? 's' : ''} — rayon ${currentRadius} km`;

      const types = ['camping', 'coworking', 'piscine', 'fontaine', 'douche', 'abri'];
      types.forEach(type => {
        const items = allResults.filter(r => r.type === type);
        const listEl = document.getElementById('list-' + type);
        const countBadge = document.getElementById('count-' + type);
        if (countBadge) countBadge.textContent = items.length;
        if (listEl) {
          listEl.innerHTML = items.length === 0
            ? '<li class="no-results"><i class="fas fa-search"></i> Aucun résultat dans cette catégorie.</li>'
            : items.map(r => renderItemHTML(r)).join('');
        }
      });

      const allList = document.getElementById('results-list');
      allList.innerHTML = filtered.length === 0
        ? '<li class="no-results"><i class="fas fa-search"></i> Aucun résultat. Sélectionnez une étape ou géolocalisez-vous.</li>'
        : filtered.map(r => renderItemHTML(r)).join('');
    }

    // ── Carte Leaflet ─────────────────────────────────────────
    function renderMapMarkers() {
      clearMapMarkers();
      if (!currentLat || !currentLon || !leafletMap) return;

      // Cercle rayon
      radiusCircle = L.circle([currentLat, currentLon], {
        radius: currentRadius * 1000,
        color: '#9a9245',
        weight: 1.5,
        dashArray: '6 4',
        fillColor: '#9a9245',
        fillOpacity: 0.04,
      }).addTo(leafletMap);

      // Marqueur position actuelle
      const posIcon = L.divIcon({
        className: 'pos-marker-wrap',
        html: '<div class="pos-marker">📍</div>',
        iconSize: [28, 28],
        iconAnchor: [14, 28],
      });
      posMarker = L.marker([currentLat, currentLon], { icon: posIcon })
        .bindPopup('<strong>Ma position</strong>')
        .addTo(leafletMap);

      // Marqueurs résultats — via cluster groups typés
      const filtered = allResults.filter(r => activeFilters.has(r.type) && r.lat && r.lon);
      for (const r of filtered) {
        const color  = TYPE_COLORS[r.type] || '#888';
        const distPopup = r.dist !== null ? `<br><em>${r.dist.toFixed(1)} km</em>` : '';
        const popup = `<strong style="font-size:0.85rem">${escHtml(r.nom)}</strong>${distPopup}${r.adresse ? `<br><small style="color:#a0b0c0">${escHtml(r.adresse)}</small>` : ''}`;
        const cluster = mapClusters[r.type];
        if (cluster) {
          cluster.addLayer(
            L.marker([r.lat, r.lon], { icon: makeMarkerIcon(color) }).bindPopup(popup)
          );
        }
      }

      // Recadrer
      const margin = currentRadius / 90;
      leafletMap.fitBounds([
        [currentLat - margin, currentLon - margin * 1.4],
        [currentLat + margin, currentLon + margin * 1.4],
      ], { padding: [24, 24] });
    }

    function clearMapMarkers() {
      if (posMarker) { posMarker.remove(); posMarker = null; }
      if (radiusCircle) { radiusCircle.remove(); radiusCircle = null; }
      Object.values(mapClusters).forEach(cg => cg.clearLayers());
    }


    // ── Utilitaires UI ────────────────────────────────────────
    function showLoading(on) {
      const dot    = document.getElementById('rd-dot');
      const loader = document.getElementById('loading-indicator');
      const idle   = document.getElementById('results-count');
      if (on) {
        dot.className = 'rd-dot loading';
        loader.classList.remove('hidden');
        idle.classList.add('hidden');
      } else {
        dot.className = 'rd-dot active';
        loader.classList.add('hidden');
        idle.classList.remove('hidden');
      }
    }

    function updateCatLabel() {
      document.querySelectorAll('.rd-cat-dropdown').forEach(dropdown => {
        const count = dropdown.querySelectorAll('.rd-cat-cb:checked').length;
        const label = dropdown.querySelector('.rd-cat-trigger-label');
        if (label) label.textContent = `${count} catégorie${count !== 1 ? 's' : ''}`;
      });
    }

    function toggleFilter(type, forceOn) {
      const chip = document.querySelector(`.chip[data-type="${type}"]`);
      const cb   = document.querySelector(`.rd-cat-cb[data-type="${type}"]`);
      const next = forceOn !== undefined ? forceOn : !activeFilters.has(type);
      if (next) { activeFilters.add(type); chip?.classList.add('active'); chip?.setAttribute('aria-pressed', 'true'); }
      else       { activeFilters.delete(type); chip?.classList.remove('active'); chip?.setAttribute('aria-pressed', 'false'); }
      if (cb && cb.checked !== next) cb.checked = next;
      updateCatLabel();
      renderResults();
      renderMapMarkers();
    }

    function labelForType(type) {
      return {
        camping:   'Camping',
        coworking: 'Coworking',
        piscine:   'Piscine / Baignade',
        fontaine:   'Point d\'eau',
        douche:     'Douche publique',
        abri:       'Abri / Refuge',
      }[type] || type;
    }

    function escHtml(str) {
      return String(str ?? '').replace(/[&<>"']/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    }

    function skeletonHTML(n) {
      return Array.from({ length: n }, () =>
        '<li class="skeleton-item"><div class="skel-line skel-w70"></div><div class="skel-line skel-w45"></div></li>'
      ).join('');
    }

    function hintHTML(mode) {
      const m = mode || currentMode || 'pro';
      const modeDesc = m === 'cyclo'
        ? '<strong>Cyclo</strong> — Campings · Piscines · Points d\'eau · Abris'
        : '<strong>Pro</strong> — Coworkings · Liens utiles';
      return `<li class="rd-hint">
        <i class="fas fa-crosshairs"></i>
        <strong>Radar Terrain</strong>
        <ol class="rd-hint-steps">
          <li><span class="rd-hint-num">①</span> <strong>Position</strong> — Choisissez une ville dans le menu ou cliquez sur <em>📍 Je suis ici</em></li>
          <li><span class="rd-hint-num">②</span> <strong>Mode</strong> — ${modeDesc}</li>
          <li><span class="rd-hint-num">③</span> <strong>Filtres</strong> — Affinez par catégorie via le menu <em>Catégories</em> ou les chips sur la carte</li>
        </ol>
      </li>`;
    }

    // ── Tabs switching ────────────────────────────────────────
    function switchTab(tabName) {
      document.querySelectorAll('.rd-tab').forEach(t => {
        t.classList.toggle('rd-tab--active', t.dataset.tab === tabName);
        t.setAttribute('aria-selected', t.dataset.tab === tabName ? 'true' : 'false');
      });
      document.querySelectorAll('.rd-tab-content').forEach(c => {
        c.classList.toggle('rd-tab-content--active', c.id === 'tab-' + tabName);
      });
      // Refresh map when switching back to carte tab
      if (tabName === 'carte' && leafletMap) {
        setTimeout(() => leafletMap.invalidateSize(), 100);
      }
      // Rendre les liens utiles à chaque accès (données légères)
      if (tabName === 'liens-utiles') {
        renderLiensUtiles();
      }
    }

    // ── Boot ──────────────────────────────────────────────────
    document.addEventListener('DOMContentLoaded', async () => {
      await loadAdminProData();
      initMap();

      // Tab switching
      document.querySelectorAll('.rd-tab').forEach(tab => {
        tab.addEventListener('click', () => switchTab(tab.dataset.tab));
      });

      // En dev : charger automatiquement les mocks sur Fontenay-lès-Briis
      if (IS_DEV) {
        document.getElementById('results-list').innerHTML = hintHTML();
        currentLat = 48.638;
        currentLon = 2.094;
        // Mettre à jour le label position et l'état du bouton GPS (cohérence avec prod)
        const devLbl = document.getElementById('city-trigger-label');
        if (devLbl) devLbl.textContent = '🧪 Fontenay-lès-Briis';
        document.getElementById('btn-locate')?.classList.add('rd-btn--gps-active');
        showMapInfo('🧪', 'Mode Dev — données mock activées', 'info', 3000);
        setTimeout(() => search(), 300);
      } else {
        document.getElementById('results-list').innerHTML = hintHTML();
      }

      // Bouton géolocalisation
      document.getElementById('btn-locate').addEventListener('click', locateMe);

      // Bouton Actualiser — vide cache JS + relance (conserve cache PHP)
      document.getElementById('btn-refresh').addEventListener('click', () => {
        if (currentLat === null || currentLon === null) return;
        search(false); // bypass JS cache via throttle reset mais pas PHP cache
      });

      // Bouton Vider cache — vide cache JS + cache PHP + relance depuis zéro
      document.getElementById('btn-clear-cache').addEventListener('click', async () => {
        if (currentLat === null || currentLon === null) return;
        const btn = document.getElementById('btn-clear-cache');
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Purge…';
        hideApiErrorBanner();
        // Vide le cache JS complet
        searchCache.clear();
        lastSearchKey  = null;
        lastSearchTime = 0;
        // Relance avec nocache=1 → bypass PHP cache fichier
        await search(true);
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-trash-can-arrow-up"></i> Vider cache';
      });






      // Sélecteur d'étape
      // Dropdown villes Data/IA
      const cityDropdown = document.getElementById('city-dropdown');
      const cityTrigger  = document.getElementById('city-trigger');
      const cityPanel    = document.getElementById('city-panel');
      const cityLabel    = document.getElementById('city-trigger-label');

      cityTrigger.addEventListener('click', (e) => {
        e.stopPropagation();
        const open = cityDropdown.getAttribute('aria-expanded') === 'true';
        cityDropdown.setAttribute('aria-expanded', String(!open));
        cityPanel.classList.toggle('rd-city-panel--open', !open);
      });

      cityPanel.querySelectorAll('.rd-city-item').forEach(btn => {
        btn.addEventListener('click', () => {
          const lat = parseFloat(btn.dataset.lat);
          const lon = parseFloat(btn.dataset.lon);
          const label = btn.textContent.trim();
          currentLat = lat;
          currentLon = lon;
          cityLabel.textContent = label;
          // Désactiver l'état GPS du bouton "Je suis ici"
          document.getElementById('btn-locate')?.classList.remove('rd-btn--gps-active');
          cityDropdown.setAttribute('aria-expanded', 'false');
          cityPanel.classList.remove('rd-city-panel--open');
          showMapInfo('🏙️', label, 'info', 2500);
          search();
        });
      });

      document.addEventListener('click', e => {
        if (!cityDropdown.contains(e.target)) {
          cityDropdown.setAttribute('aria-expanded', 'false');
          cityPanel.classList.remove('rd-city-panel--open');
        }
      });

      // Slider rayon
      const slider = document.getElementById('radius-slider');
      slider.addEventListener('input', () => {
        currentRadius = parseInt(slider.value);
        document.getElementById('radius-val').textContent = currentRadius;
      });
      slider.addEventListener('change', () => {
        if (currentLat !== null) search();
      });

      // Chips filtres
      document.querySelectorAll('.chip').forEach(chip => {
        chip.addEventListener('click', () => toggleFilter(chip.dataset.type));
      });

      // Combobox catégories — init générique (pro + cyclo)
      document.querySelectorAll('.rd-cat-dropdown').forEach(dropdown => {
        const trigger = dropdown.querySelector('.rd-cat-trigger');
        const panel   = dropdown.querySelector('.rd-cat-panel');
        const allCb   = panel.querySelector('.rd-cat-cb-all');
        const itemCbs = Array.from(panel.querySelectorAll('.rd-cat-cb'));

        function syncAllCheckbox() {
          if (!allCb) return;
          const checkedCount = itemCbs.filter(c => c.checked).length;
          allCb.checked = checkedCount === itemCbs.length;
          allCb.indeterminate = checkedCount > 0 && checkedCount < itemCbs.length;
        }

        trigger.addEventListener('click', (e) => {
          e.stopPropagation();
          const open = dropdown.getAttribute('aria-expanded') === 'true';
          dropdown.setAttribute('aria-expanded', String(!open));
          panel.classList.toggle('rd-cat-panel--open', !open);
        });

        if (allCb) {
          allCb.addEventListener('change', () => {
            itemCbs.forEach(cb => {
              cb.checked = allCb.checked;
              toggleFilter(cb.dataset.type, allCb.checked);
            });
            setViewActive(null);
          });
        }

        itemCbs.forEach(cb => {
          cb.addEventListener('change', () => {
            toggleFilter(cb.dataset.type, cb.checked);
            syncAllCheckbox();
            setViewActive(null);
          });
        });
      });

      document.addEventListener('click', e => {
        document.querySelectorAll('.rd-cat-dropdown').forEach(dropdown => {
          if (!dropdown.contains(e.target)) {
            dropdown.setAttribute('aria-expanded', 'false');
            dropdown.querySelector('.rd-cat-panel')?.classList.remove('rd-cat-panel--open');
          }
        });
      });

      // ── Modes PRO / CYCLO ─────────────────────────────────
      const MODE_FILTERS = {
        pro:   ['coworking'],
        cyclo: ['camping', 'piscine', 'fontaine', 'douche', 'abri'],
      };
      const ALL_TYPES = ['camping', 'coworking', 'piscine', 'fontaine', 'douche', 'abri'];

      // Désactive visuellement tous les boutons de mode (filtres personnalisés)
      function setViewActive(view) {
        document.querySelectorAll('.rd-mode-btn').forEach(b => {
          b.classList.toggle('rd-mode-btn--active', b.dataset.mode === view);
        });
      }

      function applyMode(mode) {
        currentMode = mode;
        // 1. Filtres actifs
        const active = MODE_FILTERS[mode] || [];
        ALL_TYPES.forEach(t => toggleFilter(t, active.includes(t)));

        // 2. Boutons mode
        document.querySelectorAll('.rd-mode-btn').forEach(b => {
          b.classList.toggle('rd-mode-btn--active', b.dataset.mode === mode);
        });

        // 3. Panneaux de contrôles contextuels
        document.querySelectorAll('.rd-mode-controls').forEach(ctrl => {
          ctrl.classList.toggle('rd-mode-controls--hidden', ctrl.id !== `mode-ctrl-${mode}`);
        });

        // 4. Tabs — visibilité selon data-modes
        document.querySelectorAll('.rd-tab[data-modes]').forEach(tab => {
          const modes = tab.dataset.modes.split(',');
          tab.classList.toggle('rd-tab--mode-hidden', !modes.includes(mode));
        });

        // 5. Chips carte — cohérence avec les types actifs
        document.querySelectorAll('.chip[data-type]').forEach(chip => {
          chip.classList.toggle('chip--hidden', !active.includes(chip.dataset.type));
        });

        updateCatLabel();

        // 6. Hint dynamique — met à jour le guide ①②③ si aucune recherche n'a encore eu lieu
        const resultsList = document.getElementById('results-list');
        if (resultsList && resultsList.querySelector('.rd-hint')) {
          resultsList.innerHTML = hintHTML(mode);
        }

        // 7. Si le tab actif n'est plus disponible dans ce mode → retour sur Carte
        const currentTab = document.querySelector('.rd-tab--active');
        if (currentTab) {
          const modes = (currentTab.dataset.modes || '').split(',');
          if (!modes.includes(mode)) switchTab('carte');
        }

        // 7. Relancer la recherche — les sources de données diffèrent selon le mode
        if (currentLat !== null && currentLon !== null) {
          clearTimeout(modeChangeTimer);
          modeChangeTimer = setTimeout(() => search(), 300);
        }
      }

      document.querySelectorAll('.rd-mode-btn').forEach(btn => {
        btn.addEventListener('click', () => applyMode(btn.dataset.mode));
      });

      // Mode Pro actif au démarrage
      applyMode('pro');

    });

  })();
  </script>

  <style is:global>
