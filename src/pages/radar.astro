    // ── MarkerCluster helpers ─────────────────────────────────
    function makeClusterIcon(color) {
      return (cluster) => {
        const n = cluster.getChildCount();
        const size = n < 10 ? 30 : n < 100 ? 36 : 42;
        return L.divIcon({
          html: `<div style="
            background:${color};width:${size}px;height:${size}px;border-radius:50%;
            display:flex;align-items:center;justify-content:center;
            color:#fff;font-weight:700;font-size:${size < 36 ? 0.75 : 0.85}rem;
            border:2px solid rgba(11,26,46,0.8);box-shadow:0 2px 6px rgba(0,0,0,0.4)
          ">${n}</div>`,
          className: '',
          iconSize: [size, size],
          iconAnchor: [size / 2, size / 2],
        });
      };
    }

    function makeMarkerIcon(color) {
      return L.divIcon({
        html: `<div style="
          width:12px;height:12px;border-radius:50%;
          background:${color};border:2px solid #0b1a2e;
          box-shadow:0 1px 4px rgba(0,0,0,0.5)
        "></div>`,
        className: '',
        iconSize: [12, 12],
        iconAnchor: [6, 6],
      });
    }

    function createClusters() {
      const types = Object.keys(TYPE_COLORS);
      types.forEach(type => {
        const color = TYPE_COLORS[type];
        mapClusters[type] = L.markerClusterGroup({
          maxClusterRadius: 55,
          showCoverageOnHover: false,
          iconCreateFunction: makeClusterIcon(color),
        });
        leafletMap.addLayer(mapClusters[type]);
      });
    }

    // ── Init carte ────────────────────────────────────────────
