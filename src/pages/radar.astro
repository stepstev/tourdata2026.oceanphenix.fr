    // ── Overlay info centré sur la carte ────────────────────
    let _mapInfoTimer = null;
    function showMapInfo(icon, text, type = 'info', duration = 3500) {
      const overlay = document.getElementById('map-info-overlay');
      const iconEl  = document.getElementById('map-info-icon');
      const textEl  = document.getElementById('map-info-text');
      if (!overlay) return;
      iconEl.textContent = icon;
      textEl.textContent = text;
      overlay.className = `map-info-overlay map-info-overlay--${type}`;
      clearTimeout(_mapInfoTimer);
      if (duration > 0) {
        _mapInfoTimer = setTimeout(() => {
          overlay.classList.add('map-info-overlay--hidden');
        }, duration);
      }
    }
    // ── Géolocalisation ───────────────────────────────────────
    function locateMe() {
      if (!navigator.geolocation) {
        showMapInfo('❌', 'Géolocalisation non supportée par ce navigateur', 'error', 4000);
        return;
      }
      showMapInfo('📡', 'Localisation en cours…', 'loading', 0);
      navigator.geolocation.getCurrentPosition(
        pos => {
          currentLat = pos.coords.latitude;
          currentLon = pos.coords.longitude;
          showMapInfo('✅', `Position : ${currentLat.toFixed(4)}, ${currentLon.toFixed(4)}`, 'success', 3000);
          search();
        },
        err => {
          const msgs = {
            1: 'Permission refusée — activez la géolocalisation',
            2: 'Position indisponible',
            3: 'Délai dépassé',
          };
          showMapInfo('🔒', msgs[err.code] || 'Erreur de géolocalisation', 'error', 5000);
        },
        { timeout: 15000, maximumAge: 300000, enableHighAccuracy: true }
      );
    }

    // ── Haversine ─────────────────────────────────────────────
    function haversine(lat1, lon1, lat2, lon2) {
      const R = 6371;
      const dLat = (lat2 - lat1) * Math.PI / 180;
      const dLon = (lon2 - lon1) * Math.PI / 180;
      const a =
        Math.sin(dLat / 2) ** 2 +
        Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *
        Math.sin(dLon / 2) ** 2;
      return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
    }

    // ── Sources de données ────────────────────────────────────

    async function fetchOverpass(lat, lon, radiusM) {
      const query = `
        [out:json][timeout:25];
        (
          node["tourism"="camp_site"](around:${radiusM},${lat},${lon});
          way["tourism"="camp_site"](around:${radiusM},${lat},${lon});
          node["amenity"="coworking_space"](around:${radiusM},${lat},${lon});
          way["amenity"="coworking_space"](around:${radiusM},${lat},${lon});
        );
        out center;
      `;
      const resp = await fetch('https://overpass-api.de/api/interpreter', {
        method: 'POST',
        headers: { 'Content-Type': 'text/plain' },
        body: query,
        signal: AbortSignal.timeout(20000),
      });
      if (!resp.ok) throw new Error(`Overpass HTTP ${resp.status}`);
      const data = await resp.json();

      return (data.elements || []).map(el => {
        const elLat = el.lat ?? el.center?.lat;
        const elLon = el.lon ?? el.center?.lon;
        if (!elLat || !elLon) return null;

        let type = 'autre';
        if (el.tags?.tourism === 'camp_site') type = 'camping';
        else if (el.tags?.amenity === 'coworking_space') type = 'coworking';

        const adresseParts = [
          el.tags?.['addr:housenumber'],
          el.tags?.['addr:street'],
          el.tags?.['addr:city'],
        ].filter(Boolean);

        return {
          id: `osm-${el.id}`,
          nom: el.tags?.name || labelForType(type),
          type,
          lat: elLat,
          lon: elLon,
          adresse: adresseParts.join(' ') || null,
          phone: el.tags?.phone || el.tags?.['contact:phone'] || null,
          website: el.tags?.website || el.tags?.['contact:website'] || null,
          source: 'OpenStreetMap',
        };
      }).filter(Boolean);
    }

    async function fetchCampingsGouv(lat, lon, radiusKm) {
      const url = `/api/radar-proxy.php?type=campings&lat=${lat}&lon=${lon}&radius=${radiusKm}`;
      const resp = await fetch(url, { signal: AbortSignal.timeout(15000) });
      if (!resp.ok) throw new Error(`Campings proxy HTTP ${resp.status}`);
      const data = await resp.json();

      return (data.results || [])
        .filter(r => r.coordonnees_geo?.lat && r.coordonnees_geo?.lon)
        .map(r => ({
          id: `atout-${r.nom_commercial}-${r.code_postal}`,
          nom: r.nom_commercial || 'Camping',
          type: 'camping',
          lat: r.coordonnees_geo.lat,
          lon: r.coordonnees_geo.lon,
          adresse: [r.adresse, r.code_postal, r.commune].filter(Boolean).join(' '),
          classement: r.classement || null,
          nbEmplacements: r.nombre_emplacements || null,
          source: 'Atout France',
        }));
    }

    async function fetchEntreprises(lat, lon) {
      // 1. Code département via proxy (évite appel direct depuis mobile)
      const geoResp = await fetch(
        `/api/radar-proxy.php?type=commune&lat=${lat}&lon=${lon}`,
        { signal: AbortSignal.timeout(8000) }
      );
      if (!geoResp.ok) throw new Error(`Commune proxy HTTP ${geoResp.status}`);
      const geoData = await geoResp.json();
      const dept = geoData[0]?.codeDepartement;
      if (!dept) throw new Error('Département introuvable');

      // 2. Entreprises via proxy (le proxy gère les 5 codes NAF côté serveur)
      const entResp = await fetch(
        `/api/radar-proxy.php?type=entreprises&dept=${encodeURIComponent(dept)}`,
        { signal: AbortSignal.timeout(20000) }
      );
      if (!entResp.ok) throw new Error(`Entreprises proxy HTTP ${entResp.status}`);
      const entData = await entResp.json();

      if (entData._debug) console.debug('[Radar/entreprises]', entData._debug, `total brut: ${entData._count}`);

      const seen = new Set();
      const results = [];
      for (const e of (entData.results || [])) {
        if (!e.siren || seen.has(e.siren)) continue;
        seen.add(e.siren);
        const siege = e.siege;
        // GPS optionnel — on garde l'entreprise même sans coordonnées (affichée en liste, pas sur carte)
        const hasGeo = siege?.latitude && siege?.longitude;
        results.push({
          id: `siren-${e.siren}`,
          nom: e.nom_complet || 'Entreprise',
          type: 'entreprise',
          lat: hasGeo ? parseFloat(siege.latitude)  : null,
          lon: hasGeo ? parseFloat(siege.longitude) : null,
          adresse: siege ? [siege.adresse, siege.code_postal, siege.libelle_commune].filter(Boolean).join(' ') : '',
          source: 'INSEE SIRENE',
          siren: e.siren,
          naf: e.activite_principale,
          nafLabel: e.libelle_activite_principale_libelle_65 || e.activite_principale,
          effectif: e.tranche_effectif_salarie || null,
        });
      }
      return results;
    }

    function getCoworkingsNearby(lat, lon, radiusKm) {
      return COWORKINGS_STATIC
        .filter(c => haversine(lat, lon, c.lat, c.lon) <= radiusKm)
        .map(c => ({
          id: `cw-${c.ville}-${c.nom}`.replace(/\s+/g, '-').toLowerCase(),
          nom: c.nom,
          type: 'coworking',
          lat: c.lat,
          lon: c.lon,
          adresse: c.adresse,
          source: 'Données statiques',
        }));
    }

    async function fetchEvents(lat, lon, radiusKm) {
      const url = `/api/radar-proxy.php?type=events&lat=${lat}&lon=${lon}&radius=${radiusKm}`;
      const resp = await fetch(url, { signal: AbortSignal.timeout(15000) });
      if (!resp.ok) throw new Error(`Events HTTP ${resp.status}`);
      const data = await resp.json();
      if (data.error || !data.events) return [];
      return (data.events || []).map(e => {
        const loc = e.location || {};
        const title = e.title?.fr || e.title?.en || 'Événement';
        const timing = e.timings?.[0];
        const dateDebut = timing?.begin ? timing.begin.substring(0, 10) : null;
        const adresseParts = [loc.address, loc.postalCode, loc.city].filter(Boolean);
        return {
          id: `evt-${e.uid}`,
          nom: title,
          type: 'evenement',
          lat: loc.latitude ? parseFloat(loc.latitude) : null,
          lon: loc.longitude ? parseFloat(loc.longitude) : null,
          adresse: adresseParts.join(' ') || loc.name || null,
          source: 'OpenAgenda',
          dateDebut,
          url: e.links?.[0]?.link || null,
        };
      });
    }

    // ── Recherche principale ──────────────────────────────────
    async function search() {
      if (currentLat === null || currentLon === null) return;

      showLoading(true);
      clearMapMarkers();
      // Show skeletons in all lists
      ['results-list', 'list-camping', 'list-coworking', 'list-entreprise', 'list-evenement'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.innerHTML = skeletonHTML(3);
      });
      document.getElementById('results-count').textContent = '⏳ Interrogation des sources…';

      // En dev : utiliser les données mock pour avoir un rendu immédiat
      if (IS_DEV) {
        await new Promise(r => setTimeout(r, 400)); // Simule latence réseau
        allResults = MOCK_RESULTS.map(r => ({
          ...r,
          dist: haversine(currentLat, currentLon, r.lat, r.lon)
        })).filter(r => r.dist <= currentRadius).sort((a, b) => a.dist - b.dist);
        renderResults();
        renderMapMarkers();
        showLoading(false);
        const n = allResults.filter(r => activeFilters.has(r.type)).length;
        showMapInfo('🧪', `DEV — ${n} lieu${n !== 1 ? 'x' : ''} simulé${n !== 1 ? 's' : ''}`, 'info', 3000);
        return;
      }

      const radiusM = currentRadius * 1000;

      const [resOverpass, resCampings, resEntreprises, resCw, resEvents] = await Promise.allSettled([
        fetchOverpass(currentLat, currentLon, radiusM),
        fetchCampingsGouv(currentLat, currentLon, currentRadius),
        fetchEntreprises(currentLat, currentLon),
        Promise.resolve(getCoworkingsNearby(currentLat, currentLon, currentRadius)),
        fetchEvents(currentLat, currentLon, currentRadius),
      ]);

      // Log les erreurs silencieusement
      if (resOverpass.status    === 'rejected') console.warn('Overpass:', resOverpass.reason);
      if (resCampings.status    === 'rejected') console.warn('Atout France:', resCampings.reason);
      if (resEntreprises.status === 'rejected') console.warn('INSEE SIRENE:', resEntreprises.reason);
      if (resEvents.status      === 'rejected') console.warn('OpenAgenda:', resEvents.reason);

      const raw = [
        ...(resOverpass.status    === 'fulfilled' ? resOverpass.value    : []),
        ...(resCampings.status    === 'fulfilled' ? resCampings.value    : []),
        ...(resEntreprises.status === 'fulfilled' ? resEntreprises.value : []),
        ...(resCw.status          === 'fulfilled' ? resCw.value         : []),
        ...(resEvents.status      === 'fulfilled' ? resEvents.value      : []),
      ];

      // Dédupliquer par id, calculer distance, filtrer rayon, trier
      const byId = new Map();
      for (const item of raw) {
        if (!byId.has(item.id)) byId.set(item.id, item);
      }
      allResults = [...byId.values()]
        .map(r => ({
          ...r,
          dist: (r.lat && r.lon) ? haversine(currentLat, currentLon, r.lat, r.lon) : null,
        }))
        // Sans GPS : entreprises et événements toujours inclus ; autres types : filtrage par rayon
        .filter(r => r.dist === null ? (r.type === 'entreprise' || r.type === 'evenement') : r.dist <= currentRadius)
        .sort((a, b) => {
          if (a.dist === null && b.dist === null) return 0;
          if (a.dist === null) return 1;
          if (b.dist === null) return -1;
          return a.dist - b.dist;
        });

      renderResults();
      renderMapMarkers();
      showLoading(false);

      const n = allResults.filter(r => activeFilters.has(r.type)).length;
      showMapInfo('🎯', `${n} lieu${n !== 1 ? 'x' : ''} trouvé${n !== 1 ? 's' : ''} — rayon ${currentRadius} km`, 'success', 3500);
    }

    // ── Rendu résultats ───────────────────────────────────────
    function renderItemHTML(r) {
      const ficheBtn = r.type === 'entreprise' && r.siren
        ? `<a href="https://annuaire-entreprises.data.gouv.fr/entreprise/${encodeURIComponent(r.siren)}" target="_blank" rel="noopener" class="result-btn btn-fiche"><i class="fas fa-external-link-alt"></i> Fiche</a>`
        : '';
      const eventBtn = r.type === 'evenement' && r.url
        ? `<a href="${escHtml(r.url)}" target="_blank" rel="noopener" class="result-btn btn-event"><i class="fas fa-calendar-check"></i> Voir</a>`
        : '';
      const hasGeo = r.lat && r.lon;
      const mapsUrl = hasGeo ? `https://www.google.com/maps/dir/?api=1&destination=${r.lat},${r.lon}&travelmode=bicycling` : null;
      const distLabel = r.dist !== null ? `${r.dist.toFixed(1)} km` : '';
      const color = TYPE_COLORS[r.type] || '#888';
      const dateLabel = r.dateDebut ? new Date(r.dateDebut).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' }) : '';

      return `
        <li class="result-item" data-id="${r.id}" data-type="${r.type}">
          <div class="result-left">
            <span class="type-dot" style="background:${color}"></span>
          </div>
          <div class="result-body">
            <div class="result-header-row">
              <span class="result-nom">${escHtml(r.nom)}</span>
              ${distLabel ? `<span class="result-dist">${distLabel}</span>` : ''}
            </div>
            ${dateLabel ? `<div class="result-meta result-date"><i class="fas fa-calendar-days" style="color:#f43f5e"></i> ${dateLabel}</div>` : ''}
            ${r.adresse ? `<div class="result-adresse"><i class="fas fa-map-pin"></i> ${escHtml(r.adresse)}</div>` : ''}
            ${r.nafLabel ? `<div class="result-meta"><i class="fas fa-tag"></i> ${escHtml(r.nafLabel)}</div>` : ''}
            ${r.effectif ? `<div class="result-meta"><i class="fas fa-users"></i> ${escHtml(effectifLabel(r.effectif))}</div>` : ''}
            ${r.classement ? `<div class="result-meta"><i class="fas fa-star"></i> ${escHtml(String(r.classement))}</div>` : ''}
            ${r.source ? `<div class="result-source">Source : ${escHtml(r.source)}</div>` : ''}
            <div class="result-actions">
              ${mapsUrl ? `<a href="${mapsUrl}" target="_blank" rel="noopener" class="result-btn btn-go"><i class="fas fa-route"></i> Itinéraire</a>` : ''}
              ${ficheBtn}
              ${eventBtn}
            </div>
          </div>
        </li>`;
    }

    function effectifMatch(r) {
      if (r.type !== 'entreprise' || !minEffectifTranche) return true;
      if (!r.effectif) return false;
      return EFFECTIF_ORDER.indexOf(r.effectif) >= EFFECTIF_ORDER.indexOf(minEffectifTranche);
    }

    function renderResults() {
      const countEl = document.getElementById('results-count');
      const filtered = allResults.filter(r => activeFilters.has(r.type) && effectifMatch(r));

      countEl.textContent = `${filtered.length} résultat${filtered.length !== 1 ? 's' : ''} — rayon ${currentRadius} km`;

      const types = ['camping', 'coworking', 'entreprise', 'evenement'];
      types.forEach(type => {
        const items = allResults.filter(r => r.type === type && effectifMatch(r));
        const listEl = document.getElementById('list-' + type);
        const countBadge = document.getElementById('count-' + type);
        if (countBadge) countBadge.textContent = items.length;
        if (listEl) {
          listEl.innerHTML = items.length === 0
            ? '<li class="no-results"><i class="fas fa-search"></i> Aucun résultat dans cette catégorie.</li>'
            : items.map(r => renderItemHTML(r)).join('');
        }
      });

      const allList = document.getElementById('results-list');
      allList.innerHTML = filtered.length === 0
        ? '<li class="no-results"><i class="fas fa-search"></i> Aucun résultat. Sélectionnez une étape ou géolocalisez-vous.</li>'
        : filtered.map(r => renderItemHTML(r)).join('');
    }

    // ── Carte Leaflet ─────────────────────────────────────────
    function renderMapMarkers() {
      clearMapMarkers();
      if (!currentLat || !currentLon || !leafletMap) return;

      // Cercle rayon
      radiusCircle = L.circle([currentLat, currentLon], {
        radius: currentRadius * 1000,
        color: '#9a9245',
        weight: 1.5,
        dashArray: '6 4',
        fillColor: '#9a9245',
        fillOpacity: 0.04,
      }).addTo(leafletMap);

      // Marqueur position actuelle
      const posIcon = L.divIcon({
        className: 'pos-marker-wrap',
        html: '<div class="pos-marker">📍</div>',
        iconSize: [28, 28],
        iconAnchor: [14, 28],
      });
      const posM = L.marker([currentLat, currentLon], { icon: posIcon })
        .bindPopup('<strong>Ma position</strong>')
        .addTo(leafletMap);
      mapMarkers.push(posM);

      // Marqueurs résultats
      const filtered = allResults.filter(r => activeFilters.has(r.type) && r.lat && r.lon);
      for (const r of filtered) {
        const color = TYPE_COLORS[r.type] || '#888';
        const distPopup = r.dist !== null ? `<br><em>${r.dist.toFixed(1)} km</em>` : '';
        const m = L.circleMarker([r.lat, r.lon], {
          radius: 7,
          fillColor: color,
          color: '#0b1a2e',
          weight: 1.5,
          fillOpacity: 0.9,
        }).bindPopup(`
          <strong>${escHtml(r.nom)}</strong>${distPopup}
          ${r.adresse ? `<br><small>${escHtml(r.adresse)}</small>` : ''}
        `).addTo(leafletMap);
        mapMarkers.push(m);
      }

      // Recadrer
      const margin = currentRadius / 90;
      leafletMap.fitBounds([
        [currentLat - margin, currentLon - margin * 1.4],
        [currentLat + margin, currentLon + margin * 1.4],
      ], { padding: [24, 24] });
    }

    function clearMapMarkers() {
      mapMarkers.forEach(m => m.remove());
      mapMarkers = [];
      if (radiusCircle) { radiusCircle.remove(); radiusCircle = null; }
    }


    // ── Utilitaires UI ────────────────────────────────────────
    function showLoading(on) {
      const dot    = document.getElementById('rd-dot');
      const loader = document.getElementById('loading-indicator');
      const idle   = document.getElementById('results-count');
      if (on) {
        dot.className = 'rd-dot loading';
        loader.classList.remove('hidden');
        idle.classList.add('hidden');
      } else {
        dot.className = 'rd-dot active';
        loader.classList.add('hidden');
        idle.classList.remove('hidden');
      }
    }

    function updateCatLabel() {
      const count = document.querySelectorAll('.rd-cat-cb:checked').length;
      const el = document.getElementById('cat-trigger-label');
      if (el) el.textContent = `${count} catégorie${count !== 1 ? 's' : ''}`;
    }

    function toggleFilter(type, forceOn) {
      const chip = document.querySelector(`.chip[data-type="${type}"]`);
      const cb   = document.querySelector(`.rd-cat-cb[data-type="${type}"]`);
      const next = forceOn !== undefined ? forceOn : !activeFilters.has(type);
      if (next) { activeFilters.add(type); chip?.classList.add('active'); chip?.setAttribute('aria-pressed', 'true'); }
      else       { activeFilters.delete(type); chip?.classList.remove('active'); chip?.setAttribute('aria-pressed', 'false'); }
      if (cb && cb.checked !== next) cb.checked = next;
      updateCatLabel();
      renderResults();
      renderMapMarkers();
    }

    function labelForType(type) {
      return { camping: 'Camping', coworking: 'Coworking', entreprise: 'Entreprise', evenement: 'Événement' }[type] || type;
    }

    function escHtml(str) {
      return String(str ?? '').replace(/[&<>"']/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    }

    function skeletonHTML(n) {
      return Array.from({ length: n }, () =>
        '<li class="skeleton-item"><div class="skel-line skel-w70"></div><div class="skel-line skel-w45"></div></li>'
      ).join('');
    }

    function hintHTML() {
      return `<li class="rd-hint">
        <i class="fas fa-crosshairs"></i>
        <strong>Radar Terrain</strong>
        <span>Sélectionnez une étape dans le menu ou cliquez sur<br><em>📍 Je suis ici</em> pour lancer la recherche</span>
      </li>`;
    }

    // ── Tabs switching ────────────────────────────────────────
    function switchTab(tabName) {
      document.querySelectorAll('.rd-tab').forEach(t => {
        t.classList.toggle('rd-tab--active', t.dataset.tab === tabName);
        t.setAttribute('aria-selected', t.dataset.tab === tabName ? 'true' : 'false');
      });
      document.querySelectorAll('.rd-tab-content').forEach(c => {
        c.classList.toggle('rd-tab-content--active', c.id === 'tab-' + tabName);
      });
      // Refresh map when switching back to carte tab
      if (tabName === 'carte' && leafletMap) {
        setTimeout(() => leafletMap.invalidateSize(), 100);
      }
    }

    // ── Boot ──────────────────────────────────────────────────
    document.addEventListener('DOMContentLoaded', () => {
      initMap();

      // Tab switching
      document.querySelectorAll('.rd-tab').forEach(tab => {
        tab.addEventListener('click', () => switchTab(tab.dataset.tab));
      });

      // En dev : charger automatiquement les mocks sur Fontenay-lès-Briis
      if (IS_DEV) {
        document.getElementById('results-list').innerHTML = hintHTML();
        currentLat = 48.638;
        currentLon = 2.094;
        showMapInfo('🧪', 'Mode Dev — données mock activées', 'info', 3000);
        setTimeout(() => search(), 300);
      } else {
        document.getElementById('results-list').innerHTML = hintHTML();
      }

      // Bouton géolocalisation
      document.getElementById('btn-locate').addEventListener('click', locateMe);

      // Filtre effectif entreprises
      document.getElementById('effectif-select').addEventListener('change', e => {
        minEffectifTranche = e.target.value;
        renderResults();
      });


      // Sélecteur d'étape
      // Dropdown villes Data/IA
      const cityDropdown = document.getElementById('city-dropdown');
      const cityTrigger  = document.getElementById('city-trigger');
      const cityPanel    = document.getElementById('city-panel');
      const cityLabel    = document.getElementById('city-trigger-label');

      cityTrigger.addEventListener('click', (e) => {
        e.stopPropagation();
        const open = cityDropdown.getAttribute('aria-expanded') === 'true';
        cityDropdown.setAttribute('aria-expanded', String(!open));
        cityPanel.classList.toggle('rd-city-panel--open', !open);
      });

      cityPanel.querySelectorAll('.rd-city-item').forEach(btn => {
        btn.addEventListener('click', () => {
          const lat = parseFloat(btn.dataset.lat);
          const lon = parseFloat(btn.dataset.lon);
          const label = btn.textContent.trim();
          currentLat = lat;
          currentLon = lon;
          cityLabel.textContent = label;
          cityDropdown.setAttribute('aria-expanded', 'false');
          cityPanel.classList.remove('rd-city-panel--open');
          showMapInfo('🏙️', label, 'info', 2500);
          search();
        });
      });

      document.addEventListener('click', e => {
        if (!cityDropdown.contains(e.target)) {
          cityDropdown.setAttribute('aria-expanded', 'false');
          cityPanel.classList.remove('rd-city-panel--open');
        }
      });

      // Slider rayon
      const slider = document.getElementById('radius-slider');
      slider.addEventListener('input', () => {
        currentRadius = parseInt(slider.value);
        document.getElementById('radius-val').textContent = currentRadius;
      });
      slider.addEventListener('change', () => {
        if (currentLat !== null) search();
      });

      // Chips filtres
      document.querySelectorAll('.chip').forEach(chip => {
        chip.addEventListener('click', () => toggleFilter(chip.dataset.type));
      });

      // Combobox catégories
      const catDropdown = document.getElementById('cat-dropdown');
      const catTrigger  = document.getElementById('cat-trigger');
      const catPanel    = document.getElementById('cat-panel');

      catTrigger.addEventListener('click', (e) => {
        e.stopPropagation();
        const open = catDropdown.getAttribute('aria-expanded') === 'true';
        catDropdown.setAttribute('aria-expanded', String(!open));
        catPanel.classList.toggle('rd-cat-panel--open', !open);
      });

      catPanel.querySelectorAll('.rd-cat-cb').forEach(cb => {
        cb.addEventListener('change', () => {
          toggleFilter(cb.dataset.type, cb.checked);
          // Si l'utilisateur modifie manuellement → aucun preset actif
          setViewActive(null);
        });
      });

      document.addEventListener('click', e => {
        if (!catDropdown.contains(e.target)) {
          catDropdown.setAttribute('aria-expanded', 'false');
          catPanel.classList.remove('rd-cat-panel--open');
        }
      });

      // ── Toggle PRO / CYCLO ─────────────────────────────────
      const VIEWS = {
        pro:   ['coworking', 'entreprise', 'evenement'],
        cyclo: ['camping'],
      };
      const ALL_TYPES = ['camping', 'coworking', 'entreprise', 'evenement'];

      function setViewActive(view) {
        document.querySelectorAll('.rd-view-btn').forEach(b => {
          b.classList.toggle('rd-view-btn--active', b.dataset.view === view);
        });
      }

      function applyView(view) {
        const active = VIEWS[view] || [];
        ALL_TYPES.forEach(t => toggleFilter(t, active.includes(t)));
        setViewActive(view);
      }

      document.querySelectorAll('.rd-view-btn').forEach(btn => {
        btn.addEventListener('click', () => applyView(btn.dataset.view));
      });

      // Vue Pro active au démarrage
      applyView('pro');

    });

  })();
  </script>

