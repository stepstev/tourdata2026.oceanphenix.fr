---
// src/pages/radar.astro — Radar Terrain TourData 2026
// Localise en temps réel : campings, coworkings, entreprises data/IT, événements
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import CguModal from '../components/CguModal.astro';
import OceanBackground from '../components/OceanBackground.astro';
---

<BaseLayout
  title="Radar Terrain — Campings, Coworkings & Entreprises | TourData 2026"
  description="Localisez en temps réel autour de votre position : campings, coworkings, entreprises data/IT et événements IT/emploi. Outil terrain TourData 2026 — Stéphane Celton."
  lastModified="22/03/2026 12:00"
>
  <link slot="head" rel="stylesheet" href="/lib/leaflet.min.css" />
  <link slot="head" rel="stylesheet" href="/lib/MarkerCluster.css" />
  <link slot="head" rel="stylesheet" href="/lib/MarkerCluster.Default.css" />

  <OceanBackground />
  <Nav />

  <main class="radar-page main-content" id="radar-page">

    <!-- ══════════════════════════════════════════════════════ -->
    <!-- HERO — cohérent avec strava / terrain                 -->
    <!-- ══════════════════════════════════════════════════════ -->
    <section class="rd-hero">
      <div class="rd-hero-badge">
        <i class="fas fa-satellite-dish"></i> Outil Terrain — TourData 2026
      </div>
      <h2 class="page-title"><i class="fas fa-crosshairs page-title-icon"></i> Radar Terrain</h2>
      <p class="page-sub">Localisez en temps réel : coworkings, entreprises data/IT et événements IT/emploi autour de votre position — TourData 2026</p>
      <p class="rd-wip-notice"><i class="fas fa-triangle-exclamation"></i> En développement actif — données partielles</p>
    </section>

    <!-- ══════════════════════════════════════════════════════ -->
    <!-- CONTRÔLES — toolbar compacte                          -->
    <!-- ══════════════════════════════════════════════════════ -->
    <div class="rd-header">
      <div class="rd-steps-guide">
        <span class="rd-step"><span class="rd-step-num">1</span>Choisissez une position</span>
        <span class="rd-step-arrow">→</span>
        <span class="rd-step"><span class="rd-step-num">2</span>Sélectionnez le mode</span>
        <span class="rd-step-arrow">→</span>
        <span class="rd-step"><span class="rd-step-num">3</span>Consultez les résultats</span>
      </div>
      <div class="rd-toolbar">
        <!-- Dropdown custom villes Data/IA -->
        <div class="rd-city-dropdown" id="city-dropdown" role="combobox" aria-haspopup="listbox" aria-expanded="false" aria-controls="city-panel">
          <button class="rd-city-trigger" id="city-trigger" type="button" aria-label="Choisir une ville Data / IA">
            <i class="fas fa-map-location-dot rd-city-trigger-icon"></i>
            <span id="city-trigger-label">Ville Data / IA</span>
            <i class="fas fa-chevron-down rd-city-chevron"></i>
          </button>
          <div class="rd-city-panel" id="city-panel" role="listbox">

            <div class="rd-city-group">
              <div class="rd-city-group-label">Île-de-France</div>
              <button class="rd-city-item" data-lat="48.856" data-lon="2.352"><i class="fas fa-location-dot"></i> Paris</button>
              <button class="rd-city-item" data-lat="48.897" data-lon="2.088"><i class="fas fa-location-dot"></i> La Défense</button>
              <button class="rd-city-item" data-lat="48.759" data-lon="2.208"><i class="fas fa-location-dot"></i> Saclay / Paris-Sud</button>
              <button class="rd-city-item" data-lat="48.638" data-lon="2.094"><i class="fas fa-location-dot"></i> Fontenay-lès-Briis</button>
            </div>

            <div class="rd-city-group">
              <div class="rd-city-group-label">Auvergne-Rhône-Alpes</div>
              <button class="rd-city-item" data-lat="45.748" data-lon="4.847"><i class="fas fa-location-dot"></i> Lyon</button>
              <button class="rd-city-item" data-lat="45.188" data-lon="5.724"><i class="fas fa-location-dot"></i> Grenoble</button>
              <button class="rd-city-item" data-lat="45.439" data-lon="4.387"><i class="fas fa-location-dot"></i> Saint-Étienne</button>
              <button class="rd-city-item" data-lat="46.151" data-lon="6.867"><i class="fas fa-location-dot"></i> Annecy</button>
            </div>

            <div class="rd-city-group">
              <div class="rd-city-group-label">Occitanie</div>
              <button class="rd-city-item" data-lat="43.605" data-lon="1.444"><i class="fas fa-location-dot"></i> Toulouse</button>
              <button class="rd-city-item" data-lat="43.611" data-lon="3.877"><i class="fas fa-location-dot"></i> Montpellier</button>
            </div>

            <div class="rd-city-group">
              <div class="rd-city-group-label">Nouvelle-Aquitaine</div>
              <button class="rd-city-item" data-lat="44.837" data-lon="-0.579"><i class="fas fa-location-dot"></i> Bordeaux</button>
            </div>

            <div class="rd-city-group">
              <div class="rd-city-group-label">PACA</div>
              <button class="rd-city-item" data-lat="43.296" data-lon="5.381"><i class="fas fa-location-dot"></i> Marseille</button>
              <button class="rd-city-item" data-lat="43.430" data-lon="5.215"><i class="fas fa-location-dot"></i> Aix-en-Provence</button>
              <button class="rd-city-item" data-lat="43.710" data-lon="7.262"><i class="fas fa-location-dot"></i> Nice / Sophia Antipolis</button>
            </div>

            <div class="rd-city-group">
              <div class="rd-city-group-label">Pays de la Loire / Bretagne</div>
              <button class="rd-city-item" data-lat="47.218" data-lon="-1.553"><i class="fas fa-location-dot"></i> Nantes</button>
              <button class="rd-city-item" data-lat="48.117" data-lon="-1.677"><i class="fas fa-location-dot"></i> Rennes</button>
              <button class="rd-city-item" data-lat="48.390" data-lon="-4.486"><i class="fas fa-location-dot"></i> Brest</button>
            </div>

            <div class="rd-city-group">
              <div class="rd-city-group-label">Normandie</div>
              <button class="rd-city-item" data-lat="49.183" data-lon="-0.357"><i class="fas fa-location-dot"></i> Caen</button>
              <button class="rd-city-item" data-lat="49.443" data-lon="1.099"><i class="fas fa-location-dot"></i> Rouen</button>
            </div>

            <div class="rd-city-group">
              <div class="rd-city-group-label">Grand Est / Hauts-de-France</div>
              <button class="rd-city-item" data-lat="50.629" data-lon="3.057"><i class="fas fa-location-dot"></i> Lille</button>
              <button class="rd-city-item" data-lat="48.573" data-lon="7.752"><i class="fas fa-location-dot"></i> Strasbourg</button>
              <button class="rd-city-item" data-lat="49.119" data-lon="6.176"><i class="fas fa-location-dot"></i> Metz</button>
              <button class="rd-city-item" data-lat="48.692" data-lon="6.184"><i class="fas fa-location-dot"></i> Nancy</button>
            </div>

            <div class="rd-city-group">
              <div class="rd-city-group-label">Bourgogne / Centre-Val</div>
              <button class="rd-city-item" data-lat="47.322" data-lon="5.041"><i class="fas fa-location-dot"></i> Dijon</button>
              <button class="rd-city-item" data-lat="47.902" data-lon="1.909"><i class="fas fa-location-dot"></i> Orléans</button>
              <button class="rd-city-item" data-lat="47.394" data-lon="0.691"><i class="fas fa-location-dot"></i> Tours</button>
            </div>

          </div>
        </div>
        <button id="btn-locate" class="rd-btn rd-btn--primary" aria-label="Géolocaliser ma position">
          <i class="fas fa-location-dot"></i> Je suis ici
        </button>
        <button id="btn-refresh" class="rd-btn rd-btn--secondary" aria-label="Actualiser les résultats" disabled>
          <i class="fas fa-rotate-right"></i> Actualiser
        </button>
        <div class="rd-toolbar-sep" aria-hidden="true"></div>
        <div class="rd-radius-inline">
          <span class="rd-radius-label"><i class="fas fa-circle-dot"></i> <strong id="radius-val">10</strong> km</span>
          <input type="range" id="radius-slider" min="2" max="25" value="10" step="1"
            aria-label="Rayon de recherche" />
        </div>
        <div class="rd-status">
          <span class="rd-dot" id="rd-dot"></span>
          <span id="loading-indicator" class="rd-status-label hidden" aria-live="polite">Chargement…</span>
          <span id="results-count" class="rd-status-label rd-status-idle">Sélectionnez une étape</span>
        </div>

      </div>
    </div>

    <!-- ══════════════════════════════════════════════════════ -->
    <!-- MODEBAR — Sélecteur de mode + contrôles contextuels   -->
    <!-- ══════════════════════════════════════════════════════ -->
    <div class="rd-modebar">

      <!-- Sélecteur PRO / CYCLO -->
      <div class="rd-mode-toggle" role="group" aria-label="Mode de vue">
        <button class="rd-mode-btn rd-mode-btn--active" id="btn-mode-pro" data-mode="pro" type="button">
          <i class="fas fa-briefcase rd-mode-btn-icon"></i>
          <div class="rd-mode-btn-body">
            <span class="rd-mode-btn-title"><span class="rd-mode-badge">2a</span> Pro</span>
            <span class="rd-mode-btn-sub">Coworkings · Entreprises · Salons</span>
          </div>
        </button>
        <button class="rd-mode-btn" id="btn-mode-cyclo" data-mode="cyclo" type="button">
          <i class="fas fa-bicycle rd-mode-btn-icon"></i>
          <div class="rd-mode-btn-body">
            <span class="rd-mode-btn-title"><span class="rd-mode-badge">2b</span> Cyclo</span>
            <span class="rd-mode-btn-sub">Campings · Eau · Abris · Piscines</span>
          </div>
        </button>
      </div>
      <div class="rd-mode-hint" id="rd-mode-hint">
        <i class="fas fa-briefcase fa-fw"></i>
        <span id="rd-mode-hint-text">Mode <strong>Pro</strong> — coworkings et espaces de travail, entreprises data/IT du département, salons &amp; forums emploi à venir.</span>
      </div>

      <div class="rd-modebar-sep" aria-hidden="true"></div>

      <!-- Contrôles contextuels PRO -->
      <div class="rd-mode-controls" id="mode-ctrl-pro">
        <!-- Combobox catégories Pro -->
        <div class="rd-cat-dropdown" id="cat-dropdown" role="combobox" aria-haspopup="listbox" aria-expanded="false" aria-controls="cat-panel">
          <button class="rd-cat-trigger" type="button" aria-label="Filtrer les catégories">
            <i class="fas fa-layer-group rd-cat-icon"></i>
            <span class="rd-cat-trigger-label">3 catégories</span>
            <i class="fas fa-chevron-down rd-cat-chevron"></i>
          </button>
          <div class="rd-cat-panel" id="cat-panel" role="listbox">
            <div class="rd-cat-panel-header">Catégories Pro</div>
            <label class="rd-cat-item rd-cat-item--all">
              <input type="checkbox" class="rd-cat-cb-all" checked>
              <i class="fas fa-check-double"></i>
              <span>Toutes les catégories</span>
            </label>
            <label class="rd-cat-item">
              <input type="checkbox" class="rd-cat-cb" data-type="coworking" checked>
              <i class="fas fa-laptop"></i>
              <span>Coworkings</span>
            </label>
            <label class="rd-cat-item">
              <input type="checkbox" class="rd-cat-cb" data-type="entreprise" checked>
              <i class="fas fa-microchip"></i>
              <span>Entreprises Data / IT</span>
            </label>
            <label class="rd-cat-item">
              <input type="checkbox" class="rd-cat-cb" data-type="evenement" checked>
              <i class="fas fa-calendar-days"></i>
              <span>Événements IT / Emploi</span>
            </label>
          </div>
        </div>
      </div>

      <!-- Contrôles contextuels CYCLO -->
      <div class="rd-mode-controls rd-mode-controls--hidden" id="mode-ctrl-cyclo">
        <!-- Combobox catégories Cyclo -->
        <div class="rd-cat-dropdown" id="cat-dropdown-cyclo" role="combobox" aria-haspopup="listbox" aria-expanded="false" aria-controls="cat-panel-cyclo">
          <button class="rd-cat-trigger" type="button" aria-label="Filtrer les catégories">
            <i class="fas fa-layer-group rd-cat-icon"></i>
            <span class="rd-cat-trigger-label">5 catégories</span>
            <i class="fas fa-chevron-down rd-cat-chevron"></i>
          </button>
          <div class="rd-cat-panel" id="cat-panel-cyclo" role="listbox">
            <div class="rd-cat-panel-header">Catégories Cyclo</div>
            <label class="rd-cat-item rd-cat-item--all">
              <input type="checkbox" class="rd-cat-cb-all" checked>
              <i class="fas fa-check-double"></i>
              <span>Toutes les catégories</span>
            </label>
            <label class="rd-cat-item">
              <input type="checkbox" class="rd-cat-cb" data-type="camping" checked>
              <i class="fas fa-campground"></i>
              <span>Campings</span>
            </label>
            <label class="rd-cat-item">
              <input type="checkbox" class="rd-cat-cb" data-type="piscine" checked>
              <i class="fas fa-person-swimming"></i>
              <span>Piscines / Baignade</span>
            </label>
            <label class="rd-cat-item">
              <input type="checkbox" class="rd-cat-cb" data-type="fontaine" checked>
              <i class="fas fa-droplet"></i>
              <span>Points d'eau</span>
            </label>
            <label class="rd-cat-item">
              <input type="checkbox" class="rd-cat-cb" data-type="douche" checked>
              <i class="fas fa-shower"></i>
              <span>Douches publiques</span>
            </label>
            <label class="rd-cat-item">
              <input type="checkbox" class="rd-cat-cb" data-type="abri" checked>
              <i class="fas fa-house-chimney"></i>
              <span>Abris / Refuges</span>
            </label>
          </div>
        </div>
      </div>

    </div>

    <!-- ══════════════════════════════════════════════════════ -->
    <!-- CONTENU PRINCIPAL — container admin-style              -->
    <!-- ══════════════════════════════════════════════════════ -->
    <div class="rd-container">

      <!-- TABS — sous-navigation contextuelle par mode -->
      <div class="rd-tabs" role="tablist">
        <!-- Commun PRO + CYCLO -->
        <button class="rd-tab rd-tab--active" data-tab="carte" data-modes="pro,cyclo" role="tab" aria-selected="true">
          <i class="fas fa-map-marked-alt"></i> Carte
        </button>
        <!-- PRO uniquement -->
        <button class="rd-tab" data-tab="coworking" data-modes="pro" role="tab" aria-selected="false">
          <span class="rd-tab-dot" style="--dot-color:#8b5cf6"></span>
          <i class="fas fa-laptop"></i> Coworkings
          <span class="rd-tab-count" id="count-coworking">0</span>
        </button>
        <button class="rd-tab" data-tab="entreprise" data-modes="pro" role="tab" aria-selected="false">
          <span class="rd-tab-dot" style="--dot-color:#f59e0b"></span>
          <i class="fas fa-microchip"></i> Entreprises
          <span class="rd-tab-count" id="count-entreprise">0</span>
        </button>
        <button class="rd-tab" data-tab="evenement" data-modes="pro" role="tab" aria-selected="false">
          <span class="rd-tab-dot" style="--dot-color:#f43f5e"></span>
          <i class="fas fa-calendar-days"></i> Événements
          <span class="rd-tab-count" id="count-evenement">0</span>
        </button>
        <button class="rd-tab rd-tab--salons" data-tab="salons" data-modes="pro" role="tab" aria-selected="false">
          <i class="fas fa-flag"></i> Salons FR
          <span class="rd-tab-count" id="count-salons">—</span>
        </button>
        <button class="rd-tab" data-tab="liens-utiles" data-modes="pro" role="tab" aria-selected="false">
          <i class="fas fa-link"></i> Liens utiles
        </button>
        <!-- CYCLO uniquement -->
        <button class="rd-tab rd-tab--mode-hidden" data-tab="camping" data-modes="cyclo" role="tab" aria-selected="false">
          <span class="rd-tab-dot" style="--dot-color:#10b981"></span>
          <i class="fas fa-campground"></i> Campings
          <span class="rd-tab-count" id="count-camping">0</span>
        </button>
        <button class="rd-tab rd-tab--mode-hidden" data-tab="piscine" data-modes="cyclo" role="tab" aria-selected="false">
          <span class="rd-tab-dot" style="--dot-color:#38bdf8"></span>
          <i class="fas fa-person-swimming"></i> Piscines
          <span class="rd-tab-count" id="count-piscine">0</span>
        </button>
        <button class="rd-tab rd-tab--mode-hidden" data-tab="fontaine" data-modes="cyclo" role="tab" aria-selected="false">
          <span class="rd-tab-dot" style="--dot-color:#67e8f9"></span>
          <i class="fas fa-droplet"></i> Eau
          <span class="rd-tab-count" id="count-fontaine">0</span>
        </button>
        <button class="rd-tab rd-tab--mode-hidden" data-tab="douche" data-modes="cyclo" role="tab" aria-selected="false">
          <span class="rd-tab-dot" style="--dot-color:#a78bfa"></span>
          <i class="fas fa-shower"></i> Douches
          <span class="rd-tab-count" id="count-douche">0</span>
        </button>
        <button class="rd-tab rd-tab--mode-hidden" data-tab="abri" data-modes="cyclo" role="tab" aria-selected="false">
          <span class="rd-tab-dot" style="--dot-color:#84cc16"></span>
          <i class="fas fa-house-chimney"></i> Abris
          <span class="rd-tab-count" id="count-abri">0</span>
        </button>
        <!-- Commun PRO + CYCLO -->
        <button class="rd-tab" data-tab="tous" data-modes="pro,cyclo" role="tab" aria-selected="false">
          <i class="fas fa-list"></i> Tous
        </button>
      </div>

      <!-- TAB: Carte -->
      <div class="rd-tab-content rd-tab-content--active" id="tab-carte" role="tabpanel">
        <div class="rd-card">
          <div class="rd-card-header">
            <h3><i class="fas fa-map"></i> Carte interactive</h3>
            <div class="rd-card-badges filter-chips" role="group" aria-label="Filtres carte">
              <button class="chip chip--hidden" data-type="camping" aria-pressed="false" style="--dot:#10b981;--chip-color:#10b981">
                <i class="fas fa-campground"></i>Camping
              </button>
              <button class="chip active" data-type="coworking" aria-pressed="true" style="--dot:#8b5cf6;--chip-color:#8b5cf6">
                <i class="fas fa-laptop"></i>Coworking
              </button>
              <button class="chip active" data-type="entreprise" aria-pressed="true" style="--dot:#f59e0b;--chip-color:#f59e0b">
                <i class="fas fa-microchip"></i>Entreprise
              </button>
              <button class="chip active" data-type="evenement" aria-pressed="true" style="--dot:#f43f5e;--chip-color:#f43f5e">
                <i class="fas fa-calendar-days"></i>Événement
              </button>
              <button class="chip chip--hidden" data-type="piscine" aria-pressed="false" style="--dot:#38bdf8;--chip-color:#38bdf8">
                <i class="fas fa-person-swimming"></i>Piscine
              </button>
              <button class="chip chip--hidden" data-type="fontaine" aria-pressed="false" style="--dot:#67e8f9;--chip-color:#67e8f9">
                <i class="fas fa-droplet"></i>Eau
              </button>
              <button class="chip chip--hidden" data-type="douche" aria-pressed="false" style="--dot:#a78bfa;--chip-color:#a78bfa">
                <i class="fas fa-shower"></i>Douche
              </button>
              <button class="chip chip--hidden" data-type="abri" aria-pressed="false" style="--dot:#84cc16;--chip-color:#84cc16">
                <i class="fas fa-house-chimney"></i>Abri
              </button>
            </div>
          </div>
          <div class="rd-map-frame">
            <div id="radar-map" aria-label="Carte interactive des lieux proches"></div>
            <!-- Overlay info centré sur la carte -->
            <div id="map-info-overlay" class="map-info-overlay map-info-overlay--hidden" role="status" aria-live="polite">
              <span id="map-info-icon"></span>
              <span id="map-info-text"></span>
            </div>
          </div>
        </div>
      </div>

      <!-- TAB: Campings -->
      <div class="rd-tab-content" id="tab-camping" role="tabpanel">
        <div class="rd-card">
          <div class="rd-card-header">
            <h3><i class="fas fa-campground"></i> Campings à proximité</h3>
            <span class="rd-card-hint">Sources : OpenStreetMap + Atout France</span>
          </div>
          <ul class="rd-list" id="list-camping" aria-label="Liste des campings"></ul>
        </div>
      </div>

      <!-- TAB: Coworkings -->
      <div class="rd-tab-content" id="tab-coworking" role="tabpanel">
        <div class="rd-card">
          <div class="rd-card-header">
            <h3><i class="fas fa-laptop"></i> Coworkings</h3>
            <span class="rd-card-hint">Sources : OpenStreetMap + données référencées</span>
          </div>
          <ul class="rd-list" id="list-coworking" aria-label="Liste des coworkings"></ul>
        </div>
      </div>

      <!-- TAB: Entreprises -->
      <div class="rd-tab-content" id="tab-entreprise" role="tabpanel">
        <div class="rd-card">
          <div class="rd-card-header">
            <h3><i class="fas fa-microchip"></i> Entreprises Data / IT</h3>
            <span class="rd-card-hint">Source : INSEE SIRENE — codes NAF Data, IT, Conseil</span>
          </div>
          <ul class="rd-list" id="list-entreprise" aria-label="Liste des entreprises"></ul>
        </div>
      </div>

      <!-- TAB: Événements -->
      <div class="rd-tab-content" id="tab-evenement" role="tabpanel">
        <div class="rd-card">
          <div class="rd-card-header">
            <h3><i class="fas fa-calendar-days"></i> Événements IT / Data / Emploi</h3>
            <span class="rd-card-hint">Source : OpenAgenda — salons, forums emploi, meetups tech</span>
          </div>
          <div id="list-evenement" class="rd-link-table-wrap"></div>
        </div>
      </div>

      <!-- TAB: Piscines -->
      <div class="rd-tab-content" id="tab-piscine" role="tabpanel">
        <div class="rd-card">
          <div class="rd-card-header">
            <h3><i class="fas fa-person-swimming"></i> Piscines &amp; Baignade</h3>
            <span class="rd-card-hint">Source : OpenStreetMap — accès public uniquement</span>
          </div>
          <ul class="rd-list" id="list-piscine" aria-label="Liste des piscines"></ul>
        </div>
      </div>

      <!-- TAB: Points d'eau -->
      <div class="rd-tab-content" id="tab-fontaine" role="tabpanel">
        <div class="rd-card">
          <div class="rd-card-header">
            <h3><i class="fas fa-droplet"></i> Points d'eau &amp; Fontaines</h3>
            <span class="rd-card-hint">Source : OpenStreetMap — eau potable</span>
          </div>
          <ul class="rd-list" id="list-fontaine" aria-label="Liste des points d'eau"></ul>
        </div>
      </div>

      <!-- TAB: Douches -->
      <div class="rd-tab-content" id="tab-douche" role="tabpanel">
        <div class="rd-card">
