  <script is:inline>
  /* ============================================================
     RADAR TERRAIN — TourData 2026
     Stéphane Celton — OceanPhenix
  ============================================================ */
  (function () {
    'use strict';

    // ── Constantes ────────────────────────────────────────────
    const TYPE_COLORS = {
      camping:   '#10b981',
      coworking: '#8b5cf6',
      // Cyclo — sans clé API (Overpass/OSM)
