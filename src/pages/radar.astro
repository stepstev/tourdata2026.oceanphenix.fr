---
// src/pages/radar.astro — Radar Terrain TourData 2026
// Localise en temps réel : campings, coworkings, entreprises data/IT, événements
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import CguModal from '../components/CguModal.astro';
import OceanBackground from '../components/OceanBackground.astro';
---

<BaseLayout
  title="Radar Terrain — Campings, Coworkings & Entreprises | TourData 2026"
  description="Localisez en temps réel autour de votre position : campings, coworkings, entreprises data/IT et événements IT/emploi. Outil terrain TourData 2026 — Stéphane Celton."
  lastModified="22/03/2026 12:00"
>
  <link slot="head" rel="stylesheet" href="/lib/leaflet.min.css" />

  <OceanBackground />
  <Nav />

  <main class="radar-page main-content" id="radar-page">

    <!-- ══════════════════════════════════════════════════════ -->
    <!-- HERO — cohérent avec strava / terrain                 -->
    <!-- ══════════════════════════════════════════════════════ -->
    <section class="rd-hero">
      <div class="rd-hero-badge">
        <i class="fas fa-satellite-dish"></i> Outil Terrain — TourData 2026
      </div>
      <h2 class="page-title"><i class="fas fa-crosshairs page-title-icon"></i> Radar Terrain</h2>
      <p class="page-sub">Localisez en temps réel : coworkings, entreprises data/IT et événements IT/emploi autour de votre position — TourData 2026</p>
      <p class="rd-wip-notice"><i class="fas fa-triangle-exclamation"></i> En développement actif — données partielles</p>
    </section>

    <!-- ══════════════════════════════════════════════════════ -->
    <!-- CONTRÔLES — toolbar compacte                          -->
    <!-- ══════════════════════════════════════════════════════ -->
    <div class="rd-header">
      <div class="rd-toolbar">
        <!-- Dropdown custom villes Data/IA -->
        <div class="rd-city-dropdown" id="city-dropdown" role="combobox" aria-haspopup="listbox" aria-expanded="false" aria-controls="city-panel">
          <button class="rd-city-trigger" id="city-trigger" type="button" aria-label="Choisir une ville Data / IA">
            <i class="fas fa-map-location-dot rd-city-trigger-icon"></i>
            <span id="city-trigger-label">Ville Data / IA</span>
            <i class="fas fa-chevron-down rd-city-chevron"></i>
          </button>
          <div class="rd-city-panel" id="city-panel" role="listbox">

            <div class="rd-city-group">
              <div class="rd-city-group-label"><i class="fas fa-city"></i> Île-de-France</div>
              <button class="rd-city-item" data-lat="48.856" data-lon="2.352"><i class="fas fa-tower-observation" style="color:#f59e0b"></i> Paris</button>
              <button class="rd-city-item" data-lat="48.897" data-lon="2.088"><i class="fas fa-building-columns" style="color:#94a3b8"></i> La Défense</button>
              <button class="rd-city-item" data-lat="48.759" data-lon="2.208"><i class="fas fa-flask" style="color:#22d3ee"></i> Saclay / Paris-Sud</button>
              <button class="rd-city-item" data-lat="48.638" data-lon="2.094"><i class="fas fa-bicycle" style="color:#10b981"></i> Fontenay-lès-Briis</button>
            </div>

            <div class="rd-city-group">
              <div class="rd-city-group-label"><i class="fas fa-mountain-sun"></i> Auvergne-Rhône-Alpes</div>
              <button class="rd-city-item" data-lat="45.748" data-lon="4.847"><i class="fas fa-database" style="color:#f59e0b"></i> Lyon</button>
              <button class="rd-city-item" data-lat="45.188" data-lon="5.724"><i class="fas fa-atom" style="color:#38bdf8"></i> Grenoble</button>
              <button class="rd-city-item" data-lat="45.439" data-lon="4.387"><i class="fas fa-microchip" style="color:#a78bfa"></i> Saint-Étienne</button>
              <button class="rd-city-item" data-lat="46.151" data-lon="6.867"><i class="fas fa-laptop" style="color:#34d399"></i> Annecy</button>
            </div>

            <div class="rd-city-group">
              <div class="rd-city-group-label"><i class="fas fa-sun"></i> Occitanie</div>
              <button class="rd-city-item" data-lat="43.605" data-lon="1.444"><i class="fas fa-plane" style="color:#fb923c"></i> Toulouse</button>
              <button class="rd-city-item" data-lat="43.611" data-lon="3.877"><i class="fas fa-brain" style="color:#c084fc"></i> Montpellier</button>
            </div>

            <div class="rd-city-group">
              <div class="rd-city-group-label"><i class="fas fa-wine-glass"></i> Nouvelle-Aquitaine</div>
              <button class="rd-city-item" data-lat="44.837" data-lon="-0.579"><i class="fas fa-chart-line" style="color:#4ade80"></i> Bordeaux</button>
            </div>

            <div class="rd-city-group">
              <div class="rd-city-group-label"><i class="fas fa-water"></i> PACA</div>
              <button class="rd-city-item" data-lat="43.296" data-lon="5.381"><i class="fas fa-ship" style="color:#38bdf8"></i> Marseille</button>
              <button class="rd-city-item" data-lat="43.430" data-lon="5.215"><i class="fas fa-network-wired" style="color:#a78bfa"></i> Aix-en-Provence</button>
              <button class="rd-city-item" data-lat="43.710" data-lon="7.262"><i class="fas fa-microchip" style="color:#f59e0b"></i> Nice / Sophia Antipolis</button>
            </div>

            <div class="rd-city-group">
              <div class="rd-city-group-label"><i class="fas fa-anchor"></i> Pays de la Loire / Bretagne</div>
              <button class="rd-city-item" data-lat="47.218" data-lon="-1.553"><i class="fas fa-rocket" style="color:#fb923c"></i> Nantes</button>
              <button class="rd-city-item" data-lat="48.117" data-lon="-1.677"><i class="fas fa-satellite-dish" style="color:#22d3ee"></i> Rennes</button>
              <button class="rd-city-item" data-lat="48.390" data-lon="-4.486"><i class="fas fa-anchor" style="color:#60a5fa"></i> Brest</button>
            </div>

            <div class="rd-city-group">
              <div class="rd-city-group-label"><i class="fas fa-bridge"></i> Normandie</div>
              <button class="rd-city-item" data-lat="49.183" data-lon="-0.357"><i class="fas fa-graduation-cap" style="color:#a78bfa"></i> Caen</button>
              <button class="rd-city-item" data-lat="49.443" data-lon="1.099"><i class="fas fa-industry" style="color:#94a3b8"></i> Rouen</button>
            </div>

            <div class="rd-city-group">
              <div class="rd-city-group-label"><i class="fas fa-snowflake"></i> Grand Est / Hauts-de-France</div>
              <button class="rd-city-item" data-lat="50.629" data-lon="3.057"><i class="fas fa-building" style="color:#60a5fa"></i> Lille</button>
              <button class="rd-city-item" data-lat="48.573" data-lon="7.752"><i class="fas fa-landmark" style="color:#f472b6"></i> Strasbourg</button>
              <button class="rd-city-item" data-lat="49.119" data-lon="6.176"><i class="fas fa-microchip" style="color:#34d399"></i> Metz</button>
              <button class="rd-city-item" data-lat="48.692" data-lon="6.184"><i class="fas fa-flask" style="color:#38bdf8"></i> Nancy</button>
            </div>

            <div class="rd-city-group">
              <div class="rd-city-group-label"><i class="fas fa-castle"></i> Bourgogne / Centre-Val</div>
              <button class="rd-city-item" data-lat="47.322" data-lon="5.041"><i class="fas fa-chart-pie" style="color:#fb923c"></i> Dijon</button>
              <button class="rd-city-item" data-lat="47.902" data-lon="1.909"><i class="fas fa-bolt" style="color:#facc15"></i> Orléans</button>
              <button class="rd-city-item" data-lat="47.394" data-lon="0.691"><i class="fas fa-server" style="color:#a78bfa"></i> Tours</button>
            </div>

          </div>
        </div>
        <button id="btn-locate" class="rd-btn rd-btn--primary" aria-label="Géolocaliser ma position">
          <i class="fas fa-location-dot"></i> Je suis ici
        </button>
        <div class="rd-toolbar-sep" aria-hidden="true"></div>
        <!-- Toggle vue PRO / CYCLO -->
        <div class="rd-view-toggle" role="group" aria-label="Vue">
          <button class="rd-view-btn rd-view-btn--active" id="btn-view-pro" data-view="pro" type="button">
            <i class="fas fa-briefcase"></i> Pro
          </button>
          <button class="rd-view-btn" id="btn-view-cyclo" data-view="cyclo" type="button">
            <i class="fas fa-bicycle"></i> Cyclo
          </button>
        </div>
        <div class="rd-toolbar-sep" aria-hidden="true"></div>
        <div class="rd-radius-inline">
          <span class="rd-radius-label"><i class="fas fa-circle-dot"></i> <strong id="radius-val">10</strong> km</span>
          <input type="range" id="radius-slider" min="2" max="25" value="10" step="1"
            aria-label="Rayon de recherche" />
        </div>
        <div class="rd-effectif-filter">
          <label for="effectif-select" class="rd-effectif-label"><i class="fas fa-users"></i></label>
          <select id="effectif-select" class="rd-effectif-select" aria-label="Filtrer par effectif">
            <option value="">Tous effectifs</option>
            <option value="11">10+ salariés</option>
            <option value="21">50+ salariés</option>
            <option value="22">100+ salariés</option>
            <option value="32">250+ salariés</option>
          </select>
        </div>
        <div class="rd-toolbar-sep" aria-hidden="true"></div>
        <!-- Combobox catégories -->
        <div class="rd-cat-dropdown" id="cat-dropdown" role="combobox" aria-haspopup="listbox" aria-expanded="false" aria-controls="cat-panel">
          <button class="rd-cat-trigger" id="cat-trigger" type="button" aria-label="Filtrer les catégories">
            <i class="fas fa-layer-group rd-cat-icon"></i>
            <span id="cat-trigger-label">3 catégories</span>
            <i class="fas fa-chevron-down rd-cat-chevron"></i>
          </button>
          <div class="rd-cat-panel" id="cat-panel" role="listbox">
            <div class="rd-cat-panel-header">Afficher les catégories</div>
            <label class="rd-cat-item">
              <input type="checkbox" class="rd-cat-cb" data-type="camping">
              <i class="fas fa-campground" style="color:#10b981"></i>
              <span>Campings</span>
            </label>
            <label class="rd-cat-item">
              <input type="checkbox" class="rd-cat-cb" data-type="coworking" checked>
              <i class="fas fa-laptop" style="color:#8b5cf6"></i>
              <span>Coworkings</span>
            </label>
            <label class="rd-cat-item">
              <input type="checkbox" class="rd-cat-cb" data-type="entreprise" checked>
              <i class="fas fa-microchip" style="color:#f59e0b"></i>
              <span>Entreprises Data / IT</span>
            </label>
            <label class="rd-cat-item">
              <input type="checkbox" class="rd-cat-cb" data-type="evenement" checked>
              <i class="fas fa-calendar-days" style="color:#f43f5e"></i>
              <span>Événements IT / Emploi</span>
            </label>
          </div>
        </div>
        <div class="rd-status">
          <span class="rd-dot" id="rd-dot"></span>
          <span id="loading-indicator" class="rd-status-label hidden" aria-live="polite">Chargement…</span>
          <span id="results-count" class="rd-status-label rd-status-idle">Sélectionnez une étape</span>
        </div>

      </div>
    </div>

    <!-- ══════════════════════════════════════════════════════ -->
    <!-- CONTENU PRINCIPAL — container admin-style              -->
    <!-- ══════════════════════════════════════════════════════ -->
    <div class="rd-container">

      <!-- TABS — inspirés de admin-terrain -->
      <div class="rd-tabs" role="tablist">
        <button class="rd-tab rd-tab--active" data-tab="carte" role="tab" aria-selected="true">
          <i class="fas fa-map-marked-alt"></i> Carte
        </button>
        <button class="rd-tab" data-tab="camping" role="tab" aria-selected="false">
          <span class="rd-tab-dot" style="--dot-color:#10b981"></span>
          <i class="fas fa-campground" style="color:#10b981"></i> Campings
          <span class="rd-tab-count" id="count-camping">0</span>
        </button>
        <button class="rd-tab" data-tab="coworking" role="tab" aria-selected="false">
          <span class="rd-tab-dot" style="--dot-color:#8b5cf6"></span>
          <i class="fas fa-laptop" style="color:#8b5cf6"></i> Coworkings
          <span class="rd-tab-count" id="count-coworking">0</span>
        </button>
        <button class="rd-tab" data-tab="entreprise" role="tab" aria-selected="false">
          <span class="rd-tab-dot" style="--dot-color:#f59e0b"></span>
          <i class="fas fa-microchip" style="color:#f59e0b"></i> Entreprises
          <span class="rd-tab-count" id="count-entreprise">0</span>
        </button>
        <button class="rd-tab" data-tab="evenement" role="tab" aria-selected="false">
          <span class="rd-tab-dot" style="--dot-color:#f43f5e"></span>
          <i class="fas fa-calendar-days" style="color:#f43f5e"></i> Événements
          <span class="rd-tab-count" id="count-evenement">0</span>
        </button>
        <button class="rd-tab" data-tab="tous" role="tab" aria-selected="false">
          <i class="fas fa-list"></i> Tous
        </button>
      </div>

      <!-- TAB: Carte -->
      <div class="rd-tab-content rd-tab-content--active" id="tab-carte" role="tabpanel">
        <div class="rd-card">
          <div class="rd-card-header">
            <h3><i class="fas fa-map"></i> Carte interactive</h3>
            <div class="rd-card-badges filter-chips" role="group" aria-label="Filtres carte">
              <button class="chip chip--hidden" data-type="camping" aria-pressed="false" style="--dot:#10b981;--chip-color:#10b981">
                <i class="fas fa-campground"></i>Camping
              </button>
              <button class="chip active" data-type="coworking" aria-pressed="true" style="--dot:#8b5cf6;--chip-color:#8b5cf6">
                <i class="fas fa-laptop"></i>Coworking
              </button>
              <button class="chip active" data-type="entreprise" aria-pressed="true" style="--dot:#f59e0b;--chip-color:#f59e0b">
                <i class="fas fa-microchip"></i>Entreprise
              </button>
              <button class="chip active" data-type="evenement" aria-pressed="true" style="--dot:#f43f5e;--chip-color:#f43f5e">
                <i class="fas fa-calendar-days"></i>Événement
              </button>

            </div>
          </div>
          <div class="rd-map-frame">
            <div id="radar-map" aria-label="Carte interactive des lieux proches"></div>
            <!-- Overlay info centré sur la carte -->
            <div id="map-info-overlay" class="map-info-overlay map-info-overlay--hidden" role="status" aria-live="polite">
              <span id="map-info-icon"></span>
              <span id="map-info-text"></span>
            </div>
          </div>
        </div>
      </div>

      <!-- TAB: Campings -->
      <div class="rd-tab-content" id="tab-camping" role="tabpanel">
        <div class="rd-card">
          <div class="rd-card-header">
            <h3><i class="fas fa-campground" style="color:#10b981"></i> Campings à proximité</h3>
            <span class="rd-card-hint">Sources : OpenStreetMap + Atout France</span>
          </div>
          <ul class="rd-list" id="list-camping" aria-label="Liste des campings"></ul>
        </div>
      </div>

      <!-- TAB: Coworkings -->
      <div class="rd-tab-content" id="tab-coworking" role="tabpanel">
        <div class="rd-card">
          <div class="rd-card-header">
            <h3><i class="fas fa-laptop" style="color:#8b5cf6"></i> Coworkings</h3>
            <span class="rd-card-hint">Sources : OpenStreetMap + données référencées</span>
          </div>
          <ul class="rd-list" id="list-coworking" aria-label="Liste des coworkings"></ul>
        </div>
      </div>

      <!-- TAB: Entreprises -->
      <div class="rd-tab-content" id="tab-entreprise" role="tabpanel">
        <div class="rd-card">
          <div class="rd-card-header">
            <h3><i class="fas fa-microchip" style="color:#f59e0b"></i> Entreprises Data / IT</h3>
            <span class="rd-card-hint">Source : INSEE SIRENE — codes NAF Data, IT, Conseil</span>
          </div>
          <ul class="rd-list" id="list-entreprise" aria-label="Liste des entreprises"></ul>
        </div>
      </div>

      <!-- TAB: Événements -->
      <div class="rd-tab-content" id="tab-evenement" role="tabpanel">
        <div class="rd-card">
          <div class="rd-card-header">
            <h3><i class="fas fa-calendar-days" style="color:#f43f5e"></i> Événements IT / Data / Emploi</h3>
            <span class="rd-card-hint">Source : OpenAgenda — salons, forums emploi, meetups tech</span>
          </div>
          <ul class="rd-list" id="list-evenement" aria-label="Liste des événements"></ul>
        </div>
      </div>

      <!-- TAB: Tous -->
      <div class="rd-tab-content" id="tab-tous" role="tabpanel">
        <div class="rd-card">
          <div class="rd-card-header">
            <h3><i class="fas fa-list"></i> Tous les résultats</h3>
          </div>
          <ul class="rd-list" id="results-list" aria-live="polite" aria-label="Liste des lieux trouvés"></ul>
        </div>
      </div>

    </div><!-- /.rd-container -->

    <!-- ══════════════════════════════════════════════════════ -->
    <!-- NOTE TECHNIQUE                                        -->
    <!-- ══════════════════════════════════════════════════════ -->
    <div class="rd-tech-note">
      <p>
        <strong>Votre position reste dans votre navigateur.</strong>
        Le bouton « Je suis ici » utilise l'API <code>navigator.geolocation</code> du navigateur — aucune coordonnée GPS n'est envoyée à un serveur OceanPhenix.
        Les coordonnées sont transmises directement aux sources de données :
        <strong>OpenStreetMap / Overpass</strong> pour campings et coworkings ;
        <strong>OpenDataSoft / Atout France</strong> pour les hébergements classés ;
        <strong>INSEE SIRENE</strong> pour les entreprises Data &amp; IT ;
        <strong>OpenAgenda</strong> pour les événements IT, salons emploi et meetups tech (proxy PHP, clé API requise).
        Résultats mis en cache 5 à 30&nbsp;min côté serveur pour limiter les appels.
      </p>
    </div>

    <!-- ══════════════════════════════════════════════════════ -->
    <!-- TOASTS                                                -->
    <!-- ══════════════════════════════════════════════════════ -->
    <div id="toast-container" aria-live="assertive" aria-atomic="true"></div>

    <!-- ══════════════════════════════════════════════════════ -->
    <!-- FOOTER RADAR — nav + copyright                         -->
    <!-- ══════════════════════════════════════════════════════ -->
    <footer class="rd-footer">
      <nav class="rd-footer-nav" aria-label="Navigation OceanPhenix">
        <a href="/terrain"><i class="fas fa-bicycle"></i> TourData</a>
        <a href="/tourdata"><i class="fas fa-chart-pie"></i> Dashboard</a>
        <a href="/strava"><i class="fab fa-strava"></i> Strava</a>
        <a href="/radar" class="rd-footer-nav--active" aria-current="page"><i class="fas fa-crosshairs"></i> Radar</a>
        <a href="/expertises"><i class="fas fa-briefcase"></i> Expertises</a>
        <a href="/index.html"><i class="fas fa-home"></i> Accueil</a>
      </nav>
      <div class="rd-footer-copy-row">
        <span class="rd-footer-copy">© 2025–2026 <strong>OceanPhenix™</strong> · Stéphane Celton</span>
        <span class="rd-footer-sep">·</span>
        <span class="rd-footer-project"><i class="fas fa-bicycle"></i> TourData 2026</span>
        <span class="rd-footer-sep">·</span>
        <a href="#" id="cgu-link" class="rd-footer-link">CGU &amp; RGPD</a>
      </div>
    </footer>

  </main>

  <CguModal />

  <!-- Leaflet JS (local, cohérent avec terrain/strava) -->
  <script is:inline src="/lib/leaflet.min.js"></script>

  <script is:inline>
  /* ============================================================
     RADAR TERRAIN — TourData 2026
     Stéphane Celton — OceanPhenix
  ============================================================ */
  (function () {
    'use strict';

    // ── Constantes ────────────────────────────────────────────
    const TYPE_COLORS = {
      camping:    '#10b981',
      coworking:  '#8b5cf6',
      entreprise: '#f59e0b',
      evenement:  '#f43f5e',
    };
    // Coworkings statiques enrichis
    const COWORKINGS_STATIC = [
      { nom: 'La Ruche',           ville: 'Paris',       lat: 48.866, lon:  2.387, adresse: '24 Rue Brézin, 75014 Paris' },
      { nom: 'Mutinerie',          ville: 'Paris',       lat: 48.862, lon:  2.365, adresse: '181 Rue du Temple, 75003 Paris' },
      { nom: 'Darwin Écosystème',  ville: 'Bordeaux',    lat: 44.841, lon: -0.565, adresse: '87 Quai des Queyries, 33100 Bordeaux' },
      { nom: 'La Cordée',          ville: 'Lyon',        lat: 45.748, lon:  4.847, adresse: '1 Rue du Palais de Justice, 69005 Lyon' },
      { nom: 'La Cantine',         ville: 'Toulouse',    lat: 43.608, lon:  1.445, adresse: '2 Place Dupuy, 31000 Toulouse' },
      { nom: 'Remix Coworking',    ville: 'Nantes',      lat: 47.218, lon: -1.553, adresse: 'Nantes Centre' },
      { nom: 'Le Dôme',            ville: 'Caen',        lat: 49.183, lon: -0.357, adresse: 'Caen' },
      { nom: 'La Station',         ville: 'Nice',        lat: 43.706, lon:  7.267, adresse: '89 Rue de France, 06000 Nice' },
      { nom: 'Village by CA',      ville: 'Rennes',      lat: 48.112, lon: -1.680, adresse: 'Rennes' },
      { nom: 'Le Palace',          ville: 'Montpellier', lat: 43.611, lon:  3.877, adresse: 'Montpellier' },
      { nom: 'Cité de l\'innovation', ville: 'Marseille', lat: 43.293, lon: 5.393, adresse: '2 Rue de la Charité, 13002 Marseille' },
    ];

    // Tranches effectif SIRENE — ordre croissant
    const EFFECTIF_ORDER = ['00','01','02','03','11','12','21','22','31','32','41','42','51','52','53'];
    const EFFECTIF_LABELS = {
      '00':'0 salarié','01':'1-2','02':'3-5','03':'6-9',
      '11':'10-19','12':'20-49','21':'50-99','22':'100-199',
      '31':'200-249','32':'250-499','41':'500-999','42':'1 000-1 999',
      '51':'2 000-4 999','52':'5 000-9 999','53':'10 000+',
    };
    function effectifLabel(code) {
      return EFFECTIF_LABELS[code] ? `${EFFECTIF_LABELS[code]} salariés` : `Effectif ${code}`;
    }

    // ── État ──────────────────────────────────────────────────
    let currentLat = null;
    let currentLon = null;
    let currentRadius = 10;
    let minEffectifTranche = '';
    let activeFilters = new Set(); // Initialisé par applyView('pro') au boot
    let allResults = [];
    let leafletMap = null;
    let mapMarkers = [];
    let radiusCircle = null;

    // ── Mode dev : détection + mock data ──────────────────────
    const IS_DEV = location.hostname === 'localhost' || location.hostname === '127.0.0.1';

