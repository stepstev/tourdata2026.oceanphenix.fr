---
// src/pages/roadmap.astro — Roadmap sinusoïdale TourData 2026
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CopyrightBar from '../components/CopyrightBar.astro';
import OceanBackground from '../components/OceanBackground.astro';

// ── Géométrie ────────────────────────────────────────────
const NR  = 26;   // node radius
const YC  = 290;  // y centre
const YT  = 110;  // y pics (top)
const YB  = 470;  // y creux (bottom)
const VBW = 1440;
const VBH = 580;

const WAVE =
  `M 80,${YC} C 170,${YC} 170,${YT} 260,${YT}` +
  ` S 350,${YB} 440,${YB}` +
  ` S 530,${YT} 620,${YT}` +
  ` S 710,${YB} 800,${YB}` +
  ` S 890,${YT} 980,${YT}` +
  ` S 1070,${YB} 1160,${YB}` +
  ` S 1250,${YC} 1340,${YC}`;

// ── Helpers positionnement étiquettes ─────────────────────
function dateY(x: number, y: number, pos: 'top' | 'bottom') {
  return pos === 'top' ? y - NR - 56 : y + NR + 24;
}
function titleY(x: number, y: number, pos: 'top' | 'bottom') {
  return pos === 'top' ? y - NR - 38 : y + NR + 42;
}
function subY(x: number, y: number, pos: 'top' | 'bottom') {
  return pos === 'top' ? y - NR - 20 : y + NR + 58;
}
function connY1(y: number, pos: 'top' | 'bottom') {
  return pos === 'top' ? y - NR : y + NR;
}
function connY2(y: number, pos: 'top' | 'bottom') {
  return pos === 'top' ? y - NR - 12 : y + NR + 12;
}

// ── Données jalons ────────────────────────────────────────
const milestones = [
  {
    id: 'concept',
    label: 'Concept',
    sub: 'Ressentis · Douleur · Architecture · Vision · Stack',
    date: 'Fév 2026',
    href: '/concept',
    status: 'done',
    x: 80,
    y: YC,
    labelPos: 'bottom' as const,
    icon: '\uf5fd',  // fa-layer-group
  },
  {
    id: 'terrain',
    label: 'Parcours',
    sub: 'Parcours terrain · Live',
    date: '17 Avr 2026',
    href: '/terrain',
    status: 'active',
    x: 260,
    y: YT,
    labelPos: 'top' as const,
    icon: '\uf206',  // fa-bicycle
  },
  {
    id: 'tourdata',
    label: 'Dashboard',
    sub: 'KPIs · Métriques · Données',
    date: 'Mars 2026',
    href: '/tourdata',
    status: 'done',
    x: 440,
    y: YB,
    labelPos: 'bottom' as const,
    icon: '\uf200',  // fa-chart-pie
  },
  {
    id: 'strava',
    label: 'Activités',
    sub: 'GPS · Segments · Efforts',
    date: 'Avr – Mai 2026',
    href: '/strava',
    status: 'active',
    x: 620,
    y: YT,
    labelPos: 'top' as const,
    icon: '\uf0e7',  // fa-bolt
  },
  {
    id: 'radar',
    label: 'Radar Data',
    sub: 'Maturité · Score · Gaps',
    date: 'Avr – Mai 2026',
    href: '/radar',
    status: 'active',
    x: 800,
    y: YB,
    labelPos: 'bottom' as const,
    icon: '\uf05b',  // fa-crosshairs
  },
  {
    id: 'meteo',
    label: 'Météo',
    sub: 'Conditions · Alertes Route',
    date: 'Avr 2026',
    href: '/meteo',
    status: 'active',
    x: 980,
    y: YT,
    labelPos: 'top' as const,
    icon: '\uf6c4',  // fa-cloud-sun
  },
  {
    id: 'etapes',
    label: 'Étapes',
    sub: '14 villes · PME & ETI',
    date: 'Avr – Juil 2026',
    href: '/terrain#carte',
    status: 'upcoming',
    x: 1160,
    y: YB,
    labelPos: 'bottom' as const,
    icon: '\uf276',  // fa-map-pin
  },
  {
    id: 'rag',
    label: 'Post-Tour IA',
    sub: 'Rapport · RAG · Matrice',
    date: 'Juil+ 2026',
    href: '/post-tour',
    status: 'future',
    x: 1340,
    y: YC,
    labelPos: 'top' as const,
    icon: '\uf544',  // fa-robot
  },
];

// ── Longueur approximative du chemin (pour l'animation stroke-dasharray)
const WAVE_LEN = 3200;
---

<BaseLayout
  title="Vision Produit & Jalons — TourData 2026 | OceanPhenix"
  description="Roadmap sinusoïdale du projet TourData 2026 — 8 jalons du Tour de la Data à vélo. Cliquez sur un jalon pour accéder à la section correspondante."
  lastModified="03/04/2026 12:00"
>
  <link slot="head" rel="stylesheet" href="/lib/leaflet.min.css" />
  <OceanBackground />
  <Nav />

  <main class="rm-page main-content">

    <!-- ── HERO ─────────────────────────────────────── -->
    <section class="rm-hero">
      <div class="rm-hero-inner">
        <div class="rm-section-badge">
          <i class="fas fa-route"></i> Roadmap
        </div>
        <h1 class="rm-title"><i class="fas fa-route rm-cu"></i> Vision Produit &amp; Jalons</h1>
        <p class="rm-desc">
          De l'<strong>idéation</strong> au <strong>terrain</strong> — 8 jalons pour le
          Tour de la Data à vélo. Cliquez sur un jalon pour accéder à la page.
        </p>
        <div class="rm-legend">
          <span class="rm-leg rm-leg--done">    <span class="rm-dot"></span>Terminé</span>
          <span class="rm-leg rm-leg--active">  <span class="rm-dot"></span>En cours</span>
          <span class="rm-leg rm-leg--upcoming"><span class="rm-dot"></span>À venir</span>
          <span class="rm-leg rm-leg--future">  <span class="rm-dot"></span>Futur</span>
        </div>
        <p class="rm-click-hint">
          Cliquez sur un jalon pour voir le détail <i class="fas fa-arrow-down rm-hint-arrow"></i>
        </p>
      </div>
    </section>

    <!-- ── SINUSOÏDE (desktop) ────────────────────── -->
    <section class="rm-wave-section">
      <div class="rm-wave-wrapper">
        <div id="rm-map" aria-hidden="true"></div>
        <svg
          class="rm-wave-svg"
          viewBox={`0 0 ${VBW} ${VBH}`}
          preserveAspectRatio="xMidYMid meet"
          xmlns="http://www.w3.org/2000/svg"
          aria-label="Roadmap sinusoïdale TourData 2026 — 8 jalons cliquables"
          role="img"
        >
          <defs>
            <linearGradient id="rm-wg" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%"   stop-color="#4db8d4" stop-opacity="0.5"/>
              <stop offset="42%"  stop-color="#4db8d4" stop-opacity="1"/>
              <stop offset="58%"  stop-color="#d4845a" stop-opacity="1"/>
              <stop offset="100%" stop-color="#2d8bb5" stop-opacity="0.5"/>
            </linearGradient>
            <filter id="rm-bike-glow" x="-50%" y="-50%" width="200%" height="200%">
              <feDropShadow dx="0" dy="1" stdDeviation="5" flood-color="#7ecfe0" flood-opacity="0.75"/>
            </filter>
            <radialGradient id="rm-bg-grad" gradientUnits="userSpaceOnUse" cx="720" cy="290" r="680">
              <stop offset="0%"  stop-color="#0e2044" stop-opacity="0.15"/>
              <stop offset="100%" stop-color="#0e2044" stop-opacity="0.28"/>
            </radialGradient>
          </defs>

          <!-- fond sombre forcé (visible en light mode) -->
          <rect width={VBW} height={VBH} fill="url(#rm-bg-grad)" rx="16"/>

          <!-- grille de fond -->
          <!-- lignes verticales — pas de 90px -->
          {Array.from({ length: 16 }, (_, i) => (
            <line
              x1={i * 90} y1="0" x2={i * 90} y2={VBH}
              stroke="#4db8d4" stroke-width="0.8" opacity="0.30"
            />
          ))}
          <!-- lignes horizontales — pas de 72px -->
          {Array.from({ length: 9 }, (_, i) => (
            <line
              x1="0" y1={i * 72} x2={VBW} y2={i * 72}
              stroke="#4db8d4" stroke-width="0.8" opacity="0.30"
            />
          ))}
          <!-- croix d'intersection aux nœuds de grille clés -->
          {[260, 440, 620, 800, 980, 1160].map(x => (
            <g opacity="0.50">
              <line x1={x - 7} y1={VBH / 2} x2={x + 7} y2={VBH / 2} stroke="#4db8d4" stroke-width="1.5"/>
              <line x1={x} y1={VBH / 2 - 7} x2={x} y2={VBH / 2 + 7} stroke="#4db8d4" stroke-width="1.5"/>
            </g>
          ))}

          <!-- halo ambiant -->
          <path d={WAVE} stroke="#4db8d4" stroke-width="48" fill="none" stroke-linecap="round" opacity="0.06"/>
          <!-- ombre portée -->
          <path d={WAVE} stroke="#020a16" stroke-width="8" fill="none" stroke-linecap="round" opacity="0.6"/>
          <!-- vague principale — animation draw -->
          <path id="rm-wave-path" d={WAVE} stroke="url(#rm-wg)" stroke-width="3" fill="none"
                stroke-linecap="round" class="rm-wave-line"/>

          <!-- vélo animé le long de la vague -->
          <g class="rm-bike-rider">
            <text
              text-anchor="middle"
              dominant-baseline="middle"
              dy="-14"
              class="rm-bike-icon"
              filter="url(#rm-bike-glow)"
            >&#xf206;</text>
            <animateMotion dur="28s" repeatCount="indefinite" rotate="auto" calcMode="spline"
              keyTimes="0;1" keySplines="0.4 0 0.6 1">
              <mpath href="#rm-wave-path"/>
            </animateMotion>
          </g>

          {/* ── Jalons ── */}
          {milestones.map((m) => (
            <a href={m.href} aria-label={`${m.label} — ${m.date}`} class="rm-ms-link">
              <g class={`rm-ms rm-ms--${m.status}`}>
                {m.status === 'active' && (
                  <circle cx={m.x} cy={m.y} r={NR + 14} class="rm-pulse"/>
                )}
                <circle cx={m.x} cy={m.y} r={NR} class="rm-circle"/>
                <text
                  x={m.x} y={m.y} dy="0.35em"
                  text-anchor="middle"
                  class="rm-node-icon"
                >{m.icon}</text>
                <line
                  x1={m.x} y1={connY1(m.y, m.labelPos)}
                  x2={m.x} y2={connY2(m.y, m.labelPos)}
                  class="rm-conn"
                />
                <text
                  x={m.x} y={dateY(m.x, m.y, m.labelPos)}
                  text-anchor="middle" class="rm-lbl-date"
                >{m.date}</text>
                <text
                  x={m.x} y={titleY(m.x, m.y, m.labelPos)}
                  text-anchor="middle" class="rm-lbl-title"
                >{m.label}</text>
                <text
                  x={m.x} y={subY(m.x, m.y, m.labelPos)}
                  text-anchor="middle" class="rm-lbl-sub"
                >{m.sub}</text>
              </g>
            </a>
          ))}
        </svg>
      </div>
    </section>

    <!-- ── LISTE MOBILE ──────────────────────────── -->
    <section class="rm-mob-wrap">
      <div class="rm-mob-list">
        {milestones.map((m) => (
          <a href={m.href} class={`rm-mob-item rm-mob--${m.status}`}>
            <div class="rm-mob-icon">
              <i class={`fas fa-${
                m.id === 'concept'  ? 'layer-group' :
                m.id === 'terrain'  ? 'bicycle'     :
                m.id === 'tourdata' ? 'chart-pie'   :
                m.id === 'strava'   ? 'bolt'        :
                m.id === 'radar'    ? 'crosshairs'  :
                m.id === 'meteo'    ? 'cloud-sun'   :
                m.id === 'etapes'   ? 'map-pin'     :
                'robot'
              }`}></i>
            </div>
            <div class="rm-mob-body">
              <span class="rm-mob-date">{m.date}</span>
              <span class="rm-mob-label">{m.label}</span>
              <span class="rm-mob-sub">{m.sub}</span>
            </div>
            <i class="fas fa-arrow-right rm-mob-arrow"></i>
          </a>
        ))}
      </div>
    </section>

    <!-- ── RÉSUMÉ CONCEPT ─────────────────────────── -->
    <section class="rm-concept-summary">
      <div class="rm-cs-inner">
        <div class="rm-section-badge rm-cs-badge">
          <i class="fas fa-layer-group"></i> Concept
        </div>
        <h2 class="rm-cs-title"><i class="fas fa-layer-group rm-cu"></i> Pourquoi ce projet — la vision produit en bref</h2>
        <p class="rm-cs-intro">
          TourData 2026 est une démarche de <strong>rapprochement du terrain</strong> — une volonté délibérée
          d'aller chercher les vraies valeurs, les vrais besoins, les vraies douleurs là où elles existent&nbsp;:
          dans les PME et ETI qui font tourner l'économie réelle.
          Autant d'occasions de <strong>ressentir avant de modéliser</strong> —
          d'écouter les fractures data du quotidien plutôt que de les supposer depuis un bureau.
          Parce qu'un produit construit sur des ressentis terrain vaut plus que dix frameworks théoriques.
        </p>

        <div class="rm-cs-cta-wrap">
          <a href="/concept" class="rm-cs-cta">
            <i class="fas fa-layer-group"></i>
            Voir l'architecture &amp; la conception complète
            <i class="fas fa-arrow-right rm-cs-cta-arrow"></i>
          </a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
  <CopyrightBar />

  <script is:inline src="/lib/leaflet.min.js"></script>
  <script is:inline>
  (function () {
    function initRmMap() {
      var el = document.getElementById('rm-map');
      if (!el || !window.L) return;
      var map = L.map('rm-map', {
        center: [46.6, 2.3],
        zoom: 6,
        zoomControl: false,
        attributionControl: false,
        dragging: false,
        scrollWheelZoom: false,
        doubleClickZoom: false,
        touchZoom: false,
        keyboard: false,
        maxBounds: [[41.0, -5.5], [51.5, 10.0]],
        maxBoundsViscosity: 1.0,
      });
      L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
        maxZoom: 7,
      }).addTo(map);
    }
    if (document.readyState !== 'loading') initRmMap();
    else document.addEventListener('DOMContentLoaded', initRmMap);
  })();
  </script>
</BaseLayout>

<style>
/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
   ROADMAP TourData 2026
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

/* ── Page ─────────────────────────────────────────── */
.rm-page { min-height: 100vh; padding-top: 0; }

/* ── Hero ─────────────────────────────────────────── */
.rm-hero {
  text-align: center;
  padding: 5.5rem 1.5rem 2.5rem;
}
.rm-hero-inner {
  max-width: 680px;
  margin: 0 auto;
}

.rm-section-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.35rem 1.1rem;
  background: rgba(77, 184, 212, 0.08);
  border: 1px solid rgba(77, 184, 212, 0.22);
  border-radius: var(--radius-full);
  color: var(--accent-cyan);
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 1rem;
}

.rm-title {
  font-size: clamp(1.7rem, 4vw, 2.6rem);
  font-weight: 700;
  letter-spacing: -0.025em;
  color: var(--heading-color);
  margin: 0 0 0.75rem;
  line-height: 1.2;
}
.rm-cu { color: var(--accent-copper); margin-right: 0.35rem; font-size: 0.85em; vertical-align: middle; }

.rm-desc {
  font-size: var(--text-sm);
  color: var(--text-muted);
  line-height: 1.8;
  margin: 0 0 1.75rem;
}
.rm-desc strong { color: var(--text-light); font-weight: 700; }

/* ── Legend ───────────────────────────────────────── */
.rm-legend {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1.5rem;
  flex-wrap: wrap;
}
.rm-click-hint {
  margin-top: 1.1rem;
  text-align: center;
  font-size: 1.05rem;
  font-weight: 800;
  font-family: var(--font-primary);
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: #0a1e35;
  background: rgba(77,184,212,.18);
  border: 1.5px solid rgba(77,184,212,.4);
  border-radius: 999px;
  padding: 0.45rem 1.4rem;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.55rem;
  cursor: default;
  pointer-events: none;
  user-select: none;
  animation: rm-hint-blink 1.4s ease-in-out infinite;
}
.rm-click-hint i {
  font-size: 1.1rem;
  color: #0d6a8a;
}
.rm-hint-arrow {
  animation: rm-arrow-bounce 0.9s ease-in-out infinite;
}
@keyframes rm-arrow-bounce {
  0%, 100% { transform: translateY(0); }
  50%       { transform: translateY(5px); }
}
[data-theme="dark"] .rm-click-hint,
html:not([data-theme]) .rm-click-hint {
  color: #e8f4fc;
  background: rgba(77,184,212,.12);
  border-color: rgba(77,184,212,.35);
}
[data-theme="dark"] .rm-click-hint i,
html:not([data-theme]) .rm-click-hint i {
  color: #4db8d4;
}
@keyframes rm-hint-blink {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.08; }
}
.rm-leg {
  display: flex;
  align-items: center;
  gap: 0.45rem;
  font-size: 0.78rem;
  color: var(--text-muted);
  font-weight: 500;
}
.rm-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  flex-shrink: 0;
}
.rm-leg--done     .rm-dot { background: #4db8d4; }
.rm-leg--active   .rm-dot { background: #d4845a; box-shadow: 0 0 6px rgba(212,132,90,.6); }
.rm-leg--upcoming .rm-dot { border: 2px solid #2d8bb5; }
.rm-leg--future   .rm-dot { background: var(--secondary-dark); border: 1.5px solid rgba(77,184,212,.4); }

/* ── Wave section ─────────────────────────────────── */
.rm-wave-section {
  padding: 0 1.5rem 4rem;
}
.rm-wave-wrapper {
  max-width: 1480px;
  margin: 0 auto;
  overflow-x: auto;
  border-radius: 16px;
  scrollbar-width: thin;
  scrollbar-color: rgba(77,184,212,.3) transparent;
  position: relative;
}
#rm-map {
  position: absolute;
  inset: 0;
  z-index: 0;
  border-radius: 16px;
  pointer-events: none;
  opacity: 1;
  filter: contrast(1.05) brightness(1.15) saturate(0.85);
}
.rm-wave-svg {
  display: block;
  min-width: 900px;
  width: 100%;
  border-radius: 16px;
  position: relative;
  z-index: 1;
}

/* ── Wave draw animation ──────────────────────────── */
.rm-wave-line {
  stroke-dasharray: 3400;
  stroke-dashoffset: 3400;
  animation: rm-draw 2.4s cubic-bezier(.4,0,.2,1) forwards 0.5s;
}
@keyframes rm-draw { to { stroke-dashoffset: 0; } }

/* ── SVG links ────────────────────────────────────── */
.rm-ms-link { cursor: pointer; outline: none; text-decoration: none; }
.rm-ms-link:focus-visible .rm-circle { stroke: #fff; stroke-width: 3; }
.rm-ms-link:hover .rm-ms { filter: brightness(1.18); }

/* ── Node circles ─────────────────────────────────── */
.rm-circle { transition: filter 0.2s ease; }

.rm-ms--done .rm-circle {
  fill: #4db8d4;
  filter: drop-shadow(0 0 7px rgba(77,184,212,.55));
}
.rm-ms--active .rm-circle {
  fill: #d4845a;
  filter: drop-shadow(0 0 10px rgba(212,132,90,.6));
}
.rm-ms--upcoming .rm-circle {
  fill: #0d1e32;
  stroke: #2d8bb5;
  stroke-width: 2.5;
}
.rm-ms--future .rm-circle {
  fill: #0a1626;
  stroke: rgba(77,184,212,.25);
  stroke-width: 1.5;
  opacity: 0.6;
}

/* ── Pulse (active) ───────────────────────────────── */
.rm-pulse {
  fill: none;
  stroke: #d4845a;
  stroke-width: 2.5;
  transform-box: fill-box;
  transform-origin: center;
  animation: rm-pulse-anim 2.4s ease-out infinite;
}
@keyframes rm-pulse-anim {
  0%   { opacity: 0.8; transform: scale(0.8); }
  100% { opacity: 0;   transform: scale(1.6); }
}

/* ── Vélo animé ───────────────────────────────────── */
.rm-bike-rider {
  pointer-events: none;
}
.rm-bike-icon {
  font-family: "Font Awesome 6 Free", "Font Awesome 5 Free";
  font-weight: 900;
  font-size: 22px;
  fill: #7ecfe0;
  opacity: 0.92;
}

/* ── FA icons in SVG ──────────────────────────────── */
.rm-node-icon {
  font-family: "Font Awesome 6 Free", "Font Awesome 5 Free";
  font-weight: 900;
  font-size: 18px;
  fill: #fff;
  pointer-events: none;
}
.rm-ms--upcoming .rm-node-icon { fill: #2d8bb5; }
.rm-ms--future   .rm-node-icon { fill: rgba(255,255,255,.3); }

/* ── Connectors ───────────────────────────────────── */
.rm-conn {
  stroke-width: 1.2;
  stroke-dasharray: 3,3;
  opacity: 0.45;
}
.rm-ms--done     .rm-conn { stroke: #4db8d4; }
.rm-ms--active   .rm-conn { stroke: #d4845a; }
.rm-ms--upcoming .rm-conn { stroke: #2d8bb5; }
.rm-ms--future   .rm-conn { stroke: rgba(77,184,212,.2); }

/* ── Label text ───────────────────────────────────── */
.rm-lbl-date {
  font-family: "Inter", system-ui, sans-serif;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}
.rm-lbl-title {
  font-family: "Inter", system-ui, sans-serif;
  font-size: 15px;
  font-weight: 700;
  fill: #e8ecf0;
}
.rm-lbl-sub {
  font-family: "Inter", system-ui, sans-serif;
  font-size: 11px;
