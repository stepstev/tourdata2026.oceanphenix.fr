      let shift = 0, result = 0, b;
      do {
        b = encoded.charCodeAt(index++) - 63;
        result |= (b & 0x1f) << shift;
        shift += 5;
      } while (b >= 0x20);
      lat += (result & 1) ? ~(result >> 1) : (result >> 1);
      shift = 0; result = 0;
      do {
        b = encoded.charCodeAt(index++) - 63;
        result |= (b & 0x1f) << shift;
        shift += 5;
      } while (b >= 0x20);
      lng += (result & 1) ? ~(result >> 1) : (result >> 1);
      coords.push([lat / 1e5, lng / 1e5]);
    }
    return coords;
  }

  // ── Sports course à pied (affiche allure min/km) ──────────────────────────
  const RUN_TYPES = new Set(['Run', 'TrailRun', 'VirtualRun', 'Walk', 'Hike']);

  // ── Formatage ───────────────────────────────────────────────────────────
  function fmtDuration(sec) {
    const h = Math.floor(sec / 3600);
    const m = Math.floor((sec % 3600) / 60);
    return h > 0 ? h + 'h' + String(m).padStart(2, '0') : m + '\u202fmin';
  }

  function fmtDate(str) {
    return new Date(str).toLocaleDateString('fr-FR', { day: 'numeric', month: 'short' });
  }

  function fmtNum(n) {
    return typeof n === 'number' ? n.toLocaleString('fr-FR') : '\u2014';
  }

  function fmtSpeed(act) {
    if (RUN_TYPES.has(act.type) && act.avg_speed_kmh > 0) {
      const mPerKm = 60 / act.avg_speed_kmh;
      const min = Math.floor(mPerKm);
      const sec = Math.round((mPerKm - min) * 60);
      return min + "'\u202f" + String(sec).padStart(2, '0') + '"/km';
    }
    return act.avg_speed_kmh + '\u202fkm/h';
  }

  // ── Helpers DOM ─────────────────────────────────────────────────────────
  function setElText(id, val) {
    const el = document.getElementById(id);
    if (el) el.textContent = val;
  }

  function setStatus(state, label) {
    const dot     = document.getElementById('strava-status-dot');
    const updated = document.getElementById('strava-updated-at');
    if (dot)     dot.className = 'status-dot status-' + state;
    if (updated) updated.textContent = label;
  }

  function setRefreshSpinning(on) {
    const btn = document.getElementById('strava-refresh-btn');
    if (btn) btn.classList.toggle('spinning', on);
  }

  // ── Chargement Leaflet ──────────────────────────────────────────────────
  function loadLeaflet() {
    return new Promise(function (resolve, reject) {
      if (globalThis.L) { resolve(globalThis.L); return; }
      const s = document.createElement('script');
      s.src = '/lib/leaflet.min.js';
      s.onload  = function () { resolve(globalThis.L); };
      s.onerror = function () { reject(new Error('Leaflet non disponible')); };
      document.head.appendChild(s);
    });
  }

  // ── Rendu carte Leaflet ─────────────────────────────────────────────────
  function renderMap(activity) {
    if (!activity?.polyline) return;
    const coords = decodePolyline(activity.polyline);
    if (coords.length === 0) return;

    const mapSection = document.getElementById('strava-map-section');
    if (mapSection) mapSection.style.display = '';

    loadLeaflet().then(function (L) {
      if (globalThis._stravaMap) { globalThis._stravaMap.remove(); globalThis._stravaMap = null; }
      globalThis._stravaMap = L.map('strava-map', {
        zoomControl: true, scrollWheelZoom: false, attributionControl: true,
      });
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '\u00a9 <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
        maxZoom: 18,
      }).addTo(globalThis._stravaMap);

      const poly = L.polyline(coords, { color: '#fc4c02', weight: 3.5, opacity: 0.85 });
      poly.addTo(globalThis._stravaMap);
      globalThis._stravaMap.fitBounds(poly.getBounds(), { padding: [28, 28] });

      // Marqueurs départ / arrivée
      const startIcon = L.divIcon({ className: '', html: '<div style="width:10px;height:10px;border-radius:50%;background:#10b981;border:2px solid #fff;box-shadow:0 1px 4px rgba(0,0,0,.5)"></div>', iconAnchor: [5,5] });
      const endIcon   = L.divIcon({ className: '', html: '<div style="width:10px;height:10px;border-radius:50%;background:#ef4444;border:2px solid #fff;box-shadow:0 1px 4px rgba(0,0,0,.5)"></div>', iconAnchor: [5,5] });
      L.marker(coords[0], { icon: startIcon }).addTo(globalThis._stravaMap);
      L.marker(coords[coords.length - 1], { icon: endIcon }).addTo(globalThis._stravaMap);

      const caption = document.getElementById('strava-map-caption');
      if (caption) {
        caption.textContent =
          activity.name + '\u2002\u00b7\u2002' + fmtDate(activity.date) +
          '\u2002\u00b7\u2002' + activity.distance_km + '\u202fkm' +
          '\u2002\u00b7\u2002\u2191\u202f' + fmtNum(activity.elevation_m) + '\u202fm';
      }
    }).catch(function (err) {
      console.warn('[Strava] Leaflet:', err);
      const sec = document.getElementById('strava-map-section');
      if (sec) sec.style.display = 'none';
    });
  }

  // ── Filtre #TourData (toujours actif) ───────────────────────────────────
  function filterTourData(activities) {
    if (!TOURDATA_KEYWORD) return activities;
    return activities.filter(function (a) {
      return a.name.toLowerCase().includes(TOURDATA_KEYWORD.toLowerCase());
    });
  }

  // ── Stats calculées côté client sur N jours ──────────────────────────────
  function computeStats(activities, days) {
    const cutoff = Date.now() - days * 24 * 3600 * 1000;
    const inRange = activities.filter(function (a) {
      return new Date(a.date).getTime() >= cutoff;
    });
    const total_km          = inRange.reduce(function (s, a) { return s + (a.distance_km || 0); }, 0);
    const total_elevation_m = inRange.reduce(function (s, a) { return s + (a.elevation_m   || 0); }, 0);
    const total_s           = inRange.reduce(function (s, a) { return s + (a.duration_s    || 0); }, 0);
    return {
      total_km:          Math.round(total_km * 10) / 10,
      total_elevation_m: Math.round(total_elevation_m),
      total_time_h:      Math.round(total_s / 360) / 10,
      count:             inRange.length,
    };
  }

  // ── Sélecteur de période ─────────────────────────────────────────────────
  function setupDaySelector() {
    const btns = document.querySelectorAll('.day-btn');
    btns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        btns.forEach(function (b) { b.classList.remove('active'); });
        btn.classList.add('active');
        activeDays = parseInt(btn.dataset.days, 10);
        const label = document.getElementById('stat-period-label');
        if (label) label.textContent = activeDays + ' derniers jours';
        const tourdata = filterTourData(allActivities);
        renderStats30(computeStats(tourdata, activeDays));
      });
    });
  }

  // ── Rendu tableau activités (uniquement #TourData) ──────────────────────
  function renderActivities(activities) {
    const tbody = document.getElementById('strava-activity-tbody');
    if (!tbody) return;

    const displayList = filterTourData(activities || []);

    if (displayList.length === 0) {
      tbody.innerHTML = '<tr><td colspan="9" class="strava-loading-cell">Aucune activit\u00e9 #TourData trouv\u00e9e.</td></tr>';
      const count = document.getElementById('strava-activities-count');
      if (count) count.textContent = '0\u202factivit\u00e9';
      return;
    }

    const count = document.getElementById('strava-activities-count');
    if (count) count.textContent = displayList.length + '\u202factivit\u00e9' + (displayList.length > 1 ? 's' : '');

    let html = '';
    for (const act of displayList) {
      const icon  = SPORT_ICONS[act.type]  || 'fas fa-running';
      const label = SPORT_LABELS[act.type] || act.type;
      // FC
      const hrMax = act.max_hr ? '<span class="act-hr-max">/ ' + act.max_hr + '</span>' : '';
      const hr    = act.avg_hr
        ? '<span class="act-hr-val"><i class="fas fa-heartbeat"></i>' + act.avg_hr + '\u202fbpm' + hrMax + '</span>'
        : '<span style="color:var(--text-muted)">\u2014</span>';

      // Extras (calories, watts, effort)
      const chips = [];
      if (act.calories)   chips.push('<span class="act-extra-chip act-extra-chip--cal"><i class="fas fa-fire"></i>' + act.calories + '\u202fkcal</span>');
      if (act.avg_watts)  chips.push('<span class="act-extra-chip act-extra-chip--watt"><i class="fas fa-bolt"></i>' + act.avg_watts + 'W' + (act.w_avg_watts ? '\u202f(NP\u202f' + act.w_avg_watts + ')' : '') + '</span>');
      if (act.suffer)     chips.push('<span class="act-extra-chip act-extra-chip--suf"><i class="fas fa-fire-alt"></i>' + act.suffer + '\u202fEffort</span>');
      const extras = chips.length ? '<span class="act-extras">' + chips.join('') + '</span>' : '';

      // PR badge
      const prBadge = act.pr_count > 0
        ? '<span class="act-pr-badge"><i class="fas fa-medal"></i>\u202f' + act.pr_count + '\u202fPR</span>'
        : '';

      html +=
        '<tr>' +
          '<td><span class="act-sport-icon"><i class="' + icon + '"></i></span></td>' +
          '<td class="col-name">' +
            '<a class="act-name-link" href="' + act.strava_url + '" target="_blank" rel="noopener">' + act.name + '</a>' +
            '<span class="act-extras" style="margin-top:0.15rem">' +
              '<span class="act-type-tag">' + label + '</span>' +
              prBadge +
            '</span>' +
            extras +
          '</td>' +
          '<td class="col-date">' + fmtDate(act.date) + '</td>' +
          '<td class="col-dist"><strong>' + act.distance_km + '</strong>\u202fkm</td>' +
          '<td class="col-elev">\u2191\u202f' + fmtNum(act.elevation_m) + '\u202fm</td>' +
          '<td class="col-dur">' + fmtDuration(act.duration_s) + '</td>' +
          '<td class="col-speed">' + fmtSpeed(act) + '</td>' +
          '<td class="col-hr">' + hr + '</td>' +
          '<td class="col-link"><a class="act-ext-btn" href="' + act.strava_url + '" target="_blank" rel="noopener" title="Voir sur Strava"><i class="fab fa-strava"></i></a></td>' +
        '</tr>';
    }
    tbody.innerHTML = html;
  }

  // ── Helpers de rendu fetch ───────────────────────────────────────────────
  function renderAthlete(athlete) {
    const avatar = document.getElementById('strava-avatar');
    if (athlete?.avatar && avatar) { avatar.src = athlete.avatar; avatar.style.display = ''; }
    setElText('strava-athlete-name', athlete?.name || 'St\u00e9phane Celton');
    setElText('strava-athlete-city', athlete?.city || 'France');
  }

  function renderStats30(r) {
    setElText('stat-km',    r.total_km          ?? '\u2014');
    setElText('stat-elev',  r.total_elevation_m != null ? fmtNum(r.total_elevation_m) : '\u2014');
    setElText('stat-time',  r.total_time_h      ?? '\u2014');
    setElText('stat-count', r.count             ?? '\u2014');
  }

  function renderYtd(ytd) {
    if (!ytd) return;
    const ytdSection = document.getElementById('strava-ytd-section');
    if (ytdSection) ytdSection.style.display = '';
    setElText('ytd-ride', ytd.ride_km);
    setElText('ytd-run',  ytd.run_km);
    setElText('ytd-elev', fmtNum(ytd.total_elevation_m));
    if (ytd.swim_m > 0) {
      const swimWrap = document.getElementById('ytd-swim-wrap');
      if (swimWrap) swimWrap.style.display = '';
      setElText('ytd-swim', fmtNum(ytd.swim_m));
    }
  }

  // ── Fetch principal ─────────────────────────────────────────────────────
  function fetchStrava() {
    setStatus('loading', 'Actualisation\u2026');
    setRefreshSpinning(true);

    return fetch(STRAVA_API)
      .then(function (resp) {
        const cacheHeader = resp.headers.get('X-Strava-Cache');
        return resp.json().then(function (data) {
          if (data.error) throw new Error(data.error);

          renderAthlete(data.athlete);
          renderYtd(data.ytd);

          allActivities = data.activities || [];
          const tourdata = filterTourData(allActivities);
          renderStats30(computeStats(tourdata, activeDays));
          const withMap = tourdata.find(function (a) { return a.polyline; });
          if (withMap) renderMap(withMap);
          renderActivities(allActivities);
          renderRingKpi(allActivities);
          renderCharts(allActivities);

          const updatedAt = data.updated_at
            ? new Date(data.updated_at).toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' })
            : '\u2014';
          const isMock = data._mock ? ' (mock)' : '';
          setStatus(cacheHeader === 'STALE' ? 'stale' : 'ok', 'Mis \u00e0 jour\u00a0' + updatedAt + isMock);

          const errEl = document.getElementById('strava-error');
          if (errEl) errEl.style.display = 'none';
        });
      })
      .catch(function (err) {
        console.warn('[Strava] Erreur:', err.message);
        setStatus('error', 'Erreur');
        const errEl  = document.getElementById('strava-error');
        const errMsg = document.getElementById('strava-error-msg');
        const setup  = document.getElementById('strava-setup-link');
        if (errMsg) errMsg.textContent = 'Impossible de charger les donn\u00e9es Strava\u00a0: ' + err.message;
        if (setup)  setup.style.display = err.message.toLowerCase().includes('configur\u00e9') ? '' : 'none';
        if (errEl)  errEl.style.display = '';
      })
      .finally(function () { setRefreshSpinning(false); });
  }

  // ── KPI Anneau Vélo TourData ──────────────────────────────────────────────
  function renderRingKpi(activities) {
    const rides = activities.filter(function (a) {
      return RIDE_TYPES.has(a.type) &&
             a.name.toLowerCase().includes(TOURDATA_KEYWORD.toLowerCase());
    });

    if (rides.length === 0) return;

    const totalKm   = rides.reduce(function (s, a) { return s + (a.distance_km || 0); }, 0);
    const totalElev = rides.reduce(function (s, a) { return s + (a.elevation_m  || 0); }, 0);
    const totalSec  = rides.reduce(function (s, a) { return s + (a.duration_s   || 0); }, 0);
    const pct       = Math.min(totalKm / RING_GOAL_KM, 1);
    const CIRC      = 251.33; // 2π × 40

    // Valeurs
    setElText('ring-km',       Math.round(totalKm).toLocaleString('fr-FR'));
    setElText('ring-elev',     fmtNum(Math.round(totalElev)));
    setElText('ring-time',     Math.round(totalSec / 3600));
    setElText('ring-sessions', rides.length);
    setElText('ring-pct',       Math.round(pct * 100));
    setElText('ring-remaining', Math.max(0, Math.round(RING_GOAL_KM - totalKm)).toLocaleString('fr-FR'));

    // Animation de l'arc (délai pour laisser le DOM peindre)
    const fill = document.getElementById('ring-fill');
    if (fill) {
      // Couleur selon avancement
      if (pct >= 0.75)      fill.style.stroke = 'rgba(34,197,94,0.85)';
      else if (pct >= 0.4)  fill.style.stroke = 'rgba(77,184,212,0.85)';
      else                  fill.style.stroke = 'rgba(77,184,212,0.7)';
      requestAnimationFrame(function () {
        fill.style.strokeDashoffset = CIRC * (1 - pct);
      });
    }
  }

  // ── Chart.js ─────────────────────────────────────────────────────────────
  const _charts = {};

  function destroyChart(id) {
    if (_charts[id]) { _charts[id].destroy(); delete _charts[id]; }
  }

  function loadChartJs() {
    return new Promise(function (resolve, reject) {
      if (globalThis.Chart) { resolve(globalThis.Chart); return; }
      const s = document.createElement('script');
      s.src = 'https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js';
      s.onload  = function () { resolve(globalThis.Chart); };
      s.onerror = function () { reject(new Error('Chart.js indisponible')); };
      document.head.appendChild(s);
    });
  }

  function chartTheme() {
    const dark = document.documentElement.getAttribute('data-theme') !== 'light';
    return {
      text:    dark ? 'rgba(160,190,220,0.65)' : 'rgba(40,60,90,0.6)',
      grid:    dark ? 'rgba(255,255,255,0.04)'  : 'rgba(0,0,0,0.06)',
      bg:      dark ? '#0c1424'                  : '#ffffff',
    };
  }

  function mondayOf(date) {
    const d = new Date(date);
    const day = d.getDay();
    d.setDate(d.getDate() - (day === 0 ? 6 : day - 1));
    d.setHours(0, 0, 0, 0);
    return d;
  }

  // Options communes réutilisables
  function baseTooltip(th, titleColor) {
    return {
      backgroundColor: th.bg,
      titleColor: titleColor,
      bodyColor: th.text,
      borderColor: 'rgba(77,184,212,0.12)',
      borderWidth: 1,
      padding: 8,
      cornerRadius: 6,
      displayColors: false,
    };
  }

  function baseScale(th, extraX, extraY) {
    return {
      x: Object.assign({ ticks: { color: th.text, font: { size: 9 }, maxRotation: 30 },
        grid: { color: th.grid, drawTicks: false }, border: { color: 'transparent' } }, extraX),
      y: Object.assign({ ticks: { color: th.text, font: { size: 9 }, maxTicksLimit: 4 },
        grid: { color: th.grid, drawTicks: false }, border: { color: 'transparent' }, beginAtZero: true }, extraY),
    };
  }

  function isoWeek(date) {
    const d = new Date(Date.UTC(date.getFullYear(), date.getMonth(), date.getDate()));
    d.setUTCDate(d.getUTCDate() + 4 - (d.getUTCDay() || 7));
    const yearStart = new Date(Date.UTC(d.getUTCFullYear(), 0, 1));
    return Math.ceil(((d - yearStart) / 86400000 + 1) / 7);
  }

  function renderWeeklyChart(Chart, activities) {
    destroyChart('weekly');
    const N_DAYS = 28;
    const now = new Date();
    now.setHours(23, 59, 59, 0);
    const days = [];
    for (let i = N_DAYS - 1; i >= 0; i--) {
      const d = new Date(now.getTime() - i * 86400000);
      d.setHours(0, 0, 0, 0);
      const dow = d.getDay(); // 0=dim, 6=sam
      days.push({ ts: d.getTime(), km: 0,
        label: d.toLocaleDateString('fr-FR', { day: 'numeric', month: 'numeric' }),
        week: 'S\u202f' + isoWeek(d),
        isWeekend: dow === 0 || dow === 6,
        isMonday:  dow === 1,
      });
    }
    for (const act of activities) {
      const d = new Date(act.date); d.setHours(0, 0, 0, 0);
      const day = days.find(function (dd) { return dd.ts === d.getTime(); });
      if (day) day.km += act.distance_km || 0;
    }
    const th = chartTheme();
    const canvas = document.getElementById('chart-weekly');
    if (!canvas) return;
    const tooltip = baseTooltip(th, 'rgba(77,184,212,0.95)');
    tooltip.callbacks = {
      title: function (items) { return days[items[0].dataIndex].label; },
      label: function (c) { return c.parsed.y > 0 ? c.parsed.y + '\u202fkm' : 'Repos'; },
    };
    _charts['weekly'] = new Chart(canvas, {
      type: 'bar',
      data: {
        labels: days.map(function (d) { return d.isMonday ? d.week : ''; }),
        datasets: [{
          data: days.map(function (d) { return Math.round(d.km * 10) / 10; }),
          backgroundColor: days.map(function (d) {
            return d.isWeekend ? 'rgba(252,76,2,0.2)' : 'rgba(77,184,212,0.18)';
          }),
          borderColor: days.map(function (d) {
            return d.isWeekend ? 'rgba(252,76,2,0.65)' : 'rgba(77,184,212,0.65)';
          }),
          borderWidth: 1.5, borderRadius: 3, borderSkipped: false,
          hoverBackgroundColor: days.map(function (d) {
            return d.isWeekend ? 'rgba(252,76,2,0.38)' : 'rgba(77,184,212,0.35)';
          }),
        }],
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        animation: { duration: 500, easing: 'easeOutQuart' },
        plugins: { legend: { display: false }, tooltip },
        scales: baseScale(th,
          { ticks: { font: { size: 9 }, autoSkip: false, maxRotation: 0 } },
          { ticks: { maxTicksLimit: 3 } }
        ),
      },
    });
  }

  function renderSportsChart(Chart, activities) {
    destroyChart('sports');
    const counts = {};
    for (const act of activities) {
      const lbl = SPORT_LABELS[act.type] || act.type;
      counts[lbl] = (counts[lbl] || 0) + (act.distance_km || 0);
    }
    const sorted = Object.entries(counts).sort(function (a, b) { return b[1] - a[1]; });
    const COLORS = [
      'rgba(77,184,212,0.8)', 'rgba(252,76,2,0.8)', 'rgba(34,197,94,0.8)',
      'rgba(212,132,90,0.8)', 'rgba(96,165,250,0.8)', 'rgba(251,191,36,0.8)',
    ];
    const th = chartTheme();
    const canvas = document.getElementById('chart-sports');
    if (!canvas) return;
    const tooltip = baseTooltip(th, 'rgba(77,184,212,0.95)');
    tooltip.callbacks = { label: function (c) { return c.label + '\u202f:\u202f' + c.parsed + '\u202fkm'; } };
    _charts['sports'] = new Chart(canvas, {
      type: 'doughnut',
      data: {
        labels: sorted.map(function (e) { return e[0]; }),
        datasets: [{ data: sorted.map(function (e) { return Math.round(e[1] * 10) / 10; }),
          backgroundColor: sorted.map(function (_, i) { return COLORS[i % COLORS.length]; }),
          borderColor: 'rgba(10,18,34,0.7)', borderWidth: 2,
          hoverOffset: 4 }],
      },
      options: {
        responsive: true, maintainAspectRatio: false, cutout: '70%',
        animation: { duration: 500, easing: 'easeOutQuart' },
        plugins: {
          legend: { position: 'bottom', labels: { color: th.text, font: { size: 9 },
            padding: 6, boxWidth: 8, boxHeight: 8, usePointStyle: true, pointStyleWidth: 8 } },
          tooltip,
        },
      },
    });
  }

  function renderCumulChart(Chart, activities) {
    destroyChart('cumul');
    const sorted = [...activities].sort(function (a, b) { return new Date(a.date) - new Date(b.date); });
    let cumul = 0;
    const labels = [], data = [];
    for (const act of sorted) {
      cumul += act.distance_km || 0;
      labels.push(fmtDate(act.date));
      data.push(Math.round(cumul * 10) / 10);
    }
    if (data.length === 0) return;
    const th = chartTheme();
    const canvas = document.getElementById('chart-cumul');
    if (!canvas) return;
    const tooltip = baseTooltip(th, '#fc4c02');
    tooltip.callbacks = { label: function (c) { return c.parsed.y + '\u202fkm cumulés'; } };
    _charts['cumul'] = new Chart(canvas, {
      type: 'line',
      data: {
        labels,
        datasets: [{ data, borderColor: '#fc4c02', backgroundColor: 'rgba(252,76,2,0.06)',
          borderWidth: 1.5, fill: true, tension: 0.4,
          pointRadius: 0, pointHoverRadius: 4,
          pointHoverBackgroundColor: '#fc4c02', pointHoverBorderColor: '#fff', pointHoverBorderWidth: 1.5 }],
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        animation: { duration: 600, easing: 'easeOutQuart' },
        plugins: { legend: { display: false }, tooltip },
        scales: baseScale(th, { ticks: { maxTicksLimit: 7 } }, { ticks: { maxTicksLimit: 4 } }),
      },
    });
  }

  function renderCharts(activities) {
    if (!activities || activities.length === 0) return;
    const section = document.getElementById('strava-charts-section');
    if (section) section.style.display = '';
    const tourdata = filterTourData(activities);
    loadChartJs().then(function (Chart) {
      // requestAnimationFrame garantit que le DOM est peint avant que Chart.js mesure les conteneurs
      requestAnimationFrame(function () {
        renderWeeklyChart(Chart, activities);
        renderCumulChart(Chart, tourdata.length > 0 ? tourdata : activities);
      });
    }).catch(function (err) {
      console.warn('[Strava] Charts:', err.message);
      const sect = document.getElementById('strava-charts-section');
      if (sect) sect.style.display = 'none';
    });
  }

  // ── Re-rendu des graphiques au changement de thème ────────────────────
  (function () {
    const obs = new MutationObserver(function (muts) {
      muts.forEach(function (m) {
        if (m.attributeName === 'data-theme' && allActivities.length > 0) {
          renderCharts(allActivities);
        }
      });
    });
    obs.observe(document.documentElement, { attributes: true });
  }());

  // ── Init ────────────────────────────────────────────────────────────────
  let _fetchPending = false;
  function safeFetch() {
    if (_fetchPending) return;
    _fetchPending = true;
    fetchStrava().finally(function () { _fetchPending = false; });
  }

  document.addEventListener('DOMContentLoaded', function () {
    setupDaySelector();
    safeFetch();
    if (REFRESH_INTERVAL > 0) setInterval(safeFetch, REFRESH_INTERVAL);
    document.getElementById('strava-refresh-btn')?.addEventListener('click', safeFetch);
  });

})();
</script>
