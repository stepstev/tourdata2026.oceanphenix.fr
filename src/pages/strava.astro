---
// src/pages/strava.astro — Suivi activités Strava en temps réel
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CopyrightBar from '../components/CopyrightBar.astro';
import OceanBackground from '../components/OceanBackground.astro';
---

<BaseLayout
  title="Progression Strava — TourData 2026 | OceanPhenix"
  description="Suivi en temps réel des activités Strava de Stéphane Celton — km parcourus, dénivelé, carte des parcours TourData 2026."
  lastModified="19/03/2026 12:00"
>
  <link slot="head" rel="stylesheet" href="/lib/leaflet.min.css" />
  <OceanBackground />
  <Nav />

  <main class="strava-page">
    <div class="strava-container">

      <h2 class="page-title"><i class="fas fa-chart-bar page-title-icon"></i> KPI détaillés</h2>
      <p class="page-sub">Analyse des activités Strava — performances, cumuls et progression vers l'objectif TourData 2026</p>

      <!-- ══════════════════════════════════════════════════════
           HERO — Profil athlète
      ══════════════════════════════════════════════════════ -->
      <header class="strava-hero">
        <div class="strava-hero-brand">
          <i class="fab fa-strava strava-brand-icon"></i>
          <span class="strava-brand-label">TourData 2026</span>
        </div>

        <div class="strava-hero-profile">
          <img id="strava-avatar" class="strava-avatar" src="" alt="Avatar Strava" style="display:none" />
          <div class="strava-hero-info">
            <h1 id="strava-athlete-name" class="strava-hero-name">
              <span class="strava-name-loading">Chargement&hellip;</span>
            </h1>
            <p class="strava-hero-sub">
              <i class="fas fa-map-marker-alt"></i>
              <span id="strava-athlete-city">—</span>
              &ensp;·&ensp;
              <i class="fas fa-bicycle"></i> Activités via API Strava
            </p>
          </div>
          <div class="strava-hero-status">
            <button id="strava-refresh-btn" class="strava-refresh-btn" title="Rafraîchir">
              <i class="fas fa-sync-alt" id="strava-refresh-icon"></i>
            </button>
            <div class="strava-status-row">
              <span id="strava-status-dot" class="status-dot status-loading"></span>
              <span id="strava-updated-at" class="strava-updated-label">—</span>
            </div>
          </div>
        </div>

        <!-- Erreur inline -->
        <div id="strava-error" class="strava-error" style="display:none">
          <i class="fas fa-exclamation-triangle"></i>
          <span id="strava-error-msg">Erreur de chargement</span>
          <a id="strava-setup-link" href="/admin-terrain" class="strava-link" style="display:none">
            Voir la configuration Admin →
          </a>
        </div>
      </header>

      <!-- ══════════════════════════════════════════════════════
           STATS — 30 derniers jours
      ══════════════════════════════════════════════════════ -->
      <section class="strava-section" id="strava-stats-section">
        <h2 class="strava-section-title">
          <i class="fas fa-chart-line"></i>
          <span id="stat-period-label">30 derniers jours</span>
          <div class="strava-day-selector" id="strava-day-selector">
            <button class="day-btn" data-days="5">5j</button>
            <button class="day-btn" data-days="10">10j</button>
            <button class="day-btn" data-days="15">15j</button>
            <button class="day-btn" data-days="20">20j</button>
            <button class="day-btn active" data-days="30">30j</button>
          </div>
        </h2>
        <div class="strava-kpi-grid">
          <div class="strava-kpi strava-kpi--cyan">
            <div class="kpi-header">
              <i class="fas fa-route kpi-icon"></i>
              <span class="kpi-label">Parcourus</span>
            </div>
            <div class="kpi-body">
              <span class="kpi-value" id="stat-km">—</span>
              <span class="kpi-unit">km</span>
            </div>
          </div>
          <div class="strava-kpi strava-kpi--orange">
            <div class="kpi-header">
              <i class="fas fa-mountain kpi-icon"></i>
              <span class="kpi-label">Dénivelé +</span>
            </div>
            <div class="kpi-body">
              <span class="kpi-value" id="stat-elev">—</span>
              <span class="kpi-unit">m</span>
            </div>
          </div>
          <div class="strava-kpi strava-kpi--blue">
            <div class="kpi-header">
              <i class="fas fa-clock kpi-icon"></i>
              <span class="kpi-label">Temps actif</span>
            </div>
            <div class="kpi-body">
              <span class="kpi-value" id="stat-time">—</span>
              <span class="kpi-unit">h</span>
            </div>
          </div>
          <div class="strava-kpi strava-kpi--green">
            <div class="kpi-header">
              <i class="fas fa-bolt kpi-icon"></i>
              <span class="kpi-label">Séances</span>
            </div>
            <div class="kpi-body">
              <span class="kpi-value" id="stat-count">—</span>
              <span class="kpi-unit">réalisées</span>
            </div>
          </div>
        </div>
      </section>

      <!-- ══════════════════════════════════════════════════════
           CUMUL 2026 (YTD)
      ══════════════════════════════════════════════════════ -->
      <section class="strava-section" id="strava-ytd-section" style="display:none">
        <h2 class="strava-section-title">
          <i class="fas fa-trophy"></i> Cumul 2026
        </h2>
        <div class="strava-ytd-grid" id="strava-ytd-grid">
          <div class="strava-ytd-item">
            <span class="ytd-icon"><i class="fas fa-bicycle"></i></span>
            <div class="ytd-body">
              <span class="ytd-val" id="ytd-ride">—</span>
              <span class="ytd-unit">km vélo</span>
            </div>
          </div>
          <div class="strava-ytd-item">
            <span class="ytd-icon ytd-icon--run"><i class="fas fa-running"></i></span>
            <div class="ytd-body">
              <span class="ytd-val" id="ytd-run">—</span>
              <span class="ytd-unit">km run</span>
            </div>
          </div>
          <div class="strava-ytd-item">
            <span class="ytd-icon ytd-icon--elev"><i class="fas fa-mountain"></i></span>
            <div class="ytd-body">
              <span class="ytd-val" id="ytd-elev">—</span>
              <span class="ytd-unit">m D+</span>
            </div>
          </div>
          <div class="strava-ytd-item" id="ytd-swim-wrap" style="display:none">
            <span class="ytd-icon ytd-icon--swim"><i class="fas fa-swimmer"></i></span>
            <div class="ytd-body">
              <span class="ytd-val" id="ytd-swim">—</span>
              <span class="ytd-unit">m nage</span>
            </div>
          </div>
        </div>
      </section>

      <!-- ══════════════════════════════════════════════════════
           CARTE — Dernier parcours
      ══════════════════════════════════════════════════════ -->
      <section class="strava-section" id="strava-map-section" style="display:none">
        <h2 class="strava-section-title">
          <i class="fas fa-map-marked-alt"></i> Dernier parcours
        </h2>
        <div id="strava-map" class="strava-map-container"></div>
        <p class="strava-map-caption" id="strava-map-caption"></p>
      </section>

      <!-- ══════════════════════════════════════════════════════
           GRAPHIQUES — Analyses
      ══════════════════════════════════════════════════════ -->
      <section class="strava-section" id="strava-charts-section" style="display:none">
        <h2 class="strava-section-title">
          <i class="fas fa-chart-bar"></i> Analyses
        </h2>
        <div class="strava-charts-grid">
          <div class="strava-chart-wrap">
            <p class="strava-chart-title">km / jour — 28 derniers jours</p>
            <div class="chart-canvas-box"><canvas id="chart-weekly"></canvas></div>
          </div>
          <div class="strava-chart-wrap ring-chart-wrap">
            <p class="strava-chart-title"><i class="fas fa-bicycle" style="color:var(--accent-cyan);margin-right:0.3em"></i>Vélo TourData 2026</p>
            <div class="ring-kpi-wrap">
              <div class="ring-container">
                <svg class="ring-svg" viewBox="0 0 100 100" aria-hidden="true">
                  <circle class="ring-track" cx="50" cy="50" r="40"/>
                  <circle class="ring-fill" id="ring-fill" cx="50" cy="50" r="40"/>
                </svg>
                <div class="ring-center">
                  <span class="ring-value" id="ring-km">—</span>
                  <span class="ring-unit">km</span>
                </div>
              </div>
              <div class="ring-stats">
                <div class="ring-stat">
                  <span class="ring-stat-icon"><i class="fas fa-mountain"></i></span>
                  <div class="ring-stat-body">
                    <span class="ring-stat-val" id="ring-elev">—</span>
                    <span class="ring-stat-lbl">m D+</span>
                  </div>
                </div>
                <div class="ring-stat">
                  <span class="ring-stat-icon ring-stat-icon--time"><i class="fas fa-stopwatch"></i></span>
                  <div class="ring-stat-body">
                    <span class="ring-stat-val" id="ring-time">—</span>
                    <span class="ring-stat-lbl">h selle</span>
                  </div>
                </div>
                <div class="ring-stat">
                  <span class="ring-stat-icon ring-stat-icon--rides"><i class="fas fa-road"></i></span>
                  <div class="ring-stat-body">
                    <span class="ring-stat-val" id="ring-sessions">—</span>
                    <span class="ring-stat-lbl">sorties</span>
                  </div>
                </div>
                <div class="ring-goal-row">
                  <span class="ring-pct" id="ring-pct">—</span><span class="ring-pct-sym">%</span>
                  <span class="ring-goal-label">du parcours</span>
                </div>
                <div class="ring-remaining-row">
                  <i class="fas fa-route ring-remaining-icon"></i>
                  <span id="ring-remaining">—</span><span class="ring-remaining-unit"> km restants</span>
                  <span class="ring-remaining-total">/ <span id="ring-goal-km">—</span> km</span>
                </div>
              </div>
            </div>
          </div>
          <div class="strava-chart-wrap strava-chart-full">
            <p class="strava-chart-title">Progression cumulative (km)</p>
            <div class="chart-canvas-box chart-canvas-box--slim"><canvas id="chart-cumul"></canvas></div>
          </div>
        </div>
      </section>

      <!-- ══════════════════════════════════════════════════════
           TABLEAU — Activités récentes
      ══════════════════════════════════════════════════════ -->
      <section class="strava-section">
        <h2 class="strava-section-title">
          <i class="fas fa-table"></i> Activités récentes
          <span class="strava-count-badge" id="strava-activities-count"></span>
        </h2>

        <p class="strava-data-info">
          <span class="strava-data-info__chip"><i class="fab fa-strava"></i> API Strava v3</span>
          Données collectées en temps réel via l'<strong>API officielle Strava</strong> — authentification OAuth 2.0, rafraîchissement automatique du token.
          Seules les activités tagguées <code>#Tourdata2026</code> sont comptabilisées dans les indicateurs.
          Cache serveur <strong>10 min</strong> · jusqu'à <strong>100 activités</strong> récupérées par appel.
        </p>

        <div class="strava-table-wrap">
          <table class="strava-table">
            <thead>
              <tr>
                <th class="col-sport"></th>
                <th class="col-name">Activité</th>
                <th class="col-date">Date</th>
                <th class="col-dist">Distance</th>
                <th class="col-elev">D+</th>
                <th class="col-dur">Durée</th>
                <th class="col-speed">Vitesse / Allure</th>
                <th class="col-hr">FC moy / max</th>
                <th class="col-link"></th>
              </tr>
            </thead>
            <tbody id="strava-activity-tbody">
              <tr>
                <td colspan="9" class="strava-loading-cell">
                  <span class="strava-spinner"></span> Chargement des activités&hellip;
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>


    </div>
  </main>

  <Footer />
  <CopyrightBar />
</BaseLayout>

<!-- ═══════════════════════════════════════════════════════════════════════════
     STYLES — alignés 1:1 sur terrain-dashboard.css (.tdash-*)
════════════════════════════════════════════════════════════════════════════ -->
<style is:global>
/* ── Layout ──────────────────────────────────────────────────────────────── */
.strava-page {
  min-height: 100vh;
  padding: 5rem 0 3rem;
  position: relative;
  z-index: 1;
}

.strava-container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 2rem;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

/* ── Carte externe (= .tdash-outer exact) ────────────────────────────────── */
.strava-section {
  background: rgba(12, 20, 36, 0.94);
  border: 1px solid rgba(77, 184, 212, 0.14);
  border-top: 2px solid rgba(77, 184, 212, 0.28);
  border-radius: var(--radius-lg);
  padding: 1.25rem 1.5rem;
  overflow: hidden;
  box-shadow:
    0 2px 0 rgba(77, 184, 212, 0.1),
    0 16px 56px rgba(0, 0, 0, 0.38),
    0 4px 16px rgba(0, 0, 0, 0.2);
}

/* Light mode = .tdash-outer light exact */
[data-theme="light"] .strava-section {
  background: rgba(255, 255, 255, 0.95);
  border-color: rgba(26, 101, 128, 0.14);
  border-top-color: rgba(26, 101, 128, 0.45);
  box-shadow:
    0 2px 0 rgba(26, 101, 128, 0.07),
    0 16px 56px rgba(0, 0, 0, 0.07);
}

/* Titre de section (= .tdash-card-label + .tdash-current-label style) */
.strava-section-title {
  font-size: 0.78rem;
  font-weight: 700;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: var(--ls-label, 0.06em);
  margin: 0 0 1rem;
  padding-bottom: 0.6rem;
  border-bottom: 1px solid rgba(45, 130, 170, 0.08);
  display: flex;
  align-items: center;
  gap: 0.4rem;
}

/* Icône cyan */
.strava-section-title > i:first-child {
  color: var(--accent-cyan);
  font-size: 0.78rem;
}

/* Label période — écrase l'uppercase du titre */
#stat-period-label {
  font-size: 1.0rem;
  font-weight: 800;
  color: var(--white);
  text-transform: none;
  letter-spacing: -0.01em;
}

[data-theme="light"] #stat-period-label { color: var(--text-light); }

[data-theme="light"] .strava-section-title {
  border-bottom-color: rgba(10, 24, 44, 0.08);
}

/* ── HERO (= .tdash-outer + border-left brand) ───────────────────────────── */
.strava-hero {
  background: rgba(12, 20, 36, 0.94);
  border: 1px solid rgba(77, 184, 212, 0.14);
  border-left: 3px solid #fc4c02;
  border-radius: var(--radius-lg);
  padding: 1rem 1.5rem;
  overflow: hidden;
  box-shadow:
    0 16px 56px rgba(0, 0, 0, 0.38),
    0 4px 16px rgba(0, 0, 0, 0.2);
}

[data-theme="light"] .strava-hero {
  background: rgba(255, 255, 255, 0.95);
  border-color: rgba(26, 101, 128, 0.12);
  border-left-color: #fc4c02;
  box-shadow: 0 16px 56px rgba(0, 0, 0, 0.07);
}

/* Brand bar (= .tdash-brand) */
.strava-hero-brand {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-bottom: 0.875rem;
  padding-bottom: 0.6rem;
  border-bottom: 1px solid rgba(45, 130, 170, 0.08);
}

[data-theme="light"] .strava-hero-brand {
  border-bottom-color: rgba(10, 24, 44, 0.08);
}

.strava-brand-icon { color: #fc4c02; font-size: 1.15rem; }

/* = .tdash-brand text */
.strava-brand-label {
  font-size: var(--text-base);
  font-weight: 700;
  color: var(--white);
}

[data-theme="light"] .strava-brand-label { color: var(--text-light); }


/* Profil (= .tdash-profile inline) */
.strava-hero-profile {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  flex-wrap: wrap;
}

/* Avatar (= .tdash-avatar) */
.strava-avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  border: 2px solid rgba(77, 184, 212, 0.3);
  object-fit: cover;
  flex-shrink: 0;
}

.strava-hero-info { flex: 1; min-width: 0; }

/* Nom (= .tdash-profile-info strong) */
.strava-hero-name {
  font-size: var(--text-sm);
  font-weight: 700;
  color: var(--white);
  margin: 0 0 0.15rem;
  display: block;
}

[data-theme="light"] .strava-hero-name { color: var(--text-light); }

.strava-name-loading {
  font-size: var(--text-sm);
  font-weight: 400;
  color: var(--text-muted);
  font-style: italic;
}

/* Sous-infos (= .tdash-profile-info span) */
.strava-hero-sub {
  font-size: 0.8rem;
  color: var(--text-muted);
  display: flex;
  align-items: center;
  gap: 0.35rem;
  flex-wrap: wrap;
}

.strava-hero-sub i { color: var(--accent-cyan); font-size: 0.75rem; }

/* Contrôles à droite (= .tdash-profile-links) */
.strava-hero-status {
  margin-left: auto;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 0.4rem;
}

/* Bouton refresh (= .tdash-profile-links a) */
.strava-refresh-btn {
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(77, 184, 212, 0.08);
  border: 1px solid rgba(77, 184, 212, 0.2);
  color: var(--text-muted);
  cursor: pointer;
  font-size: 0.9rem;
  transition: var(--transition-fast);
}

.strava-refresh-btn:hover {
  color: var(--accent-cyan);
  background: rgba(77, 184, 212, 0.2);
  border-color: rgba(77, 184, 212, 0.4);
}

.strava-refresh-btn.spinning i { animation: spin 0.8s linear infinite; }
@keyframes spin { 100% { transform: rotate(360deg); } }

/* Statut */
.strava-status-row {
  display: flex;
  align-items: center;
  gap: 0.32rem;
  font-size: 0.8rem;
  color: var(--text-muted);
  white-space: nowrap;
}

.status-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}

.status-dot.status-loading { background: #f59e0b; animation: blink 1.2s infinite; }
.status-dot.status-ok      { background: #22c55e; }
.status-dot.status-stale   { background: #f59e0b; }
.status-dot.status-error   { background: #ef4444; }

@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }

/* Erreur */
.strava-error {
  background: rgba(239, 68, 68, 0.07);
  border: 1px solid rgba(239, 68, 68, 0.18);
  border-radius: var(--radius-sm);
  padding: 0.65rem 1rem;
  color: #fca5a5;
  margin-top: 0.875rem;
  display: flex;
  align-items: center;
  gap: 0.6rem;
  flex-wrap: wrap;
  font-size: var(--text-sm);
}

.strava-link { color: var(--accent-cyan); font-size: var(--text-sm); }

/* ── KPI Grid (= .tdash-card) ────────────────────────────────────────────── */
.strava-kpi-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0.5rem;
}

/* Inner card = .tdash-card exact */
.strava-kpi {
  background: rgba(18, 30, 52, 0.8);
  border: 1px solid rgba(77, 184, 212, 0.1);
  border-radius: var(--radius-md);
  padding: 0.875rem 1rem 0.9rem;
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
  position: relative;
  overflow: hidden;
  transition: background var(--transition-fast), box-shadow var(--transition-fast), transform var(--transition-fast);
}

/* Barre couleur haut */
.strava-kpi::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  border-radius: 2px 2px 0 0;
}

.strava-kpi--cyan::before   { background: linear-gradient(90deg, var(--accent-cyan), var(--accent-light-cyan)); }
.strava-kpi--orange::before { background: linear-gradient(90deg, var(--accent-orange), var(--accent-copper-light)); }
.strava-kpi--blue::before   { background: linear-gradient(90deg, var(--accent-blue), #4db8d4); }
.strava-kpi--green::before  { background: linear-gradient(90deg, #22c55e, #4ade80); }

/* Light = .tdash-card light */
[data-theme="light"] .strava-kpi {
  background: rgba(240, 247, 252, 0.9);
  border-color: rgba(26, 101, 128, 0.1);
}

.strava-kpi:hover {
  background: rgba(24, 42, 74, 0.9);
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.25);
  transform: translateY(-1px);
}
[data-theme="light"] .strava-kpi:hover {
  background: rgba(228, 240, 248, 0.95);
  box-shadow: 0 4px 16px rgba(26, 101, 128, 0.1);
  transform: translateY(-1px);
}

/* Header label + icon (= .tdash-card-label + icône) */
.kpi-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* Label = .tdash-card-label exact */
.kpi-label {
  font-size: 0.72rem;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

/* Icône */
.kpi-icon { font-size: 1.15rem; color: var(--accent-cyan); opacity: 0.85; }
.strava-kpi--orange .kpi-icon { color: var(--accent-orange); }
.strava-kpi--blue   .kpi-icon { color: var(--accent-blue); }
.strava-kpi--green  .kpi-icon { color: #22c55e; }

/* Valeur */
.kpi-body {
  display: flex;
  align-items: baseline;
  gap: 0.25rem;
  line-height: 1;
  margin-top: 0.1rem;
}

.kpi-value {
  font-size: 2.4rem;
  font-weight: 800;
