---
// src/pages/tourdata.astro — Dashboard TourData 2026
// Vue synthétique : données Strava live + itinéraire JSON + métriques admin
import BaseLayout    from '../layouts/BaseLayout.astro';
import Nav           from '../components/Nav.astro';
import Footer        from '../components/Footer.astro';
import CopyrightBar  from '../components/CopyrightBar.astro';
import OceanBackground from '../components/OceanBackground.astro';
import etapesData    from '../data/terrain-etapes.json';

const projet    = etapesData.projet;
const etapes    = etapesData.etapes;
const position  = etapesData.positionActuelle;
const dashboard = etapesData.dashboard;

const GOAL_KM   = Number(String(projet.kmTotal).replace(/[^0-9]/g, '')) || 2500;
const NB_CIBLES = etapes.filter(e => e.type === 'etape').length;

function fmtMonthYear(iso) {
  if (!iso) return '—';
  const d = new Date(iso);
  return d.toLocaleDateString('fr-FR', { month: 'long', year: 'numeric' });
}
function fmtNum(n) {
  if (n == null) return '—';
  return Number(n).toLocaleString('fr-FR');
}

const departLabel = fmtMonthYear(position.dateDepart); // "avril 2026"
---

<BaseLayout
  title="TourData 2026 — Dashboard | OceanPhenix"
  description="Tableau de bord TourData 2026 : suivi physique Strava, itinéraire France à vélo, rencontres entreprises data. Stéphane Celton — OceanPhenix."
  lastModified="20/03/2026 12:00"
>
  <OceanBackground />
  <Nav />

  <main class="td-page">
    <div class="td-outer">

      <h2 class="page-title"><i class="fas fa-tachometer-alt page-title-icon"></i> Dashboard &amp; suivi</h2>
      <p class="page-sub">Suivi en temps réel du parcours TourData 2026 — étapes, rencontres entreprises et préparation physique</p>

      <!-- ══════════════════════════════════════════
           1. HEADER — Brand + badges
      ══════════════════════════════════════════ -->
      <header class="td-header">
        <div class="td-header-left">
          <div class="td-brand">
            <span class="td-brand-icon"><i class="fas fa-bicycle"></i></span>
            <div>
              <span class="td-brand-title">TourData 2026</span>
              <span class="td-brand-sub">{projet.porteur} &nbsp;·&nbsp; {position.ville} → France</span>
            </div>
          </div>
        </div>
        <div class="td-header-badges">
          <span class="td-badge td-badge--green">
            <i class="fas fa-calendar-check"></i> Départ : {departLabel}
          </span>
          <span class="td-badge td-badge--outline">
            <i class="fas fa-route"></i> <span id="live-km-total">{projet.kmTotal}</span> km prévus
          </span>
        </div>
      </header>

      <!-- ══════════════════════════════════════════
           2. PRÉPARATION PHYSIQUE (Strava live)
      ══════════════════════════════════════════ -->
      <section class="td-section">
        <div class="td-section-head">
          <span class="td-section-label">
            Préparation physique —
            <span id="td-period-lbl">30 derniers jours</span>
          </span>
          <div class="td-api-status">
            <span id="td-status-dot" class="td-dot td-dot--loading"></span>
            <span id="td-updated" class="td-api-lbl">—</span>
            <button id="td-refresh" class="td-refresh-btn" title="Rafraîchir">
              <i class="fas fa-sync-alt" id="td-refresh-icon"></i>
            </button>
          </div>
        </div>
        <div id="td-error" class="td-error" style="display:none">
          <i class="fas fa-exclamation-triangle"></i>
          <span id="td-error-msg">Erreur de chargement</span>
        </div>
        <div class="td-kpi-row">
          <div class="td-kpi">
            <span class="td-kpi-val" id="td-km">—</span>
            <span class="td-kpi-lbl">km parcourus</span>
          </div>
          <div class="td-kpi">
            <span class="td-kpi-val" id="td-elev">—</span>
            <span class="td-kpi-lbl">D+ (m)</span>
          </div>
          <div class="td-kpi">
            <span class="td-kpi-val" id="td-time">—</span>
            <span class="td-kpi-lbl">heures actif</span>
          </div>
          <div class="td-kpi">
            <span class="td-kpi-val" id="td-count">—</span>
            <span class="td-kpi-lbl">séances</span>
          </div>
        </div>
      </section>

      <!-- ══════════════════════════════════════════
           3. CUMUL VÉLO + ACTIVITÉ RÉCENTE
      ══════════════════════════════════════════ -->
      <div class="td-two-col">

        <!-- Cumul 2026 — Vélo -->
        <div class="td-card">
          <div class="td-card-label-row">
            <span class="td-dot td-dot--green"></span>
            <span class="td-card-lbl">Cumul 2026 — Vélo</span>
          </div>
          <div class="td-cumul-val">
            <span class="td-cumul-km" id="td-ring-km">—</span>
            <span class="td-cumul-unit">km</span>
          </div>
          <p class="td-cumul-sub">sur <span id="live-km-total2">{GOAL_KM.toLocaleString('fr-FR')}</span> km objectif</p>
          <div class="td-progress-track">
            <div class="td-progress-fill" id="td-progress-fill" style="width:0%"></div>
          </div>
          <div class="td-cumul-footer">
            <span class="td-pct-lbl" id="td-pct">—% accompli</span>
            <span class="td-obj-badge">Obj. {departLabel}</span>
          </div>
        </div>

        <!-- Activité récente -->
        <div class="td-card">
          <div class="td-card-label-row">
            <span class="td-dot td-dot--orange"></span>
            <span class="td-card-lbl" id="td-last-date-lbl">Activité récente</span>
          </div>
          <p class="td-act-name" id="td-last-name">—</p>
          <p class="td-act-meta" id="td-last-meta">—</p>
          <div class="td-act-stats">
            <div class="td-act-stat">
              <span class="td-act-val" id="td-last-km">—</span>
              <span class="td-act-lbl">km</span>
            </div>
            <div class="td-act-stat">
              <span class="td-act-val" id="td-last-elev">—</span>
              <span class="td-act-lbl">D+ (m)</span>
            </div>
            <div class="td-act-stat">
              <span class="td-act-val" id="td-last-cumul">—</span>
              <span class="td-act-lbl">km cumul</span>
            </div>
          </div>
        </div>

      </div>

      <!-- ══════════════════════════════════════════
           4. ITINÉRAIRE DU TOUR (statique JSON)
      ══════════════════════════════════════════ -->
      <section class="td-section">
        <div class="td-section-head">
          <span class="td-section-label">Itinéraire du Tour</span>
          <span class="td-section-meta"><span id="td-etapes-meta-live">{etapes.filter(e => e.type === 'etape').length} étapes</span> · <span id="live-periode">{projet.periode}</span></span>
        </div>
        <div class="td-card td-card--list">
          <ul class="td-etapes-list" id="td-etapes-list-live">
            {etapes.map((etape) => {
              const isDepart  = etape.type === 'depart';
              const isArrivee = etape.type === 'arrivee';
              const extraLabel = isDepart ? ' — Départ' : isArrivee ? ' — Retour' : '';
              const dotCls = etape.statut === 'actuel' ? 'td-dot--live'
                           : isArrivee                 ? 'td-dot--orange'
                           : isDepart                  ? 'td-dot--green'
                           : 'td-dot--blue';
              const badgeTxt = etape.statut === 'actuel' ? 'En cours'
                             : isDepart                  ? fmtMonthYear(etape.dateEstimee)
                             : isArrivee                 ? fmtMonthYear(etape.dateEstimee)
                             : 'Planifié';
              const badgeCls = etape.statut === 'actuel' ? 'td-pill--live'
                             : isDepart                  ? 'td-pill--green'
                             : isArrivee                 ? 'td-pill--orange'
                             : 'td-pill--muted';
              const kmLabel = isDepart ? 'Km 0'
                : `~${fmtNum(etape.distanceDepuisDepart)} km`;
              return (
                <li class={`td-etape-row${isDepart || isArrivee ? ' td-etape-row--accent' : ''}`}>
                  <span class={`td-dot ${dotCls}`}></span>
                  <span class="td-etape-ville">{etape.ville}{extraLabel}</span>
                  <span class="td-etape-sep"></span>
                  <span class="td-etape-km">{kmLabel}</span>
                  <span class={`td-pill ${badgeCls}`}>{badgeTxt}</span>
                </li>
              );
            })}
          </ul>
        </div>
      </section>

      <!-- ══════════════════════════════════════════
           5. RENCONTRES DATA TERRAIN (admin info)
      ══════════════════════════════════════════ -->
      <section class="td-section">
        <div class="td-section-head">
          <span class="td-section-label">Rencontres Data Terrain</span>
          <div class="td-section-actions">
            <a href="https://airtable.com/appFS7Qn7look1ZCy/pagY5TG49K4TMFpnG"
               target="_blank" rel="noopener"
               class="td-action-link">
              <i class="fas fa-database"></i> Airtable
            </a>
            <a href="/admin-terrain" class="td-action-link">
              <i class="fas fa-cog"></i> Admin
            </a>
          </div>
        </div>
        <div class="td-two-col">

          <div class="td-card">
            <div class="td-card-label-row">
              <span class="td-dot td-dot--green"></span>
              <span class="td-card-lbl">Entreprises contactées</span>
            </div>
            <span class="td-big-num" id="live-rencontres">{dashboard.rencontresEntreprises}</span>
            <p class="td-big-sub">confirmées · <span id="live-nb-villes2">{NB_CIBLES}</span> villes cibles</p>
            <div class="td-terrain-links">
              <a href="https://airtable.com/appFS7Qn7look1ZCy/pagY5TG49K4TMFpnG"
                 target="_blank" rel="noopener" class="td-terrain-btn">
                <i class="fas fa-building"></i> Voir les entreprises
              </a>
            </div>
          </div>

          <div class="td-card">
            <div class="td-card-label-row">
              <span class="td-dot td-dot--orange"></span>
              <span class="td-card-lbl">Interviews terrain</span>
            </div>
            <span class="td-big-num" id="live-besoins">{dashboard.besoinsIdentifies}</span>
            <p class="td-big-sub">réalisées · objectif 10+</p>
            <div class="td-terrain-links">
              <a href="https://airtable.com/appFS7Qn7look1ZCy/pag6744ywS37n7FeJ"
                 target="_blank" rel="noopener" class="td-terrain-btn">
                <i class="fas fa-microphone-alt"></i> Interviews & besoins
              </a>
            </div>
          </div>

        </div>
      </section>

      <!-- ══════════════════════════════════════════
           6. STATUSBAR — Info API / Admin
      ══════════════════════════════════════════ -->
      <footer class="td-statusbar">
        <div class="td-statusbar-left">
          <span class="td-statusbar-chip">
            <i class="fab fa-strava"></i> API Strava v3
          </span>
          <span class="td-statusbar-item" id="td-api-info">Cache 10 min · max 100 activités</span>
        </div>
        <div class="td-statusbar-right">
          <span class="td-statusbar-item" id="td-act-count">—</span>
          <a href="/strava" class="td-statusbar-link">
            <i class="fas fa-chart-line"></i> Analyses détaillées
          </a>
          <a href="/terrain" class="td-statusbar-link">
            <i class="fas fa-map-marked-alt"></i> Carte terrain
          </a>
        </div>
      </footer>

    </div>
  </main>

  <Footer />
  <CopyrightBar />
</BaseLayout>

<!-- ══════════════════════════════════════════════════════════════
     STYLES
══════════════════════════════════════════════════════════════ -->
<style is:global>

/* ── Outer layout ──────────────────────────────────────────── */
.td-page {
  min-height: 100vh;
  padding: 5rem 1.5rem 3rem;
  position: relative;
  z-index: 1;
}

.td-outer {
  max-width: 960px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 0.875rem;
}

/* ── Header ────────────────────────────────────────────────── */

.td-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 0.75rem;
  background: rgba(12, 20, 36, 0.92);
  border: 1px solid rgba(45, 130, 170, 0.12);
  border-left: 3px solid var(--accent-cyan);
  border-radius: var(--radius-lg);
  padding: 1rem 1.5rem;
  box-shadow: 0 12px 48px rgba(0,0,0,0.3);
}

[data-theme="light"] .td-header {
  background: rgba(255,255,255,0.95);
  border-color: rgba(10,24,44,0.08);
  border-left-color: var(--accent-cyan);
  box-shadow: 0 4px 24px rgba(0,0,0,0.08);
}

.td-header-left { display: flex; align-items: center; }

.td-brand { display: flex; align-items: center; gap: 0.7rem; }

.td-brand-icon {
  width: 40px;
  height: 40px;
  background: rgba(77,184,212,0.12);
  border: 1px solid rgba(77,184,212,0.25);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--accent-cyan);
  font-size: 1.15rem;
  flex-shrink: 0;
}

.td-brand-title {
  display: block;
  font-size: 1.2rem;
  font-weight: 800;
  color: var(--heading-color);
  letter-spacing: -0.03em;
  line-height: 1.15;
}

[data-theme="light"] .td-brand-title { color: var(--heading-color); }

.td-brand-sub {
  display: block;
  font-size: 0.78rem;
  color: var(--text-muted);
  letter-spacing: 0.01em;
  margin-top: 0.05rem;
}

.td-header-badges {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.td-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
  font-size: 0.78rem;
  font-weight: 700;
  border-radius: 20px;
  padding: 0.3rem 0.75rem;
  letter-spacing: 0.01em;
  white-space: nowrap;
}

.td-badge--green {
  background: rgba(34,197,94,0.12);
  border: 1px solid rgba(34,197,94,0.3);
  color: #22c55e;
}

.td-badge--outline {
  background: rgba(77,184,212,0.08);
  border: 1px solid rgba(77,184,212,0.3);
  color: var(--accent-cyan);
}

/* ── Section shell ───────────────────────────────────────── */
.td-section {
  background: rgba(12, 20, 36, 0.92);
  border: 1px solid rgba(45, 130, 170, 0.12);
  border-radius: var(--radius-lg);
  padding: 1.25rem 1.5rem 1.5rem;
  box-shadow: 0 12px 48px rgba(0,0,0,0.3);
}

[data-theme="light"] .td-section {
  background: rgba(255,255,255,0.95);
  border-color: rgba(10,24,44,0.08);
  box-shadow: 0 4px 24px rgba(0,0,0,0.07);
}

.td-section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.5rem;
  flex-wrap: wrap;
  padding-bottom: 0.9rem;
  margin-bottom: 1rem;
  border-bottom: 1px solid rgba(45,130,170,0.1);
}

[data-theme="light"] .td-section-head {
  border-bottom-color: rgba(10,24,44,0.08);
}

.td-section-label {
  font-size: 0.78rem;
  font-weight: 700;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.07em;
}

.td-section-meta {
  font-size: 0.75rem;
  color: var(--text-muted);
  letter-spacing: 0.02em;
}

.td-section-actions {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.td-action-link {
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--accent-cyan);
  background: rgba(77,184,212,0.07);
  border: 1px solid rgba(77,184,212,0.2);
  border-radius: 20px;
  padding: 0.2rem 0.6rem;
  text-decoration: none;
  transition: background 0.2s;
}

.td-action-link:hover {
  background: rgba(77,184,212,0.16);
  border-color: rgba(77,184,212,0.4);
}

/* ── API status (strava prep header) ───────────────────────── */
.td-api-status {
  display: flex;
  align-items: center;
  gap: 0.4rem;
}

.td-api-lbl {
  font-size: 0.72rem;
  color: var(--text-muted);
  white-space: nowrap;
}

.td-refresh-btn {
  width: 24px;
  height: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(77,184,212,0.07);
  border: 1px solid rgba(77,184,212,0.18);
  color: var(--text-muted);
  cursor: pointer;
  font-size: 0.78rem;
  transition: var(--transition-fast);
}

.td-refresh-btn:hover { color: var(--accent-cyan); background: rgba(77,184,212,0.18); }

.td-refresh-btn.spinning i { animation: td-spin 0.8s linear infinite; }
@keyframes td-spin { 100% { transform: rotate(360deg); } }

/* Error banner */
.td-error {
  background: rgba(239,68,68,0.07);
  border: 1px solid rgba(239,68,68,0.18);
  border-radius: var(--radius-sm);
  padding: 0.55rem 1rem;
  color: #fca5a5;
  font-size: 0.85rem;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-bottom: 0.875rem;
}

/* ── KPI Row ─────────────────────────────────────────────── */
.td-kpi-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
}

.td-kpi {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
  padding: 0.1rem 1.25rem 0.1rem 0;
  border-right: 1px solid rgba(45,130,170,0.1);
}

.td-kpi:first-child { padding-left: 0; }
.td-kpi:last-child  { border-right: none; }

[data-theme="light"] .td-kpi { border-right-color: rgba(10,24,44,0.08); }

.td-kpi-val {
  font-size: 2.4rem;
  font-weight: 800;
  color: var(--heading-color);
  letter-spacing: -0.05em;
  line-height: 1;
}

[data-theme="light"] .td-kpi-val { color: var(--heading-color); }

.td-kpi-lbl {
  font-size: 0.72rem;
  font-weight: 600;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-top: 0.15rem;
}

/* ── Two-column grid ─────────────────────────────────────── */
.td-two-col {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.875rem;
}

/* ── Cards ───────────────────────────────────────────────── */
.td-card {
  background: rgba(12, 20, 36, 0.92);
  border: 1px solid rgba(45, 130, 170, 0.12);
  border-radius: var(--radius-lg);
  padding: 1.25rem 1.5rem;
  box-shadow: 0 12px 48px rgba(0,0,0,0.3);
}

[data-theme="light"] .td-card {
  background: rgba(255,255,255,0.95);
  border-color: rgba(10,24,44,0.08);
  box-shadow: 0 4px 24px rgba(0,0,0,0.07);
}

.td-card--list { padding: 0.5rem 0; }

.td-card-label-row {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  margin-bottom: 0.75rem;
}

.td-card-lbl {
  font-size: 0.72rem;
  font-weight: 700;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

/* ── Dots ─────────────────────────────────────────────────── */
.td-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  display: inline-block;
  flex-shrink: 0;
}

.td-dot--green   { background: #22c55e; }
.td-dot--orange  { background: var(--accent-orange); }
.td-dot--blue    { background: var(--accent-cyan); opacity: 0.6; }
.td-dot--loading { background: #f59e0b; animation: td-blink 1.2s infinite; }
.td-dot--ok      { background: #22c55e; }
.td-dot--error   { background: #ef4444; }
.td-dot--live    { background: #22c55e; animation: td-pulse 2s ease infinite; }

@keyframes td-blink  { 0%,100%{opacity:1} 50%{opacity:0.3} }
@keyframes td-pulse  { 0%,100%{opacity:1} 50%{opacity:0.4} }

/* ── Cumul vélo card ─────────────────────────────────────── */
.td-cumul-val {
  display: flex;
  align-items: baseline;
  gap: 0.3rem;
  margin-bottom: 0.15rem;
}

.td-cumul-km {
  font-size: 2.8rem;
  font-weight: 800;
  color: var(--heading-color);
  letter-spacing: -0.05em;
  line-height: 1;
}

[data-theme="light"] .td-cumul-km { color: var(--heading-color); }

.td-cumul-unit {
  font-size: 1rem;
  font-weight: 600;
  color: var(--text-muted);
  align-self: flex-end;
  padding-bottom: 0.3rem;
}

.td-cumul-sub {
  font-size: 0.82rem;
  color: var(--text-muted);
  margin: 0 0 0.75rem;
}

.td-progress-track {
  height: 5px;
  background: rgba(77,184,212,0.1);
  border-radius: 10px;
  overflow: hidden;
  margin-bottom: 0.5rem;
}

.td-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--accent-cyan), #22c55e);
  border-radius: 10px;
  transition: width 0.9s cubic-bezier(0.4,0,0.2,1);
}

.td-cumul-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 0.5rem;
  margin-top: 0.1rem;
}

.td-pct-lbl {
  font-size: 0.78rem;
  font-weight: 600;
  color: var(--accent-cyan);
}

.td-obj-badge {
  font-size: 0.72rem;
  font-weight: 600;
  color: var(--text-muted);
  background: rgba(77,184,212,0.06);
  border: 1px solid rgba(77,184,212,0.18);
  border-radius: 20px;
  padding: 0.12rem 0.5rem;
  white-space: nowrap;
}

/* ── Activité récente card ────────────────────────────────── */
