<!-- ══════════════════════════════════════════════════════════════
     SCRIPT — Terrain live (localStorage → étapes list)
══════════════════════════════════════════════════════════════ -->
<script src="/js/terrain-live.js" is:inline></script>

<!-- ══════════════════════════════════════════════════════════════
     SCRIPT — Strava API live
══════════════════════════════════════════════════════════════ -->
<script is:inline>
(function () {
  'use strict';

  const IS_LOCAL  = location.hostname === 'localhost' || location.hostname === '127.0.0.1';
  const API_URL   = IS_LOCAL ? '/api/strava-mock.json' : '/api/strava.php';
  const KEYWORD   = '#tourdata2026';
  let GOAL_KM = 2500;
  try {
    const _adminRaw = localStorage.getItem('op-terrain-admin');
    if (_adminRaw) {
      const _adminData = JSON.parse(_adminRaw);
      const _km = Number(String(_adminData?.projet?.kmTotal || '').replace(/[^0-9]/g, ''));
      if (_km > 0) GOAL_KM = _km;
    }
  } catch (_) { /* use default */ }
  const RIDE_TYPES = new Set(['Ride','VirtualRide','MountainBikeRide','GravelRide','EMountainBikeRide']);

  const SPORT_LABELS = {
    Ride:'Vélo', VirtualRide:'Vélo virtuel', MountainBikeRide:'VTT',
    GravelRide:'Gravel', EMountainBikeRide:'E-VTT', Run:'Course',
    TrailRun:'Trail', Walk:'Marche', Hike:'Rando', Swim:'Natation',
  };

  function $(id) { return document.getElementById(id); }
  function setText(id, val) { const el = $(id); if (el) el.textContent = val ?? '—'; }
  function fmtN(n) { return Number(n).toLocaleString('fr-FR'); }

  function isTourData(a) {
    return a.name && a.name.toLowerCase().includes(KEYWORD);
  }

  function computeStats(acts, days) {
    const cut = Date.now() - days * 86400000;
    const flt = acts.filter(a => new Date(a.date).getTime() >= cut);
    return {
      km    : Math.round(flt.reduce((s,a) => s + (a.distance_km || 0), 0) * 10) / 10,
      elev  : Math.round(flt.reduce((s,a) => s + (a.elevation_m  || 0), 0)),
      hours : Math.round(flt.reduce((s,a) => s + (a.duration_s   || 0), 0) / 360) / 10,
      count : flt.length,
    };
  }

  function setStatus(state, label) {
    const dot = $('td-status-dot');
    if (dot) dot.className = 'td-dot td-dot--' + (state === 'loading' ? 'loading' : state === 'ok' ? 'ok' : 'error');
    setText('td-updated', label);
  }

  function setSpinning(on) {
    const btn = $('td-refresh');
    if (btn) btn.classList.toggle('spinning', on);
  }

  function renderPrep(acts) {
    const s = computeStats(acts, 30);
    setText('td-km',    s.km);
    setText('td-elev',  fmtN(s.elev));
    setText('td-time',  s.hours);
    setText('td-count', s.count);
  }

  function renderCumul(acts) {
    const rides = acts.filter(a => isTourData(a) && RIDE_TYPES.has(a.type));
    const total = rides.reduce((s,a) => s + (a.distance_km || 0), 0);
    const pct   = Math.min(total / GOAL_KM, 1);
    const pctRnd = Math.round(pct * 100);

    setText('td-ring-km', fmtN(Math.round(total)));
    setText('td-pct', pctRnd + '% accompli');

    const bar = $('td-progress-fill');
    if (bar) requestAnimationFrame(function () { bar.style.width = (pct * 100) + '%'; });
  }

  function renderLastActivity(acts) {
    const tourdata = acts.filter(isTourData);
    if (tourdata.length === 0) return;

    const sorted = [...tourdata].sort(function (a, b) {
      return new Date(b.date) - new Date(a.date);
    });
    const last   = sorted[0];
    const cumul  = tourdata.reduce(function (s,a) { return s + (a.distance_km || 0); }, 0);

    const d       = new Date(last.date);
    const dateStr = d.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long' });
    const lbl$    = $('td-last-date-lbl');
    if (lbl$) lbl$.textContent = 'Activité récente — ' + dateStr;

    setText('td-last-name', last.name);
    setText('td-last-meta',
      dateStr + ' · ' + (SPORT_LABELS[last.type] || last.type) + ' · #Tourdata2026');
    setText('td-last-km',    last.distance_km);
    setText('td-last-elev',  Math.round(last.elevation_m || 0));
    setText('td-last-cumul', Math.round(cumul * 10) / 10);
  }

  function renderAdmin(data, cacheHeader) {
    const actCount = (data.activities || []).length;
    setText('td-act-count', actCount + ' activité' + (actCount > 1 ? 's' : '') + ' récupérée' + (actCount > 1 ? 's' : ''));

    const updAt    = data.updated_at
      ? new Date(data.updated_at).toLocaleTimeString('fr-FR', { hour:'2-digit', minute:'2-digit' })
      : '—';
    const isMock   = data._mock ? ' (mock)' : '';
    const isStale  = cacheHeader === 'STALE' ? ' · cache' : '';
    setStatus('ok', 'Mis à jour ' + updAt + isMock + isStale);
  }

  var _pending = false;

  function fetchData() {
    if (_pending) return;
    _pending = true;
    setStatus('loading', 'Actualisation…');
    setSpinning(true);

    fetch(API_URL)
      .then(function (resp) {
        var cache = resp.headers.get('X-Strava-Cache');
        return resp.json().then(function (data) {
          if (data.error) throw new Error(data.error);
          var acts = data.activities || [];
          renderPrep(acts);
          renderCumul(acts);
          renderLastActivity(acts);
          renderAdmin(data, cache);
          var errEl = $('td-error');
          if (errEl) errEl.style.display = 'none';
        });
      })
      .catch(function (err) {
        setStatus('error', 'Erreur API');
        var errEl  = $('td-error');
        var errMsg = $('td-error-msg');
        if (errMsg) errMsg.textContent = err.message;
        if (errEl)  errEl.style.display = '';
      })
      .finally(function () {
        _pending = false;
        setSpinning(false);
      });
  }

  document.addEventListener('DOMContentLoaded', function () {
    fetchData();
    var btn = $('td-refresh');
    if (btn) btn.addEventListener('click', fetchData);
    // Refresh auto toutes les 5 minutes si pas local
    if (!IS_LOCAL) setInterval(fetchData, 300000);
  });
})();
</script>
